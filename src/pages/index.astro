---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import QuoteSection from '../components/QuoteSection.astro';
import SobreMi from '../components/SobreMi.astro';
import Servicios from '../components/Servicios.astro';
import Philosophy from '../components/Philosophy.astro';
import Proceso from '../components/Proceso.astro';
import FAQ from '../components/FAQ.astro';
import Contacto from '../components/Contacto.astro';
import BlogSection from '../components/BlogSection.astro';
import Footer from '../components/Footer.astro';
import SectionDivider from '../components/SectionDivider.astro';

const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://lucia-psicologa.vercel.app/#webpage',
    url: 'https://lucia-psicologa.vercel.app/',
    name: 'Lucía Millán Jiménez | Psicóloga en Ciudad Real',
    description:
      'Psicóloga en Ciudad Real. Terapia individual online y presencial para ansiedad, duelo, autoestima, trauma y bienestar emocional.',
    inLanguage: 'es-ES',
    isPartOf: { '@id': 'https://lucia-psicologa.vercel.app/#website' },
    about: { '@id': 'https://lucia-psicologa.vercel.app/#lucia-millan-jimenez' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: '¿La terapia puede ser online o presencial?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Sí. La consulta ofrece terapia individual presencial en Ciudad Real y sesiones online para personas que prefieren o necesitan un formato a distancia.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Cuándo conviene pedir ayuda psicológica?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Conviene pedir ayuda cuando el malestar emocional, la ansiedad, el duelo, la baja autoestima o una experiencia difícil empiezan a limitar tu vida cotidiana, tus relaciones o tu descanso.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Qué ocurre en la primera sesión?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'La primera sesión sirve para escuchar tu situación, entender qué necesitas y acordar una forma de trabajo clara, respetando tu ritmo y tus objetivos.',
        },
      },
    ],
  },
];
---

<Layout
  title="Lucía Millán Jiménez | Psicología Clínica en Ciudad Real"
  description="Psicóloga colegiada en Ciudad Real. Terapia individual online y presencial con enfoque integrador: TCC, ACT, TFE y técnicas psicosomáticas. Un espacio seguro para tu bienestar emocional."
  schema={homeSchema}
>
  <Navigation />
  <main>
    <Hero />

    <!-- Dark to light: organic ink bleed -->
    <SectionDivider variant="ink" toColor="var(--white-warm)" />

    <SobreMi />

    <!-- Warm to parchment: gentle wave -->
    <SectionDivider variant="wave" toColor="var(--parchment)" />

    <QuoteSection />

    <!-- Parchment to cream-warm: soft hill -->
    <SectionDivider variant="hill" toColor="var(--cream-warm)" />

    <Servicios />

    <!-- Cream-warm to dark: ink bleed separator -->
    <SectionDivider variant="ink" toColor="#0c0907" height="clamp(56px, 7vw, 96px)" />

    <Philosophy />

    <!-- Dark to parchment: ink bleed separator -->
    <SectionDivider variant="ink" toColor="var(--parchment)" height="clamp(56px, 7vw, 96px)" />

    <Proceso />

    <!-- Paper to white-warm: gentle wave -->
    <SectionDivider variant="wave" toColor="var(--white-warm)" />

    <FAQ />

    <!-- White-warm to cream: valley divider -->
    <SectionDivider variant="valley" toColor="var(--cream)" />

    <Contacto />

    <!-- Cream to parchment: arch divider -->
    <SectionDivider variant="arch" toColor="var(--parchment)" />

    <BlogSection />
  </main>
  <Footer />
</Layout>
