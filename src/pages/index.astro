---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import SobreMi from '../components/SobreMi.astro';
import Proceso from '../components/Proceso.astro';
import FAQ from '../components/FAQ.astro';
import Contacto from '../components/Contacto.astro';
import BlogSection from '../components/BlogSection.astro';
import Footer from '../components/Footer.astro';
import SectionDivider from '../components/SectionDivider.astro';

const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://lucia-psicologa.vercel.app/#webpage',
    url: 'https://lucia-psicologa.vercel.app/',
    name: 'Psicóloga clínica en Ciudad Real · Terapia online · Lucía Millán Jiménez',
    description:
      'Psicóloga clínica en Ciudad Real. Terapia individual presencial y online, integradora y orientada a objetivos. Primera respuesta en 24 h.',
    inLanguage: 'es-ES',
    isPartOf: { '@id': 'https://lucia-psicologa.vercel.app/#website' },
    about: { '@id': 'https://lucia-psicologa.vercel.app/#lucia-millan-jimenez' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: '¿Cuánto dura una sesión?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Las sesiones individuales duran alrededor de 50 minutos. En trabajo de trauma, algunas sesiones pueden ampliarse a 60–90 minutos si tiene sentido clínico y lo acordamos previamente.',
        },
      },
      {
        '@type': 'Question',
        name: '¿La terapia puede ser online?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Sí. Atiendo terapia presencial en Ciudad Real y sesiones online para personas que prefieren o necesitan un formato a distancia. En ambos casos mantenemos encuadre, confidencialidad y seguimiento.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Qué ocurre en la primera sesión?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Revisamos el motivo de consulta, desde cuándo ocurre, cómo afecta a tu vida y qué esperas de la terapia. También resolvemos dudas y definimos un primer objetivo de trabajo.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Con qué frecuencia se acude?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Lo habitual es empezar con una sesión semanal. Después podemos ajustar la frecuencia según la evolución, los objetivos y tu disponibilidad.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Qué enfoque de terapia utilizas?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Trabajo desde un modelo integrador que combina Terapia Cognitivo-Conductual, ACT, Terapia Focalizada en la Emoción y técnicas psicosomáticas. La intervención se adapta a tu caso, no al revés.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Lo que cuente será confidencial?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Sí. La información que compartas se trata con confidencialidad profesional y de acuerdo con la normativa de protección de datos.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Cómo puedo pedir cita?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Puedes escribir desde el formulario, por email o por teléfono. Respondo en un plazo máximo de 24 horas laborables para orientarte y valorar un primer hueco.',
        },
      },
    ],
  },
];
---

<Layout
  title="Psicóloga clínica en Ciudad Real · Terapia online · Lucía Millán Jiménez"
  description="Psicóloga clínica en Ciudad Real. Terapia individual presencial y online, integradora y orientada a objetivos. Primera respuesta en 24 h."
  schema={homeSchema}
>
  <Navigation />
  <main>
    <Hero />

    <!-- Dark hero to warm cream: organic ink bleed -->
    <SectionDivider variant="ink" toColor="var(--white-warm)" />

    <Servicios />

    <!-- White-warm to parchment: gentle wave -->
    <SectionDivider variant="wave" toColor="var(--parchment)" />

    <SobreMi />

    <!-- Parchment to cream: soft hill -->
    <SectionDivider variant="hill" toColor="var(--cream)" />

    <Proceso />

    <!-- Cream to white-warm: gentle wave -->
    <SectionDivider variant="wave" toColor="var(--white-warm)" />

    <FAQ />

    <!-- White-warm to cream: valley divider -->
    <SectionDivider variant="valley" toColor="var(--cream)" />

    <Contacto />

    <!-- Cream to parchment: arch divider -->
    <SectionDivider variant="arch" toColor="var(--parchment)" />

    <BlogSection />
  </main>
  <Footer />
</Layout>
