---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import SobreMi from '../components/SobreMi.astro';
import Proceso from '../components/Proceso.astro';
import BlogSection from '../components/BlogSection.astro';
import FAQ from '../components/FAQ.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
import SectionDivider from '../components/SectionDivider.astro';

const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://lucia-psicologa.vercel.app/#webpage',
    url: 'https://lucia-psicologa.vercel.app/',
    name: 'Psicóloga clínica · Terapia individual · Lucía Millán Jiménez',
    description:
      'Psicología clínica en Ciudad Real. Terapia individual presencial y online para ansiedad, trauma, duelo y malestar emocional, con enfoque integrador y formación en EMDR.',
    inLanguage: 'es-ES',
    isPartOf: { '@id': 'https://lucia-psicologa.vercel.app/#website' },
    about: { '@id': 'https://lucia-psicologa.vercel.app/#lucia-millan-jimenez' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: '¿Cuánto dura una sesión?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Las sesiones individuales duran alrededor de 50 minutos. En trabajo de trauma o EMDR pueden ampliarse a 60–90 minutos si lo acordamos previamente y tiene sentido clínico.',
        },
      },
      {
        '@type': 'Question',
        name: '¿La terapia puede ser online?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Sí. Atiendo de forma presencial en Ciudad Real y online. En ambos casos mantenemos el mismo encuadre y seguimiento clínico.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Qué ocurre en la primera sesión?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Revisamos el motivo de consulta, desde cuándo ocurre, cómo afecta a tu vida y qué esperas de la terapia. También resolvemos dudas, valoramos qué enfoque puede encajar mejor y definimos un primer objetivo.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Siempre se trabaja con la misma terapia?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. Integro TCC, ACT, TFE, IFS y EMDR según tu problemática, tus recursos y el momento del proceso. La intervención se adapta a cada persona.',
        },
      },
      {
        '@type': 'Question',
        name: '¿El EMDR sirve para cualquier caso?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No siempre. Primero se evalúa la historia, la estabilidad actual y los recursos de regulación. Si EMDR no es lo más adecuado en ese momento, se trabaja con otro enfoque o se prepara el proceso antes de iniciar el reprocesamiento.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Con qué frecuencia se acude?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Lo habitual es empezar con una sesión semanal. Después podemos ajustar la frecuencia según la evolución y tus circunstancias.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Cómo puedo pedir cita?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Puedes escribir desde el formulario de contacto, por email o por teléfono. Te respondo para orientarte, resolver dudas iniciales y valorar un primer hueco.',
        },
      },
    ],
  },
];
---

<Layout
  title="Psicóloga clínica · Terapia individual · Lucía Millán Jiménez"
  description="Psicología clínica en Ciudad Real. Terapia individual presencial y online para ansiedad, trauma, duelo y malestar emocional, con enfoque integrador y formación en EMDR."
  schema={homeSchema}
>
  <Navigation />
  <main>
    <Hero />

    <!-- Dark hero to warm cream -->
    <SectionDivider variant="ink" toColor="var(--white-warm)" />

    <Servicios />

    <!-- Cream to parchment -->
    <SectionDivider variant="wave" toColor="var(--parchment)" />

    <SobreMi />

    <!-- Parchment to cream -->
    <SectionDivider variant="hill" toColor="var(--cream)" />

    <Proceso />

    <!-- Cream to warm cream -->
    <SectionDivider variant="wave" toColor="var(--white-warm)" />

    <BlogSection />

    <!-- Cream to parchment -->
    <SectionDivider variant="valley" toColor="var(--parchment)" />

    <FAQ />

    <!-- Parchment to cream -->
    <SectionDivider variant="arch" toColor="var(--cream)" />

    <Contacto />
  </main>
  <Footer />
</Layout>
