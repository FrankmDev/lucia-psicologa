---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import GrainOverlay from '../../components/ui/GrainOverlay.astro';
import AmbientLight from '../../components/ui/AmbientLight.astro';
import DustParticles from '../../components/ui/DustParticles.astro';
import FloatOrb from '../../components/ui/FloatOrb.astro';
import InkBlob from '../../components/ui/InkBlob.astro';
import BotanicalSVG from '../../components/ui/BotanicalSVG.astro';
import Container from '../../components/ui/Container.astro';
import { articles, getArticleImage, getRelatedArticles } from '../../data/blog';

export const getStaticPaths = (() => articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }))) satisfies GetStaticPaths;

const { article } = Astro.props;
const related = getRelatedArticles(article.slug, 2);

const formattedDate = new Date(article.dateISO).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const heroImage = getArticleImage(article.slug, 1800, 1200);
const pullQuote = article.excerpt;
const articleURL = `https://luciamillanpsicologia.es/blog/${article.slug}`;
const articleSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: article.title,
    description: article.metaDescription,
    image: {
      '@type': 'ImageObject',
      url: heroImage,
      width: 1800,
      height: 1200,
    },
    datePublished: article.dateISO,
    dateModified: article.dateISO,
    author: {
      '@type': 'Person',
      name: 'Lucía Millán Jiménez',
      jobTitle: 'Psicóloga Clínica',
      url: 'https://luciamillanpsicologia.es/',
    },
    publisher: { '@id': 'https://luciamillanpsicologia.es/#lucia-millan-jimenez' },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': articleURL,
    },
    inLanguage: 'es-ES',
    keywords: article.keywords.join(', '),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Inicio',
        item: 'https://luciamillanpsicologia.es/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Blog',
        item: 'https://luciamillanpsicologia.es/blog',
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: article.title,
        item: articleURL,
      },
    ],
  },
];
---

<Layout title={article.metaTitle} description={article.metaDescription} keywords={article.keywords} image={heroImage} type="article" schema={articleSchema}>
  <Navigation />

  <main class="article-page" data-article-page>
    <GrainOverlay opacity={0.024} />
    <AmbientLight color="rgba(196,170,148,0.06)" />
    <DustParticles count={10} color="rgba(196,170,148,0.13)" />
    <FloatOrb size={300} top="8%" right="-6%" color="var(--sage-muted)" blur={100} animation="float-1" />
    <FloatOrb size={200} bottom="15%" left="-4%" color="var(--gold-soft)" opacity={0.35} animation="float-2" />
    <InkBlob width={280} height={200} top="20%" left="-3%" color="var(--earth)" opacity={0.03} animation="morph-2" />
    <BotanicalSVG variant="right" color="var(--sage-muted)" opacity={0.04} width={60} style="right: 2%; top: 30%;" />

    <article class="article-shell">
      <!-- Hero -->
      <header class="article-hero">
        <Container maxWidth="820px">
          <nav aria-label="Breadcrumb" class="article-breadcrumb">
            <a href="/">Inicio</a>
            <span aria-hidden="true">/</span>
            <a href="/blog">Blog</a>
            <span aria-hidden="true">/</span>
            <span aria-current="page">{article.title}</span>
          </nav>

          <div class="article-hero__meta">
            <span>{article.categoryLabel}</span>
            <span aria-hidden="true">/</span>
            <time datetime={article.dateISO}>{formattedDate}</time>
            <span aria-hidden="true">/</span>
            <span>{article.readTime}</span>
          </div>

          <h1 class="article-title">{article.title}</h1>
          <p class="article-deck">{article.metaDescription}</p>

          <div class="article-actions">
            <a href="/#contacto" class="article-btn article-btn--solid">
              <span>Solicitar primera sesión</span>
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <a href="/blog" class="article-btn article-btn--ghost">
              <span>Volver al blog</span>
            </a>
          </div>
        </Container>

        <figure class="article-hero__media" data-article-image>
          <img src={heroImage} alt={`Imagen principal para ${article.title}`} width="1800" height="1200" loading="eager" decoding="async" />
          <figcaption>{article.categoryLabel} &middot; Lectura clínica</figcaption>
        </figure>
      </header>

      <!-- Reading area -->
      <section class="article-reading">
        <Container maxWidth="820px">
          <div class="article-reading__inner">
            <div class="article-aside" aria-label="Resumen del artículo">
              <div class="article-aside__panel">
                <p>{pullQuote}</p>
                <a href="/#contacto" class="article-aside__link">Solicitar orientación</a>
              </div>
            </div>

            <div class="article-content" data-article-content set:html={article.content} />
          </div>
        </Container>
      </section>

      <!-- Final CTA -->
      <aside class="article-final-cta" aria-labelledby="article-cta-title">
        <Container maxWidth="820px">
          <div class="article-final-cta__inner">
            <div>
              <h2 id="article-cta-title">Si lo leído encaja con tu situación, podemos valorarlo juntos.</h2>
              <p>Cuéntame qué te preocupa, desde cuándo ocurre, qué modalidad prefieres y qué necesitas aclarar antes de empezar.</p>
            </div>
            <a href="/#contacto" class="article-btn article-btn--solid">
              <span>Enviar mensaje inicial</span>
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        </Container>
      </aside>

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="article-related" aria-labelledby="related-heading">
          <Container maxWidth="820px">
            <div class="article-related__header">
              <h2 id="related-heading">Seguir leyendo</h2>
              <a href="/blog">Todos los artículos</a>
            </div>

            <div class="article-related__grid">
              {related.map(relatedArticle => (
                <a href={`/blog/${relatedArticle.slug}`} class="related-card">
                  <figure>
                    <img src={getArticleImage(relatedArticle.slug, 1200, 900)} alt={`Imagen editorial para ${relatedArticle.title}`} loading="lazy" decoding="async" />
                  </figure>
                  <div>
                    <span>{relatedArticle.categoryLabel} / {relatedArticle.readTime}</span>
                    <h3>{relatedArticle.title}</h3>
                    <p>{relatedArticle.excerpt}</p>
                  </div>
                </a>
              ))}
            </div>
          </Container>
        </section>
      )}
    </article>
  </main>

  <Footer />
</Layout>

<script>
  const page = document.querySelector('[data-article-page]');
  const image = document.querySelector('[data-article-image]');
  const content = document.querySelector('[data-article-content]');

  if (page && image && content) {
    const targets = [...content.querySelectorAll('h2, blockquote, .lead, ul')];
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        entry.target.classList.toggle('is-visible', entry.isIntersecting);
      });
    }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });

    targets.forEach((target) => observer.observe(target));

    const updateImage = () => {
      const rect = image.getBoundingClientRect();
      const viewport = window.innerHeight || 1;
      const progress = Math.min(1, Math.max(0, 1 - Math.abs(rect.top + rect.height * 0.45 - viewport * 0.48) / viewport));
      image.style.setProperty('--article-image-scale', String(0.94 + progress * 0.06));
      image.style.setProperty('--article-image-opacity', String(0.72 + progress * 0.28));
    };

    updateImage();
    window.addEventListener('scroll', updateImage, { passive: true });
    window.addEventListener('resize', updateImage);
  }
</script>

<style is:global>
  .article-page {
    position: relative;
    width: 100%;
    min-height: 100dvh;
    overflow-x: hidden;
    background:
      radial-gradient(ellipse at 18% 4%, rgba(196,170,148,0.11) 0%, transparent 42%),
      radial-gradient(ellipse at 90% 26%, rgba(107,125,106,0.09) 0%, transparent 42%),
      linear-gradient(180deg, var(--parchment) 0%, var(--cream) 100%);
    padding: 8.5rem 0 0;
    isolation: isolate;
  }

  /* ===== BREADCRUMB ===== */
  .article-breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem;
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(122,101,88,0.58);
    margin-bottom: 1.6rem;
  }

  .article-breadcrumb a {
    color: rgba(122,101,88,0.72);
    transition: color 0.4s ease;
  }

  .article-breadcrumb a:hover {
    color: var(--ink);
  }

  /* ===== HERO ===== */
  .article-hero {
    position: relative;
    z-index: 2;
    padding: 2rem 0 0;
  }

  .article-hero__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.62rem;
    margin-bottom: 1.25rem;
    font-size: var(--type-micro);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
  }

  .article-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-page-title);

    font-weight: 400;
    line-height: 1.02;
    letter-spacing: 0;
    color: var(--ink);
  }

  .article-deck {
    max-width: 62ch;
    margin: 1.6rem 0 0;
    font-family: var(--font-body);
    font-size: var(--type-lead);
    font-weight: 300;
    line-height: 1.75;
    color: rgba(61,48,40,0.78);
  }

  .article-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  /* ===== BUTTONS ===== */
  .article-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-height: 52px;
    padding: 0 1.55rem;
    border-radius: 999px;
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: transform 0.55s var(--ease-out-expo), background 0.55s ease, border-color 0.55s ease, color 0.55s ease;
  }

  .article-btn--solid {
    background: var(--ink);
    border: 1px solid var(--ink);
    color: var(--white-warm);
    box-shadow: 0 18px 46px rgba(42,31,26,0.13);
  }

  .article-btn--solid:hover {
    transform: translateY(-3px);
    background: var(--taupe-dark);
    border-color: var(--taupe-dark);
  }

  .article-btn--ghost {
    background: rgba(255,253,249,0.52);
    border: 1px solid rgba(196,170,148,0.22);
    color: var(--ink);
  }

  .article-btn--ghost:hover {
    transform: translateY(-3px);
    background: rgba(255,253,249,0.88);
    border-color: rgba(107,125,106,0.28);
  }

  .article-btn svg {
    transition: transform 0.5s var(--ease-out-expo);
  }

  .article-btn:hover svg {
    transform: translateX(4px);
  }

  /* ===== HERO IMAGE ===== */
  .article-hero__media {
    --article-image-scale: 0.96;
    --article-image-opacity: 0.88;
    position: relative;
    overflow: hidden;
    aspect-ratio: 21 / 9;
    margin: 3.5rem auto 0;
    width: min(1120px, calc(100% - 10vw));
    border-radius: 4px;
    border: 1px solid rgba(196,170,148,0.18);
    background: var(--cream-warm);
    box-shadow: 0 28px 90px rgba(42,31,26,0.11);
  }

  .article-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(var(--article-image-scale));
    opacity: var(--article-image-opacity);
    filter: grayscale(16%) sepia(8%) saturate(0.78) contrast(1.08);
    transition: transform 0.2s linear, opacity 0.2s linear;
  }

  .article-hero__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 44%, rgba(42,31,26,0.38) 100%),
      radial-gradient(circle at 16% 14%, rgba(255,253,249,0.34), transparent 40%);
    pointer-events: none;
  }

  .article-hero__media figcaption {
    position: absolute;
    left: 1.1rem;
    bottom: 1rem;
    z-index: 2;
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,253,249,0.78);
  }

  /* ===== READING ===== */
  .article-reading {
    border-top: 1px solid rgba(196,170,148,0.16);
  }

  .article-reading__inner {
    padding: 5rem 0 7rem;
  }

  .article-aside {
    margin-bottom: 4rem;
  }

  .article-aside__panel {
    padding: 1.35rem 0 0 1.15rem;
    border-left: 1px solid rgba(196,170,148,0.38);
  }

  .article-aside__panel p {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);

    font-weight: 400;
    line-height: 1.28;
    color: rgba(42,31,26,0.82);
  }

  .article-aside__link {
    display: inline-flex;
    margin-top: 1.2rem;
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe-dark);
    border-bottom: 1px solid rgba(122,101,88,0.32);
    transition: color 0.4s ease, border-color 0.4s ease;
  }

  .article-aside__link:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  /* ===== ARTICLE CONTENT ===== */
  .article-content {
    min-width: 0;
    font-family: var(--font-body);
    color: var(--ink-soft);
    font-size: var(--type-lead);
    font-weight: 300;
    line-height: 1.88;
  }

  .article-content > *:first-child {
    margin-top: 0;
  }

  .article-content p {
    margin: 0 0 1.55rem;
  }

  .article-content .lead {
    margin-bottom: 2.4rem;
    padding: 0 0 2rem;
    border-bottom: 1px solid rgba(196,170,148,0.18);
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);

    font-weight: 400;
    line-height: 1.42;
    color: var(--ink);
  }

  .article-content h2 {
    margin: 4.6rem 0 1.25rem;
    font-family: var(--font-display);
    font-size: var(--type-section-title-sm);

    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-wrap: balance;
  }

  .article-content h3 {
    margin: 2.7rem 0 0.9rem;
    font-family: var(--font-body);
    font-size: var(--type-lead);
    font-weight: 500;
    line-height: 1.35;
    color: var(--ink);
  }

  .article-content strong {
    font-weight: 500;
    color: var(--ink);
  }

  .article-content em {
    color: var(--taupe-dark);
  }

  .article-content a {
    color: var(--taupe-dark);
    text-decoration: underline;
    text-decoration-color: rgba(122,101,88,0.3);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition: color 0.35s ease, text-decoration-color 0.35s ease;
  }

  .article-content a:hover {
    color: var(--ink);
    text-decoration-color: rgba(42,31,26,0.5);
  }

  .article-content ul {
    display: grid;
    gap: 0.75rem;
    margin: 1.8rem 0 2.4rem;
    padding: 0;
    list-style: none;
  }

  .article-content li {
    position: relative;
    padding: 1rem 1rem 1rem 1.25rem;
    background: rgba(255,253,249,0.42);
    border: 1px solid rgba(196,170,148,0.12);
    border-radius: 4px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.52);
  }

  .article-content li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(196,170,148,0.45);
  }

  .article-content blockquote {
    position: relative;
    margin: 3rem 0;
    padding: clamp(1.6rem, 3vw, 2.4rem);
    overflow: hidden;
    background:
      linear-gradient(140deg, rgba(255,253,249,0.74), rgba(245,240,232,0.44)),
      radial-gradient(circle at 12% 20%, rgba(168,169,158,0.12), transparent 42%);
    border: 1px solid rgba(196,170,148,0.17);
    border-radius: 4px;
    box-shadow: 0 20px 64px rgba(42,31,26,0.055);
  }

  .article-content blockquote::before {
    content: '';
    position: absolute;
    inset: 1rem auto 1rem 1rem;
    width: 1px;
    background: rgba(196,170,148,0.48);
  }

  .article-content blockquote p {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);

    font-weight: 400;
    line-height: 1.22;
    color: var(--ink);
  }

  .article-content blockquote cite {
    display: block;
    font-size: var(--type-meta);
    font-style: normal;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: rgba(122,101,88,0.72);
  }

  /* Scroll reveal */
  .article-content h2,
  .article-content blockquote,
  .article-content .lead,
  .article-content ul {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s var(--ease-out-expo), transform 0.85s var(--ease-out-expo);
  }

  .article-content h2.is-visible,
  .article-content blockquote.is-visible,
  .article-content .lead.is-visible,
  .article-content ul.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== FINAL CTA ===== */
  .article-final-cta {
    width: min(1120px, calc(100% - 10vw));
    margin: 0 auto 7rem;
  }

  .article-final-cta__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
    padding: clamp(2rem, 4vw, 3.2rem);
    background:
      linear-gradient(135deg, rgba(255,253,249,0.78), rgba(245,240,232,0.5)),
      radial-gradient(circle at 86% 20%, rgba(107,125,106,0.11), transparent 40%);
    border: 1px solid rgba(196,170,148,0.18);
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(42,31,26,0.06);
  }

  .article-final-cta h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-section-title-sm);

    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    color: var(--ink);
  }

  .article-final-cta p {
    max-width: 58ch;
    margin: 1rem 0 0;
    font-size: var(--type-body);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(61,48,40,0.72);
  }

  /* ===== RELATED ===== */
  .article-related {
    width: min(1120px, calc(100% - 10vw));
    margin: 0 auto;
    padding: 0 0 8rem;
  }

  .article-related__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.6rem;
  }

  .article-related__header h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-section-title-sm);

    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    color: var(--ink);
  }

  .article-related__header a {
    flex: 0 0 auto;
    font-size: var(--type-micro);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe-dark);
    border-bottom: 1px solid rgba(122,101,88,0.32);
    transition: color 0.4s ease, border-color 0.4s ease;
  }

  .article-related__header a:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  .article-related__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .related-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid rgba(196, 170, 148, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(251, 248, 241, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.28), transparent 35%);
    box-shadow: 0 8px 32px rgba(42, 31, 26, 0.035);
    transition:
      transform 0.48s var(--ease-out-expo),
      border-color 0.35s ease,
      box-shadow 0.45s var(--ease-out-expo);
  }

  .related-card:hover {
    transform: translateY(-0.3rem);
    border-color: rgba(107, 125, 106, 0.85);
    box-shadow: 0 1.2rem 2.4rem rgba(57, 54, 48, 0.07);
  }

  .related-card figure {
    margin: 0;
    overflow: hidden;
    background: var(--cream-warm);
    aspect-ratio: 4 / 3;
    position: relative;
  }

  .related-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(12%) sepia(8%) saturate(0.82) contrast(1.04) brightness(0.96);
    transform: scale(1.02);
    transition: transform 0.85s var(--ease-out-expo), filter 0.85s ease;
  }

  .related-card:hover img {
    transform: scale(1.06);
    filter: grayscale(4%) sepia(4%) saturate(0.92) contrast(1.08) brightness(1);
  }

  .related-card figure::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(42, 31, 26, 0.18) 100%);
    pointer-events: none;
  }

  .related-card > div {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
