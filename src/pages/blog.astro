---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { getSortedArticles } from '../data/blog';

const sortedArticles = getSortedArticles();

const imageSeeds: Record<string, string> = {
  'emdr-cordoba': 'quiet-therapy-room',
  'duelo-perdida-cordoba': 'soft-window-light',
  'ansiedad-cordoba': 'calm-breathing-space',
  'mindfulness-regulacion-cordoba': 'mediterranean-stillness',
  'primera-consulta-cordoba': 'warm-consultation',
  'autoestima-cordoba': 'gentle-portrait-light',
};

const getArticleImage = (slug: string) =>
  `https://picsum.photos/seed/${imageSeeds[slug] ?? slug}/1200/900`;
---

<Layout
  title="Blog | Lucía Millán Jiménez | Psicología en Ciudad Real"
  description="Artículos sobre psicología, ansiedad, duelo, mindfulness y bienestar emocional en Ciudad Real. Información útil y cercana para cuidar tu salud mental."
>
  <Navigation />

  <main class="blog-page">
    <!-- Header -->
    <header class="blog-page__header">
      <div class="blog-page__eyebrow-wrap reveal">
        <span class="eyebrow-line" aria-hidden="true"></span>
        <span class="type-eyebrow blog-page__eyebrow">Blog</span>
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="blog-page__title reveal">
        <span class="title-word">Reflexiones desde</span>
        <span class="title-word title-word--accent">la consulta</span>
      </h1>
      <p class="blog-page__subtitle reveal">
        Artículos sobre salud mental, terapia y bienestar emocional escritos desde mi práctica clínica en Ciudad Real.
      </p>
    </header>

    <!-- Articles Grid -->
    <section class="blog-page__grid" aria-label="Artículos del blog">
      <div class="blog-grid">
        {sortedArticles.map((article, i) => (
          <article class="blog-grid-card" style={`transition-delay: ${i * 80}ms`}>
            <a href={`/blog/${article.slug}`} class="blog-grid-card__link">
              <!-- Image -->
              <figure class="blog-grid-card__media">
                <img
                  src={getArticleImage(article.slug)}
                  alt={`Imagen editorial para ${article.title}`}
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <span class="blog-grid-card__image-scrim" aria-hidden="true"></span>
                <!-- Number watermark -->
                <span class="blog-grid-card__number" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
              </figure>

              <!-- Content -->
              <div class="blog-grid-card__body">
                <!-- Top: category + read time -->
                <div class="blog-grid-card__top">
                  <span class="blog-grid-card__category">{article.categoryLabel}</span>
                  <span class="blog-grid-card__read">{article.readTime}</span>
                </div>

                <h2 class="blog-grid-card__title">{article.title}</h2>
                <p class="blog-grid-card__excerpt">{article.excerpt}</p>
              </div>

              <!-- Footer -->
              <div class="blog-grid-card__footer">
                <time datetime={article.dateISO} class="blog-grid-card__date">
                  {article.date}
                </time>
                <span class="blog-grid-card__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>

              <!-- Hover line -->
              <div class="blog-grid-card__hover-line" aria-hidden="true"></div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .blog-page {
    position: relative;
    background: var(--parchment);
    padding: 10rem 0 8rem;
    min-height: 100vh;
  }

  /* Header */
  .blog-page__header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 5rem;
    padding: 0 6vw;
  }
  .blog-page__eyebrow-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--earth);
    opacity: 0.2;
  }
  .blog-page__eyebrow {
    font-size: var(--type-meta);
    letter-spacing: 0.35em;
    color: var(--taupe);
    opacity: 0.7;
  }
  .blog-page__title {
    margin: 0 0 1rem;
    line-height: 1.0;
  }
  .title-word {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--type-section-title);
    line-height: var(--leading-title);
    color: var(--ink);
    letter-spacing: 0.02em;
  }
  .title-word--accent {
    color: var(--ink-soft);
    font-weight: 400;
  }
  .blog-page__subtitle {
    font-family: var(--font-body);
    font-size: var(--type-section-subtitle);
    font-weight: 300;
    color: var(--taupe);
    opacity: 0.7;
    letter-spacing: 0.02em;
    margin: 0 auto;
    max-width: 50ch;
  }

  /* Grid */
  .blog-page__grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 6vw;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Card */
  .blog-grid-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-radius: 0.75rem;
  }

  /* Per-card accent colors */
  .blog-grid-card:nth-child(6n+1) {
    --blog-accent: rgba(107, 125, 106, 0.85);
    --blog-accent-soft: rgba(107, 125, 106, 0.12);
  }
  .blog-grid-card:nth-child(6n+2) {
    --blog-accent: rgba(184, 168, 138, 0.95);
    --blog-accent-soft: rgba(184, 168, 138, 0.14);
  }
  .blog-grid-card:nth-child(6n+3) {
    --blog-accent: rgba(138, 145, 130, 0.92);
    --blog-accent-soft: rgba(138, 145, 130, 0.14);
  }
  .blog-grid-card:nth-child(6n+4) {
    --blog-accent: rgba(122, 113, 102, 0.88);
    --blog-accent-soft: rgba(122, 113, 102, 0.12);
  }
  .blog-grid-card:nth-child(6n+5) {
    --blog-accent: rgba(168, 169, 158, 0.85);
    --blog-accent-soft: rgba(168, 169, 158, 0.14);
  }
  .blog-grid-card:nth-child(6n+6) {
    --blog-accent: rgba(154, 140, 120, 0.9);
    --blog-accent-soft: rgba(154, 140, 120, 0.13);
  }

  .blog-grid-card__link {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(251, 248, 241, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.28), transparent 35%);
    border: 1px solid rgba(196, 170, 148, 0.14);
    box-shadow: 0 8px 32px rgba(42, 31, 26, 0.035);
    transition:
      transform 0.48s var(--ease-out-expo),
      border-color 0.35s ease,
      box-shadow 0.45s var(--ease-out-expo);
  }

  /* Radial glow decoration */
  .blog-grid-card__link::after {
    content: '';
    position: absolute;
    inset: auto -12% -16% auto;
    width: 9rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, var(--blog-accent-soft), transparent 68%);
    pointer-events: none;
    opacity: 0.45;
    transform: scale(0.84);
    transition: transform 0.7s var(--ease-out-expo), opacity 0.45s ease;
  }

  .blog-grid-card__link:hover {
    transform: translateY(-0.3rem);
    border-color: var(--blog-accent);
    box-shadow: 0 1.2rem 2.4rem rgba(57, 54, 48, 0.07);
  }

  .blog-grid-card__link:hover::after {
    transform: scale(1.08);
    opacity: 0.72;
  }

  /* Image */
  .blog-grid-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--cream-warm);
  }

  .blog-grid-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(12%) sepia(8%) saturate(0.82) contrast(1.04) brightness(0.96);
    transform: scale(1.02);
    transition: transform 0.85s var(--ease-out-expo), filter 0.85s ease;
  }

  .blog-grid-card:hover .blog-grid-card__media img {
    transform: scale(1.06);
    filter: grayscale(4%) sepia(4%) saturate(0.92) contrast(1.08) brightness(1);
  }

  .blog-grid-card__image-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(42, 31, 26, 0.18) 100%);
    pointer-events: none;
  }

  .blog-grid-card__number {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    z-index: 3;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.4rem;
    color: var(--parchment);
    opacity: 0.7;
    line-height: 1;
    user-select: none;
    transition: opacity 0.6s ease, transform 0.6s var(--ease-out-expo);
  }
  .blog-grid-card:hover .blog-grid-card__number {
    opacity: 1;
    transform: translateY(-2px);
  }

  .blog-grid-card__top {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.05rem;
  }
  .blog-grid-card__category {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    padding: 0.25rem 0.55rem;
    border: 1px solid rgba(111, 125, 103, 0.14);
    border-radius: 999px;
    color: rgba(47, 45, 40, 0.62);
    background: rgba(255, 255, 255, 0.65);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition:
      transform 0.35s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }
  .blog-grid-card:hover .blog-grid-card__category {
    transform: translateY(-1px);
    border-color: var(--blog-accent);
    background: var(--blog-accent-soft);
    color: rgba(47, 45, 40, 0.78);
  }
  .blog-grid-card__read {
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.45;
  }

  .blog-grid-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: clamp(1rem, 1.4vw, 1.35rem);
  }
  .blog-grid-card__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.15rem, 1.5vw, 1.5rem);
    line-height: 1.15;
    color: var(--ink);
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 14ch;
    transition: color 0.5s ease, transform 0.45s var(--ease-out-expo);
  }
  .blog-grid-card:hover .blog-grid-card__title {
    color: var(--blog-accent);
    transform: translateY(-1px);
  }
  .blog-grid-card__excerpt {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 0.9vw, 0.88rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--ink-soft);
    opacity: 0.68;
    margin: 0;
    transition: color 0.35s ease, transform 0.45s var(--ease-out-expo);
  }
  .blog-grid-card:hover .blog-grid-card__excerpt {
    transform: translateY(-1px);
  }

  .blog-grid-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.85rem;
    padding-left: clamp(1rem, 1.4vw, 1.35rem);
    padding-right: clamp(1rem, 1.4vw, 1.35rem);
    padding-bottom: clamp(1rem, 1.4vw, 1.35rem);
    border-top: 1px solid rgba(196, 170, 148, 0.1);
  }
  .blog-grid-card__date {
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(122, 101, 88, 0.55);
  }
  .blog-grid-card__arrow {
    color: var(--taupe);
    opacity: 0.38;
    transition: all 0.5s var(--ease-out-expo);
    transform: translateX(-4px);
  }
  .blog-grid-card:hover .blog-grid-card__arrow {
    opacity: 0.85;
    transform: translateX(0);
    color: var(--blog-accent);
  }

  .blog-grid-card__hover-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blog-accent), transparent);
    opacity: 0.2;
    transition: width 0.9s var(--ease-out-expo);
  }
  .blog-grid-card:hover .blog-grid-card__hover-line {
    width: 100%;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.2rem;
    }
  }
  @media (max-width: 640px) {
    .blog-page {
      padding: 7rem 0 5rem;
    }
    .blog-page__header {
      margin-bottom: 2.8rem;
      padding: 0 5vw;
    }
    .blog-page__title {
      line-height: 1.05;
    }
    .title-word {
      font-size: clamp(2.4rem, 11vw, 3.6rem);
      letter-spacing: -0.02em;
    }
    .blog-page__subtitle {
      font-size: 0.95rem;
      line-height: 1.6;
    }
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      max-width: 420px;
      margin: 0 auto;
      padding: 0 5vw;
    }
    .blog-grid-card__media {
      aspect-ratio: 16 / 10;
    }
    .blog-grid-card__body {
      padding: 1rem;
    }
    .blog-grid-card__footer {
      padding-left: 1rem;
      padding-right: 1rem;
      padding-bottom: 1rem;
    }
    .blog-grid-card__title {
      font-size: clamp(1.1rem, 4.5vw, 1.35rem);
      max-width: none;
    }
    .blog-grid-card__excerpt {
      font-size: 0.82rem;
    }
  }
</style>
