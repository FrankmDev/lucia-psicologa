---
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';

const faqs = [
  {
    k: 'Duración',
    q: '¿Cuánto dura una sesión?',
    a: 'Las sesiones individuales duran alrededor de 50 minutos. En trabajo de trauma o EMDR pueden ampliarse a 60–90 minutos si lo acordamos previamente y tiene sentido clínico.',
  },
  {
    k: 'Modalidad',
    q: '¿La terapia puede ser online?',
    a: 'Sí. Atiendo de forma presencial en Ciudad Real y online. En ambos casos mantenemos el mismo encuadre y seguimiento clínico.',
  },
  {
    k: 'Primera sesión',
    q: '¿Qué ocurre en la primera sesión?',
    a: 'Revisamos el motivo de consulta, desde cuándo ocurre, cómo afecta a tu vida y qué esperas de la terapia. También resolvemos dudas, valoramos qué enfoque puede encajar mejor y definimos un primer objetivo.',
  },
  {
    k: 'Enfoque',
    q: '¿Siempre se trabaja con la misma terapia?',
    a: 'No. Integro TCC, ACT, TFE, IFS y EMDR según tu problemática, tus recursos y el momento del proceso. La idea es adaptar la intervención a ti, no encajarte en una técnica cerrada.',
  },
  {
    k: 'EMDR',
    q: '¿El EMDR sirve para cualquier caso?',
    a: 'No siempre. Primero evaluamos tu historia, tu estabilidad actual y tus recursos de regulación. Si EMDR no es lo más adecuado en ese momento, trabajamos con otro enfoque o preparamos el proceso antes de iniciar el reprocesamiento.',
  },
  {
    k: 'Frecuencia',
    q: '¿Con qué frecuencia se acude?',
    a: 'Lo habitual es empezar con una sesión semanal. Después podemos ajustar la frecuencia según la evolución y tus circunstancias.',
  },
  {
    k: 'Contacto',
    q: '¿Cómo puedo pedir cita?',
    a: 'Puedes escribir desde el formulario de contacto, por email o por teléfono. Te respondo para orientarte, resolver dudas iniciales y valorar un primer hueco.',
  },
];
---

<section id="faq" class="faq" data-faq>
  <GrainOverlay opacity={0.012} />
  <AmbientLight color="rgba(255,255,255,0.24)" />
  <FloatOrb size={360} top="-14%" right="-10%" color="rgba(141,151,132,0.12)" blur={145} opacity={0.32} animation="float-1" />
  <FloatOrb size={240} bottom="4%" left="-8%" color="rgba(216,211,200,0.24)" blur={120} opacity={0.28} animation="float-2" />

  <Container maxWidth="860px" padding="0 clamp(1rem, 4vw, 4rem)">
    <div class="faq-shell">
      <header class="faq-header reveal-blur" data-delay="80">
        <span class="section-eyebrow">Preguntas frecuentes</span>
        <h2>Lo que suele preguntarse antes de empezar.</h2>
      </header>

      <div class="faq-panel reveal-scale" data-delay="180">
        <div class="faq-list" aria-label="Preguntas frecuentes">
          {faqs.map((faq, i) => (
            <article class="faq-item reveal-up" data-faq-item style={`transition-delay: ${220 + i * 55}ms`}>
              <h3>
                <button
                  class="faq-trigger"
                  aria-expanded="false"
                  aria-controls={`faq-answer-${i}`}
                >
                  <div class="faq-trigger__copy">
                    <span class="faq-number">{String(i + 1).padStart(2, '0')}</span>
                    <span class="faq-kicker">{faq.k}</span>
                    <span class="faq-question">{faq.q}</span>
                  </div>
                  <span class="faq-icon" aria-hidden="true">
                    <svg viewBox="0 0 18 18" fill="none" class="faq-icon-svg" aria-hidden="true">
                      <line x1="9" y1="4.5" x2="9" y2="13.5" stroke="currentColor" stroke-width="1.05" class="faq-icon-v"/>
                      <line x1="4.5" y1="9" x2="13.5" y2="9" stroke="currentColor" stroke-width="1.05"/>
                    </svg>
                  </span>
                </button>
              </h3>

              <div id={`faq-answer-${i}`} class="faq-answer">
                <div class="faq-answer__inner">
                  <div class="faq-answer__body">
                    <p>{faq.a}</p>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .faq {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py--compact) 0 calc(var(--section-py--compact) + 0.5rem);
    background:
      radial-gradient(circle at 12% 8%, rgba(255, 255, 255, 0.92), transparent 28%),
      radial-gradient(circle at 84% 18%, rgba(223, 228, 216, 0.34), transparent 30%),
      radial-gradient(circle at 68% 84%, rgba(184, 168, 138, 0.08), transparent 28%),
      linear-gradient(180deg, var(--color-surface-white) 0%, var(--color-surface-elevated) 64%, #f5f1ea 100%);
  }

  .faq::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.008) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 42%, #000 0%, transparent 73%);
    opacity: 0.68;
  }

  .faq-shell {
    position: relative;
    z-index: 2;
  }

  .faq-header {
    max-width: 50rem;
    margin: 0 auto clamp(2.4rem, 4vw, 3.4rem);
    text-align: center;
  }

  .faq-header h2 {
    max-width: 49rem;
    margin: 1rem auto 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .faq-panel {
    position: relative;
    max-width: 100%;
    margin: 0 auto;
  }

  .faq-list {
    position: relative;
  }

  .faq-item {
    border-top: 1px solid rgba(111, 125, 103, 0.085);
    transition: border-color 0.35s ease;
    position: relative;
    padding-left: 0;
  }
  .faq-item:first-child {
    border-top: 0;
  }
  .faq-item:hover,
  .faq-item.open {
    border-top-color: rgba(111, 125, 103, 0.14);
  }

  .faq-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    bottom: 50%;
    width: 2px;
    background: rgba(111, 125, 103, 0.18);
    border-radius: 1px;
    transform: translateY(-50%);
    transition: top 0.7s var(--ease-out-expo), bottom 0.7s var(--ease-out-expo), opacity 0.5s ease;
    opacity: 0;
  }
  .faq-item.open::before {
    top: 0;
    bottom: 0;
    opacity: 1;
  }

  .faq-item h3 {
    margin: 0;
  }

  .faq-trigger {
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: var(--card-pd-sm) 0;
    border: 0;
    background: transparent;
    text-align: left;
    color: inherit;
    cursor: pointer;
  }

  .faq-trigger__copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .faq-number {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    color: rgba(184, 168, 138, 0.55);
    line-height: 1;
    margin-bottom: 0.15rem;
    transition: color 0.35s ease;
  }
  .faq-item:hover .faq-number,
  .faq-item.open .faq-number {
    color: rgba(184, 168, 138, 0.85);
  }

  .faq-kicker {
    display: inline-block;
    margin-bottom: 0.35rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.76;
  }

  .faq-question {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: normal;
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.015em;
    text-wrap: balance;
    transition: color 0.35s ease;
  }
  .faq-item:hover .faq-question,
  .faq-item.open .faq-question {
    color: var(--color-accent-deep);
  }

  .faq-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    color: var(--color-ink);
    opacity: 0.24;
    flex-shrink: 0;
    transition: transform 0.45s var(--ease-out-expo), opacity 0.35s ease, color 0.35s ease;
  }
  .faq-item:hover .faq-icon,
  .faq-item.open .faq-icon {
    color: var(--color-accent);
    opacity: 0.5;
  }
  .faq-item.open .faq-icon {
    transform: rotate(45deg);
  }

  .faq-icon-svg {
    width: 100%;
    height: 100%;
  }
  .faq-icon-v {
    transform-origin: center;
    transition: transform 0.45s var(--ease-out-expo);
  }
  .faq-item.open .faq-icon-v {
    transform: scaleY(0);
  }

  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.7s var(--ease-out-expo);
  }
  .faq-answer.open {
    grid-template-rows: 1fr;
  }

  .faq-answer__inner {
    overflow: hidden;
  }

  .faq-answer__body {
    max-width: 41rem;
    padding: 0.1rem 0 1.5rem;
    transform: translateY(10px);
    opacity: 0;
    transition: transform 0.55s var(--ease-out-expo) 0.08s, opacity 0.4s ease 0.08s;
  }
  .faq-answer.open .faq-answer__body {
    transform: translateY(0);
    opacity: 1;
  }
  .faq-answer__body p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    font-weight: 300;
    line-height: 1.72;
    text-wrap: pretty;
  }

  @media (max-width: 768px) {
    .faq {
      padding: 4.8rem 0 5.8rem;
    }

    .faq-header {
      margin-bottom: 2rem;
      padding: 0 4vw;
    }

    .faq-header h2 {
      font-size: var(--type-section-title-sm);
      line-height: 1.02;
      letter-spacing: -0.02em;
    }

    .section-eyebrow {
      gap: 0.55rem;
      letter-spacing: 0.18em;
    }
    .section-eyebrow::before,
    .section-eyebrow::after {
      width: 1.45rem;
    }

    .faq-trigger {
      gap: 0.8rem;
      padding: var(--card-pd-sm) 0;
    }

    .faq-kicker {
      font-size: var(--type-micro);
      letter-spacing: 0.16em;
      margin-bottom: 0.25rem;
    }

    .faq-question {
      font-size: var(--type-card-title);
      line-height: 1.16;
    }

    .faq-icon {
      width: 1.5rem;
      height: 1.5rem;
    }

    .faq-answer__body {
      padding-bottom: 1.1rem;
    }

    .faq-answer__body p {
      font-size: var(--type-body-sm);
      line-height: 1.68;
    }
  }

  @media (max-width: 480px) {
    .faq-header {
      margin-bottom: 1.8rem;
    }
    .faq-icon {
      width: 1.4rem;
      height: 1.4rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const isOpen = answer?.classList.contains('open');

      document.querySelectorAll('.faq-item').forEach((sibling) => {
        if (sibling !== item) {
          sibling.classList.remove('open');
          const siblingAnswer = sibling.querySelector('.faq-answer');
          siblingAnswer?.classList.remove('open');
          const siblingTrigger = sibling.querySelector('.faq-trigger');
          siblingTrigger?.setAttribute('aria-expanded', 'false');
        }
      });

      answer?.classList.toggle('open');
      item?.classList.toggle('open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
