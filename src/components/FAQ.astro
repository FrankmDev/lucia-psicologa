---
import SectionHeader from './ui/SectionHeader.astro';
import CardSurface from './ui/CardSurface.astro';
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import InkBlob from './ui/InkBlob.astro';
import BotanicalSVG from './ui/BotanicalSVG.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';

const faqs = [
  { q: "Cuanto dura una sesion de terapia?", a: "Las sesiones individuales tienen una duracion aproximada de 50-55 minutos. En terapia de pareja, la sesion puede extenderse hasta 75 minutos." },
  { q: "Ofreces terapia online?", a: "Si, ofrezco sesiones online a traves de una plataforma segura y encriptada. La terapia online ha demostrado ser igual de efectiva que la presencial." },
  { q: "Con que frecuencia debo acudir?", a: "Generalmente recomiendo una sesion semanal, especialmente al inicio. Esta regularidad permite mantener la continuidad y profundidad del trabajo." },
  { q: "Cuanto tiempo dura un proceso terapeutico?", a: "La duracion depende de tus objetivos y la complejidad de la demanda. Algunas personas encuentran alivio en pocas sesiones; otras prefieren un acompanamiento mas largo." },
  { q: "Que es el EMDR y para que sirve?", a: "EMDR es una terapia especializada para procesar experiencias dificiles. Utiliza estimulacion bilateral para ayudar al cerebro a reprocesar recuerdos de forma mas adaptativa, reduciendo su impacto emocional." },
  { q: "Como puedo pedir cita?", a: "Puedes contactarme a traves del formulario de esta web, por email o por telefono. Te respondere en un plazo maximo de 24 horas laborables." },
];
---

<section id="faq" class="faq" data-faq>
  <GrainOverlay opacity={0.02} />
  <AmbientLight color="rgba(196,170,148,0.04)" />
  <DustParticles count={10} color="rgba(196,170,148,0.15)" />
  <FloatOrb size={320} top="10%" right="-5%" color="var(--sage-muted)" blur={110} opacity={0.35} animation="float-1" />
  <FloatOrb size={220} bottom="15%" left="-3%" color="var(--gold-soft)" opacity={0.35} animation="float-2" />

  <InkBlob width={360} height={280} bottom="10%" left="-10%" color="var(--earth)" opacity={0.04} animation="morph-2" />
  <InkBlob width={260} height={200} top="20%" right="-5%" color="var(--sage)" opacity={0.025} animation="morph-blob" />

  <BotanicalSVG variant="right" opacity={0.04} width={85} />
  <BotanicalSVG variant="left" color="var(--sage-muted)" opacity={0.035} width={65} />

  <div class="faq-watermark" aria-hidden="true">
    <span class="watermark-text">FAQ</span>
  </div>

  <Container maxWidth="1200px">
    <div class="faq-layout">
      <!-- Left column: intro -->
      <div class="faq-intro">
        <SectionHeader
          eyebrow="FAQ"
          title={['Preguntas', 'frecuentes']}
          subtitle="Todo lo que necesitas saber antes de dar el primer paso. Si tienes otra duda, no dudes en escribirme."
          variant="editorial"
          align="start"
          index="06"
          class="reveal-blur"
        />

        <div class="faq-intro__visual reveal-scale" data-delay="400">
          <div class="intro-visual__frame">
            <div class="intro-visual__line intro-visual__line--h" aria-hidden="true"></div>
            <div class="intro-visual__line intro-visual__line--v" aria-hidden="true"></div>
            <div class="intro-visual__num" aria-hidden="true">06</div>
            <p class="intro-visual__text">Respuestas claras para que tomes la mejor decision.</p>
          </div>
        </div>
      </div>

      <!-- Right column: accordion -->
      <div class="faq-accordion">
        <div class="faq-list stagger-children" data-delay="300">
          {faqs.map((faq, i) => (
            <div class="faq-item reveal-up" data-faq-item>
              <CardSurface watermark={`0${i + 1}`} class="faq-item-surface" hoverable={true}>
                <div class="faq-glow" aria-hidden="true"></div>
                <div class="faq-item-header">
                  <div class="faq-item-meta">
                    <span class="faq-item-num">0{i + 1}</span>
                    <span class="faq-item-sep" aria-hidden="true"></span>
                  </div>

                  <button
                    class="faq-trigger"
                    aria-expanded="false"
                    aria-controls={`faq-answer-${i}`}
                  >
                    <span class="faq-q">{faq.q}</span>
                    <span class="faq-icon" aria-hidden="true">
                      <svg class="faq-icon-svg" viewBox="0 0 14 14" aria-hidden="true">
                        <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1" class="faq-icon-v"/>
                        <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1"/>
                      </svg>
                    </span>
                  </button>
                </div>

                <div id={`faq-answer-${i}`} class="faq-answer">
                  <div class="faq-answer-inner">
                    <div class="faq-answer-content">
                      <div class="faq-answer-accent" aria-hidden="true"></div>
                      <div class="faq-answer-body">
                        <p>{faq.a}</p>
                        <svg class="faq-answer-line" viewBox="0 0 200 2" preserveAspectRatio="none" aria-hidden="true">
                          <path d="M0 1 Q100 0 200 1" stroke="var(--sage-light)" stroke-width="0.6" fill="none" class="faq-answer-line-path"/>
                        </svg>
                      </div>
                    </div>
                  </div>
                </div>
              </CardSurface>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="faq-footer reveal-up" data-delay="600">
      <div class="faq-footer-ornament" aria-hidden="true">
        <span class="footer-line"></span>
        <span class="footer-fleur">&#10086;</span>
        <span class="footer-line"></span>
      </div>
      <p class="faq-footer-text">Tienes otra pregunta?</p>
      <a href="#contacto" class="faq-footer-link">
        <span class="footer-link-text">Escribeme directamente</span>
        <span class="footer-link-line" aria-hidden="true"></span>
        <span class="footer-link-dot" aria-hidden="true"></span>
      </a>
    </div>
  </Container>

  <PageNumber number="06" />
</section>

<style>
  .faq {
    position: relative;
    width: 100%;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 70% 20%, rgba(107,125,106,0.035) 0%, transparent 50%),
      radial-gradient(ellipse at 30% 80%, rgba(196,170,148,0.04) 0%, transparent 45%),
      var(--white-warm);
    padding: 10rem 0 12rem;
  }
  .faq::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: min(40vw, 500px);
    height: min(40vw, 500px);
    border-radius: 50%;
    border: 1px solid rgba(107,125,106,0.03);
    transform: translate(30%, -30%);
    pointer-events: none;
    z-index: 0;
  }

  .faq-watermark {
    position: absolute;
    bottom: 10%;
    right: -1%;
    pointer-events: none;
    z-index: 0;
    user-select: none;
    transform: rotate(-90deg);
    transform-origin: right bottom;
  }
  .watermark-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(5rem, 10vw, 8rem);
    color: var(--earth);
    opacity: 0.02;
    line-height: 1;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .faq-layout {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: start;
    margin-bottom: 5rem;
  }

  .faq-intro {
    position: sticky;
    top: 8rem;
  }
  .faq-intro :global(.section-header) {
    margin-bottom: 3rem;
  }

  .faq-intro__visual {
    position: relative;
    padding: 2rem;
  }
  .intro-visual__frame {
    position: relative;
    padding: 2rem 1.5rem;
    border: 1px solid var(--line);
    background: rgba(255,253,249,0.5);
    transition: border-color 0.6s ease, box-shadow 0.6s ease;
  }
  .intro-visual__frame:hover {
    border-color: rgba(196,170,148,0.18);
    box-shadow: 0 12px 32px rgba(44,44,44,0.03);
  }
  .intro-visual__line {
    position: absolute;
    background: var(--earth);
    opacity: 0.08;
  }
  .intro-visual__line--h {
    top: -1px;
    left: 2rem;
    width: 40px;
    height: 1px;
  }
  .intro-visual__line--v {
    top: 2rem;
    left: -1px;
    width: 1px;
    height: 40px;
  }
  .intro-visual__num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 3rem;
    color: var(--earth);
    opacity: 0.1;
    line-height: 1;
    margin-bottom: 1rem;
  }
  .intro-visual__text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--taupe);
    opacity: 0.7;
    margin: 0;
  }

  .faq-accordion {
    position: relative;
    z-index: 1;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .faq-item-surface {
    padding: 2.4rem 2.2rem 2rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.7s var(--ease-out-expo), box-shadow 0.7s ease;
  }
  .faq-item.open .faq-item-surface,
  .faq-item:hover .faq-item-surface {
    transform: translateY(-5px);
    box-shadow:
      0 12px 32px rgba(44,44,44,0.04),
      0 4px 12px rgba(44,44,44,0.02);
  }
  .faq-item.open .faq-item-surface {
    border-left: 2px solid rgba(107,125,106,0.15);
  }

  .faq-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(196,170,148,0.04) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.7s ease;
    pointer-events: none;
    z-index: 0;
  }
  .faq-item:hover .faq-glow,
  .faq-item.open .faq-glow {
    opacity: 1;
  }

  .faq-item-header {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .faq-item-meta {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
    min-width: 2.5rem;
  }
  .faq-item-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 0.8rem;
    color: var(--taupe);
    opacity: 0.3;
    letter-spacing: 0.05em;
    transition: opacity 0.4s ease, color 0.4s ease;
  }
  .faq-item.open .faq-item-num,
  .faq-item:hover .faq-item-num {
    opacity: 0.65;
    color: var(--sage-dark);
  }
  .faq-item-sep {
    width: 1px;
    height: 10px;
    background: var(--earth);
    opacity: 0;
    margin-left: 0.6rem;
    transition: opacity 0.5s ease;
  }
  .faq-item.open .faq-item-sep,
  .faq-item:hover .faq-item-sep {
    opacity: 0.1;
  }

  .faq-trigger {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    position: relative;
    z-index: 1;
  }

  .faq-q {
    flex: 1;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.15rem, 1.6vw, 1.4rem);
    color: var(--ink);
    line-height: 1.25;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 0 rgba(255,255,255,0.5);
    transition: color 0.4s ease;
    padding-right: 1rem;
  }
  .faq-item:hover .faq-q {
    color: var(--earth);
  }
  .faq-item.open .faq-q {
    color: var(--ink-soft);
  }

  .faq-icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    opacity: 0.25;
    transition: opacity 0.4s ease, transform 0.5s var(--ease-out-expo);
  }
  .faq-item.open .faq-icon,
  .faq-item:hover .faq-icon {
    opacity: 0.55;
  }
  .faq-item.open .faq-icon {
    transform: rotate(45deg);
  }
  .faq-icon-svg {
    width: 20px;
    height: 20px;
    overflow: visible;
  }
  .faq-icon-v {
    transform-origin: center;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .faq-item.open .faq-icon-v {
    transform: scaleY(0);
  }

  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.7s var(--ease-out-expo);
    position: relative;
    z-index: 1;
  }
  .faq-answer.open {
    grid-template-rows: 1fr;
  }
  .faq-answer-inner {
    overflow: hidden;
  }

  .faq-answer-content {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    padding-top: 1.6rem;
    padding-left: 4rem;
    padding-right: 2rem;
    transform: translateY(8px);
    opacity: 0;
    transition: transform 0.6s var(--ease-out-expo) 0.1s, opacity 0.5s ease 0.1s;
  }
  .faq-answer.open .faq-answer-content {
    transform: translateY(0);
    opacity: 1;
  }

  .faq-answer-accent {
    width: 2px;
    height: 0;
    background: var(--sage-muted);
    opacity: 0.25;
    margin-top: 0.5rem;
    flex-shrink: 0;
    transition: height 0.8s var(--ease-out-expo) 0.15s;
  }
  .faq-answer.open .faq-answer-accent {
    height: 44px;
  }

  .faq-answer-body {
    flex: 1;
  }
  .faq-answer-body p {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.88rem;
    line-height: 1.78;
    color: var(--ink-soft);
    opacity: 0.88;
    max-width: 48ch;
    margin: 0 0 1rem;
  }

  .faq-answer-line {
    width: 100%;
    height: 2px;
    pointer-events: none;
    overflow: visible;
  }
  .faq-answer-line-path {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    transition: stroke-dashoffset 1.2s var(--ease-out-expo) 0.3s;
  }
  .faq-answer.open .faq-answer-line-path {
    stroke-dashoffset: 0;
  }

  .faq-footer {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }
  .faq-footer-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .footer-line {
    display: block;
    width: 0;
    height: 1px;
    background: var(--earth);
    opacity: 0.15;
    transition: width 0.8s var(--ease-out-expo), opacity 0.4s ease;
  }
  .faq-footer.visible .footer-line {
    width: 32px;
    opacity: 0.25;
  }
  .footer-fleur {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1rem;
    color: var(--sage);
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .faq-footer.visible .footer-fleur {
    opacity: 0.5;
  }
  .faq-footer-text {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.85rem;
    color: var(--taupe);
    opacity: 0.6;
    margin: 0;
  }
  .faq-footer-link {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--taupe-dark);
    text-decoration: none;
    position: relative;
    padding: 0.5rem 0;
    transition: color 0.4s ease;
  }
  .faq-footer-link:hover {
    color: var(--sage-dark);
  }
  .footer-link-text {
    position: relative;
  }
  .footer-link-line {
    display: block;
    width: 0;
    height: 1px;
    background: var(--earth);
    opacity: 0.2;
    transition: width 0.8s var(--ease-out-expo), opacity 0.4s ease;
  }
  .faq-footer-link:hover .footer-link-line {
    width: 100%;
    opacity: 0.4;
  }
  .footer-link-dot {
    position: absolute;
    bottom: -1px;
    left: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--earth);
    opacity: 0;
    transform: translateX(-50%) scale(0);
    transition: opacity 0.4s ease, transform 0.4s var(--ease-out-expo);
  }
  .faq-footer-link:hover .footer-link-dot {
    opacity: 0.4;
    transform: translateX(-50%) scale(1);
  }

  @media (max-width: 900px) {
    .faq-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .faq-intro {
      position: relative;
      top: auto;
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
    }
    .faq-intro__visual {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .faq {
      padding: 8rem 0 10rem;
    }
    .faq-item-surface {
      padding: 2rem 1.6rem 1.8rem;
    }
    .faq-item-header {
      gap: 1rem;
    }
    .faq-item-meta {
      min-width: 2rem;
    }
    .faq-item-num {
      font-size: 0.7rem;
    }
    .faq-q {
      font-size: clamp(1.05rem, 4vw, 1.25rem);
    }
    .faq-icon {
      width: 18px;
      height: 18px;
    }
    .faq-icon-svg {
      width: 18px;
      height: 18px;
    }
    .faq-answer-content {
      padding-left: 0;
      padding-right: 0;
      gap: 0.8rem;
    }
    .faq-answer-accent {
      width: 2px;
    }
    .faq-answer-body p {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .faq-item-surface {
      padding: 1.8rem 1.4rem 1.6rem;
    }
    .faq-item-meta {
      display: none;
    }
    .faq-answer-content {
      padding-top: 1.2rem;
    }
    .faq-answer-accent {
      display: none;
    }
    .faq-answer-line {
      display: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const isOpen = answer?.classList.contains('open');

      document.querySelectorAll('.faq-item').forEach(sibling => {
        if (sibling !== item) {
          sibling.classList.remove('open');
          const sa = sibling.querySelector('.faq-answer');
          sa?.classList.remove('open');
          const st = sibling.querySelector('.faq-trigger');
          st?.setAttribute('aria-expanded', 'false');
        }
      });

      answer?.classList.toggle('open');
      item?.classList.toggle('open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));

      if (!isOpen && item) {
        setTimeout(() => {
          const rect = item.getBoundingClientRect();
          const offset = 120;
          if (rect.top < offset) {
            window.scrollBy({ top: rect.top - offset, behavior: 'smooth' });
          }
        }, 350);
      }
    });
  });
</script>
