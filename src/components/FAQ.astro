---
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';

const faqs = [
  {
    k: 'Duración',
    q: '¿Cuánto dura una sesión?',
    a: 'Las sesiones individuales duran alrededor de 50 minutos. En trabajo de trauma o EMDR pueden ampliarse a 60–90 minutos si lo acordamos previamente y tiene sentido clínico.',
  },
  {
    k: 'Modalidad',
    q: '¿La terapia puede ser online?',
    a: 'Sí. Atiendo de forma presencial en Ciudad Real y online. En ambos casos mantenemos el mismo encuadre y seguimiento clínico.',
  },
  {
    k: 'Primera sesión',
    q: '¿Qué ocurre en la primera sesión?',
    a: 'Revisamos el motivo de consulta, desde cuándo ocurre, cómo afecta a tu vida y qué esperas de la terapia. También resolvemos dudas, valoramos qué enfoque puede encajar mejor y definimos un primer objetivo.',
  },
  {
    k: 'Enfoque',
    q: '¿Siempre se trabaja con la misma terapia?',
    a: 'No. Integro TCC, ACT, TFE, IFS y EMDR según tu problemática, tus recursos y el momento del proceso. La idea es adaptar la intervención a ti, no encajarte en una técnica cerrada.',
  },
  {
    k: 'EMDR',
    q: '¿El EMDR sirve para cualquier caso?',
    a: 'No siempre. Primero evaluamos tu historia, tu estabilidad actual y tus recursos de regulación. Si EMDR no es lo más adecuado en ese momento, trabajamos con otro enfoque o preparamos el proceso antes de iniciar el reprocesamiento.',
  },
  {
    k: 'Frecuencia',
    q: '¿Con qué frecuencia se acude?',
    a: 'Lo habitual es empezar con una sesión semanal. Después podemos ajustar la frecuencia según la evolución y tus circunstancias.',
  },
  {
    k: 'Contacto',
    q: '¿Cómo puedo pedir cita?',
    a: 'Puedes escribir desde el formulario de contacto, por email o por teléfono. Te respondo para orientarte, resolver dudas iniciales y valorar un primer hueco.',
  },
];

const categoryColors: Record<string, string> = {
  'Duración': '122, 138, 122',
  'Modalidad': '138, 154, 137',
  'Primera sesión': '111, 125, 103',
  'Enfoque': '156, 146, 126',
  'EMDR': '184, 168, 138',
  'Frecuencia': '138, 145, 130',
  'Contacto': '108, 128, 128',
};
---

<section id="faq" class="faq section--white-warm" data-faq>
  <GrainOverlay opacity={0.012} />
  <AmbientLight color="rgba(255,255,255,0.24)" />
  <FloatOrb size={360} top="-14%" right="-10%" color="rgba(141,151,132,0.12)" blur={145} opacity={0.32} animation="float-1" />
  <FloatOrb size={240} bottom="4%" left="-8%" color="rgba(216,211,200,0.24)" blur={120} opacity={0.28} animation="float-2" />

  <Container maxWidth="980px" padding="0 var(--content-padding-x)">
    <div class="faq-shell">
      <header class="faq-header reveal-blur" data-delay="80">
        <span class="section-eyebrow">Preguntas frecuentes</span>
        <h2>Lo que suele preguntarse antes de empezar.</h2>
        <p>Resolvemos las dudas más habituales sobre duración, modalidad, enfoques y primeros pasos.</p>
      </header>

      <div class="faq-panel reveal-scale" data-delay="180">
        <div class="faq-list" aria-label="Preguntas frecuentes">
          {faqs.map((faq, i) => (
            <article class="faq-item reveal-up" data-faq-item style={`--category-hue: ${categoryColors[faq.k] || '111, 125, 103'}; transition-delay: ${220 + i * 55}ms`}>
              <h3>
                <button
                  class="faq-trigger"
                  aria-expanded="false"
                  aria-controls={`faq-answer-${i}`}
                >
                  <span class="faq-chip">{faq.k}</span>
                  <span class="faq-question">{faq.q}</span>
                  <span class="faq-icon" aria-hidden="true">
                    <svg viewBox="0 0 20 20" fill="none" class="faq-icon-svg" aria-hidden="true">
                      <rect x="2" y="9" width="16" height="2" rx="1" fill="currentColor" class="faq-icon-h"/>
                      <rect x="9" y="2" width="2" height="16" rx="1" fill="currentColor" class="faq-icon-v"/>
                    </svg>
                  </span>
                </button>
              </h3>

              <div id={`faq-answer-${i}`} class="faq-answer">
                <div class="faq-answer__inner">
                  <div class="faq-answer__body">
                    <p>{faq.a}</p>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .faq {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py--compact) 0 calc(var(--section-py--compact) + 0.5rem);
  }

  .section--white-warm {
    background:
      radial-gradient(circle at 12% 8%, rgba(255, 255, 255, 0.95), transparent 28%),
      radial-gradient(circle at 84% 18%, rgba(223, 228, 216, 0.38), transparent 30%),
      radial-gradient(circle at 68% 84%, rgba(184, 168, 138, 0.08), transparent 28%),
      linear-gradient(180deg, var(--color-surface-white) 0%, var(--color-surface-elevated) 64%, #f5f1ea 100%);
  }

  .faq::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.008) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 42%, #000 0%, transparent 73%);
    opacity: 0.68;
  }

  .faq-shell {
    position: relative;
    z-index: 2;
  }

  .faq-header {
    max-width: 50rem;
    margin: 0 auto clamp(2.4rem, 4vw, 3.4rem);
    text-align: center;
  }

  .faq-header h2 {
    max-width: 49rem;
    margin: 1rem auto 0.85rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);

    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .faq-header p {
    max-width: 38rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.7;
    text-wrap: pretty;
  }

  .faq-panel {
    position: relative;
    max-width: 100%;
    margin: 0 auto;
  }

  .faq-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    position: relative;
    border: 1px solid rgba(111, 125, 103, 0.08);
    border-radius: var(--card-radius-sm);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.62), rgba(252, 249, 243, 0.46));
    box-shadow: 0 0.25rem 0.6rem rgba(57, 54, 48, 0.02);
    overflow: hidden;
    transition: border-color 0.4s ease, background 0.4s ease, box-shadow 0.4s ease, transform 0.4s var(--ease-out-expo);
  }

  .faq-item:hover {
    border-color: rgba(111, 125, 103, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.82), rgba(252, 249, 243, 0.64));
    box-shadow: 0 0.5rem 1.2rem rgba(57, 54, 48, 0.04);
  }

  .faq-item.open {
    border-color: rgba(var(--category-hue), 0.24);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(252, 249, 243, 0.82));
    box-shadow:
      0 0.75rem 1.8rem rgba(57, 54, 48, 0.05),
      0 0 0 1px rgba(var(--category-hue), 0.06) inset;
    transform: translateY(-2px);
  }

  .faq-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, rgba(var(--category-hue), 0.55), rgba(var(--category-hue), 0.2));
    border-radius: 0 3px 3px 0;
    opacity: 0;
    transform: scaleY(0.75);
    transform-origin: center;
    transition: opacity 0.45s ease, transform 0.5s var(--ease-out-expo);
  }
  .faq-item.open::before {
    opacity: 1;
    transform: scaleY(1);
  }

  .faq-item h3 {
    margin: 0;
  }

  .faq-trigger {
    width: 100%;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.85rem 1rem;
    align-items: center;
    padding: clamp(1rem, 1.8vw, 1.25rem) clamp(1.1rem, 2vw, 1.5rem);
    border: 0;
    border-radius: inherit;
    background: transparent;
    text-align: left;
    color: inherit;
    cursor: pointer;
    transition: color 0.35s ease;
  }

  .faq-trigger:focus-visible {
    outline: 2px solid rgba(var(--category-hue), 0.35);
    outline-offset: -2px;
  }

  .faq-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.6rem;
    padding: 0.12rem 0.7rem;
    border-radius: 999px;
    background: rgba(var(--category-hue), 0.08);
    border: 1px solid rgba(var(--category-hue), 0.16);
    color: rgba(var(--category-hue), 0.92);
    font-size: var(--type-micro);
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    transition: background 0.35s ease, border-color 0.35s ease, color 0.35s ease;
  }

  .faq-item:hover .faq-chip,
  .faq-item.open .faq-chip {
    background: rgba(var(--category-hue), 0.14);
    border-color: rgba(var(--category-hue), 0.28);
    color: rgba(var(--category-hue), 1);
  }

  .faq-question {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: normal;
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.015em;
    text-wrap: balance;
    transition: color 0.35s ease;
    grid-column: 2;
  }

  .faq-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 50%;
    color: rgba(111, 125, 103, 0.4);
    background: rgba(111, 125, 103, 0.05);
    border: 1px solid rgba(111, 125, 103, 0.12);
    flex-shrink: 0;
    grid-row: 1;
    grid-column: 3;
    transition: transform 0.45s var(--ease-out-expo), color 0.35s ease, background 0.35s ease, border-color 0.35s ease;
  }

  .faq-item:hover .faq-icon,
  .faq-item.open .faq-icon {
    color: rgba(var(--category-hue), 0.85);
    background: rgba(var(--category-hue), 0.1);
    border-color: rgba(var(--category-hue), 0.24);
  }

  .faq-icon-svg {
    width: 0.85rem;
    height: 0.85rem;
  }
  .faq-icon-v {
    transform-origin: center;
    transition: transform 0.4s var(--ease-out-expo), opacity 0.3s ease;
  }
  .faq-item.open .faq-icon {
    transform: rotate(135deg);
  }
  .faq-item.open .faq-icon-v {
    transform: scaleY(0);
    opacity: 0;
  }

  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.55s var(--ease-out-expo);
  }
  .faq-answer.open {
    grid-template-rows: 1fr;
  }

  .faq-answer__inner {
    overflow: hidden;
    min-height: 0;
  }

  .faq-answer__body {
    max-width: 46rem;
    padding: 0.25rem 0 1.45rem clamp(1.1rem, 2vw, 1.5rem);
    opacity: 0;
    transition: opacity 0.4s ease 0.12s;
  }
  .faq-answer.open .faq-answer__body {
    opacity: 1;
  }
  .faq-answer__body p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    font-weight: 300;
    line-height: 1.72;
    text-wrap: pretty;
  }

  @media (max-width: 768px) {
    .faq {
      padding: 4.8rem 0 5.8rem;
    }

    .faq-header {
      margin-bottom: 2rem;
    }

    .faq-header h2 {
      font-size: var(--type-section-title-sm);
      line-height: 1.02;
      letter-spacing: -0.02em;
    }

    .faq-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }

    .section-eyebrow {
      gap: 0.55rem;
      letter-spacing: 0.18em;
    }
    .section-eyebrow::before,
    .section-eyebrow::after {
      width: 1.45rem;
    }

    .faq-list {
      gap: 0.6rem;
    }

    .faq-trigger {
      gap: 0.6rem 0.75rem;
      padding: var(--card-pd-sm) clamp(0.9rem, 3vw, 1.2rem);
    }

    .faq-chip {
      grid-row: 1;
      grid-column: 1 / -1;
      justify-self: start;
    }

    .faq-question {
      grid-column: 1 / span 2;
      font-size: var(--type-card-title);
      line-height: 1.16;
    }

    .faq-icon {
      grid-row: 2;
      grid-column: 3;
      width: 1.8rem;
      height: 1.8rem;
    }

    .faq-answer__body {
      padding: 0 1rem 1.1rem;
    }

    .faq-answer__body p {
      font-size: var(--type-body-sm);
      line-height: 1.68;
    }
  }

  @media (max-width: 480px) {
    .faq-header {
      margin-bottom: 1.8rem;
    }
    .faq-icon {
      width: 1.7rem;
      height: 1.7rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const isOpen = answer?.classList.contains('open');

      document.querySelectorAll('.faq-item').forEach((sibling) => {
        if (sibling !== item) {
          sibling.classList.remove('open');
          const siblingAnswer = sibling.querySelector('.faq-answer');
          siblingAnswer?.classList.remove('open');
          const siblingTrigger = sibling.querySelector('.faq-trigger');
          siblingTrigger?.setAttribute('aria-expanded', 'false');
        }
      });

      answer?.classList.toggle('open');
      item?.classList.toggle('open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
