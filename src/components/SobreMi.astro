---
import Button from './ui/Button.astro';
import PageNumber from './ui/PageNumber.astro';
import Container from './ui/Container.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import BotanicalSVG from './ui/BotanicalSVG.astro';
import SectionHeader from './ui/SectionHeader.astro';

/* Imágenes finales del proyecto */
const imgMain   = "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=900&auto=format&fit=crop";
const imgSecond = "https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=600&auto=format&fit=crop";
---

<section id="sobre-mi" class="sobre-mi" data-sobremi>
  <GrainOverlay opacity={0.02} />
  <AmbientLight color="rgba(196,170,148,0.03)" />
  <DustParticles count={8} color="rgba(196,170,148,0.12)" />

  <FloatOrb size={400} top="-8%" right="-6%" color="var(--sage-muted)" blur={130} animation="float-1" />
  <FloatOrb size={280} bottom="12%" left="-6%" color="var(--gold-soft)" opacity={0.28} animation="float-2" />
  <FloatOrb size={160} top="55%" right="8%" color="var(--sage-muted)" opacity={0.18} animation="float-3" />

  <InkBlob width={360} height={280} top="-4%" left="-4%" color="var(--sage)" opacity={0.025} animation="morph-2" />
  <InkBlob width={300} height={240} bottom="-4%" right="-4%" color="var(--gold)" opacity={0.02} animation="morph-blob" />

  <BotanicalSVG variant="left" color="var(--sage-dark)" opacity={0.04} width={65} style="left: 1%; top: 22%;" />
  <BotanicalSVG variant="right" color="var(--gold)" opacity={0.06} width={75} style="right: 2%; top: 58%; animation-delay: -5s;" />

  <div class="sm-watermark" aria-hidden="true">
    <span class="watermark-text">Sobre mi</span>
  </div>

  <Container maxWidth="1120px">
    <div class="sm-editorial" data-editorial>

      <!-- LEFT: IMAGE COLUMN -->
      <div class="sm-editorial__visual reveal-scale" data-delay="100">
        <div class="photo-composition">
          <!-- Main portrait -->
          <div class="photo-main" data-spotlight>
            <div class="photo-main__spotlight" aria-hidden="true"></div>
            <div class="photo-main__mat">
              <img src={imgMain} alt="Lucía Martínez, Psicóloga Clínica" decoding="async" loading="lazy" />
            </div>
            <!-- Corner marks -->
            <div class="photo-main__mark photo-main__mark--tl" aria-hidden="true"></div>
            <div class="photo-main__mark photo-main__mark--tr" aria-hidden="true"></div>
            <div class="photo-main__mark photo-main__mark--bl" aria-hidden="true"></div>
            <div class="photo-main__mark photo-main__mark--br" aria-hidden="true"></div>
            <!-- Subtle watermark num -->
            <span class="photo-main__num" aria-hidden="true">02</span>
          </div>

          <!-- Secondary detail photo -->
          <div class="photo-detail reveal-up" data-delay="400">
            <div class="photo-detail__inner">
              <img src={imgSecond} alt="Detalle del espacio de consulta" decoding="async" loading="lazy" />
            </div>
            <span class="photo-detail__caption" aria-hidden="true">Espacio</span>
          </div>

          <!-- Signature flourish -->
          <div class="photo-flourish" aria-hidden="true">
            <svg viewBox="0 0 120 40" fill="none" aria-hidden="true">
              <path d="M2,20 Q30,5 60,20 T118,20" stroke="rgba(196,170,148,0.2)" stroke-width="1" fill="none" stroke-linecap="round"/>
              <circle cx="60" cy="20" r="2" fill="rgba(196,170,148,0.25)"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- RIGHT: CONTENT COLUMN -->
      <div class="sm-editorial__text">
        <SectionHeader
          eyebrow="Sobre mí"
          title={['Un espacio para', 'encontrarte']}
          variant="editorial"
          align="start"
          index="02"
          class="reveal-blur"
        />

        <div class="sm-prose reveal-up" data-delay="300">
          <p class="lead">
            Soy <strong>Lucía Martínez</strong>, psicóloga clínica colegiada en Córdoba. Mi objetivo es crear un entorno de confianza donde puedas explorar lo que te ocurre sin juicios ni prisas.
          </p>
          <p>
            Integro terapia cognitivo-conductual y EMDR con una forma de acompañar humana, cuidando el ritmo que cada historia necesita para sanar de raíz. No se trata de forzar el cambio, sino de crear un lugar interno donde puedas empezar a sentirte a salvo.
          </p>
          <p>
            Te escucho, te acompaño y te brindo las herramientas necesarias para que puedas recuperar la serenidad y la claridad en tu día a día.
          </p>
        </div>

        <div class="sm-divider reveal-up" data-delay="450" aria-hidden="true">
          <span class="divider-track"></span>
          <span class="divider-dot"></span>
        </div>

        <div class="sm-cta reveal-up" data-delay="550">
          <Button href="#contacto" variant="solid">
            Reserva tu primera sesión
          </Button>
        </div>
      </div>

    </div>
  </Container>

  <PageNumber number="02" />
</section>

<style>
  /* ─────────────────────────────────────────
     SECTION SHELL
     ───────────────────────────────────────── */
  .sobre-mi {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: clamp(7rem, 10vw, 12rem) 0 clamp(8rem, 12vw, 14rem);
    background:
      radial-gradient(ellipse at 30% 20%, rgba(196,170,148,0.04) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 75%, rgba(107,125,106,0.025) 0%, transparent 45%),
      var(--parchment);
  }

  /* Watermark */
  .sm-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    user-select: none;
  }
  .watermark-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(8rem, 18vw, 16rem);
    color: var(--earth);
    opacity: 0.015;
    line-height: 1;
    letter-spacing: -0.03em;
    white-space: nowrap;
  }

  /* ─────────────────────────────────────────
     EDITORIAL GRID
     ───────────────────────────────────────── */
  .sm-editorial {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(3rem, 5vw, 6rem);
    align-items: stretch;
    position: relative;
    z-index: 2;
  }

  /* Connecting decorative line */
  .sm-editorial::before {
    content: '';
    position: absolute;
    left: calc(50% - 0.5px);
    top: 10%;
    width: 1px;
    height: 80%;
    background: linear-gradient(180deg, transparent, rgba(196,170,148,0.08), transparent);
    pointer-events: none;
    z-index: 0;
  }

  /* ─────────────────────────────────────────
     VISUAL COLUMN
     ───────────────────────────────────────── */
  .sm-editorial__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-composition {
    position: relative;
    width: 100%;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Main portrait — passe-partout style */
  .photo-main {
    position: relative;
    width: 100%;
    padding: 18px;
    background: rgba(250,246,240,0.85);
    border: 1px solid rgba(196,170,148,0.12);
    box-shadow:
      0 4px 20px rgba(0,0,0,0.03),
      0 24px 60px rgba(107,125,106,0.06),
      inset 0 0 0 1px rgba(255,255,255,0.6);
    transition: box-shadow 0.7s ease, border-color 0.5s ease, transform 0.8s var(--ease-out-expo);
    z-index: 2;
  }
  .photo-main:hover {
    border-color: rgba(196,170,148,0.22);
    box-shadow:
      0 6px 28px rgba(0,0,0,0.04),
      0 32px 80px rgba(107,125,106,0.1),
      inset 0 0 0 1px rgba(255,255,255,0.8);
    transform: translateY(-3px);
  }

  .photo-main__mat {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }
  .photo-main__mat img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(8%) saturate(0.88) contrast(1.02);
    transition: transform 10s ease, filter 0.8s ease;
  }
  .photo-main:hover .photo-main__mat img {
    transform: scale(1.03);
    filter: grayscale(0%) saturate(0.95) contrast(1.03);
  }

  /* Corner marks */
  .photo-main__mark {
    position: absolute;
    width: 10px;
    height: 10px;
    pointer-events: none;
    z-index: 3;
    opacity: 0;
    transition: opacity 0.6s ease, width 0.6s var(--ease-out-expo), height 0.6s var(--ease-out-expo);
  }
  .photo-main__mark--tl {
    top: 8px; left: 8px;
    border-top: 1px solid rgba(196,170,148,0.35);
    border-left: 1px solid rgba(196,170,148,0.35);
  }
  .photo-main__mark--tr {
    top: 8px; right: 8px;
    border-top: 1px solid rgba(196,170,148,0.35);
    border-right: 1px solid rgba(196,170,148,0.35);
  }
  .photo-main__mark--bl {
    bottom: 8px; left: 8px;
    border-bottom: 1px solid rgba(196,170,148,0.35);
    border-left: 1px solid rgba(196,170,148,0.35);
  }
  .photo-main__mark--br {
    bottom: 8px; right: 8px;
    border-bottom: 1px solid rgba(196,170,148,0.35);
    border-right: 1px solid rgba(196,170,148,0.35);
  }
  .photo-main:hover .photo-main__mark {
    opacity: 0.6;
    width: 18px;
    height: 18px;
  }

  /* Spotlight follow */
  .photo-main__spotlight {
    position: absolute;
    inset: 0;
    background: radial-gradient(500px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(196,170,148,0.05), transparent 40%);
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .photo-main:hover .photo-main__spotlight {
    opacity: 1;
  }

  /* Background number inside frame */
  .photo-main__num {
    position: absolute;
    bottom: 28px;
    right: 28px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 3.5rem;
    color: var(--earth);
    opacity: 0.04;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 1;
    transition: opacity 0.6s ease;
  }
  .photo-main:hover .photo-main__num {
    opacity: 0.08;
  }

  /* Secondary detail photo */
  .photo-detail {
    position: absolute;
    bottom: -24px;
    right: -32px;
    width: 38%;
    max-width: 160px;
    padding: 5px;
    background: var(--parchment);
    border: 1px solid rgba(196,170,148,0.12);
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
    z-index: 4;
    overflow: hidden;
    transition: transform 0.6s var(--ease-out-expo), box-shadow 0.5s ease;
  }
  .photo-detail:hover {
    transform: translateY(-2px) rotate(-1deg);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
  }
  .photo-detail__inner {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .photo-detail__inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.85) contrast(1.05);
    transition: transform 8s ease;
  }
  .photo-detail:hover .photo-detail__inner img {
    transform: scale(1.06);
  }
  .photo-detail__caption {
    position: absolute;
    bottom: 4px;
    right: 8px;
    font-family: var(--font-body);
    font-size: 0.5rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.3;
    pointer-events: none;
    z-index: 2;
  }

  /* Flourish line below composition */
  .photo-flourish {
    position: absolute;
    bottom: -56px;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 40px;
    pointer-events: none;
    z-index: 1;
    opacity: 0.7;
  }
  .photo-flourish svg {
    width: 100%;
    height: 100%;
  }

  /* ─────────────────────────────────────────
     TEXT COLUMN
     ───────────────────────────────────────── */
  .sm-editorial__text {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
    justify-content: center;
    padding: 2rem 0;
  }

  .sm-header-override {
    margin-bottom: 0 !important;
    padding-left: 0 !important;
    padding-bottom: 0 !important;
  }
  .sm-header-override::before {
    display: none !important;
  }

  /* Prose */
  .sm-prose {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .sm-prose p {
    font-family: var(--font-body);
    font-size: clamp(0.98rem, 1.1vw, 1.08rem);
    font-weight: 300;
    line-height: 1.8;
    color: var(--ink-soft);
    margin: 0;
    max-width: 50ch;
  }
  .sm-prose p.lead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.15rem, 1.6vw, 1.35rem);
    color: var(--ink);
    border-left: 1px solid rgba(196,170,148,0.18);
    padding-left: 1.4rem;
    margin-left: 0.2rem;
    line-height: 1.65;
    letter-spacing: 0.01em;
  }
  .sm-prose p strong {
    font-weight: 400;
    color: var(--earth);
  }

  /* Divider */
  .sm-divider {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 0.2rem;
  }
  .divider-track {
    display: block;
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, rgba(196,170,148,0.25), transparent);
  }
  .divider-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(196,170,148,0.2);
  }

  /* CTA */
  .sm-cta {
    margin-top: 0.4rem;
  }

  /* ─────────────────────────────────────────
     RESPONSIVE
     ───────────────────────────────────────── */
  @media (max-width: 1024px) {
    .sm-editorial {
      grid-template-columns: 1fr;
      gap: 4rem;
      align-items: center;
    }
    .sm-editorial::before {
      display: none;
    }
    .sm-editorial__visual {
      order: -1;
    }
    .photo-composition {
      margin: 0 auto;
    }
    .photo-detail {
      right: -16px;
      bottom: -20px;
    }
    .photo-flourish {
      display: none;
    }
    .sm-editorial__text {
      padding: 0;
      align-items: center;
      text-align: center;
    }
    .sm-prose p.lead {
      margin-left: 0;
      border-left: none;
      padding-left: 0;
      text-align: center;
    }
    .sm-prose p {
      text-align: center;
      max-width: 48ch;
    }
    .sm-divider {
      align-self: center;
    }
    .sm-cta {
      align-self: center;
    }
  }

  @media (max-width: 768px) {
    .sobre-mi {
      padding: 6rem 0 8rem;
    }
    .photo-main {
      padding: 12px;
    }
    .photo-detail {
      right: 8px;
      bottom: -16px;
      width: 34%;
      max-width: 130px;
    }
    .photo-main__num {
      font-size: 2.5rem;
      bottom: 18px;
      right: 18px;
    }
    .watermark-text {
      font-size: 5rem;
    }
  }

  @media (max-width: 480px) {
    .photo-main {
      padding: 8px;
    }
    .photo-detail {
      display: none;
    }
    .sm-prose p.lead {
      font-size: 1.1rem;
    }
    .sm-prose p {
      font-size: 0.95rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .photo-main,
    .photo-detail,
    .photo-main__mat img,
    .photo-detail__inner img {
      transition: none !important;
    }
    .photo-main:hover {
      transform: none;
    }
  }
</style>

<script>
  (function() {
    'use strict';

    /* Spotlight follow on main photo */
    const spotFrame = document.querySelector('[data-spotlight]');
    if (spotFrame && !window.matchMedia('(pointer: coarse)').matches) {
      spotFrame.addEventListener('mousemove', (e) => {
        const rect = spotFrame.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        spotFrame.style.setProperty('--mouse-x', `${x}%`);
        spotFrame.style.setProperty('--mouse-y', `${y}%`);
      });
    }
  })();
</script>
