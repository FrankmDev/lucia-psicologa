---
import Button from './ui/Button.astro';
import PageNumber from './ui/PageNumber.astro';
import Container from './ui/Container.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

import portraitImage from '../assets/about.avif';

const credentials = [
  'Psicóloga general sanitaria colegiada',
  'Grado en Psicología',
  'Formación oficial Nivel I en EMDR',
  'Enfoque integrador',
  'Presencial y online',
];

const emdrPoints = [
  {
    title: 'Procesamiento seguro',
    text: 'Recursos de regulación antes de abordar recuerdos dolorosos.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    title: 'Trauma y heridas relacionales',
    text: 'Traumas evidentes o heridas silenciosas, ambas merecen atención.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Alivio de síntomas',
    text: 'Menos carga emocional asociada a recuerdos, imágenes y sensaciones.',
    icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z',
  },
  {
    title: 'Reestructuración cognitiva',
    text: 'Nuevas perspectivas sobre lo vivido, con menor culpa o vergüenza.',
    icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  },
];

---

<section id="sobre-mi" class="sobre-mi section--parchment-warm" data-sobremi>
  <GrainOverlay opacity={0.012} />
  <AmbientLight color="rgba(255,255,255,0.28)" />
  <FloatOrb size={420} top="-18%" right="-12%" color="rgba(141,151,132,0.14)" blur={150} animation="float-1" />
  <FloatOrb size={260} bottom="6%" left="-9%" color="rgba(216,211,200,0.28)" opacity={0.36} blur={120} animation="float-2" />

  <Container maxWidth="1480px" padding="0 var(--content-padding-x)">
    <div class="sm-shell">
      <header class="sm-header reveal-blur" data-delay="80">
        <span class="sm-eyebrow">Sobre mí</span>
        <h2>Un espacio tranquilo para procesar lo que aún pesa.</h2>
        <p>
          Acompañamiento psicológico cercano y respetuoso, con formación especializada en trauma.
        </p>
      </header>

      <article class="sm-panel reveal-scale" data-delay="180">
        <div class="sm-panel__visual">
          <figure class="sm-portrait sm-portrait--main">
            <img src={portraitImage.src} alt="Lucía Millán Jiménez, psicóloga general sanitaria" width={portraitImage.width} height={portraitImage.height} sizes="(max-width: 960px) 72vw, 360px" decoding="async" loading="lazy" />
            <figcaption>
              <span>Lucía Millán Jiménez</span>
            </figcaption>
          </figure>
        </div>

        <div class="sm-panel__content">
          <span class="sm-label">Conoce a Lucía</span>
          <p class="sm-lead">
            Soy <strong>Lucía Millán Jiménez</strong>, psicóloga general sanitaria colegiada, con <strong>Grado en Psicología</strong> y formación especializada en trauma. Adapto la terapia a cada persona según su historia, problemática y necesidades, integrando distintos enfoques cuando encaja clínicamente.
          </p>

          <p>
            Cuento con la formación oficial de <strong>Nivel I en EMDR</strong>, avalada por la Asociación EMDR España y EMDR Europa, e impartida a través de Imaya Formación. Integro el modelo PISA (Procesamiento de la Información a Sistemas Adaptativos, el modelo clínico del EMDR, sin relación con el informe educativo) para trabajar trauma, bloqueos y experiencias dolorosas mediante estimulación bilateral —una técnica que combina movimientos oculares u otros estímulos alternos para ayudar al cerebro a reprocesar el recuerdo— cuando encaja en el proceso.
          </p>

          <ul class="sm-credentials" aria-label="Credenciales y modalidad">
            {credentials.map((credential) => (
              <li>{credential}</li>
            ))}
          </ul>

          <div class="sm-actions">
            {/* CTA unificado: "Solicitar primera sesión" en todos los CTAs principales.
                Las tarjetas de Especialidades mantienen "Consultar enfoque" como variante intencional. */}
            <Button href="#contacto" variant="solid" class="sm-button">
              Solicitar primera sesión
            </Button>
            <a href="#servicios" class="sm-link">
              <span>Ver servicios</span>
              <span class="sm-link__line" aria-hidden="true"></span>
            </a>
          </div>
        </div>
      </article>

      <div class="sm-emdr reveal-up" data-delay="260">
        <div class="sm-emdr__copy">
          <div class="sm-emdr__intro">
            <span class="sm-label">¿Qué es el EMDR?</span>
            <h3>Reprocesar lo vivido para que ocupe menos.</h3>
            <p>
              El EMDR reprocesa experiencias "atascadas" en el sistema nervioso: recuerdos intrusivos, reacciones corporales o creencias dolorosas. No borra lo ocurrido, lo integra con menos carga emocional.
            </p>
            <p>
              Se apoya en estimulación bilateral —movimientos oculares, sonidos alternos o tapping— para ayudar al cerebro a integrar lo vivido sin revivirlo con la misma intensidad.
            </p>
          </div>

          <ul class="sm-emdr__topics" aria-label="Situaciones en las que puede ayudar el EMDR">
            <li class="sm-emdr__topic">
              <span class="sm-emdr__topic-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <path d="M9 12l2 2 4-4"/>
                </svg>
              </span>
              <span>Trauma, TEPT y experiencias estresantes</span>
            </li>
            <li class="sm-emdr__topic">
              <span class="sm-emdr__topic-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </span>
              <span>Ansiedad, pánico y fobias</span>
            </li>
            <li class="sm-emdr__topic">
              <span class="sm-emdr__topic-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                </svg>
              </span>
              <span>Duelo y heridas relacionales</span>
            </li>
          </ul>
        </div>
        <div class="sm-emdr__points">
          {emdrPoints.map((point, index) => (
            <article class="sm-point reveal-up" style={`transition-delay: ${340 + index * 80}ms`}>
              <span class="sm-point__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d={point.icon} />
                </svg>
              </span>
              <h4>{point.title}</h4>
              <p>{point.text}</p>
            </article>
          ))}
        </div>
      </div>

    </div>
  </Container>

  <PageNumber number="02" />
</section>

<style>
  .sobre-mi {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
  }

  .section--parchment-warm {
    background:
      radial-gradient(circle at 10% 8%, rgba(255, 255, 255, 0.9), transparent 28%),
      radial-gradient(circle at 86% 12%, rgba(223, 228, 216, 0.52), transparent 32%),
      radial-gradient(circle at 72% 78%, rgba(184, 168, 138, 0.12), transparent 30%),
      linear-gradient(180deg, #faf8f3 0%, #f1ece2 58%, #ebe5d8 100%);
  }

  .sobre-mi::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.012) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.009) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 48%, #000 0%, transparent 72%);
  }

  .sm-shell {
    position: relative;
    z-index: 2;
  }

  .sm-header {
    max-width: 54rem;
    margin: 0 auto clamp(2.25rem, 4vw, 3.4rem);
    text-align: center;
  }

  .sm-eyebrow,
  .sm-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .sm-eyebrow::before,
  .sm-eyebrow::after,
  .sm-label::before {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .sm-header h2 {
    max-width: 52rem;
    margin: 1rem auto 1rem;
    font-family: var(--font-display);
    font-size: var(--type-section-title);

    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .sm-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: var(--type-lead);
    line-height: 1.78;
    text-wrap: pretty;
  }

  .sm-panel {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 4vw, 4.8rem);
    align-items: stretch;
    padding: var(--card-pd-md);
    border-radius: var(--card-radius);
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0.72), rgba(255, 253, 248, 0.22) 55%, transparent),
      radial-gradient(circle at 8% 8%, rgba(223, 228, 216, 0.38), transparent 30%);
    border: 1px solid rgba(111, 125, 103, 0.12);
    box-shadow: 0 1.4rem 3.2rem rgba(57, 54, 48, 0.045);
    overflow: hidden;
  }

  .sm-panel__visual {
    display: flex;
    flex-direction: column;
    gap: var(--card-pd-sm);
    padding: var(--card-pd-sm);
    border-radius: var(--card-radius-sm);
    background:
      radial-gradient(circle at 74% 16%, rgba(255, 255, 255, 0.55), transparent 26%),
      linear-gradient(135deg, rgba(255, 253, 248, 0.42), transparent 42%),
      linear-gradient(180deg, var(--color-accent-pale), #d7decf);
    box-shadow:
      inset 0 0 0 1px rgba(111, 125, 103, 0.1),
      0 18px 44px rgba(57, 54, 48, 0.04);
  }

  .sm-portrait {
    position: relative;
    margin: 0;
    border-radius: 999px 999px 1rem 1rem;
    background: rgba(255, 253, 248, 0.42);
    box-shadow:
      0 22px 48px rgba(76, 83, 70, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    overflow: hidden;
    transition: transform 0.6s var(--ease-out-expo), box-shadow 0.6s ease;
    will-change: transform;
  }

  .sm-portrait--main {
    flex: 1 1 auto;
    min-height: clamp(20rem, 28vw, 26rem);
  }

  .sm-portrait:hover {
    transform: translateY(-0.18rem);
    box-shadow:
      0 26px 56px rgba(76, 83, 70, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .sm-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: inherit;
    filter: grayscale(8%) saturate(0.78) brightness(1.05) contrast(0.98);
  }

  .sm-portrait figcaption {
    position: absolute;
    left: clamp(0.85rem, 1.8vw, 1.1rem);
    right: clamp(0.85rem, 1.8vw, 1.1rem);
    bottom: clamp(0.85rem, 1.8vw, 1.1rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 0.84rem;
    border: 1px solid rgba(255, 253, 248, 0.32);
    border-radius: 999px;
    background: rgba(245, 240, 232, 0.92);
  }

  .sm-portrait figcaption span {
    display: block;
    width: 100%;
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--type-kicker);

    font-weight: 400;
    color: rgba(47, 45, 40, 0.9);
  }

  .sm-panel__content {
    max-width: 45rem;
    padding: var(--card-pd-lg) var(--card-pd-md);
    justify-self: start;
  }

  .sm-label {
    justify-content: flex-start;
    margin-bottom: 1.08rem;
  }

  .sm-panel__content p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.84;
    text-wrap: pretty;
  }

  .sm-panel__content p + p {
    margin-top: 1rem;
  }

  .sm-lead {
    font-family: var(--font-display);
    font-size: var(--type-card-title) !important;

    font-weight: 400;
    line-height: 1.52 !important;
    color: rgba(47, 45, 40, 0.9) !important;
  }

  .sm-lead strong {
    color: var(--color-accent);
    font-weight: 500;
  }

  .sm-credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .sm-credentials li {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.52rem 0.78rem;
    border: 1px solid rgba(111, 125, 103, 0.18);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(250, 248, 242, 0.38));
    color: #5d6258;
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.14em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .sm-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.15rem;
    margin-top: clamp(1.65rem, 3vw, 2.3rem);
  }

  .sm-actions :global(.sm-button.btn--solid) {
    min-height: 3.2rem;
    padding: 1rem 1.65rem;
    border-color: #65745f;
    border-radius: 999px;
    background: linear-gradient(135deg, #65745f, #839079);
    color: #fff;
    box-shadow:
      0 14px 28px rgba(101, 116, 95, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }

  .sm-actions :global(.sm-button.btn--solid::before) {
    background: linear-gradient(135deg, #34372f, #56614f);
  }

  .sm-link {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    gap: 0.72rem;
    color: #58564f;
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: color 0.25s ease, letter-spacing 0.25s ease;
  }

  .sm-link__line {
    width: 2.45rem;
    height: 1px;
    background: rgba(101, 116, 95, 0.36);
    transform-origin: left;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .sm-link:hover {
    color: var(--color-accent);
    letter-spacing: 0.23em;
  }

  .sm-link:hover .sm-link__line {
    transform: scaleX(1.16);
    background: rgba(101, 116, 95, 0.62);
  }

  /* ── EMDR block ─────────────────────────────────────────── */
  .sm-emdr {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: stretch;
    margin-top: clamp(2.2rem, 4vw, 3.4rem);
    padding: var(--card-pd-lg);
    border-radius: var(--card-radius);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.74), rgba(250, 248, 242, 0.42)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.34), transparent 30%);
    border: 1px solid rgba(111, 125, 103, 0.1);
  }

  .sm-emdr__copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: clamp(1.1rem, 1.8vw, 1.5rem);
  }

  .sm-emdr__copy .sm-label {
    margin-bottom: 0.9rem;
  }

  .sm-emdr__copy h3 {
    margin: 0 0 0.85rem;
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);

    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .sm-emdr__copy p {
    margin: 0 0 0.9rem;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .sm-emdr__copy p:last-child {
    margin-bottom: 0;
  }

  .sm-emdr__topics {
    display: flex;
    flex-direction: column;
    gap: 0.72rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sm-emdr__topic {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.78rem 1rem;
    border-radius: var(--card-radius-sm);
    background: rgba(255, 255, 255, 0.52);
    border: 1px solid rgba(111, 125, 103, 0.1);
    color: var(--color-text-secondary);
    font-size: var(--type-card-body);
    line-height: 1.45;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .sm-emdr__topic:hover {
    background: rgba(255, 255, 255, 0.82);
    border-color: rgba(111, 125, 103, 0.18);
    transform: translateX(3px);
  }

  .sm-emdr__topic-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    color: var(--color-accent);
    background: rgba(111, 125, 103, 0.08);
  }

  .sm-emdr__points {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: clamp(0.75rem, 1.5vw, 1rem);
  }

  .sm-point {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.55rem;
    padding: clamp(1rem, 1.8vw, 1.35rem);
    border-radius: var(--card-radius-sm);
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(111, 125, 103, 0.1);
    transition: transform 0.35s ease, border-color 0.35s ease, background 0.35s ease, box-shadow 0.35s ease;
  }

  .sm-point:hover {
    transform: translateY(-3px);
    border-color: rgba(111, 125, 103, 0.2);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 0.8rem 1.8rem rgba(57, 54, 48, 0.06);
  }

  .sm-point__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.6rem;
    color: var(--color-accent);
    background: rgba(111, 125, 103, 0.08);
    border: 1px solid rgba(111, 125, 103, 0.08);
    flex-shrink: 0;
  }

  .sm-point h4 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);

    font-weight: 400;
    line-height: 1.12;
    color: rgba(47, 45, 40, 0.9);
  }

  .sm-point p {
    margin: 0;
    color: #5f5c55;
    font-size: var(--type-card-body);
    line-height: 1.58;
    flex: 1;
  }

  @media (max-width: 960px) {
    .sm-panel {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .sm-panel__visual {
      flex-direction: row;
      height: auto;
    }

    .sm-portrait--main {
      min-height: clamp(22rem, 50vw, 30rem);
      flex: 1 1 100%;
    }

    .sm-panel__content {
      max-width: 46rem;
      margin-inline: auto;
      padding: clamp(2rem, 5vw, 3.3rem);
      justify-self: center;
      text-align: center;
    }

    .sm-label {
      justify-content: center;
    }

    .sm-credentials,
    .sm-actions {
      justify-content: center;
    }

    .sm-emdr {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }

    .sm-emdr__copy {
      text-align: center;
      align-items: center;
    }

    .sm-emdr__copy .sm-label {
      justify-content: center;
    }

    .sm-emdr__topics {
      text-align: left;
      width: min(100%, 28rem);
    }

    .sm-emdr__points {
      grid-auto-rows: auto;
    }
  }

  @media (max-width: 720px) {
    .sobre-mi {
      padding: 4.8rem 0 5.8rem;
    }

    .sobre-mi::before {
      opacity: 0.55;
      background-size: 6.5rem 6.5rem;
    }

    .sm-header {
      margin-bottom: 1.8rem;
    }

    .sm-header h2 {
      font-size: var(--type-section-title);
      line-height: 1.02;
      letter-spacing: -0.03em;
    }

    .sm-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }

    .sm-panel {
      padding: var(--card-pd-sm);
      border-radius: var(--card-radius-sm);
    }

    .sm-panel__visual {
      flex-direction: column;
      border-radius: var(--card-radius-sm);
      padding: var(--card-pd-sm);
    }

    .sm-portrait--main {
      min-height: clamp(18rem, 55vw, 24rem);
      border-radius: var(--card-radius-sm);
    }

