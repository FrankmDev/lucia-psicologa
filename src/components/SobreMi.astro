---
import Button from './ui/Button.astro';
import PageNumber from './ui/PageNumber.astro';
import Container from './ui/Container.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

import portraitImage from '../assets/about.avif';

const credentials = [
  'Psicóloga clínica colegiada',
  'Enfoque integrador',
  'Presencial y online',
];

const values = [
  {
    title: 'Escucha',
    text: 'Un espacio sin juicio para poner palabras a lo que necesitas cuidar.',
  },
  {
    title: 'Claridad',
    text: 'Un proceso comprensible, con herramientas clínicas y pasos claros.',
  },
  {
    title: 'Cuidado',
    text: 'Avanzar a tu ritmo, con seguridad y sin exigirte más de lo necesario.',
  },
];
---

<section id="sobre-mi" class="sobre-mi" data-sobremi>
  <GrainOverlay opacity={0.012} />
  <AmbientLight color="rgba(255,255,255,0.28)" />
  <FloatOrb size={420} top="-18%" right="-12%" color="rgba(141,151,132,0.14)" blur={150} animation="float-1" />
  <FloatOrb size={260} bottom="6%" left="-9%" color="rgba(216,211,200,0.28)" opacity={0.36} blur={120} animation="float-2" />

  <Container maxWidth="1320px" padding="0 clamp(1rem, 4vw, 4.5rem)">
    <div class="sm-shell">
      <header class="sm-header reveal-blur" data-delay="80">
        <span class="sm-eyebrow">Sobre mí</span>
        <h2>Un espacio tranquilo para volver a escucharte.</h2>
        <p>
          Acompañamiento psicológico cercano y respetuoso para comprender lo que te ocurre sin prisas.
        </p>
      </header>

      <article class="sm-panel reveal-scale" data-delay="180">
        <div class="sm-panel__mark" aria-hidden="true">L</div>
        <div class="sm-panel__visual">
          <figure class="sm-portrait">
            <img src={portraitImage.src} alt="Lucía Millán Jiménez, psicóloga clínica" width={portraitImage.width} height={portraitImage.height} sizes="(max-width: 960px) 72vw, 360px" decoding="async" loading="lazy" />
            <figcaption>
              <span>Lucía Millán Jiménez</span>
            </figcaption>
          </figure>

        </div>

        <div class="sm-panel__content">
          <span class="sm-label">Conoce a Lucía</span>
          <p class="sm-lead">
            Soy <strong>Lucía Millán Jiménez</strong>, psicóloga clínica colegiada. Cada persona necesita una mirada diferente, por eso adapto cada intervención a lo que te ocurre ahora. Combino TCC, ACT, TFE y trabajo psicosomático para ayudarte a sentirte mejor y recuperar el rumbo.
          </p>

          <ul class="sm-credentials" aria-label="Credenciales y modalidad">
            {credentials.map((credential) => (
              <li>{credential}</li>
            ))}
          </ul>

          <blockquote class="sm-quote">
            <p>“La terapia también puede sentirse como un lugar de descanso.”</p>
          </blockquote>

          <div class="sm-actions">
            <Button href="#contacto" variant="solid" class="sm-button">
              Reserva tu primera sesión
            </Button>
            <a href="#servicios" class="sm-link">
              <span>Ver servicios</span>
              <span class="sm-link__line" aria-hidden="true"></span>
            </a>
          </div>
        </div>
      </article>

      <div class="sm-values" aria-label="Forma de acompañamiento">
        {values.map((value, index) => (
          <article class="sm-value reveal-up" style={`transition-delay: ${320 + index * 80}ms`}>
            <span aria-hidden="true">0{index + 1}</span>
            <h3>{value.title}</h3>
            <p>{value.text}</p>
          </article>
        ))}
      </div>
    </div>
  </Container>

  <PageNumber number="02" />
</section>

<style>
  .sobre-mi {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 1rem);
    background:
      radial-gradient(circle at 14% 8%, rgba(255, 255, 255, 0.95), transparent 30%),
      radial-gradient(circle at 82% 12%, rgba(223, 228, 216, 0.58), transparent 32%),
      radial-gradient(circle at 72% 76%, rgba(184, 168, 138, 0.11), transparent 30%),
      linear-gradient(180deg, #fffdfa 0%, var(--color-surface-elevated) 58%, #f4f1e9 100%);
  }

  .sobre-mi::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.008) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 48%, #000 0%, transparent 72%);
  }

  .sm-shell {
    position: relative;
    z-index: 2;
  }

  .sm-header {
    max-width: 54rem;
    margin: 0 auto clamp(2.25rem, 4vw, 3.4rem);
    text-align: center;
  }

  .sm-eyebrow,
  .sm-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .sm-eyebrow::before,
  .sm-eyebrow::after,
  .sm-label::before {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .sm-header h2 {
    max-width: 52rem;
    margin: 1rem auto 1rem;
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .sm-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: var(--type-lead);
    line-height: 1.78;
    text-wrap: pretty;
  }

  .sm-panel {
    position: relative;
    display: grid;
    grid-template-columns: minmax(22rem, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(2rem, 4vw, 4.8rem);
    align-items: stretch;
    padding: clamp(1.1rem, 2.4vw, 2rem);
    border-block: 1px solid rgba(111, 125, 103, 0.16);
    border-radius: 0;
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0.62), rgba(255, 253, 248, 0.18) 45%, transparent),
      radial-gradient(circle at 8% 8%, rgba(223, 228, 216, 0.34), transparent 30%);
    box-shadow: none;
    overflow: hidden;
  }

  .sm-panel::before {
    content: '';
    position: absolute;
    left: clamp(1.1rem, 2.4vw, 2rem);
    right: clamp(1.1rem, 2.4vw, 2rem);
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, rgba(111, 125, 103, 0.14), transparent 62%);
    pointer-events: none;
  }

  .sm-panel::after {
    content: '';
    position: absolute;
    inset: clamp(0.55rem, 1vw, 0.8rem);
    border-block: 1px solid rgba(184, 168, 138, 0.13);
    pointer-events: none;
  }

  .sm-panel__mark {
    position: absolute;
    right: clamp(1.1rem, 2.4vw, 2rem);
    top: clamp(0.7rem, 1.7vw, 1.2rem);
    z-index: 0;
    font-family: var(--font-display);
    font-size: var(--type-decorative-xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    color: rgba(111, 125, 103, 0.035);
    user-select: none;
  }

  .sm-panel__visual,
  .sm-panel__content {
    position: relative;
    z-index: 1;
  }

  .sm-panel__visual {
    display: flex;
    align-items: stretch;
    justify-content: center;
    height: 100%;
    min-height: clamp(30rem, 38vw, 36rem);
    padding: clamp(1.1rem, 2.4vw, 2rem);
    overflow: visible;
    background:
      radial-gradient(circle at 74% 16%, rgba(255, 255, 255, 0.55), transparent 26%),
      linear-gradient(135deg, rgba(255, 253, 248, 0.38), transparent 42%),
      linear-gradient(180deg, var(--color-accent-pale), #d7decf);
    box-shadow:
      inset 0 0 0 1px rgba(111, 125, 103, 0.12),
      0 18px 44px rgba(57, 54, 48, 0.045);
  }

  .sm-panel__visual::after {
    content: '';
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: clamp(1.1rem, 2.4vw, 2rem);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(111, 125, 103, 0.22), transparent);
    pointer-events: none;
  }

  .sm-panel__visual::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 9%;
    width: min(70%, 22rem);
    aspect-ratio: 1;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 999px 999px 3rem 3rem;
    pointer-events: none;
  }

  .sm-portrait {
    position: relative;
    width: 100%;
    max-width: none;
    height: 100%;
    min-height: 100%;
    margin: 0;
    transform: none;
    padding: 0;
    border-radius: 999px 999px 1rem 1rem;
    background: rgba(255, 253, 248, 0.42);
    box-shadow:
      0 22px 48px rgba(76, 83, 70, 0.145),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    overflow: hidden;
    transition: transform 0.6s var(--ease-out-expo), box-shadow 0.6s ease;
  }

  .sm-panel:hover .sm-portrait {
    transform: translateY(-0.18rem);
    box-shadow:
      0 26px 56px rgba(76, 83, 70, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .sm-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: inherit;
    filter: grayscale(8%) saturate(0.78) brightness(1.05) contrast(0.98);
  }

  .sm-portrait figcaption {
    position: absolute;
    left: clamp(0.85rem, 1.8vw, 1.1rem);
    right: clamp(0.85rem, 1.8vw, 1.1rem);
    bottom: clamp(0.85rem, 1.8vw, 1.1rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 0.84rem;
    border: 1px solid rgba(255, 253, 248, 0.32);
    border-radius: 999px;
    background: rgba(245, 240, 232, 0.92);
  }

  .sm-portrait figcaption span {
    display: block;
    width: 100%;
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--type-kicker);
    font-style: italic;
    font-weight: 300;
    color: rgba(47, 45, 40, 0.9);
  }

  .sm-panel__content {
    max-width: 45rem;
    padding: clamp(1.65rem, 3.6vw, 3.8rem) clamp(1rem, 3.2vw, 3.1rem);
    justify-self: start;
  }

  .sm-label {
    justify-content: flex-start;
    margin-bottom: 1.08rem;
  }

  .sm-panel__content p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.84;
    text-wrap: pretty;
  }

  .sm-panel__content p + p {
    margin-top: 1rem;
  }

  .sm-lead {
    font-family: var(--font-display);
    font-size: var(--type-card-title) !important;
    font-style: italic;
    font-weight: 300;
    line-height: 1.52 !important;
    color: rgba(47, 45, 40, 0.9) !important;
  }

  .sm-lead strong {
    color: var(--color-accent);
    font-weight: 500;
  }

  .sm-credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .sm-credentials li {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.52rem 0.78rem;
    border: 1px solid rgba(111, 125, 103, 0.18);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(250, 248, 242, 0.38));
    color: #5d6258;
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.14em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .sm-quote {
    margin: clamp(1.6rem, 3vw, 2.2rem) 0 0;
    padding: clamp(1.05rem, 2.4vw, 1.45rem) clamp(1.05rem, 2.4vw, 1.5rem);
    border-radius: 1.1rem;
    background:
      linear-gradient(180deg, rgba(223, 228, 216, 0.45), rgba(255, 255, 255, 0.32));
  }

  .sm-quote p {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.45;
    color: rgba(47, 45, 40, 0.78);
  }

  .sm-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.15rem;
    margin-top: clamp(1.65rem, 3vw, 2.3rem);
  }

  .sm-actions :global(.sm-button.btn--solid) {
    min-height: 3.2rem;
    padding: 1rem 1.65rem;
    border-color: #65745f;
    border-radius: 999px;
    background: linear-gradient(135deg, #65745f, #839079);
    color: #fff;
    box-shadow:
      0 14px 28px rgba(101, 116, 95, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }

  .sm-actions :global(.sm-button.btn--solid::before) {
    background: linear-gradient(135deg, #34372f, #56614f);
  }

  .sm-link {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    gap: 0.72rem;
    color: #58564f;
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: color 0.25s ease, letter-spacing 0.25s ease;
  }

  .sm-link__line {
    width: 2.45rem;
    height: 1px;
    background: rgba(101, 116, 95, 0.36);
    transform-origin: left;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .sm-link:hover {
    color: var(--color-accent);
    letter-spacing: 0.23em;
  }

  .sm-link:hover .sm-link__line {
    transform: scaleX(1.16);
    background: rgba(101, 116, 95, 0.62);
  }

  .sm-values {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.85rem, 1.8vw, 1.15rem);
    margin-top: clamp(1.05rem, 2.4vw, 1.7rem);
  }

  .sm-value {
    min-height: 11.5rem;
    padding: clamp(1.3rem, 2.5vw, 1.85rem);
    border-block: 1px solid rgba(111, 125, 103, 0.16);
    border-inline: 0;
    border-radius: 0;
    background:
      radial-gradient(circle at 100% 0%, rgba(223, 228, 216, 0.5), transparent 38%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(250, 248, 242, 0.12));
    box-shadow: none;
    transition: transform 0.35s ease, border-color 0.35s ease, background 0.35s ease;
  }

  .sm-value:hover {
    transform: translateY(-0.18rem);
    border-color: rgba(111, 125, 103, 0.22);
    background:
      radial-gradient(circle at 100% 0%, rgba(223, 228, 216, 0.62), transparent 38%),
      rgba(255, 253, 248, 0.86);
  }

  .sm-value span {
    display: inline-flex;
    margin-bottom: clamp(1.5rem, 3vw, 2.2rem);
    font-family: var(--font-display);
    font-size: var(--type-body);
    font-style: italic;
    color: rgba(111, 125, 103, 0.72);
  }

  .sm-value h3 {
    margin: 0 0 0.48rem;
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.1;
    color: rgba(47, 45, 40, 0.9);
  }

  .sm-value p {
    margin: 0;
    color: #5f5c55;
    font-size: var(--type-card-body);
    line-height: 1.68;
  }

  @media (max-width: 960px) {
    .sm-panel {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .sm-panel__visual {
      min-height: clamp(29rem, 76vw, 38rem);
    }

    .sm-panel__content {
      max-width: 46rem;
      margin-inline: auto;
      padding: clamp(2rem, 5vw, 3.3rem);
      justify-self: center;
      text-align: center;
    }

    .sm-label {
      justify-content: center;
    }

    .sm-credentials,
    .sm-actions {
      justify-content: center;
    }

    .sm-quote {
      border-radius: 1rem;
      background: rgba(223, 228, 216, 0.3);
    }
  }

  @media (max-width: 720px) {
    .sobre-mi {
      padding: 5rem 0 6rem;
    }

    .sobre-mi::before {
      opacity: 0.55;
      background-size: 6.5rem 6.5rem;
    }

    .sm-header {
      margin-bottom: 1.8rem;
      padding: 0 4vw;
    }

    .sm-header h2 {
      font-size: var(--type-section-title);
      line-height: 1.02;
      letter-spacing: -0.03em;
    }

    .sm-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }

    .sm-panel {
      padding: 0.6rem;
      border-radius: 1.1rem;
    }

    .sm-panel::before, .sm-panel::after {
      display: none;
    }

    .sm-panel__visual {
      min-height: clamp(22rem, 95vw, 26rem);
      border-radius: 0.85rem;
      padding: 0.8rem;
    }

    .sm-panel__visual::before {
      top: 7%;
      width: min(72%, 16rem);
    }

    .sm-portrait {
      width: 100%;
      padding-bottom: 0;
    }

    .sm-portrait figcaption {
      align-items: center;
      flex-direction: column;
      padding: 0.55rem 0.7rem;
      border-radius: 999px;
    }

    .sm-portrait figcaption span {
      width: 100%;
      text-align: center;
      font-size: var(--type-body);
    }

    .sm-panel__content {
      padding: 1.5rem 0.6rem 0.9rem;
    }

    .sm-lead {
      font-size: var(--type-card-title-sm) !important;
      line-height: 1.45 !important;
    }

    .sm-panel__content p {
      font-size: var(--type-body-sm);
      line-height: 1.72;
    }

    .sm-credentials {
      flex-direction: column;
      gap: 0.5rem;
    }

    .sm-credentials li {
      justify-content: center;
      width: 100%;
      min-height: 2.4rem;
      text-align: center;
      font-size: var(--type-meta);
      letter-spacing: 0.12em;
    }

    .sm-actions {
      align-items: stretch;
      flex-direction: column;
      gap: 0.8rem;
    }

    .sm-actions :global(.sm-button.btn--solid) {
      justify-content: center;
      width: 100%;
      min-height: 2.9rem;
      padding: 0.9rem 1.4rem;
      font-size: var(--type-meta);
      letter-spacing: 0.16em;
    }

    .sm-link {
      justify-content: center;
      width: 100%;
      min-height: 2.8rem;
      font-size: var(--type-meta);
      letter-spacing: 0.18em;
    }

    .sm-values {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }

    .sm-value {
      min-height: auto;
      padding: 1.2rem;
    }
    .sm-value span {
      margin-bottom: 1.1rem;
      font-size: var(--type-body-sm);
    }
    .sm-value h3 {
      font-size: var(--type-card-title);
    }
    .sm-value p {
      font-size: var(--type-card-body);
      line-height: 1.62;
    }
  }

  @media (max-width: 420px) {
    .sm-eyebrow,
    .sm-label {
      gap: 0.55rem;
      letter-spacing: 0.18em;
    }

    .sm-eyebrow::before,
    .sm-eyebrow::after,
    .sm-label::before {
      width: 1.45rem;
    }

    .sm-portrait {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sm-portrait,
    .sm-value {
      transition: none;
    }

    .sm-panel:hover .sm-portrait,
    .sm-value:hover {
      transform: none;
    }
  }
</style>
