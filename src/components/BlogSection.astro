---
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import BotanicalSVG from './ui/BotanicalSVG.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import { getLatestArticles } from '../data/blog';

const articles = getLatestArticles(3);

const imageSeeds: Record<string, string> = {
  'emdr-cordoba': 'quiet-therapy-room',
  'duelo-perdida-cordoba': 'soft-window-light',
  'ansiedad-cordoba': 'calm-breathing-space',
  'mindfulness-cordoba': 'mediterranean-stillness',
  'terapia-psicologica-cordoba': 'warm-consultation',
  'autoestima-cordoba': 'gentle-portrait-light',
};

const getArticleImage = (slug: string) =>
  `https://picsum.photos/seed/${imageSeeds[slug] ?? slug}/1400/980`;
---

<section id="blog" class="blog-section" data-blog-section>
  <GrainOverlay opacity={0.025} />
  <AmbientLight color="rgba(196,170,148,0.055)" />
  <DustParticles count={12} color="rgba(196,170,148,0.15)" />
  <FloatOrb size={360} top="-12%" left="-8%" color="var(--sage-muted)" blur={120} animation="float-1" />
  <FloatOrb size={240} bottom="8%" right="-4%" color="var(--gold-soft)" opacity={0.48} animation="float-2" />
  <InkBlob width={320} height={240} top="12%" right="-5%" color="var(--earth)" opacity={0.035} animation="morph-2" />
  <BotanicalSVG variant="left" color="var(--earth)" opacity={0.04} width={70} />
  <BotanicalSVG variant="right" color="var(--sage-muted)" opacity={0.05} width={58} style="right: 3%; bottom: 18%;" />

  <div class="blog-section__wash" aria-hidden="true"></div>

  <Container maxWidth="1160px">
    <div class="blog-intro">
      <header class="blog-header reveal-blur" data-delay="80">
        <span class="blog-eyebrow">Blog</span>
        <h2>Lecturas para volver a ti.</h2>
        <p>
          Artículos sobre trauma, duelo, ansiedad y bienestar emocional escritos desde la práctica clínica, con calma y rigor.
        </p>
      </header>
    </div>

    <div class="blog-grid stagger-children" data-delay="300">
      {articles.map((article, i) => (
        <article class="blog-card reveal-up" style={`transition-delay: ${i * 120}ms`}>
          <a href={`/blog/${article.slug}`} class="blog-card__link" aria-label={`Leer artículo: ${article.title}`}>
            <!-- Number watermark -->
            <span class="blog-card__number" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>

            <!-- Image -->
            <figure class="blog-card__media">
              <img
                src={getArticleImage(article.slug)}
                alt={`Imagen editorial para ${article.title}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
              <span class="blog-card__image-scrim" aria-hidden="true"></span>
            </figure>

            <!-- Body -->
            <div class="blog-card__body">
              <!-- Top: category + read time -->
              <div class="blog-card__top">
                <span class="blog-card__category">{article.categoryLabel}</span>
                <span class="blog-card__read">{article.readTime}</span>
              </div>

              <!-- Title -->
              <h3 class="blog-card__title">{article.title}</h3>

              <!-- Excerpt -->
              <p class="blog-card__excerpt">{article.excerpt}</p>

              <!-- Footer -->
              <div class="blog-card__footer">
                <time datetime={article.dateISO}>{article.date}</time>
                <span class="blog-card__arrow" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M3.5 9h10.4M10.1 5.2 13.9 9l-3.8 3.8" stroke="currentColor" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
            </div>

            <!-- Hover line -->
            <div class="blog-card__hover-line" aria-hidden="true"></div>
          </a>
        </article>
      ))}
    </div>

    <div class="blog-footer reveal-up" data-delay="650">
      <!-- Marquee -->
      <div class="blog-marquee" aria-hidden="true">
        <div class="blog-marquee__track">
          <span class="blog-marquee__item">EMDR</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Duelo</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Ansiedad</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Mindfulness</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Autoestima</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Terapia</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">EMDR</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Duelo</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Ansiedad</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Mindfulness</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Autoestima</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Terapia</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
        </div>
      </div>

      <!-- CTA -->
      <div class="blog-cta">
        <a href="/blog" class="btn-blog">
          <span class="btn-blog__text">Ver todos los artículos</span>
          <span class="btn-blog__line" aria-hidden="true"></span>
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <p class="blog-cta__note">Escritura pausada, sin ruido. Lo que necesitas, cuando lo necesitas.</p>
      </div>
    </div>
  </Container>

  <PageNumber number="08" />
</section>

<style>
  .blog-section {
    position: relative;
    width: 100%;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 22% 18%, var(--gold-soft) 0%, transparent 42%),
      radial-gradient(ellipse at 82% 76%, rgba(107,125,106,0.075) 0%, transparent 48%),
      linear-gradient(180deg, var(--parchment) 0%, var(--cream) 100%);
    padding: 10rem 0 12rem;
    isolation: isolate;
  }

  .blog-section__wash {
    position: absolute;
    inset: 12% 3% auto;
    height: 48%;
    pointer-events: none;
    z-index: 0;
    background:
      linear-gradient(115deg, rgba(253,251,247,0.54), transparent 58%),
      radial-gradient(circle at 58% 42%, var(--sage-muted), transparent 45%);
    filter: blur(10px);
    opacity: 0.9;
  }

  .blog-intro {
    position: relative;
    z-index: 2;
    max-width: 920px;
    margin: 0 auto 4.5rem;
  }

  .blog-header {
    max-width: 54rem;
    margin: 0 auto clamp(2.25rem, 4vw, 3.4rem);
    text-align: center;
  }

  .blog-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--earth);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .blog-eyebrow::before,
  .blog-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(107, 125, 106, 0.34);
  }

  .blog-header h2 {
    max-width: 52rem;
    margin: 1rem auto 1rem;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6.5vw, 5.35rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.045em;
    color: var(--ink);
    text-wrap: balance;
  }

  .blog-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--ink-soft);
    font-size: clamp(1rem, 1.35vw, 1.12rem);
    line-height: 1.78;
    text-wrap: pretty;
  }

  /* ===== 3-COLUMN GRID ===== */
  .blog-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  /* ===== CARD ===== */
  .blog-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-radius: 0.75rem;
  }

  /* Per-card accent colors */
  .blog-card:nth-child(1) {
    --blog-accent: rgba(107, 125, 106, 0.85);
    --blog-accent-soft: rgba(107, 125, 106, 0.12);
    --blog-accent-glow: rgba(107, 125, 106, 0.06);
  }

  .blog-card:nth-child(2) {
    --blog-accent: var(--gold);
    --blog-accent-soft: var(--gold-soft);
    --blog-accent-glow: rgba(184, 168, 138, 0.06);
  }

  .blog-card:nth-child(3) {
    --blog-accent: rgba(138, 154, 137, 0.92);
    --blog-accent-soft: rgba(138, 154, 137, 0.14);
    --blog-accent-glow: rgba(138, 154, 137, 0.06);
  }

  .blog-card__link {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    color: inherit;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(253, 251, 247, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(229, 223, 212, 0.28), transparent 35%);
    border: 1px solid var(--line);
    box-shadow: 0 8px 32px rgba(44, 44, 44, 0.035);
    transition:
      transform 0.48s var(--ease-out-expo),
      border-color 0.35s ease,
      box-shadow 0.45s var(--ease-out-expo);
  }

  /* Inner border highlight */
  .blog-card__link::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.4);
    opacity: 0.6;
  }

  /* Radial glow decoration */
  .blog-card__link::after {
    content: '';
    position: absolute;
    inset: auto -12% -16% auto;
    width: 9rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, var(--blog-accent-soft), transparent 68%);
    pointer-events: none;
    opacity: 0.45;
    transform: scale(0.84);
    transition: transform 0.7s var(--ease-out-expo), opacity 0.45s ease;
  }

  .blog-card__link:hover {
    transform: translateY(-0.3rem);
    border-color: var(--blog-accent);
    box-shadow: 0 1.2rem 2.4rem rgba(44, 44, 44, 0.07);
  }

  .blog-card__link:hover::after {
    transform: scale(1.08);
    opacity: 0.72;
  }

  /* ===== NUMBER WATERMARK ===== */
  .blog-card__number {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    z-index: 3;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.4rem;
    color: var(--parchment);
    opacity: 0.7;
    line-height: 1;
    user-select: none;
    transition: opacity 0.6s ease, transform 0.6s var(--ease-out-expo);
  }

  .blog-card__link:hover .blog-card__number {
    opacity: 1;
    transform: translateY(-2px);
  }

  /* ===== IMAGE ===== */
  .blog-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--cream-warm);
  }

  .blog-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(12%) sepia(8%) saturate(0.82) contrast(1.04) brightness(0.96);
    transform: scale(1.02);
    transition: transform 0.85s var(--ease-out-expo), filter 0.85s ease;
  }

  .blog-card__link:hover .blog-card__media img {
    transform: scale(1.06);
    filter: grayscale(4%) sepia(4%) saturate(0.92) contrast(1.08) brightness(1);
  }

  .blog-card__image-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(42, 31, 26, 0.18) 100%);
    pointer-events: none;
  }

  /* ===== BODY ===== */
  .blog-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: clamp(1rem, 1.4vw, 1.35rem);
    flex: 1;
    position: relative;
    z-index: 1;
  }

  /* Top: category + read time */
  .blog-card__top {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.05rem;
  }

  .blog-card__category {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    padding: 0.25rem 0.55rem;
    border: 1px solid rgba(107, 125, 106, 0.14);
    border-radius: 999px;
    color: rgba(44, 44, 44, 0.62);
    background: rgba(255, 255, 255, 0.65);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition:
      transform 0.35s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .blog-card__link:hover .blog-card__category {
    transform: translateY(-1px);
    border-color: var(--blog-accent);
    background: var(--blog-accent-soft);
    color: rgba(44, 44, 44, 0.78);
  }

  .blog-card__read {
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.45;
  }
  .blog-card__title {
    margin: 0;
    max-width: 14ch;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.5vw, 1.5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    transition: transform 0.45s var(--ease-out-expo), color 0.35s ease;
  }

  /* Excerpt */
  .blog-card__excerpt {
    flex: 1;
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 0.9vw, 0.88rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--ink-soft);
    opacity: 0.68;
    transition: color 0.35s ease, transform 0.45s var(--ease-out-expo);
  }

  .blog-card__link:hover .blog-card__title,
  .blog-card__link:hover .blog-card__excerpt {
    transform: translateY(-1px);
  }

  /* Footer */
  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid var(--line);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--taupe);
  }

  .blog-card__arrow {
    display: inline-flex;
    flex: 0 0 auto;
    color: var(--taupe);
    opacity: 0.38;
    transform: translateX(-4px);
    transition: transform 0.55s var(--ease-out-expo), opacity 0.55s ease, color 0.55s ease;
  }

  .blog-card__link:hover .blog-card__arrow {
    color: var(--blog-accent);
    opacity: 0.85;
    transform: translateX(0);
  }

  /* Hover line */
  .blog-card__hover-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blog-accent), transparent);
    opacity: 0.2;
    transition: width 0.9s var(--ease-out-expo);
    z-index: 2;
  }

  .blog-card__link:hover .blog-card__hover-line {
    width: 100%;
  }

  /* ===== FOOTER: MARQUEE + CTA ===== */
  .blog-footer {
    position: relative;
    z-index: 2;
    margin-top: 4.5rem;
  }

  /* ===== MARQUEE ===== */
  .blog-marquee {
    position: relative;
    overflow: hidden;
    padding: 1.35rem 0;
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }

  .blog-marquee::before,
  .blog-marquee::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-soft), transparent);
  }

  .blog-marquee::before { top: 0; }
  .blog-marquee::after { bottom: 0; }

  .blog-marquee__track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: blog-marquee 40s linear infinite;
    will-change: transform;
  }

  .blog-marquee__item {
    display: inline-flex;
    align-items: center;
    padding: 0 0.15rem;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.6vw, 1.55rem);
    font-style: italic;
    font-weight: 300;
    color: var(--taupe);
    white-space: nowrap;
    transition: color 0.3s ease;
    letter-spacing: 0.01em;
  }

  .blog-marquee__dot {
    display: inline-flex;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--gold-soft);
    margin: 0 1.35rem;
    flex-shrink: 0;
  }

  @keyframes blog-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ===== CTA ===== */
  .blog-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;
    margin-top: 2.8rem;
    text-align: center;
  }

  .btn-blog {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 3.35rem;
    padding: 0 2.2rem;
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
    border-radius: 999px;
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    overflow: hidden;
    transition:
      border-color 0.45s ease,
      color 0.45s ease,
      transform 0.55s var(--ease-out-expo);
  }

  .btn-blog__text {
    position: relative;
    z-index: 1;
  }

  .btn-blog__line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0;
    height: 100%;
    background: var(--ink);
    transform: translate(-50%, -50%);
    border-radius: inherit;
    transition: width 0.55s var(--ease-out-expo);
    z-index: 0;
  }

  .btn-blog:hover {
    border-color: var(--ink);
    color: var(--white-warm);
    transform: translateY(-2px);
  }

  .btn-blog:hover .btn-blog__line {
    width: 100%;
  }

  .btn-blog svg {
    position: relative;
    z-index: 1;
    transition: transform 0.55s var(--ease-out-expo);
  }

  .btn-blog:hover svg {
    transform: translateX(4px);
  }

  .blog-cta__note {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(0.88rem, 1.1vw, 1rem);
    font-style: italic;
    font-weight: 300;
    color: var(--taupe);
    letter-spacing: 0.01em;
    line-height: 1.5;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 980px) {
    .blog-section {
      padding: 8rem 0 10rem;
    }

    .blog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  @media (max-width: 640px) {
    .blog-section {
      padding: 6.5rem 0 8rem;
    }

    .blog-intro {
      margin-bottom: 3rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }

    .blog-card__media {
      aspect-ratio: 16 / 10;
    }

    .blog-card__body {
      padding: 1.2rem;
    }

    .blog-card__footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .blog-footer {
      margin-top: 3.5rem;
    }

    .btn-blog {
      width: 100%;
      max-width: 20rem;
      padding-inline: 1.4rem;
      text-align: center;
    }

    .blog-cta__note {
      font-size: 0.85rem;
    }
  }
</style>
