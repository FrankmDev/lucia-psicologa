---
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import BotanicalSVG from './ui/BotanicalSVG.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import { getLatestArticles } from '../data/blog';

const articles = getLatestArticles(3);

const imageSeeds: Record<string, string> = {
  'emdr-cordoba': 'quiet-therapy-room',
  'duelo-perdida-cordoba': 'soft-window-light',
  'ansiedad-cordoba': 'calm-breathing-space',
  'mindfulness-cordoba': 'mediterranean-stillness',
  'terapia-psicologica-cordoba': 'warm-consultation',
  'autoestima-cordoba': 'gentle-portrait-light',
};

const getArticleImage = (slug: string) =>
  `https://picsum.photos/seed/${imageSeeds[slug] ?? slug}/1400/980`;
---

<section id="blog" class="blog-section" data-blog-section>
  <GrainOverlay opacity={0.018} />
  <AmbientLight color="rgba(196,170,148,0.045)" />
  <DustParticles count={12} color="rgba(196,170,148,0.12)" />
  <FloatOrb size={360} top="-12%" left="-8%" color="var(--sage-muted)" blur={120} animation="float-1" />
  <FloatOrb size={240} bottom="8%" right="-4%" color="var(--gold-soft)" opacity={0.48} animation="float-2" />
  <InkBlob width={320} height={240} top="12%" right="-5%" color="var(--earth)" opacity={0.03} animation="morph-2" />
  <BotanicalSVG variant="left" color="var(--earth)" opacity={0.04} width={70} />
  <BotanicalSVG variant="right" color="var(--sage-muted)" opacity={0.05} width={58} style="right: 3%; bottom: 18%;" />

  <div class="blog-section__wash" aria-hidden="true"></div>

  <Container maxWidth="1180px">
    <div class="blog-intro">
      <header class="blog-header reveal-blur" data-delay="80">
        <span class="blog-eyebrow">Blog</span>
        <h2>Lecturas para volver a ti.</h2>
        <p>
          Artículos sobre trauma, duelo, ansiedad y bienestar emocional escritos desde la práctica clínica, con calma y rigor.
        </p>
      </header>
    </div>

    <div class="blog-grid stagger-children" data-delay="300">
      {articles.map((article, i) => (
        <article class="blog-card reveal-up" style={`transition-delay: ${i * 100}ms`}>
          <a href={`/blog/${article.slug}`} class="blog-card__link" aria-label={`Leer artículo: ${article.title}`}>
            <!-- Image -->
            <figure class="blog-card__media">
              <img
                src={getArticleImage(article.slug)}
                alt={`Imagen editorial para ${article.title}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
              <span class="blog-card__image-scrim" aria-hidden="true"></span>
            </figure>

            <!-- Body -->
            <div class="blog-card__body">
              <!-- Top: category + read time -->
              <div class="blog-card__top">
                <span class="blog-card__category">{article.categoryLabel}</span>
                <span class="blog-card__divider" aria-hidden="true"></span>
                <span class="blog-card__read">{article.readTime}</span>
              </div>

              <!-- Title -->
              <h3 class="blog-card__title">{article.title}</h3>

              <!-- Excerpt -->
              <p class="blog-card__excerpt">{article.excerpt}</p>

              <!-- Footer -->
              <div class="blog-card__footer">
                <time datetime={article.dateISO}>{article.date}</time>
                <span class="blog-card__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="blog-footer reveal-up" data-delay="650">
      <!-- Marquee -->
      <div class="blog-marquee" aria-hidden="true">
        <div class="blog-marquee__track">
          <span class="blog-marquee__item">EMDR</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Duelo</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Ansiedad</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Mindfulness</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Autoestima</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Terapia</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">EMDR</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Duelo</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Ansiedad</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Mindfulness</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Autoestima</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
          <span class="blog-marquee__item">Terapia</span>
          <span class="blog-marquee__dot" aria-hidden="true"></span>
        </div>
      </div>

      <!-- CTA -->
      <div class="blog-cta">
        <a href="/blog" class="btn-blog">
          <span class="btn-blog__text">Ver todos los artículos</span>
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <p class="blog-cta__note">Escritura pausada, sin ruido. Lo que necesitas, cuando lo necesitas.</p>
      </div>
    </div>
  </Container>

  <PageNumber number="08" />
</section>

<style>
  .blog-section {
    --blog-ink: #2f2d28;
    --blog-text: rgba(47, 45, 40, 0.72);
    --blog-muted: rgba(47, 45, 40, 0.52);
    --blog-line: rgba(111, 125, 103, 0.18);
    --blog-line-soft: rgba(111, 125, 103, 0.11);
    --blog-sage: #6f7d67;
    --blog-sage-deep: #56645a;
    --blog-cream: #fbf8f1;
    --blog-paper: #fffdf8;
    --blog-gold: #b8a88a;
    --blog-gold-soft: rgba(184, 168, 138, 0.14);

    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: clamp(5.8rem, 8vw, 8.5rem) 0 clamp(6.5rem, 9vw, 9.4rem);
    background:
      radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.88), transparent 30%),
      radial-gradient(circle at 84% 14%, rgba(223, 228, 216, 0.58), transparent 30%),
      radial-gradient(circle at 70% 76%, rgba(184, 168, 138, 0.12), transparent 32%),
      linear-gradient(180deg, #fffdfa 0%, var(--blog-cream) 58%, #f2efe8 100%);
  }

  .blog-section::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.01) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 74%);
    opacity: 0.55;
  }

  .blog-section::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    box-shadow: inset 0 0 180px rgba(255, 255, 255, 0.22);
  }

  .blog-section__wash {
    position: absolute;
    inset: 12% 3% auto;
    height: 48%;
    pointer-events: none;
    z-index: 0;
    background:
      linear-gradient(115deg, rgba(253,251,247,0.54), transparent 58%),
      radial-gradient(circle at 58% 42%, var(--sage-muted), transparent 45%);
    filter: blur(10px);
    opacity: 0.9;
  }

  .blog-intro {
    position: relative;
    z-index: 2;
    max-width: 920px;
    margin: 0 auto clamp(2.25rem, 4vw, 3.4rem);
  }

  .blog-header {
    max-width: 54rem;
    margin: 0 auto clamp(2.25rem, 4vw, 3.4rem);
    text-align: center;
  }

  .blog-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--blog-sage);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .blog-eyebrow::before,
  .blog-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .blog-header h2 {
    max-width: 52rem;
    margin: 1rem auto 1rem;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6.5vw, 5.35rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.045em;
    color: var(--blog-ink);
    text-wrap: balance;
  }

  .blog-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--blog-muted);
    font-size: clamp(1rem, 1.35vw, 1.12rem);
    line-height: 1.78;
    text-wrap: pretty;
  }

  /* ===== 3-COLUMN GRID ===== */
  .blog-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: auto;
    gap: clamp(1.2rem, 2vw, 1.5rem);
    align-items: stretch;
  }

  /* ===== CARD ===== */
  .blog-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-radius: 1rem;
    background: rgba(255, 253, 248, 0.6);
    border: 1px solid var(--blog-line-soft);
    transition:
      transform 0.5s var(--ease-out-expo),
      box-shadow 0.5s var(--ease-out-expo),
      border-color 0.4s ease;
  }

  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 1.5rem 3rem rgba(57, 54, 48, 0.08);
    border-color: rgba(111, 125, 103, 0.2);
  }

  /* Per-card accent colors */
  .blog-card:nth-child(1) { --card-accent: #6f7d67; }
  .blog-card:nth-child(2) { --card-accent: #b8a88a; }
  .blog-card:nth-child(3) { --card-accent: #8a9a89; }

  .blog-card__link {
    position: relative;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    overflow: hidden;
    color: inherit;
    height: 100%;
    border-radius: inherit;
  }

  /* ===== IMAGE ===== */
  .blog-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--cream-warm);
  }

  .blog-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(10%) saturate(0.85) contrast(1.03) brightness(0.97);
    transform: scale(1.02);
    transition: transform 0.85s var(--ease-out-expo), filter 0.85s ease;
  }

  .blog-card:hover .blog-card__media img {
    transform: scale(1.05);
    filter: grayscale(2%) saturate(0.95) contrast(1.05) brightness(1);
  }

  .blog-card__image-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(42, 31, 26, 0.12) 100%);
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .blog-card:hover .blog-card__image-scrim {
    opacity: 0.7;
  }

  /* ===== BODY ===== */
  .blog-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: clamp(1.1rem, 1.6vw, 1.4rem);
    position: relative;
    z-index: 1;
  }

  /* Top: category + read time */
  .blog-card__top {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.15rem;
  }

  .blog-card__category {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    padding: 0.22rem 0.55rem;
    border-radius: 999px;
    color: var(--card-accent);
    background: rgba(255, 255, 255, 0.8);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border: 1px solid rgba(111, 125, 103, 0.12);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .blog-card:hover .blog-card__category {
    border-color: rgba(111, 125, 103, 0.22);
    background: rgba(255, 255, 255, 0.95);
  }

  .blog-card__divider {
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--blog-gold-soft);
    opacity: 0.6;
  }

  .blog-card__read {
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--blog-muted);
  }

  .blog-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.6vw, 1.55rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--blog-ink);
    transition: color 0.35s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.36em;
  }

  .blog-card:hover .blog-card__title {
    color: var(--card-accent);
  }

  /* Excerpt */
  .blog-card__excerpt {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(0.82rem, 0.92vw, 0.9rem);
    font-weight: 300;
    line-height: 1.7;
    color: var(--blog-text);
    opacity: 0.8;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 5.1em;
  }

  /* Footer */
  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.6rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--blog-line-soft);
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--blog-muted);
  }

  .blog-card__arrow {
    display: inline-flex;
    flex: 0 0 auto;
    color: var(--blog-muted);
    opacity: 0.35;
    transform: translateX(-3px);
    transition: transform 0.5s var(--ease-out-expo), opacity 0.5s ease, color 0.5s ease;
  }

  .blog-card:hover .blog-card__arrow {
    color: var(--card-accent);
    opacity: 0.75;
    transform: translateX(0);
  }

  /* ===== FOOTER: MARQUEE + CTA ===== */
  .blog-footer {
    position: relative;
    z-index: 2;
    margin-top: clamp(3.2rem, 5vw, 4.5rem);
  }

  /* ===== MARQUEE ===== */
  .blog-marquee {
    position: relative;
    overflow: hidden;
    padding: 1.35rem 0;
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }

  .blog-marquee::before,
  .blog-marquee::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blog-gold-soft), transparent);
  }

  .blog-marquee::before { top: 0; }
  .blog-marquee::after { bottom: 0; }

  .blog-marquee__track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: blog-marquee 40s linear infinite;
    will-change: transform;
  }

  .blog-marquee__item {
    display: inline-flex;
    align-items: center;
    padding: 0 0.15rem;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.6vw, 1.55rem);
    font-style: italic;
    font-weight: 300;
    color: var(--taupe);
    white-space: nowrap;
    transition: color 0.3s ease;
    letter-spacing: 0.01em;
  }

  .blog-marquee__dot {
    display: inline-flex;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--blog-gold-soft);
    margin: 0 1.35rem;
    flex-shrink: 0;
  }

  @keyframes blog-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ===== CTA ===== */
  .blog-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;
    margin-top: 2.8rem;
    text-align: center;
  }

  .btn-blog {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 3.2rem;
    padding: 0.78rem 1.65rem;
    border: 1px solid rgba(111, 125, 103, 0.28);
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    overflow: hidden;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.14);
    transition:
      transform 0.45s var(--ease-out-expo),
      box-shadow 0.45s ease,
      background 0.35s ease,
      border-color 0.35s ease;
  }

  .btn-blog:hover {
    transform: translateY(-2px);
    box-shadow: 0 1.1rem 1.9rem rgba(86, 100, 90, 0.17);
    border-color: rgba(86, 100, 90, 0.35);
  }

  .btn-blog svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .btn-blog:hover svg {
    transform: translateX(3px);
  }

  .blog-cta__note {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(0.88rem, 1.1vw, 1rem);
    font-style: italic;
    font-weight: 300;
    color: var(--blog-muted);
    letter-spacing: 0.01em;
    line-height: 1.5;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1100px) {
    .blog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  @media (max-width: 640px) {
    .blog-section {
      padding: 5.2rem 0 6.5rem;
    }

    .blog-intro {
      margin-bottom: 2.8rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }

    .blog-card__media {
      aspect-ratio: 16 / 10;
    }

    .blog-card__body {
      padding: 1.1rem;
    }

    .blog-card__title {
      min-height: auto;
    }

    .blog-card__excerpt {
      min-height: auto;
    }

    .blog-card__footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .blog-footer {
      margin-top: 3rem;
    }

    .btn-blog {
      width: 100%;
      max-width: 20rem;
      padding-inline: 1.4rem;
      text-align: center;
    }

    .blog-cta__note {
      font-size: 0.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-card,
    .btn-blog,
    .btn-blog svg,
    .blog-card__arrow,
    .blog-card__media img {
      transition: none !important;
    }

    .blog-card:hover,
    .btn-blog:hover {
      transform: none;
    }

    .blog-marquee__track {
      animation: none;
    }
  }
</style>
