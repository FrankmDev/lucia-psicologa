---
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import { getArticleImage, getLatestArticles } from '../data/blog';

const articles = getLatestArticles(3);
---

<section id="blog" class="blog-section" data-blog-section>
  <GrainOverlay opacity={0.014} />
  <AmbientLight color="rgba(196,170,148,0.045)" />
  <FloatOrb size={320} top="-12%" left="-8%" color="var(--sage-muted)" blur={120} animation="float-1" />
  <FloatOrb size={200} bottom="8%" right="-4%" color="var(--gold-soft)" opacity={0.42} animation="float-2" />

  <div class="blog-section__wash" aria-hidden="true"></div>

  <Container maxWidth="1080px">
    <header class="blog-header reveal-blur" data-delay="80">
      <span class="section-eyebrow">Lecturas</span>
      <h2>Artículos para entender lo que te ocurre con más contexto.</h2>
      <p>
        Información sobre ansiedad, trauma, EMDR, duelo, autoestima y regulación emocional escrita con criterio clínico y lenguaje claro.
      </p>
    </header>

    <div class="blog-grid stagger-children">
      {articles.map((article, i) => (
        <article class={`blog-card blog-card--${i === 0 ? 'featured' : 'compact'} reveal-up`} style={`transition-delay: ${i * 120}ms`}>
          <a href={`/blog/${article.slug}`} class="blog-card__link" aria-label={`Leer artículo: ${article.title}`}>
            <figure class="blog-card__media">
              <img
                src={getArticleImage(article.slug, 1400, 980)}
                alt={`Imagen editorial para ${article.title}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
              <span class="blog-card__image-scrim" aria-hidden="true"></span>
              <span class="blog-card__image-frame" aria-hidden="true"></span>
            </figure>

            <div class="blog-card__body">
              <div class="blog-card__top">
                <span class="blog-card__category">{article.categoryLabel}</span>
                <span class="blog-card__divider" aria-hidden="true"></span>
                <span class="blog-card__read">{article.readTime}</span>
              </div>
              <h3 class="blog-card__title">{article.title}</h3>
              <p class="blog-card__excerpt">{article.excerpt}</p>
              <div class="blog-card__footer">
                <time datetime={article.dateISO}>{article.date}</time>
                <span class="blog-card__arrow" aria-hidden="true">
                  <span class="arrow-line"></span>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M1 7h10M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="blog-footer reveal-up" data-delay="580">
      <a href="/blog" class="blog-footer__cta">
        <span>Leer más artículos</span>
        <span class="cta-line" aria-hidden="true"></span>
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </Container>
</section>

<style>
  .blog-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
    background:
      radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.88), transparent 30%),
      radial-gradient(circle at 84% 14%, rgba(223, 228, 216, 0.58), transparent 30%),
      radial-gradient(circle at 70% 76%, rgba(184, 168, 138, 0.12), transparent 32%),
      linear-gradient(180deg, #fffdfa 0%, var(--color-surface) 58%, #f2efe8 100%);
  }

  .blog-section::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.01) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 74%);
    opacity: 0.55;
  }

  .blog-section::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    box-shadow: inset 0 0 180px rgba(255, 255, 255, 0.22);
  }

  .blog-section__wash {
    position: absolute;
    inset: 12% 3% auto;
    height: 48%;
    pointer-events: none;
    z-index: 0;
    background:
      linear-gradient(115deg, rgba(253,251,247,0.54), transparent 58%),
      radial-gradient(circle at 58% 42%, var(--sage-muted), transparent 45%);
    filter: blur(10px);
    opacity: 0.9;
  }

  .blog-header {
    position: relative;
    z-index: 2;
    max-width: 54rem;
    margin: 0 auto clamp(2.25rem, 4vw, 3.4rem);
    text-align: center;
  }

  .blog-header h2 {
    max-width: 52rem;
    margin: 1rem auto 1rem;
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .blog-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: var(--type-lead);
    line-height: 1.78;
    text-wrap: pretty;
  }

  .blog-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-template-rows: auto auto;
    gap: clamp(1.2rem, 2vw, 1.5rem);
    align-items: stretch;
  }

  .blog-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-radius: 1rem;
    background: rgba(255, 253, 248, 0.6);
    border: 1px solid var(--color-line-accent-soft);
    transition:
      transform 0.5s var(--ease-out-expo),
      box-shadow 0.5s var(--ease-out-expo),
      border-color 0.4s ease;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 1.5rem 3rem rgba(57, 54, 48, 0.08);
    border-color: rgba(111, 125, 103, 0.2);
  }

  .blog-card--featured {
    --card-accent: #6f7d67;
    grid-column: 1 / -1;
  }
  .blog-card--compact:nth-child(2) {
    --card-accent: #b8a88a;
    grid-column: span 7;
  }
  .blog-card--compact:nth-child(3) {
    --card-accent: #8a9a89;
    grid-column: span 5;
  }

  .blog-card__link {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    color: inherit;
    height: 100%;
    border-radius: inherit;
    text-decoration: none;
  }

  .blog-card--featured .blog-card__link {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    min-height: clamp(18rem, 32vw, 26rem);
  }

  .blog-card__media {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: inherit;
  }

  .blog-card--featured .blog-card__media {
    border-radius: 1rem 0 0 1rem;
  }

  .blog-card--compact .blog-card__media {
    aspect-ratio: 16 / 10;
  }

  .blog-card__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease-out-expo);
  }

  .blog-card:hover .blog-card__media img {
    transform: scale(1.06);
  }

  .blog-card__image-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 40%, rgba(13,10,8,0.22) 100%);
    transition: opacity 0.5s ease;
    opacity: 0.7;
  }
  .blog-card:hover .blog-card__image-scrim {
    opacity: 0.5;
  }

  .blog-card__image-frame {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
    pointer-events: none;
  }

  .blog-card--featured .blog-card__image-frame {
    border-radius: 1rem 0 0 1rem;
  }

  .blog-card__body {
    display: flex;
    flex-direction: column;
    padding: clamp(1.2rem, 2vw, 1.6rem);
    gap: 0.55rem;
  }

  .blog-card--featured .blog-card__body {
    justify-content: center;
    padding: clamp(1.6rem, 3vw, 2.4rem);
    gap: 0.7rem;
  }

  .blog-card__top {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: var(--type-meta);
    line-height: 1;
  }

  .blog-card__category {
    color: var(--card-accent);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    position: relative;
    display: inline-block;
  }
  .blog-card__category::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.45s var(--ease-out-expo), opacity 0.3s ease;
    opacity: 0.3;
  }
  .blog-card:hover .blog-card__category::after {
    transform: scaleX(1);
    transform-origin: left;
    opacity: 0.6;
  }

  .blog-card__divider {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--color-line);
    opacity: 0.5;
  }

  .blog-card__read {
    color: var(--color-text-muted);
  }

  .blog-card__title {
    margin: 0.15rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    text-wrap: balance;
    transition: color 0.35s ease;
  }

  .blog-card:hover .blog-card__title {
    color: var(--color-accent-deep);
  }

  .blog-card--featured .blog-card__title {
    font-size: clamp(1.35rem, 2.6vw, 1.85rem);
    line-height: 1.14;
    letter-spacing: -0.02em;
  }

  .blog-card__excerpt {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.68;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-wrap: pretty;
  }

  .blog-card--featured .blog-card__excerpt {
    -webkit-line-clamp: 3;
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.85rem;
    font-size: var(--type-meta);
    color: var(--color-text-muted);
  }

  .blog-card__arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--card-accent);
    transition: gap 0.35s var(--ease-out-expo);
  }
  .blog-card:hover .blog-card__arrow {
    gap: 0.55rem;
  }

  .arrow-line {
    display: inline-block;
    width: 0;
    height: 1px;
    background: currentColor;
    transition: width 0.35s var(--ease-out-expo);
  }
  .blog-card:hover .arrow-line {
    width: 1.2rem;
  }

  .blog-card__arrow svg {
    transition: transform 0.35s var(--ease-out-expo);
  }
  .blog-card:hover .blog-card__arrow svg {
    transform: translateX(2px);
  }

  .blog-footer {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  .blog-footer__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-accent-deep);
    font-size: var(--type-caption);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.35s ease;
  }
  .blog-footer__cta:hover {
    color: var(--color-ink);
  }

  .cta-line {
    display: inline-block;
    width: 2.4rem;
    height: 1px;
    background: rgba(101, 116, 95, 0.36);
    transform-origin: left;
    transition: transform 0.35s ease, background 0.35s ease;
  }
  .blog-footer__cta:hover .cta-line {
    transform: scaleX(1.3);
    background: var(--color-accent);
  }

  .blog-footer__cta svg {
    transition: transform 0.35s var(--ease-out-expo);
  }
  .blog-footer__cta:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 820px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    .blog-card--featured,
    .blog-card--compact:nth-child(2),
    .blog-card--compact:nth-child(3) {
      grid-column: 1 / -1;
    }
    .blog-card--featured .blog-card__link {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .blog-card--featured .blog-card__media {
      aspect-ratio: 16 / 9;
      border-radius: 1rem 1rem 0 0;
    }
    .blog-card--featured .blog-card__image-frame {
      border-radius: 1rem 1rem 0 0;
    }
    .blog-card--featured .blog-card__body {
      padding: clamp(1.2rem, 3vw, 1.6rem);
    }
  }

  @media (max-width: 520px) {
    .blog-section {
      padding: 4.8rem 0 5.8rem;
    }
    .blog-header {
      margin-bottom: 1.8rem;
      padding: 0 4vw;
    }
    .blog-header h2 {
      font-size: var(--type-section-title-sm);
      line-height: 1.02;
    }
    .blog-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }
    .blog-card--compact .blog-card__media {
      aspect-ratio: 16 / 11;
    }
    .blog-card__excerpt {
      font-size: var(--type-body-sm);
      line-height: 1.62;
    }
    .blog-card__footer {
      font-size: var(--type-micro);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-card,
    .blog-card__media img,
    .blog-card__arrow,
    .blog-card__arrow svg,
    .arrow-line,
    .blog-footer__cta,
    .blog-footer__cta svg {
      transition: none;
    }
    .blog-card:hover,
    .blog-card:hover .blog-card__media img {
      transform: none;
    }
  }
</style>
