---

<!-- Spacer for fixed footer reveal effect -->
<div class="footer-spacer" id="footerSpacer" aria-hidden="true"></div>

<footer class="site-footer dark-surface" id="siteFooter" data-footer data-surface="dark">
  <!-- Background layers -->
  <div class="footer-bg">
    <div class="footer-overlay"></div>
    <div class="footer-vignette" aria-hidden="true"></div>
    <div class="footer-grid" aria-hidden="true"></div>
  </div>

  <GrainOverlay animated opacity={0.015} zIndex={2} />
  <AmbientLight color="rgba(184,168,148,0.04)" />
  <DustParticles count={10} color="rgba(196,170,148,0.06)" />

  <FloatOrb size={260} top="10%" right="8%" color="rgba(196,170,148,0.06)" blur={90} animation="float-1" />
  <FloatOrb size={200} bottom="20%" left="6%" color="rgba(111,125,103,0.05)" blur={80} animation="float-2" />

  <InkBlob width={320} height={240} top="-8%" right="-4%" color="var(--earth)" opacity={0.025} />
  <InkBlob width={240} height={180} bottom="-6%" left="-6%" color="var(--sage)" opacity={0.02} animation="morph-2" />

  <BotanicalSVG variant="left" color="rgba(196,170,148,0.04)" opacity={0.5} width={48} />
  <BotanicalSVG variant="right" color="rgba(111,125,103,0.05)" opacity={0.5} width={42} style="right: 5%; bottom: 18%;" />

  <div class="footer-inner">

    <!-- Main grid: CTA left | Contact right -->
    <div class="footer-main-grid">
      
      <!-- Left: CTA -->
      <div class="footer-cta-area reveal-left" data-delay="100">
        <div class="footer-eyebrow">
          <span>Contacto</span>
        </div>
        
        <h2 class="footer-title">
          <span class="title-inner">Hablemos</span>
        </h2>

        <p class="footer-desc">
          Estoy aquí para acompañarte. Escríbeme y daremos juntos el primer paso hacia tu bienestar.
        </p>

        <a href="mailto:luciamillanpsico@gmail.com" class="btn-footer-cta magnetic-btn">
          <span class="cta-text">Escríbeme</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Right: Contact grid -->
      <div class="footer-contact-area reveal-right" data-delay="200">
        <div class="contact-grid">
          {contactItems.map((item) => (
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={item.icon} />
                </svg>
              </div>
              <span class="contact-label">{item.label}</span>
              {item.href ? (
                <a href={item.href} class="contact-value" target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                  {item.value}
                </a>
              ) : (
                <span class="contact-value">{item.value}</span>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="footer-divider reveal-scale-x" data-delay="400" aria-hidden="true"></div>

    <!-- Bottom row: social + extra links -->
    <div class="footer-bottom-row reveal-up" data-delay="500">
      <div class="social-row">
        {socialLinks.map(link => (
          <a href={link.href} class="social-link" aria-label={link.label} target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d={link.icon} fill="currentColor"/>
            </svg>
          </a>
        ))}
      </div>

      <div class="extra-links-row">
        {extraLinks.map(link => (
          <a href={link.href} class="extra-link" target="_blank" rel="noopener noreferrer">{link.label}</a>
        ))}
      </div>
    </div>

    <!-- Copyright bar -->
    <div class="footer-copyright reveal-up" data-delay="600">
      <span class="copy-text">&copy; {currentYear} Lucía Millán Jiménez · Psicóloga Clínica</span>
      <div class="legal-row">
        <a href="/aviso-legal" class="legal-link">Aviso legal</a>
        <span class="legal-sep">·</span>
        <a href="/privacidad" class="legal-link">Privacidad</a>
        <span class="legal-sep">·</span>
        <a href="/cookies" class="legal-link">Cookies</a>
      </div>
    </div>

  </div>

  <!-- Back to top -->
  <button class="back-top" id="backTop" aria-label="Volver arriba">
    <svg class="back-top-progress" viewBox="0 0 44 44" aria-hidden="true">
      <circle class="progress-track" cx="22" cy="22" r="20" fill="none" stroke="rgba(196,170,148,0.1)" stroke-width="1.5"/>
      <circle class="progress-ring" cx="22" cy="22" r="20" fill="none" stroke="rgba(196,170,148,0.45)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="125.6" stroke-dashoffset="125.6"/>
    </svg>
    <span class="back-top-icon">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M7 12V2M7 2L3 6M7 2L11 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </button>
</footer>

<script>
  (function() {
    const footer = document.getElementById('siteFooter');
    const spacer = document.getElementById('footerSpacer');
    if (!footer || !spacer) return;

    // Calculate and set spacer height to match footer
    function updateSpacer() {
      requestAnimationFrame(() => {
        const height = footer.getBoundingClientRect().height;
        spacer.style.height = height + 'px';
      });
    }
    
    // Run multiple times to ensure correct measurement after layout
    updateSpacer();
    window.addEventListener('resize', updateSpacer, { passive: true });
    window.addEventListener('load', updateSpacer, { passive: true });
    document.fonts.ready.then(updateSpacer);
    setTimeout(updateSpacer, 100);

    // Back to top
    const btn = document.getElementById('backTop');
    if (btn) {
      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // Scroll progress ring
    const progressRing = footer.querySelector('.progress-ring');
    if (progressRing) {
      const circumference = 2 * Math.PI * 20;
      progressRing.style.strokeDasharray = circumference;
      progressRing.style.strokeDashoffset = circumference;

      function setProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? scrollTop / docHeight : 0;
        const offset = circumference - (progress * circumference);
        progressRing.style.strokeDashoffset = offset;
      }
      window.addEventListener('scroll', setProgress, { passive: true });
      setProgress();
    }
  })();
</script>

<style>
  /* ═══════════════════════════════════════════════════════════
     FOOTER REVEAL — Fixed footer with dynamic spacer
     The footer sits fixed beneath the main content,
     revealed as the page scrolls past the spacer.
     ═══════════════════════════════════════════════════════════ */

  .footer-spacer {
    display: block;
    position: relative;
    z-index: 0;
    background: transparent;
  }

  .site-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    background: var(--color-bg);
    color: var(--color-ink);
    overflow: hidden;
  }

  /* ── Background Layers ────────────────────────────────────── */
  .footer-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .footer-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(42, 31, 26, 0.4) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(196, 170, 148, 0.03) 0%, transparent 40%),
      linear-gradient(180deg, rgba(26, 21, 18, 0.6) 0%, rgba(26, 21, 18, 0.3) 50%, rgba(26, 21, 18, 0.65) 100%);
    z-index: 1;
  }
  .footer-vignette {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 180px 60px rgba(13, 10, 8, 0.55);
    z-index: 1;
    pointer-events: none;
  }
  .footer-grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(rgba(196, 170, 148, 0.012) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196, 170, 148, 0.009) 1px, transparent 1px);
    background-size: 8rem 8rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 70%);
    opacity: 0.4;
  }

  /* ── Inner Container ──────────────────────────────────────── */
  .footer-inner {
    position: relative;
    z-index: 3;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 3.5rem) var(--section-padding-x);
  }

  /* ═══════════════════════════════════════════════════════════
     MAIN GRID — 2 columns: CTA left | Contact right
     ═══════════════════════════════════════════════════════════ */
  .footer-main-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
    margin-bottom: clamp(2rem, 3vw, 2.5rem);
  }

  /* ── CTA Area ─────────────────────────────────────────────── */
  .footer-cta-area {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .footer-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: var(--type-eyebrow);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .footer-eyebrow::before {
    content: '';
    width: 1.8rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.35);
  }

  .footer-title {
    margin: 0;
    line-height: 1;
  }
  .title-inner {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--type-section-title-sm);
    line-height: var(--leading-tight);
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }

  .footer-desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: var(--type-section-subtitle);
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 36ch;
    margin: 0.25rem 0 0.5rem;
  }

  /* Primary CTA — Compact sage pill */
  .btn-footer-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    min-height: 2.8rem;
    padding: 0.75rem 1.8rem;
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.92), rgba(86, 100, 90, 0.92));
    color: #fbf8f1;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--type-meta);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(111, 125, 103, 0.3);
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 0.6rem 1.2rem rgba(86, 100, 90, 0.15);
    overflow: hidden;
    transition:
      transform 0.5s var(--ease-out-expo),
      box-shadow 0.45s ease,
      border-color 0.4s ease;
  }
  .btn-footer-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.05);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.6s var(--ease-out-expo);
  }
  .btn-footer-cta:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }
  .btn-footer-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.9rem 1.8rem rgba(86, 100, 90, 0.22);
    border-color: rgba(111, 125, 103, 0.45);
  }
  .btn-footer-cta:active {
    transform: translateY(0);
    transition-duration: 0.2s;
  }
  .btn-footer-cta .cta-text {
    position: relative;
    z-index: 1;
  }
  .btn-footer-cta svg {
    position: relative;
    z-index: 1;
    transition: transform 0.5s var(--ease-out-expo);
    opacity: 0.7;
  }
  .btn-footer-cta:hover svg {
    transform: translateX(4px);
    opacity: 1;
  }

  /* ── Contact Area ─────────────────────────────────────────── */
  .footer-contact-area {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 2.5rem;
    width: 100%;
    max-width: 420px;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .contact-item:hover {
    transform: translateY(-2px);
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(196, 170, 148, 0.12);
    background: rgba(245, 240, 232, 0.03);
    color: rgba(196, 170, 148, 0.5);
    margin-bottom: 0.4rem;
    transition: all 0.5s var(--ease-out-expo);
  }
  .contact-item:hover .contact-icon {
    border-color: rgba(196, 170, 148, 0.25);
    color: rgba(196, 170, 148, 0.85);
    background: rgba(245, 240, 232, 0.05);
    transform: translateY(-2px);
  }

  .contact-label {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.45);
  }

  .contact-value {
    font-family: var(--font-body);
    font-size: var(--type-card-body);
    font-weight: 300;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.35s ease;
    line-height: 1.5;
    white-space: nowrap;
  }
  .contact-value:hover {
    color: var(--color-ink);
  }

  /* ═══════════════════════════════════════════════════════════
     DIVIDER
     ═══════════════════════════════════════════════════════════ */
  .footer-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(196, 170, 148, 0.12) 20%,
      rgba(196, 170, 148, 0.12) 80%,
      transparent 100%
    );
    margin-bottom: clamp(1.2rem, 2vw, 1.5rem);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 1.6s var(--ease-out-expo);
    opacity: 0.5;
  }
  .footer-divider.visible {
    transform: scaleX(1);
  }

  /* ═══════════════════════════════════════════════════════════
     BOTTOM ROW — Social + Extra links
     ═══════════════════════════════════════════════════════════ */
  .footer-bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: clamp(1.2rem, 2vw, 1.5rem);
  }

  .social-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(196, 170, 148, 0.1);
    background: rgba(245, 240, 232, 0.02);
    color: rgba(245, 240, 232, 0.35);
    transition: all 0.5s var(--ease-out-expo);
    position: relative;
    overflow: hidden;
  }
  .social-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(196, 170, 148, 0.1) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .social-link:hover {
    background: rgba(245, 240, 232, 0.06);
    border-color: rgba(196, 170, 148, 0.2);
    color: rgba(245, 240, 232, 0.9);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
  }
  .social-link:hover::before {
    opacity: 1;
  }
  .social-link svg {
    width: 14px; height: 14px;
    position: relative;
    z-index: 1;
  }

  .extra-links-row {
    display: flex;
    align-items: center;
    gap: 0.5rem 1.5rem;
    flex-wrap: wrap;
  }
