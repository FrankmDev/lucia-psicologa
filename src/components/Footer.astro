---
import AmbientLight from './ui/AmbientLight.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import BotanicalSVG from './ui/BotanicalSVG.astro';
import DustParticles from './ui/DustParticles.astro';

const currentYear = new Date().getFullYear();
const isHomePath = Astro.url.pathname === '/';
const resolveHref = (href: string) => (isHomePath ? href : `/${href}`);

const socialLinks = [
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/luciamillanpsico/',
    icon: 'M8 3C5.24 3 3 5.24 3 8v8c0 2.76 2.24 5 5 5h8c2.76 0 5-2.24 5-5V8c0-2.76-2.24-5-5-5H8zm0 1.5h8c1.93 0 3.5 1.57 3.5 3.5v8c0 1.93-1.57 3.5-3.5 3.5H8c-1.93 0-3.5-1.57-3.5-3.5V8c0-1.93 1.57-3.5 3.5-3.5zm9.5 2a1 1 0 100 2 1 1 0 000-2zm-5 1.5a4.5 4.5 0 100 9 4.5 4.5 0 000-9zm0 1.5a3 3 0 110 6 3 3 0 010-6z',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/luc%C3%ADa-mill%C3%A1n-jim%C3%A9nez-304258389/',
    icon: 'M4.5 3C3.67 3 3 3.67 3 4.5S3.67 6 4.5 6 6 5.33 6 4.5 5.33 3 4.5 3zM3 7.5h3V18H3V7.5zm5.5 0h2.9v1.4h.04c.4-.76 1.4-1.4 2.9-1.4 3.1 0 3.66 2.04 3.66 4.7V18h-3v-5.3c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V18h-3V7.5z',
  },
  {
    label: 'WhatsApp',
    href: 'https://wa.me/34722535914',
    icon: 'M12 2C6.48 2 2 6.48 2 12c0 1.82.49 3.53 1.35 5L2 22l5.09-1.33A9.96 9.96 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-1.64 0-3.17-.48-4.46-1.3l-.32-.2-3.02.79.8-2.94-.2-.33A8.01 8.01 0 014 12c0-4.41 3.59-8 8-8s8 3.59 8 8-3.59 8-8 8zm4.24-5.52c-.23-.12-1.37-.68-1.58-.75-.21-.08-.36-.12-.51.12-.15.23-.59.75-.72.9-.13.15-.27.17-.5.06-.23-.12-.97-.36-1.85-1.14-.68-.6-1.14-1.35-1.27-1.58-.13-.23-.01-.36.1-.48.1-.1.23-.27.34-.4.11-.13.15-.23.23-.38.08-.15.04-.28-.02-.4-.06-.12-.51-1.23-.7-1.68-.18-.44-.37-.38-.51-.39l-.43-.01c-.15 0-.4.06-.61.28-.21.23-.8.78-.8 1.9s.82 2.2.93 2.35c.12.15 1.62 2.47 3.92 3.46.55.24.97.38 1.31.49.55.17 1.05.15 1.44.09.44-.06 1.37-.56 1.56-1.1.2-.54.2-1 .14-1.1-.06-.1-.23-.16-.46-.27z',
  },
];

const extraLinks = [
  { label: 'Doctoralia', href: 'https://www.doctoralia.es/lucia-millan-jimenez/psicologo/ciudad-real' },
  { label: 'Google', href: 'https://www.google.com/maps/search/?api=1&query=Luc%C3%ADa+Mill%C3%A1n+Jim%C3%A9nez+Psic%C3%B3loga+Ciudad+Real' },
];

const contactItems = [
  { label: 'Email', value: 'luciamillanpsico@gmail.com', href: 'mailto:luciamillanpsico@gmail.com' },
  { label: 'Teléfono', value: '722 53 59 14', href: 'tel:+34722535914' },
  { label: 'Dirección', value: 'c/ Toledo, 8, 2° Planta', href: 'https://www.google.com/maps/search/?api=1&query=Calle+Toledo+8+Ciudad+Real' },
  { label: 'Horario', value: 'Lun — Vie, 9:00 — 20:00' },
];

const navLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Blog', href: '#blog' },
  { label: 'Contacto', href: '#contacto' },
];
---

<!-- Spacer for fixed footer reveal effect -->
<div class="footer-spacer" id="footerSpacer" aria-hidden="true"></div>

<footer class="site-footer dark-surface" id="siteFooter" data-footer data-surface="dark">
  <!-- Background layers -->
  <div class="footer-bg">
    <div class="footer-overlay"></div>
    <div class="footer-vignette" aria-hidden="true"></div>
    <div class="footer-grid" aria-hidden="true"></div>
  </div>

  <!-- Faded atmospheric word -->
  <div class="footer-word" aria-hidden="true">Escucha</div>

  <GrainOverlay animated opacity={0.015} zIndex={2} />
  <AmbientLight color="rgba(184,168,148,0.04)" />
  <DustParticles count={10} color="rgba(196,170,148,0.06)" />

  <FloatOrb size={260} top="10%" right="8%" color="rgba(196,170,148,0.06)" blur={90} animation="float-1" />
  <FloatOrb size={200} bottom="20%" left="6%" color="rgba(111,125,103,0.05)" blur={80} animation="float-2" />

  <InkBlob width={320} height={240} top="-8%" right="-4%" color="var(--earth)" opacity={0.025} />
  <InkBlob width={240} height={180} bottom="-6%" left="-6%" color="var(--sage)" opacity={0.02} animation="morph-2" />

  <BotanicalSVG variant="left" color="rgba(196,170,148,0.04)" opacity={0.5} width={48} />
  <BotanicalSVG variant="right" color="rgba(111,125,103,0.05)" opacity={0.5} width={42} style="right: 5%; bottom: 18%;" />

  <div class="footer-inner">

    <!-- Top: identity + tagline -->
    <div class="footer-identity reveal-up" data-delay="100">
      <a href={isHomePath ? '#inicio' : '/'} class="footer-mark" aria-label="Inicio">
        <span class="footer-mark__name">Lucía Millán Jiménez</span>
        <span class="footer-mark__role">Psicología clínica · Ciudad Real</span>
      </a>
      <p class="footer-tagline">Acompañamiento psicológico para entender lo que te ocurre y trabajarlo con un enfoque adaptado a tu caso.</p>
    </div>

    <div class="footer-divider reveal-scale-x" data-delay="250" aria-hidden="true">
      <span class="divider-line"></span>
      <span class="divider-dot"></span>
      <span class="divider-line"></span>
    </div>

    <!-- Main columns -->
    <div class="footer-columns reveal-up" data-delay="300">
      <nav class="footer-col footer-col--nav" aria-label="Navegación">
        <span class="footer-col__title">Navegación</span>
        <div class="footer-col__links">
          {navLinks.map((l) => (
            <a href={resolveHref(l.href)} class="footer-link">
              <span>{l.label}</span>
              <span class="link-arrow" aria-hidden="true">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M1 5h8M5 1l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </nav>

      <div class="footer-col" aria-label="Contacto">
        <span class="footer-col__title">Contacto</span>
        <div class="footer-col__links">
          {contactItems.map((item) => (
            item.href ? (
              <a href={item.href} class="footer-link" {...(item.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                <span>{item.value}</span>
                <span class="link-arrow" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                    <path d="M1 5h8M5 1l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
            ) : (
              <span class="footer-link is-static">{item.value}</span>
            )
          ))}
        </div>
      </div>

      <div class="footer-col" aria-label="Redes y directorios">
        <span class="footer-col__title">Sígueme</span>
        <div class="footer-social">
          {socialLinks.map(link => (
            <a href={link.href} class="social-link" aria-label={link.label} target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d={link.icon} fill="currentColor"/>
              </svg>
            </a>
          ))}
        </div>
        <div class="footer-directories">
          {extraLinks.map(link => (
            <a href={link.href} class="directory-link" target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer-divider reveal-scale-x" data-delay="450" aria-hidden="true">
      <span class="divider-line"></span>
      <span class="divider-dot"></span>
      <span class="divider-line"></span>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom reveal-up" data-delay="500">
      <span class="copy-text">&copy; {currentYear} Lucía Millán Jiménez · Psicóloga Clínica</span>
      <div class="legal-row">
        <a href="/aviso-legal" class="legal-link">Aviso legal</a>
        <span class="legal-sep">·</span>
        <a href="/privacidad" class="legal-link">Privacidad</a>
        <span class="legal-sep">·</span>
        <a href="/cookies" class="legal-link">Cookies</a>
      </div>
    </div>

  </div>

  <!-- Back to top -->
  <button class="back-top" id="backTop" aria-label="Volver arriba">
    <svg class="back-top-progress" viewBox="0 0 44 44" aria-hidden="true">
      <circle class="progress-track" cx="22" cy="22" r="20" fill="none" stroke="rgba(196,170,148,0.1)" stroke-width="1.5"/>
      <circle class="progress-ring" cx="22" cy="22" r="20" fill="none" stroke="rgba(196,170,148,0.45)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="125.6" stroke-dashoffset="125.6"/>
    </svg>
    <span class="back-top-icon">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M7 12V2M7 2L3 6M7 2L11 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </button>
</footer>

<script>
  (function() {
    const footer = document.getElementById('siteFooter');
    const spacer = document.getElementById('footerSpacer');
    if (!footer || !spacer) return;

    function updateSpacer() {
      requestAnimationFrame(() => {
        const height = footer.getBoundingClientRect().height;
        spacer.style.height = height + 'px';
      });
    }

    updateSpacer();
    window.addEventListener('resize', updateSpacer, { passive: true });
    window.addEventListener('load', updateSpacer, { passive: true });
    document.fonts.ready.then(updateSpacer);
    setTimeout(updateSpacer, 100);

    const btn = document.getElementById('backTop');
    if (btn) {
      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    const progressRing = footer.querySelector('.progress-ring');
    if (progressRing) {
      const circumference = 2 * Math.PI * 20;
      progressRing.style.strokeDasharray = circumference;
      progressRing.style.strokeDashoffset = circumference;

      function setProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? scrollTop / docHeight : 0;
        const offset = circumference - (progress * circumference);
        progressRing.style.strokeDashoffset = offset;
      }
      window.addEventListener('scroll', setProgress, { passive: true });
      setProgress();
    }
  })();
</script>

<style>
  .footer-spacer {
    display: block;
    position: relative;
    z-index: 0;
    background: transparent;
  }

  .site-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    background: var(--color-bg);
    color: var(--color-ink);
    overflow: hidden;
  }

  .footer-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .footer-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(42, 31, 26, 0.4) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(196, 170, 148, 0.03) 0%, transparent 40%),
      linear-gradient(180deg, rgba(26, 21, 18, 0.6) 0%, rgba(26, 21, 18, 0.3) 50%, rgba(26, 21, 18, 0.65) 100%);
    z-index: 1;
  }
  .footer-vignette {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 180px 60px rgba(13, 10, 8, 0.55);
    z-index: 1;
    pointer-events: none;
  }
  .footer-grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(rgba(196, 170, 148, 0.012) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196, 170, 148, 0.009) 1px, transparent 1px);
    background-size: 8rem 8rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 70%);
    opacity: 0.4;
  }

  .footer-word {
    position: absolute;
    top: 52%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(5.5rem, 18vw, 14rem);
    font-weight: 300;
    letter-spacing: 0.08em;
    color: rgba(245, 240, 232, 0.009);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.35) 20%, rgba(0,0,0,0.35) 80%, transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.35) 20%, rgba(0,0,0,0.35) 80%, transparent 100%);
  }

  .footer-inner {
    position: relative;
    z-index: 3;
    max-width: 1480px;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 3.5rem) var(--content-padding-x);
  }

  /* ── Identity ─────────────────────────────────────────── */
  .footer-identity {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.2rem 3rem;
    margin-bottom: clamp(1.6rem, 3vw, 2.2rem);
  }

  .footer-mark {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.35s ease;
  }
  .footer-mark:hover { opacity: 0.72; }

  .footer-mark__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--type-panel-title);
    line-height: 1.05;
    color: var(--color-ink);
  }
  .footer-mark__role {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.45);
  }

  .footer-tagline {
    max-width: 22rem;
    margin: 0;
    font-size: var(--type-body-sm);
    line-height: 1.65;
    color: rgba(245, 240, 232, 0.38);
    text-wrap: pretty;
    text-align: right;
  }

  /* ── Divider ──────────────────────────────────────────── */
  .footer-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 140px;
    margin: 0 auto;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 1.6s var(--ease-out-expo);
    opacity: 0.55;
  }
  .footer-divider.visible {
    transform: scaleX(1);
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: rgba(184, 168, 138, 0.2);
  }
  .divider-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(184, 168, 138, 0.4);
    flex-shrink: 0;
    box-shadow: 0 0 0 2px rgba(184, 168, 138, 0.08);
  }

  /* ── Columns ──────────────────────────────────────────── */
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding: clamp(1.6rem, 3vw, 2.2rem) 0;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .footer-col__title {
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(184, 168, 138, 0.65);
  }

  .footer-col__links {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    min-height: 44px;
    padding: 0.35rem 0.5rem 0.35rem 0;
    font-size: var(--type-body);
    color: rgba(245, 240, 232, 0.58);
    text-decoration: none;
    border-radius: 8px;
    transition: color 0.35s ease, background 0.35s ease, transform 0.35s var(--ease-out-expo);
    line-height: 1.6;
  }
  .footer-link:hover {
    color: rgba(245, 240, 232, 0.98);
    background: rgba(245, 240, 232, 0.04);
    transform: translateX(3px);
  }
  .footer-link.is-static {
    cursor: default;
    pointer-events: none;
  }
  .footer-link.is-static:hover {
    color: rgba(245, 240, 232, 0.58);
    background: transparent;
    transform: none;
  }

  .link-arrow {
    opacity: 0;
    transform: translateX(-4px);
    color: rgba(184, 168, 138, 0.55);
    transition: opacity 0.35s var(--ease-out-expo), transform 0.35s var(--ease-out-expo), color 0.3s ease;
  }
  .footer-link:hover .link-arrow {
    opacity: 1;
    transform: translateX(0);
    color: rgba(184, 168, 148, 0.85);
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(196, 170, 148, 0.14);
    background: rgba(245, 240, 232, 0.04);
    color: rgba(245, 240, 232, 0.6);
    transition: all 0.5s var(--ease-out-expo);
    position: relative;
    overflow: hidden;
  }
  .social-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(196, 170, 148, 0.1) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .social-link::after {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 50%;
    border: 1px solid rgba(196, 170, 148, 0.04);
    opacity: 0;
    transition: opacity 0.5s ease, transform 0.5s var(--ease-out-expo);
    transform: scale(0.85);
  }
  .social-link:hover {
    background: rgba(245, 240, 232, 0.1);
    border-color: rgba(196, 170, 148, 0.35);
    color: rgba(245, 240, 232, 0.98);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
  }
  .social-link:hover::before {
    opacity: 1;
  }
  .social-link:hover::after {
    opacity: 1;
    transform: scale(1);
  }
  .social-link svg {
    width: 17px; height: 17px;
    position: relative;
    z-index: 1;
  }

  .footer-directories {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-top: 0.2rem;
  }
  .directory-link {
    font-size: var(--type-caption);
    color: rgba(245, 240, 232, 0.42);
    text-decoration: none;
    transition: color 0.35s ease;
    position: relative;
    padding: 2px 0;
  }
  .directory-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(196, 170, 148, 0.2);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .directory-link:hover {
    color: rgba(245, 240, 232, 0.92);
  }
  .directory-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ── Bottom bar ───────────────────────────────────────── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    padding-top: clamp(1.2rem, 2vw, 1.5rem);
    font-size: var(--type-caption);
    font-weight: 400;
    color: rgba(245, 240, 232, 0.4);
  }
  .copy-text {
    letter-spacing: 0.04em;
  }
  .legal-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .legal-link {
    color: inherit;
    text-decoration: none;
    position: relative;
    transition: color 0.35s ease;
    padding: 2px 0;
    letter-spacing: 0.08em;
  }
  .legal-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(196, 170, 148, 0.2);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .legal-link:hover {
    color: rgba(245, 240, 232, 0.95);
  }
  .legal-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .legal-sep {
    color: rgba(196, 170, 148, 0.2);
    user-select: none;
  }

  /* ── Back to top ──────────────────────────────────────── */
  .back-top {
    position: fixed;
    bottom: max(1.5rem, env(safe-area-inset-bottom));
    right: max(1.5rem, env(safe-area-inset-right));
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: rgba(245, 240, 232, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 900;
    transition: all 0.45s var(--ease-out-expo);
    padding: 0;
  }
  .back-top:hover {
    color: rgba(245, 240, 232, 0.95);
    transform: translateY(-4px);
  }
  .back-top-progress {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
