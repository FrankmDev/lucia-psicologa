---
import AmbientLight from './ui/AmbientLight.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import BotanicalSVG from './ui/BotanicalSVG.astro';
import DustParticles from './ui/DustParticles.astro';

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    label: 'Instagram',
    href: '#',
    icon: 'M8 3C5.24 3 3 5.24 3 8v8c0 2.76 2.24 5 5 5h8c2.76 0 5-2.24 5-5V8c0-2.76-2.24-5-5-5H8zm0 1.5h8c1.93 0 3.5 1.57 3.5 3.5v8c0 1.93-1.57 3.5-3.5 3.5H8c-1.93 0-3.5-1.57-3.5-3.5V8c0-1.93 1.57-3.5 3.5-3.5zm9.5 2a1 1 0 100 2 1 1 0 000-2zm-5 1.5a4.5 4.5 0 100 9 4.5 4.5 0 000-9zm0 1.5a3 3 0 110 6 3 3 0 010-6z',
  },
  {
    label: 'LinkedIn',
    href: '#',
    icon: 'M4.5 3C3.67 3 3 3.67 3 4.5S3.67 6 4.5 6 6 5.33 6 4.5 5.33 3 4.5 3zM3 7.5h3V18H3V7.5zm5.5 0h2.9v1.4h.04c.4-.76 1.4-1.4 2.9-1.4 3.1 0 3.66 2.04 3.66 4.7V18h-3v-5.3c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V18h-3V7.5z',
  },
  {
    label: 'WhatsApp',
    href: '#',
    icon: 'M12 2C6.48 2 2 6.48 2 12c0 1.82.49 3.53 1.35 5L2 22l5.09-1.33A9.96 9.96 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-1.64 0-3.17-.48-4.46-1.3l-.32-.2-3.02.79.8-2.94-.2-.33A8.01 8.01 0 014 12c0-4.41 3.59-8 8-8s8 3.59 8 8-3.59 8-8 8zm4.24-5.52c-.23-.12-1.37-.68-1.58-.75-.21-.08-.36-.12-.51.12-.15.23-.59.75-.72.9-.13.15-.27.17-.5.06-.23-.12-.97-.36-1.85-1.14-.68-.6-1.14-1.35-1.27-1.58-.13-.23-.01-.36.1-.48.1-.1.23-.27.34-.4.11-.13.15-.23.23-.38.08-.15.04-.28-.02-.4-.06-.12-.51-1.23-.7-1.68-.18-.44-.37-.38-.51-.39l-.43-.01c-.15 0-.4.06-.61.28-.21.23-.8.78-.8 1.9s.82 2.2.93 2.35c.12.15 1.62 2.47 3.92 3.46.55.24.97.38 1.31.49.55.17 1.05.15 1.44.09.44-.06 1.37-.56 1.56-1.1.2-.54.2-1 .14-1.1-.06-.1-.23-.16-.46-.27z',
  },
];
---

<footer class="site-footer" id="siteFooter" data-footer>
  <!-- Top edge wave -->
  <div class="footer-wave" aria-hidden="true">
    <svg class="footer-wave-svg" viewBox="0 0 1440 48" preserveAspectRatio="none" aria-hidden="true">
      <path class="footer-wave-path footer-wave-path--1" d="M0,24 C360,38 720,10 1080,24 C1260,30 1350,16 1440,24"/>
      <path class="footer-wave-path footer-wave-path--2" d="M0,28 C240,18 480,40 720,28 C960,20 1200,34 1440,28"/>
      <path class="footer-wave-path footer-wave-path--3" d="M0,20 C180,32 540,14 900,20 C1170,28 1350,16 1440,20"/>
      <path class="footer-wave-path footer-wave-path--4" d="M0,26 C300,16 600,34 900,26 C1200,18 1350,30 1440,26" opacity="0.4"/>
    </svg>
  </div>

  <!-- Background layers -->
  <div class="footer-bg">
    <div class="footer-overlay"></div>
    <div class="footer-vignette" aria-hidden="true"></div>
    <div class="footer-grid" aria-hidden="true"></div>
  </div>

  <GrainOverlay animated opacity={0.018} zIndex={2} />
  <AmbientLight color="rgba(184,168,148,0.04)" />
  <DustParticles count={12} color="rgba(196,170,148,0.08)" />

  <FloatOrb size={320} top="12%" right="12%" color="rgba(196,170,148,0.07)" blur={100} animation="float-1" />
  <FloatOrb size={260} bottom="30%" left="8%" color="rgba(111,125,103,0.06)" blur={90} animation="float-2" />
  <FloatOrb size={180} top="55%" right="6%" color="rgba(168,146,124,0.05)" blur={70} animation="float-3" />

  <InkBlob width={380} height={280} top="-6%" right="-6%" color="var(--earth)" opacity={0.03} />
  <InkBlob width={280} height={220} bottom="-4%" left="-4%" color="var(--sage)" opacity={0.025} animation="morph-2" />

  <BotanicalSVG variant="left" color="rgba(196,170,148,0.05)" opacity={0.6} width={55} />
  <BotanicalSVG variant="right" color="rgba(111,125,103,0.06)" opacity={0.6} width={48} style="right: 4%; bottom: 22%;" />

  <div class="footer-inner">

    <!-- Hero area -->
    <div class="footer-hero reveal-blur" data-delay="100">
      <span class="footer-eyebrow">Contacto</span>

      <h2 class="footer-title">
        <span class="title-inner">Hablemos</span>
      </h2>

      <p class="footer-desc">
        Estoy aquí para acompañarte. Escríbeme y daremos juntos el primer paso hacia tu bienestar.
      </p>

      <a href="mailto:hola@luciapsicologia.es" class="btn-footer-cta">
        <span class="cta-text">Escríbeme</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Contact row -->
    <div class="contact-row reveal-up" data-delay="300">
      <a href="mailto:hola@luciapsicologia.es" class="contact-item">
        <span class="contact-label">Email</span>
        <span class="contact-value">hola@luciapsicologia.es</span>
      </a>
      <span class="contact-sep" aria-hidden="true"></span>
      <a href="tel:+34600123456" class="contact-item">
        <span class="contact-label">Teléfono</span>
        <span class="contact-value">+34 600 123 456</span>
      </a>
      <span class="contact-sep" aria-hidden="true"></span>
      <div class="contact-item">
        <span class="contact-label">Horario</span>
        <span class="contact-value">Lun — Vie, 9:00 — 20:00</span>
      </div>
    </div>

    <!-- Social links -->
    <div class="social-row stagger-children" data-delay="500">
      {socialLinks.map(link => (
        <a href={link.href} class="social-link reveal-up" aria-label={link.label} target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d={link.icon} fill="currentColor"/>
          </svg>
        </a>
      ))}
    </div>

    <!-- Divider -->
    <div class="footer-divider reveal-up" data-delay="600" aria-hidden="true"></div>

    <!-- Bottom bar -->
    <div class="footer-bottom reveal-up" data-delay="700">
      <span class="bottom-copy">&copy; {currentYear} Lucía Martínez · Psicóloga Clínica</span>
      <div class="bottom-legal">
        <a href="#" class="legal-link">Aviso legal</a>
        <a href="#" class="legal-link">Privacidad</a>
        <a href="#" class="legal-link">Cookies</a>
      </div>
    </div>

  </div>

  <!-- Back to top -->
  <button class="back-top" id="backTop" aria-label="Volver arriba">
    <svg class="back-top-progress" viewBox="0 0 44 44" aria-hidden="true">
      <circle class="progress-track" cx="22" cy="22" r="20" fill="none" stroke="rgba(196,170,148,0.1)" stroke-width="1.5"/>
      <circle class="progress-ring" cx="22" cy="22" r="20" fill="none" stroke="rgba(196,170,148,0.45)" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="125.6" stroke-dashoffset="125.6"/>
    </svg>
    <span class="back-top-icon">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M7 12V2M7 2L3 6M7 2L11 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </button>
</footer>

<script>
  (function() {
    const footer = document.getElementById('siteFooter');
    if (!footer) return;

    // Reveal footer margin fix
    const mainEl = document.querySelector('main') || document.body;
    function setRevealMargin() {
      mainEl.style.marginBottom = footer.offsetHeight + 'px';
    }
    window.addEventListener('load', setRevealMargin);
    window.addEventListener('resize', setRevealMargin);

    // Ensure previous section has background for reveal effect
    const prev = footer.previousElementSibling;
    if (prev) {
      prev.style.position = 'relative';
      prev.style.zIndex = '1';
      const bg = getComputedStyle(prev).backgroundColor;
      if (!bg || bg === 'rgba(0, 0, 0, 0)' || bg === 'transparent') {
        prev.style.background = 'var(--paper, #f6f3ee)';
      }
    }

    // Back to top
    const btn = document.getElementById('backTop');
    if (btn) {
      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // Scroll progress ring
    const progressRing = footer.querySelector('.progress-ring');
    if (progressRing) {
      const circumference = 2 * Math.PI * 20;
      progressRing.style.strokeDasharray = circumference;
      progressRing.style.strokeDashoffset = circumference;

      function setProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? scrollTop / docHeight : 0;
        const offset = circumference - (progress * circumference);
        progressRing.style.strokeDashoffset = offset;
      }
      window.addEventListener('scroll', setProgress, { passive: true });
      setProgress();
    }
  })();
</script>

<style>
  /* ═══════════════════════════════════════════════════════════
     FOOTER — Warm Depth Editorial
     Deep warm earth tones that feel connected to the site's palette.
     ═══════════════════════════════════════════════════════════ */

  .site-footer {
    --foot-cream: #f5f0e8;
    --foot-gold: #c4aa94;
    --foot-gold-soft: rgba(196, 170, 148, 0.12);
    --foot-sage: #6f7d67;
    --foot-sage-soft: rgba(111, 125, 103, 0.15);
    --foot-ink: #f5f0e8;
    --foot-ink-muted: rgba(245, 240, 232, 0.55);
    --foot-ink-faint: rgba(245, 240, 232, 0.3);
    --foot-line: rgba(196, 170, 148, 0.1);

    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    background: #1a1512;
    color: var(--foot-cream);
    padding: 2.5rem 0 3rem;
    overflow: hidden;
    box-shadow: 0 -40px 100px rgba(0, 0, 0, 0.25);
  }

  /* ── Top Edge Wave ───────────────────────────────────────── */
  .footer-wave {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 36px;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .footer-wave-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 200%;
    height: 100%;
    display: block;
  }
  .footer-wave-path {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .footer-wave-path--1 {
    stroke: rgba(196, 170, 148, 0.1);
    stroke-width: 0.8;
    animation: wave-drift-1 28s ease-in-out infinite alternate;
  }
  .footer-wave-path--2 {
    stroke: rgba(196, 170, 148, 0.05);
    stroke-width: 0.5;
    animation: wave-drift-2 36s ease-in-out infinite alternate-reverse;
  }
  .footer-wave-path--3 {
    stroke: rgba(111, 125, 103, 0.06);
    stroke-width: 0.6;
    animation: wave-drift-3 32s ease-in-out infinite alternate;
  }
  .footer-wave-path--4 {
    stroke: rgba(196, 170, 148, 0.04);
    stroke-width: 0.4;
    animation: wave-drift-2 42s ease-in-out infinite alternate;
  }
  @keyframes wave-drift-1 {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50px); }
  }
  @keyframes wave-drift-2 {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-30px); }
  }
  @keyframes wave-drift-3 {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-40px); }
  }

  /* ── Background Layers ────────────────────────────────────── */
  .footer-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .footer-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 15%, rgba(42, 31, 26, 0.35) 0%, transparent 55%),
      radial-gradient(ellipse at 25% 75%, rgba(196, 170, 148, 0.04) 0%, transparent 45%),
      radial-gradient(ellipse at 75% 60%, rgba(111, 125, 103, 0.04) 0%, transparent 40%),
      linear-gradient(180deg, rgba(26, 21, 18, 0.5) 0%, rgba(26, 21, 18, 0.1) 45%, rgba(26, 21, 18, 0.55) 100%);
    z-index: 1;
  }
  .footer-vignette {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 200px 70px rgba(13, 10, 8, 0.5);
    z-index: 1;
    pointer-events: none;
  }
  .footer-grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(rgba(196, 170, 148, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196, 170, 148, 0.012) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 72%);
    opacity: 0.5;
  }

  /* ── Inner Container ──────────────────────────────────────── */
  .footer-inner {
    position: relative;
    z-index: 3;
    max-width: 980px;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6rem) 6vw 0;
  }

  /* ═══════════════════════════════════════════════════════════
     HERO AREA
     ═══════════════════════════════════════════════════════════ */
  .footer-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }

  /* Eyebrow with hairlines */
  .footer-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--foot-sage);
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  .footer-eyebrow::before,
  .footer-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.3);
  }

  /* Title */
  .footer-title {
    margin: 0;
    line-height: 1;
  }
  .title-inner {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--type-section-title);
    line-height: var(--leading-title);
    color: var(--foot-cream);
    letter-spacing: -0.02em;
    position: relative;
  }
  .title-inner::after {
    content: '';
    position: absolute;
    bottom: 0.04em;
    left: 10%;
    width: 80%;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(196, 170, 148, 0.18), transparent);
    border-radius: 1px;
  }

  /* Description */
  .footer-desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: var(--type-section-subtitle);
    line-height: 1.75;
    color: var(--foot-ink-muted);
    max-width: 38ch;
    margin: 0;
  }

  /* Primary CTA — Sage gradient pill */
  .btn-footer-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 3.2rem;
    padding: 0.85rem 2.2rem;
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--type-meta);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(111, 125, 103, 0.35);
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 0.9rem 1.8rem rgba(86, 100, 90, 0.18);
    margin-top: 0.5rem;
    overflow: hidden;
    transition:
      transform 0.5s var(--ease-out-expo),
      box-shadow 0.45s ease,
      border-color 0.4s ease;
  }
  .btn-footer-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.06);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.6s var(--ease-out-expo);
  }
  .btn-footer-cta:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }
  .btn-footer-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 1.2rem 2.4rem rgba(86, 100, 90, 0.24);
    border-color: rgba(111, 125, 103, 0.5);
  }
  .btn-footer-cta:active {
    transform: translateY(0);
    transition-duration: 0.2s;
  }
  .btn-footer-cta .cta-text {
    position: relative;
    z-index: 1;
  }
  .btn-footer-cta svg {
    position: relative;
    z-index: 1;
    transition: transform 0.5s var(--ease-out-expo);
    opacity: 0.7;
  }
  .btn-footer-cta:hover svg {
    transform: translateX(4px);
    opacity: 1;
  }

  /* ═══════════════════════════════════════════════════════════
     CONTACT ROW
     ═══════════════════════════════════════════════════════════ */
  .contact-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
    padding: 1.6rem 0;
    border-top: 1px solid var(--foot-line);
    border-bottom: 1px solid var(--foot-line);
  }
  .contact-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0 2.2rem;
    text-decoration: none;
    transition: opacity 0.4s ease, transform 0.5s var(--ease-out-expo);
  }
  .contact-item:hover {
    opacity: 0.92;
    transform: translateY(-2px);
  }
  .contact-item[href]:hover .contact-value {
    color: var(--foot-cream);
  }
  .contact-label {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.32);
  }
  .contact-value {
    font-family: var(--font-body);
    font-size: var(--type-card-body);
    font-weight: 300;
    color: var(--foot-ink-muted);
    transition: color 0.35s ease;
    white-space: nowrap;
  }
  .contact-sep {
    width: 1px;
    height: 28px;
    background: linear-gradient(180deg, transparent, rgba(196, 170, 148, 0.14), transparent);
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════════════════════════
     SOCIAL ROW
     ═══════════════════════════════════════════════════════════ */
  .social-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(196, 170, 148, 0.1);
    background: rgba(245, 240, 232, 0.03);
    color: rgba(245, 240, 232, 0.4);
    transition: all 0.5s var(--ease-out-expo);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    position: relative;
    overflow: hidden;
  }
  .social-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(196, 170, 148, 0.12) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .social-link:hover {
    background: rgba(245, 240, 232, 0.07);
    border-color: rgba(196, 170, 148, 0.25);
    color: rgba(245, 240, 232, 0.95);
    transform: translateY(-4px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
  }
  .social-link:hover::before {
    opacity: 1;
  }
  .social-link svg {
    width: 15px; height: 15px;
    position: relative;
    z-index: 1;
  }

  /* ═══════════════════════════════════════════════════════════
     DIVIDER
     ═══════════════════════════════════════════════════════════ */
  .footer-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(196, 170, 148, 0.12) 25%,
      rgba(196, 170, 148, 0.12) 75%,
      transparent 100%
    );
    margin-bottom: 2rem;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 1.6s var(--ease-out-expo);
    opacity: 0.5;
  }
  .footer-divider.visible {
    transform: scaleX(1);
  }

  /* ═══════════════════════════════════════════════════════════
     BOTTOM BAR
     ═══════════════════════════════════════════════════════════ */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: var(--type-meta);
    font-weight: 400;
    color: var(--foot-ink-faint);
  }
  .bottom-copy {
    letter-spacing: 0.04em;
  }
  .bottom-legal {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }
  .legal-link {
    color: inherit;
    text-decoration: none;
    position: relative;
    transition: color 0.35s ease;
    padding: 2px 0;
    letter-spacing: 0.08em;
  }
  .legal-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(196, 170, 148, 0.25);
    transform: scaleX(0);
    transform-origin: right;
