---
const links = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="site-footer">
  <div class="footer-watermark" aria-hidden="true">L</div>

  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="footer-mark">L</span>
        <div class="footer-brand-text">
          <span class="footer-name">Lucía</span>
          <span class="footer-role">Psicóloga Clínica</span>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Pie">
        {links.map(l => (
          <a href={l.href} class="footer-nav-link">{l.label}</a>
        ))}
      </nav>

      <div class="footer-contact">
        <span class="contact-label">Contacto</span>
        <a href="mailto:hola@lucia.com" class="contact-link">hola@lucia.com</a>
        <a href="tel:+34600123456" class="contact-link">+34 600 123 456</a>
      </div>
    </div>

    <div class="footer-tagline">
      <p class="type-display">Preparando el futuro</p>
      <p class="type-display">de tu bienestar emocional.</p>
    </div>

    <div class="footer-bottom">
      <div class="footer-legal">
        <span>Colegiada nº 12.456</span>
        <span class="sep">·</span>
        <a href="#">Aviso legal</a>
        <span class="sep">·</span>
        <a href="#">Privacidad</a>
      </div>
      <span class="footer-copy">© {new Date().getFullYear()} Lucía. Todos los derechos reservados.</span>
    </div>
  </div>

  <button class="back-top" id="backTop" aria-label="Volver arriba">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 14V2M8 2L3 7M8 2L13 7" stroke="currentColor" stroke-width="1.2"/></svg>
  </button>
</footer>

<script>
  const btn = document.getElementById('backTop');
  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

<style>
  .site-footer {
    position: relative;
    background: var(--ink);
    color: #fff;
    padding: 6rem 0 2.5rem;
    overflow: hidden;
  }

  .footer-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 50vw;
    color: rgba(255,255,255,0.015);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .footer-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 6vw;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 2fr 1fr;
    gap: 4rem;
    padding-bottom: 4rem;
    border-bottom: 0.5px solid rgba(255,255,255,0.07);
    margin-bottom: 4rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .footer-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.3rem;
    transition: border-color 0.4s ease, transform 0.5s var(--ease-out-expo);
  }
  .footer-brand:hover .footer-mark {
    border-color: rgba(255,255,255,0.5);
    transform: rotate(8deg);
  }
  .footer-brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .footer-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    font-weight: 300;
    color: rgba(255,255,255,0.9);
  }
  .footer-role {
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    align-content: flex-start;
  }
  .footer-nav-link {
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    transition: color 0.3s ease;
    position: relative;
  }
  .footer-nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0;
    width: 0; height: 1px;
    background: rgba(255,255,255,0.5);
    transition: width 0.4s var(--ease-out-expo);
  }
  .footer-nav-link:hover {
    color: rgba(255,255,255,0.75);
  }
  .footer-nav-link:hover::after {
    width: 100%;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .contact-label {
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-bottom: 0.5rem;
  }
  .contact-link {
    font-size: 0.8rem;
    font-weight: 300;
    color: rgba(255,255,255,0.45);
    transition: color 0.3s ease;
  }
  .contact-link:hover {
    color: rgba(255,255,255,0.8);
  }

  .footer-tagline {
    margin-bottom: 5rem;
  }
  .footer-tagline .type-display {
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: rgba(255,255,255,0.85);
    line-height: 1.15;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 0.5px solid rgba(255,255,255,0.05);
  }
  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6rem;
    font-weight: 300;
    color: rgba(255,255,255,0.2);
  }
  .footer-legal a {
    color: rgba(255,255,255,0.2);
    transition: color 0.3s ease;
  }
  .footer-legal a:hover {
    color: rgba(255,255,255,0.6);
  }
  .sep { opacity: 0.3; }
  .footer-copy {
    font-size: 0.6rem;
    font-weight: 300;
    color: rgba(255,255,255,0.15);
  }

  .back-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px; height: 48px;
    border-radius: 50%;
    border: 0.5px solid rgba(255,255,255,0.15);
    background: rgba(42,31,26,0.8);
    color: rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 800;
    transition: all 0.4s var(--ease-out-expo);
    backdrop-filter: blur(8px);
  }
  .back-top:hover {
    background: var(--taupe);
    border-color: var(--taupe);
    color: #fff;
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }
    .back-top {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 42px; height: 42px;
    }
  }
</style>
