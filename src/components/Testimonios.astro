---
const testimonials = [
  { text: "Lucía me ayudó a entender que no estaba rota, solo estaba respondiendo a mucho dolor acumulado. Gracias a ella he recuperado mi paz.", author: "Marta", detail: "Terapia individual · 8 meses" },
  { text: "El EMDR cambió mi vida. Llevaba años con pesadillas y ansiedad constante. Hoy duermo bien y me siento libre.", author: "Ana", detail: "EMDR · 4 meses" },
  { text: "Nunca había sentido tanta calidez y profesionalidad a la vez. Lucía sabe exactamente cuándo escuchar y cuándo guiar.", author: "Carmen", detail: "Crecimiento personal · 1 año" },
  { text: "La terapia online me permitió compatibilizar mis horarios imposibles con un proceso terapéutico real y profundo.", author: "Laura", detail: "Terapia online · 6 meses" },
  { text: "Después de mi divorcio pensé que no volvería a ser yo. Lucía me acompañó a reconstruirme desde la raíz.", author: "Elena", detail: "Terapia individual · 10 meses" },
];
---

<section class="testimonios">
  <div class="testi-inner">
    <div class="testi-header reveal">
      <span class="type-eyebrow">Testimonios</span>
      <h2 class="testi-title">
        <span class="type-display">Palabras de</span>
        <span class="type-display accent">quienes confiaron</span>
      </h2>
    </div>

    <div class="quote-stage" id="quoteStage">
      {testimonials.map((t, i) => (
        <div class={`quote-slide ${i === 0 ? 'active' : ''}`} data-index={i}>
          <blockquote class="quote-text">"{t.text}"</blockquote>
          <div class="quote-author">
            <span class="author-name">{t.author}</span>
            <span class="author-detail">{t.detail}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="quote-nav">
      <div class="nav-dots" id="navDots">
        {testimonials.map((_, i) => (
          <button class={`nav-dot ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={`Testimonio ${i + 1}`}></button>
        ))}
      </div>
      <div class="nav-arrows">
        <button class="arrow-btn" id="prevQuote" aria-label="Anterior">←</button>
        <button class="arrow-btn" id="nextQuote" aria-label="Siguiente">→</button>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.quote-slide');
  const dots = document.querySelectorAll('.nav-dot');
  const prevBtn = document.getElementById('prevQuote');
  const nextBtn = document.getElementById('nextQuote');
  let current = 0;

  function show(index) {
    slides.forEach((s, i) => {
      s.classList.toggle('active', i === index);
    });
    dots.forEach((d, i) => {
      d.classList.toggle('active', i === index);
    });
    current = index;
  }

  dots.forEach(d => d.addEventListener('click', () => show(+d.dataset.index)));
  prevBtn.addEventListener('click', () => show((current - 1 + slides.length) % slides.length));
  nextBtn.addEventListener('click', () => show((current + 1) % slides.length));

  // Auto-advance
  setInterval(() => show((current + 1) % slides.length), 7000);
</script>

<style>
  .testimonios {
    background: var(--cream-warm);
    padding: 10rem 0 8rem;
    overflow: hidden;
  }
  .testi-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 6vw;
    text-align: center;
  }

  .testi-header {
    margin-bottom: 5rem;
  }
  .testi-header .type-eyebrow {
    display: block;
    margin-bottom: 1.5rem;
  }
  .testi-title {
    display: flex;
    flex-direction: column;
    gap: 0.05em;
  }
  .testi-title .type-display {
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: var(--ink);
  }
  .testi-title .accent {
    color: var(--taupe);
  }

  .quote-stage {
    position: relative;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .quote-slide {
    position: absolute;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
    pointer-events: none;
    width: 100%;
  }
  .quote-slide.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
    position: relative;
  }

  .quote-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.4rem, 2.8vw, 2.2rem);
    line-height: 1.45;
    color: var(--ink);
    margin-bottom: 2.5rem;
    position: relative;
  }
  .quote-text::before {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: var(--mint);
    margin: 0 auto 2rem;
  }

  .quote-author {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }
  .author-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--taupe);
  }
  .author-detail {
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.5;
  }

  .quote-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    margin-top: 4rem;
  }
  .nav-dots {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .nav-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: transparent;
    cursor: pointer;
    transition: all 0.4s var(--ease-out-expo);
    padding: 0;
  }
  .nav-dot.active {
    background: var(--ink);
    border-color: var(--ink);
    transform: scale(1.3);
  }

  .nav-arrows {
    display: flex;
    gap: 1rem;
  }
  .arrow-btn {
    width: 44px; height: 44px;
    border: 0.5px solid var(--line);
    border-radius: 50%;
    background: transparent;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.4s var(--ease-out-expo);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .arrow-btn:hover {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }

  @media (max-width: 640px) {
    .quote-stage { min-height: 360px; }
    .quote-nav { flex-direction: column; gap: 1.5rem; }
  }
</style>
