---
import InkBlob from './ui/InkBlob.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';

const lines = [
  { text: 'La terapia empieza', accent: false },
  { text: 'con una evaluación honesta', accent: false },
  { text: 'de lo que te ocurre.', accent: false },
  { text: 'Después elegimos objetivos,', accent: true },
  { text: 'enfoque y ritmo de trabajo.', accent: true },
];
---

<section class="quote-section torn-edge-top torn-edge-bottom">
  <GrainOverlay opacity={0.02} />
  <AmbientLight color="rgba(196,170,148,0.02)" />
  <DustParticles count={12} color="rgba(196,170,148,0.15)" />
  <FloatOrb size={300} top="20%" right="5%" color="var(--sage-muted)" opacity={0.08} animation="float-3" />
  <InkBlob width={400} height={320} top="-10%" left="-5%" color="var(--sage)" opacity={0.06} />
  <InkBlob width={350} height={280} bottom="-5%" right="-8%" color="var(--gold)" opacity={0.06} animation="morph-2" />
  <InkBlob width={250} height={200} top="30%" right="10%" color="var(--earth)" opacity={0.03} animation="morph-blob" />

  <div class="quote-separator top" aria-hidden="true">
    <span></span>
    <span></span>
  </div>

  <div class="quote-dots" aria-hidden="true">
    <span class="quote-dot"></span>
    <span class="quote-dot"></span>
    <span class="quote-dot"></span>
    <span class="quote-dot"></span>
  </div>

  <Container maxWidth="1180px">
    <div class="quote-inner">
      <div class="quote-mark open" aria-hidden="true" data-parallax="0.04">&#8220;</div>
      <blockquote class="quote-text reveal-blur" data-word-reveal>
        {lines.map(({ text, accent }) => (
          <span class:list={['line', { accent }]}>
            {text.split(/\s+/).map((word, i, arr) => (
              <>
                <span class="word">{word}</span>
                {i < arr.length - 1 && ' '}
              </>
            ))}
          </span>
        ))}
      </blockquote>
      <div class="quote-mark close" aria-hidden="true" data-parallax="-0.03">&#8221;</div>
      <div class="quote-attribution reveal-up" data-delay="400">
        <span class="attr-line" aria-hidden="true"></span>
        <span class="attr-text">Filosofía de trabajo</span>
        <span class="attr-line" aria-hidden="true"></span>
      </div>
    </div>
  </Container>

  <div class="quote-separator bottom" aria-hidden="true">
    <span></span>
    <span></span>
  </div>
</section>

<style>
  .quote-section {
    position: relative;
    background:
      linear-gradient(90deg, rgba(196,170,148,0.03), transparent 18%, transparent 82%, rgba(168,169,158,0.03)),
      radial-gradient(ellipse at 50% 42%, rgba(196,170,148,0.045) 0%, transparent 52%),
      radial-gradient(ellipse at 18% 78%, rgba(107,125,106,0.025) 0%, transparent 42%),
      var(--parchment);
    padding: clamp(7rem, 12vw, 13rem) 0;
    overflow: hidden;
    text-align: center;
    &::before {
      content: '';
      position: absolute; inset: clamp(1.25rem, 3vw, 3rem) clamp(1rem, 3vw, 2.75rem);
      border-top: 1px solid rgba(122,101,88,0.08);
      border-bottom: 1px solid rgba(122,101,88,0.08);
      pointer-events: none;
      z-index: 0;
    }
  }

  .quote-separator {
    position: absolute;
    left: 50%;
    width: min(88vw, 1120px);
    height: 18px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 2;
    span {
      position: absolute;
      left: 0;
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent 0%, rgba(122,101,88,0.16) 18%, rgba(196,170,148,0.34) 50%, rgba(122,101,88,0.16) 82%, transparent 100%);
      transform-origin: center;
    }
    span:first-child { top: 3px; transform: scaleX(0.92); opacity: 0.72; }
    span:last-child { top: 12px; transform: scaleX(0.74); opacity: 0.4; }
    &.top { top: clamp(2rem, 4vw, 4rem); }
    &.bottom {
      bottom: clamp(2rem, 4vw, 4rem);
      span:first-child { transform: scaleX(0.76); }
      span:last-child { transform: scaleX(0.94); }
    }
  }

  .quote-dots { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .quote-dot {
    position: absolute; border-radius: 50%; background: var(--earth); will-change: transform;
    &:nth-child(1) { width: 4px; height: 4px; top: 15%; left: 12%; opacity: 0.08; animation: float-gentle 10s ease-in-out infinite; }
    &:nth-child(2) { width: 3px; height: 3px; top: 60%; right: 15%; opacity: 0.06; animation: float-gentle-reverse 12s ease-in-out infinite; animation-delay: -3s; }
    &:nth-child(3) { width: 5px; height: 5px; bottom: 20%; left: 25%; opacity: 0.05; animation: float-gentle 14s ease-in-out infinite; animation-delay: -6s; }
    &:nth-child(4) { width: 3px; height: 3px; top: 35%; right: 30%; opacity: 0.07; animation: float-gentle-reverse 9s ease-in-out infinite; animation-delay: -2s; }
  }

  .quote-inner {
    position: relative;
    z-index: 2;
    width: min(100%, 1080px);
    margin: 0 auto;
    padding: 0 clamp(0.2rem, 2vw, 1.5rem);
  }

  .quote-mark {
    position: relative;
    font-family: var(--font-display); font-style: italic; font-size: var(--type-decorative-xl);
    font-weight: 300; color: var(--earth); line-height: 0.5; opacity: 0; user-select: none;
    display: block; transition: opacity 1.2s ease, transform 1.2s var(--ease-out-expo);
    will-change: transform; text-shadow: none;
    &.open { text-align: left; margin-left: clamp(0rem, 4vw, 4rem); margin-bottom: -0.35rem; transform: translateY(30px); }
    &.close { text-align: right; margin-right: clamp(0rem, 4vw, 4rem); margin-top: -0.7rem; transform: translateY(-30px); }
    &.visible { opacity: 0.13; transform: translateY(0); }
    .quote-section:hover & { opacity: 0.2; }
    .quote-section:hover &.open { transform: translateY(-4px); }
    .quote-section:hover &.close { transform: translateY(4px); }
    .quote-section:hover &.visible { opacity: 0.22; }
  }

  .quote-text {
    font-family: var(--font-display); font-style: italic; font-weight: 300;
    font-size: var(--type-section-title-sm); line-height: 1.18; color: var(--ink); margin: 1.2rem auto;
    max-width: 1050px;
    text-wrap: balance;
    text-shadow: none;
    .line { display: block; width: max-content; max-width: 100%; margin-inline: auto; overflow: hidden; padding: 0.08em 0; }
    .word { display: inline-block; opacity: 0; transform: translateY(20px); transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo); }
    &.visible .word { opacity: 1; transform: translateY(0); }
    .accent { color: var(--earth); }
  }

  .quote-attribution {
    display: flex; align-items: center; justify-content: center; gap: clamp(0.9rem, 2vw, 1.4rem); margin-top: clamp(2.5rem, 5vw, 4.25rem);
    .attr-line {
      display: block; width: clamp(44px, 7vw, 96px); height: 1px; flex: 0 0 auto;
      background: linear-gradient(90deg, transparent, rgba(196,170,148,0.95));
      transform: scaleX(0); transform-origin: left;
      opacity: 0.2; transition: transform 1.4s var(--ease-out-expo);
      &:last-child { display: block; transform: rotate(180deg) scaleX(0); transform-origin: right; }
    }
    &.visible .attr-line { transform: scaleX(1); }
    &.visible .attr-line:last-child { transform: rotate(180deg) scaleX(1); }
    .attr-text {
      font-family: var(--font-body); font-size: var(--type-meta); font-weight: 400;
      letter-spacing: 0.22em; text-transform: uppercase; color: var(--taupe);
      opacity: 0; transition: opacity 0.8s ease 0.4s;
      white-space: nowrap;
    }
    &.visible .attr-text { opacity: 0.64; }
  }

  @media (max-width: 768px) {
    .quote-section { padding: 4.8rem 0; }
    .quote-separator { width: calc(100vw - 2rem); }
    .quote-mark { font-size: var(--type-decorative-lg); }
    .quote-text {
      font-size: var(--type-subsection-title);
      line-height: 1.22;
      margin: 0.8rem auto;
      .line { width: auto; }
    }
    .quote-attribution {
      gap: 0.6rem;
      margin-top: 2rem;
      .attr-text { font-size: var(--type-micro); letter-spacing: 0.14em; }
      &.visible .attr-line { width: 30px; }
    }
  }

  @media (max-width: 480px) {
    .quote-section { padding: 4rem 0; }
    .quote-mark.open { margin-left: 0.5rem; }
    .quote-mark.close { margin-right: 0.5rem; }
  }
</style>

<script>
  document.querySelectorAll('[data-word-reveal]').forEach(el => {
    const words = el.querySelectorAll('.word');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        words.forEach((w, i) => w.style.transitionDelay = `${i * 55}ms`);
        entry.target.classList.add('visible');
        entry.target.closest('.quote-section')?.querySelectorAll('.quote-mark').forEach((m, i) => {
          setTimeout(() => m.classList.add('visible'), 300 + i * 200);
        });
        io.unobserve(entry.target);
      });
    }, { threshold: 0.3 });
    io.observe(el);
  });
</script>
