---
interface Props {
  text: string;
  light?: boolean;
  centered?: boolean;
  variant?: 'default' | 'simple';
}

const { text, light = false, centered = true, variant = 'default' } = Astro.props;
---

<div class:list={['eyebrow', `eyebrow--${variant}`, { 'eyebrow--light': light, 'eyebrow--centered': centered }]}>
  <span class="eyebrow-line" aria-hidden="true"></span>
  {variant === 'default' && <span class="eyebrow-dot" aria-hidden="true"></span>}
  <span class="eyebrow-text">{text}</span>
  {variant === 'default' && <span class="eyebrow-dot" aria-hidden="true"></span>}
  <span class="eyebrow-line" aria-hidden="true"></span>
</div>

<style>
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.8rem;
  }
  .eyebrow--centered {
    justify-content: center;
  }

  .eyebrow-line {
    display: block;
    width: 28px;
    height: 1px;
    background: rgba(196, 170, 148, 0.3);
  }
  .eyebrow--light .eyebrow-line {
    background: rgba(196, 170, 148, 0.25);
  }
  .eyebrow--simple .eyebrow-line {
    width: 40px;
    background: rgba(196, 170, 148, 0.25);
  }
  .eyebrow--light.eyebrow--simple .eyebrow-line {
    background: rgba(196, 170, 148, 0.25);
  }

  .eyebrow-dot {
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(196, 170, 148, 0.4);
    animation: dot-pulse 3s ease-in-out infinite;
  }
  .eyebrow--light .eyebrow-dot {
    background: rgba(196, 170, 148, 0.35);
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.3); }
  }

  .eyebrow-text {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--taupe);
    white-space: nowrap;
  }
  .eyebrow--light .eyebrow-text {
    color: rgba(245, 240, 232, 0.65);
  }
  .eyebrow--simple .eyebrow-text {
    font-size: var(--type-meta);
    letter-spacing: 0.28em;
  }

  @media (max-width: 768px) {
    .eyebrow {
      gap: 0.6rem;
      margin-bottom: 1.4rem;
    }
    .eyebrow-line {
      width: 20px;
    }
    .eyebrow--simple .eyebrow-line {
      width: 28px;
    }
    .eyebrow-text {
      font-size: var(--type-meta);
      letter-spacing: 0.18em;
    }
  }
</style>
