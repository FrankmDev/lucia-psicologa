---
interface Props {
  maxWidth?: string | number;
  padding?: string;
  class?: string;
}

const {
  maxWidth = '1100px',
  padding = '0 6vw',
  class: className = ''
} = Astro.props;

const widthStyle = typeof maxWidth === 'number' ? `${maxWidth}px` : maxWidth;
---

<div class:list={['container', className]} style={`max-width: ${widthStyle}; padding: ${padding};`}>
  <slot />
</div>

<style>
  .container {
    position: relative;
    z-index: 2;
    margin: 0 auto;
    width: 100%;
  }
</style>
