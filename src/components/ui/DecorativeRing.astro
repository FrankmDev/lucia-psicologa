---
interface Props {
  size?: number;
  top?: string;
  bottom?: string;
  left?: string;
  right?: string;
  opacity?: number;
  duration?: number;
  reverse?: boolean;
  class?: string;
}

const {
  size = 350,
  top,
  bottom,
  left,
  right,
  opacity = 0.08,
  duration = 40,
  reverse = false,
  class: className = ''
} = Astro.props;
---

<div
  class:list={['deco-ring', { 'deco-ring--reverse': reverse }, className]}
  aria-hidden="true"
  style={`
    width: ${size}px;
    height: ${size}px;
    ${top !== undefined ? `top: ${top};` : ''}
    ${bottom !== undefined ? `bottom: ${bottom};` : ''}
    ${left !== undefined ? `left: ${left};` : ''}
    ${right !== undefined ? `right: ${right};` : ''}
    opacity: ${opacity};
    animation-duration: ${duration}s;
  `}
></div>

<style>
  .deco-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(196,170,148,0.08);
    pointer-events: none;
    z-index: 1;
    animation: ring-spin 40s linear infinite;
  }
  .deco-ring--reverse {
    animation-direction: reverse;
  }
  @keyframes ring-spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @media (max-width: 1024px) {
    .deco-ring {
      display: none;
    }
  }
</style>
