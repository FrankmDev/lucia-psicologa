---
interface Props {
  eyebrow?: string;
  title: string[];
  subtitle?: string;
  light?: boolean;
  align?: 'start' | 'center' | 'end';
  class?: string;
  variant?: 'default' | 'minimal' | 'ornamented' | 'editorial';
  size?: 'default' | 'large' | 'small' | 'hero';
  tag?: string;
  scrollHint?: boolean;
  decor?: 'none' | 'line' | 'flourish';
  accentIndex?: number;
  index?: string;
  breadcrumbs?: string[];
}

const {
  eyebrow,
  title,
  subtitle,
  light = false,
  align = 'center',
  class: className = '',
  variant = 'default',
  size = 'default',
  tag,
  scrollHint = false,
  decor = 'none',
  accentIndex = title.length - 1,
  index,
  breadcrumbs,
} = Astro.props;

/* Delays */
const dTag = 0;
const dEyebrow = 100;
const dBreadcrumb = dEyebrow + 80;
const dTitleBase = 220;
const dTitleStep = 160;
const dSubtitle = dTitleBase + title.length * dTitleStep + 120;
const dDecor = dSubtitle + 160;
const dScroll = dSubtitle + 380;
const dFrame = dTitleBase + 60;
---

<header
  class:list={[
    'section-header',
    `section-header--${size}`,
    `section-header--${variant}`,
    `section-header--align-${align}`,
    { 'section-header--light': light },
    className,
  ]}
>
  {/* Hand-drawn frame (ornamented / editorial only) */}
  {(variant === 'ornamented' || variant === 'editorial') && (
    <svg class="section-header__frame" viewBox="0 0 400 200" preserveAspectRatio="none" aria-hidden="true">
      <rect
        x="2" y="2" width="396" height="196"
        rx="8" ry="8"
        fill="none"
        stroke="currentColor"
        stroke-width="0.6"
        vector-effect="non-scaling-stroke"
        class="frame-rect"
      />
    </svg>
  )}

  {/* Soft organic blob backdrop */}
  <div class="section-header__blob" aria-hidden="true"></div>

  {/* Watermark index — stroke outline */}
  {index && (
    <div class="section-header__watermark" aria-hidden="true">
      <span class="watermark-num">{index}</span>
    </div>
  )}

  {/* Botanical flourish */}
  {decor === 'flourish' && (
    <svg class="section-header__flourish" viewBox="0 0 120 120" fill="none" aria-hidden="true">
      <path d="M60 118 Q56 78 60 56 Q64 30 42 14 Q26 2 8 10" stroke="currentColor" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.5"/>
      <path d="M60 96 Q84 84 92 62 Q100 40 88 24" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.3"/>
      <path d="M60 72 Q40 64 28 50 Q18 38 30 26" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.3"/>
      <circle cx="60" cy="56" r="3" fill="currentColor" opacity="0.35"/>
    </svg>
  )}

  {/* Tag — archive label */}
  {tag && (
    <div class="section-header__tag reveal-theatre" style={`transition-delay:${dTag}ms`}>
      <span class="tag-punch" aria-hidden="true"></span>
      <span class="tag-pill">{tag}</span>
    </div>
  )}

  {/* Eyebrow — physical archive label */}
  {eyebrow && (
    <div class="section-header__eyebrow reveal-theatre" style={`transition-delay:${dEyebrow}ms`}>
      {index && <span class="eyebrow-index" aria-hidden="true">{index}</span>}
      <span class="eyebrow-line eyebrow-line--start" aria-hidden="true"></span>
      <span class="eyebrow-text">{eyebrow}</span>
      <span class="eyebrow-line eyebrow-line--end" aria-hidden="true"></span>
    </div>
  )}

  {/* Breadcrumbs */}
  {breadcrumbs && breadcrumbs.length > 0 && (
    <nav class="section-header__breadcrumbs reveal-theatre" aria-label="Breadcrumb" style={`transition-delay:${dBreadcrumb}ms`}>
      {breadcrumbs.map((crumb, i) => (
        <>
          <span class="breadcrumb-item">{crumb}</span>
          {i < breadcrumbs.length - 1 && <span class="breadcrumb-sep" aria-hidden="true"></span>}
        </>
      ))}
    </nav>
  )}

  {/* Title — theatrical perspective reveal */}
  <h2 class="section-header__title">
    {title.map((line, i) => (
      <span
        class:list={[
          'title-line',
          'reveal-theatre',
          { 'title-line--accent': i === accentIndex },
        ]}
        style={`transition-delay:${dTitleBase + i * dTitleStep}ms`}
      >
        <span class="title-line__text">{line}</span>
        {i === accentIndex && <span class="accent-blob" aria-hidden="true"></span>}
      </span>
    ))}
  </h2>

  {/* Subtitle */}
  {subtitle && (
    <p class="section-header__subtitle reveal-theatre" style={`transition-delay:${dSubtitle}ms`}>
      {subtitle}
    </p>
  )}

  {/* Decor line */}
  {decor === 'line' && (
    <div class="section-header__decor-line reveal-theatre" aria-hidden="true" style={`transition-delay:${dDecor}ms`}></div>
  )}

  {/* Scroll hint */}
  {scrollHint && (
    <div class="section-header__scroll-hint reveal-theatre" aria-hidden="true" style={`transition-delay:${dScroll}ms`}>
      <span class="scroll-hint-line"></span>
      <span class="scroll-hint-text">Scroll</span>
      <span class="scroll-hint-line"></span>
    </div>
  )}
</header>

<style>
  /* ═══════════════════════════════════════════
     BASE — architectural container
     ═══════════════════════════════════════════ */
  .section-header {
    position: relative;
    display: flex;
    flex-direction: column;
    margin-bottom: 5rem;
    padding: 2.5rem 0 2rem;
    perspective: 1200px;
  }
  .section-header--align-start { text-align: left; align-items: flex-start; }
  .section-header--align-center { text-align: center; align-items: center; }
  .section-header--align-end { text-align: right; align-items: flex-end; }

  /* ═══════════════════════════════════════════
     HAND-DRAWN FRAME — SVG stroke draw
     ═══════════════════════════════════════════ */
  .section-header__frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    color: var(--earth);
    opacity: 0;
    transition: opacity 1.5s ease 0.3s;
  }
  .section-header.visible .section-header__frame { opacity: 1; }

  .frame-rect {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    transition: stroke-dashoffset 2.5s var(--ease-out-expo) 0.4s;
  }
  .section-header.visible .frame-rect {
    stroke-dashoffset: 0;
  }

  /* ═══════════════════════════════════════════
     ORGANIC BLOB BACKDROP
     ═══════════════════════════════════════════ */
  .section-header__blob {
    position: absolute;
    top: 50%;
    width: 75%;
    height: 200%;
    background: radial-gradient(ellipse at center, rgba(196,170,148,0.04) 0%, transparent 65%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 3s var(--ease-out-expo);
  }
  .section-header--align-start .section-header__blob { left: -15%; transform: translate(0, -50%); }
  .section-header--align-center .section-header__blob { left: 50%; transform: translate(-50%, -50%); }
  .section-header--align-end .section-header__blob { right: -15%; left: auto; transform: translate(0, -50%); }
  .section-header.visible .section-header__blob { opacity: 1; }

  /* ═══════════════════════════════════════════
     WATERMARK — stroke outline, enormous
     ═══════════════════════════════════════════ */
  .section-header__watermark {
    position: absolute;
    top: 50%;
    pointer-events: none;
    z-index: 0;
    user-select: none;
    line-height: 1;
  }
  .section-header--align-start .section-header__watermark { left: -2rem; transform: translate(0, -50%); }
  .section-header--align-center .section-header__watermark { left: 50%; transform: translate(-50%, -50%); }
  .section-header--align-end .section-header__watermark { right: -2rem; transform: translate(0, -50%); }

  .watermark-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(6rem, 14vw, 12rem);
    -webkit-text-stroke: 1.5px var(--earth);
    color: transparent;
    opacity: 0;
    letter-spacing: -0.04em;
    transform: scale(0.85);
    transition: opacity 2.5s var(--ease-out-expo) 0.2s, transform 2.5s var(--ease-out-expo) 0.2s;
  }
  .section-header.visible .watermark-num {
    opacity: 0.06;
    transform: scale(1);
  }

  /* ═══════════════════════════════════════════
     BOTANICAL FLOURISH
     ═══════════════════════════════════════════ */
  .section-header__flourish {
    position: absolute;
    width: 90px;
    height: 90px;
    pointer-events: none;
    z-index: 1;
    color: var(--earth);
    opacity: 0;
    transition: opacity 2s var(--ease-out-expo) 0.6s;
  }
  .section-header--align-start .section-header__flourish {
    right: -2.5rem;
    top: -1rem;
    transform: scaleX(-1);
  }
  .section-header--align-center .section-header__flourish {
    left: 50%;
    bottom: -0.5rem;
    transform: translateX(-50%);
  }
  .section-header--align-end .section-header__flourish {
    left: -2.5rem;
    top: -1rem;
  }
  .section-header.visible .section-header__flourish { opacity: 0.09; }

  /* ═══════════════════════════════════════════
     THEATRICAL REVEAL — blur + rotateX + clip
     ═══════════════════════════════════════════ */
  .reveal-theatre {
    opacity: 0;
    transform: translateY(55px) rotateX(22deg);
    filter: blur(14px);
    clip-path: inset(0 0 100% 0);
    transition:
      opacity 1.4s var(--ease-out-expo),
      transform 1.4s var(--ease-out-expo),
      filter 1.4s var(--ease-out-expo),
      clip-path 1.5s var(--ease-out-expo);
  }
  .reveal-theatre.visible {
    opacity: 1;
    transform: translateY(0) rotateX(0deg);
    filter: blur(0);
    clip-path: inset(0 0 0% 0);
  }

  /* ═══════════════════════════════════════════
     TAG — archive punch label
     ═══════════════════════════════════════════ */
  .section-header__tag {
    margin-bottom: 1.2rem;
    position: relative;
    z-index: 2;
  }
  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--earth);
    background: var(--cream-warm);
    border: 1px solid var(--line);
    padding: 5px 14px 5px 10px;
    border-radius: 2px;
    transition: all 0.6s var(--ease-out-expo);
    position: relative;
  }
  .tag-punch {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--cream);
    border: 1px solid var(--line);
    box-shadow: inset 0 0 0 1px rgba(196,170,148,0.15);
    flex-shrink: 0;
  }
  .section-header:hover .tag-pill {
    border-color: var(--earth);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(196,170,148,0.08);
  }

  /* ═══════════════════════════════════════════
     EYEBROW — physical archive label
     ═══════════════════════════════════════════ */
  .section-header__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.4rem;
    position: relative;
    z-index: 2;
  }
  .section-header--align-start .section-header__eyebrow { justify-content: flex-start; }
  .section-header--align-center .section-header__eyebrow { justify-content: center; }
  .section-header--align-end .section-header__eyebrow { justify-content: flex-end; }

  .eyebrow-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--earth);
    border: 1px solid rgba(196,170,148,0.35);
    padding: 4px 8px;
    border-radius: 45% 55% 50% 50% / 50% 45% 55% 50%;
    line-height: 1;
    transition: all 0.5s var(--ease-out-expo);
  }
  .section-header:hover .eyebrow-index {
    border-color: rgba(196,170,148,0.6);
    transform: scale(1.08);
  }

  .eyebrow-line {
    display: block;
    height: 1px;
    width: 0;
    opacity: 0.2;
    transition: width 1.2s var(--ease-out-expo);
  }
  .eyebrow-line--start {
    background: linear-gradient(90deg, transparent, var(--earth));
  }
  .eyebrow-line--end {
    background: linear-gradient(90deg, var(--earth), transparent);
  }
  .section-header.visible .eyebrow-line { width: 32px; }
  .section-header.visible .eyebrow-line--start { transition-delay: 0.3s; }
  .section-header.visible .eyebrow-line--end { transition-delay: 0.5s; }

  .eyebrow-text {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.55;
    white-space: nowrap;
    padding: 4px 0;
    border-bottom: 1px dashed rgba(196,170,148,0.15);
  }

  /* ═══════════════════════════════════════════
     BREADCRUMBS — stitch trail
     ═══════════════════════════════════════════ */
  .section-header__breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.2rem;
    position: relative;
    z-index: 2;
  }
  .breadcrumb-item {
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.35;
    transition: opacity 0.4s ease;
  }
  .section-header:hover .breadcrumb-item { opacity: 0.6; }
  .breadcrumb-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--earth);
    opacity: 0.15;
  }

  /* ═══════════════════════════════════════════
     TITLE — dramatic scale + outline mix
     ═══════════════════════════════════════════ */
  .section-header__title {
    position: relative;
    z-index: 2;
    margin: 0;
    line-height: 1.05;
  }

  .title-line {
    position: relative;
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(2.6rem, 5.5vw, 4.8rem);
    line-height: 1.05;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .title-line + .title-line {
    margin-top: 0.08em;
  }

  /* Staggered indent for start alignment */
  .section-header--align-start .title-line:nth-child(2) {
    padding-left: 0.35em;
  }
  .section-header--align-start .title-line:nth-child(3) {
    padding-left: 0.7em;
  }

  /* Outline/Fill mix for editorial */
  .section-header--editorial .title-line:first-child,
  .section-header--ornamented .title-line:first-child {
    -webkit-text-stroke: 1.2px var(--ink);
    color: transparent;
    font-weight: 400;
  }

  /* ═══════════════════════════════════════════
     ACCENT — organic blob highlight
     ═══════════════════════════════════════════ */
  .title-line--accent {
    position: relative;
    font-weight: 400;
    color: var(--earth);
  }
  .title-line--accent .title-line__text {
    position: relative;
    z-index: 2;
  }

  .accent-blob {
    position: absolute;
    inset: -0.12em -0.3em -0.08em -0.2em;
    background: rgba(168,169,158,0.1);
    border-radius: 45% 55% 50% 50% / 50% 45% 55% 50%;
    z-index: 0;
    transform: scale(0);
    transition: transform 1.6s var(--ease-out-expo) 0.9s;
    pointer-events: none;
  }
  .section-header.visible .accent-blob {
    transform: scale(1);
  }

  /* Small diamond seal after accent */
  .title-line--accent::after {
    content: '';
    position: absolute;
    bottom: 0.25em;
    right: -0.75em;
    width: 5px;
    height: 5px;
    background: var(--earth);
    opacity: 0;
    transform: rotate(45deg) scale(0);
    transition: opacity 0.7s var(--ease-out-expo) 1.3s, transform 0.7s var(--ease-out-expo) 1.3s;
  }
  .section-header.visible .title-line--accent::after {
    opacity: 0.2;
    transform: rotate(45deg) scale(1);
  }

  /* ═══════════════════════════════════════════
     SUBTITLE — editorial block
     ═══════════════════════════════════════════ */
  .section-header__subtitle {
    position: relative;
    z-index: 2;
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    font-weight: 300;
    color: var(--taupe);
    opacity: 0.6;
    letter-spacing: 0.01em;
    line-height: 1.75;
    max-width: 520px;
    margin: 1.1rem 0 0;
    padding-bottom: 1.8rem;
  }
  .section-header--align-start .section-header__subtitle { margin-left: 0; margin-right: auto; }
  .section-header--align-center .section-header__subtitle { margin-left: auto; margin-right: auto; }
  .section-header--align-end .section-header__subtitle { margin-left: auto; margin-right: 0; }

  /* Stitch divider */
  .section-header__subtitle::after {
    content: '';
    position: absolute;
    bottom: 0;
    width: 0;
    height: 1px;
    border-top: 1px dashed var(--earth);
    opacity: 0.25;
    transition: width 1.2s var(--ease-out-expo) 0.7s;
  }
  .section-header--align-start .section-header__subtitle::after { left: 0; transform: none; }
  .section-header--align-center .section-header__subtitle::after { left: 50%; transform: translateX(-50%); }
  .section-header--align-end .section-header__subtitle::after { right: 0; left: auto; transform: none; }
  .section-header.visible .section-header__subtitle::after { width: 48px; }

  /* ═══════════════════════════════════════════
     DECOR LINE
     ═══════════════════════════════════════════ */
  .section-header__decor-line {
    width: 1px;
    height: 0;
    background: linear-gradient(180deg, var(--earth), transparent);
    opacity: 0.15;
    margin-top: 1.6rem;
    transition: height 1.4s var(--ease-out-expo) 0.6s;
  }
  .section-header.visible .section-header__decor-line { height: 60px; }

  /* ═══════════════════════════════════════════
     SCROLL HINT
     ═══════════════════════════════════════════ */
  .section-header__scroll-hint {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2.2rem;
    position: relative;
    z-index: 2;
  }
  .section-header--align-start .section-header__scroll-hint { justify-content: flex-start; }
  .section-header--align-center .section-header__scroll-hint { justify-content: center; }
  .section-header--align-end .section-header__scroll-hint { justify-content: flex-end; }

  .scroll-hint-text {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.3;
  }
  .scroll-hint-line {
    display: block;
    width: 18px;
    height: 1px;
    background: var(--taupe);
    opacity: 0.1;
  }

  /* ═══════════════════════════════════════════
     SIZE VARIANTS
     ═══════════════════════════════════════════ */
  .section-header--hero .title-line {
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
  }
  .section-header--large .title-line {
    font-size: clamp(2.4rem, 5vw, 4.2rem);
  }
  .section-header--small {
    margin-bottom: 2.5rem;
    padding: 1rem 0;
  }
  .section-header--small .title-line {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
  }

  /* ═══════════════════════════════════════════
     LIGHT VARIANT
     ═══════════════════════════════════════════ */
  .section-header--light .title-line {
    color: #F5F0E8;
  }
  .section-header--light .title-line--accent {
    color: rgba(245, 240, 232, 0.85);
  }
  .section-header--light .section-header--editorial .title-line:first-child,
  .section-header--light .section-header--ornamented .title-line:first-child {
    -webkit-text-stroke: 1.2px rgba(245,240,232,0.6);
  }
  .section-header--light .accent-blob {
    background: rgba(245,240,232,0.08);
  }
  .section-header--light .title-line--accent::after {
    background: rgba(245, 240, 232, 0.3);
  }
  .section-header--light .section-header__subtitle {
    color: rgba(245, 240, 232, 0.45);
  }
  .section-header--light .section-header__subtitle::after {
    border-color: rgba(245,240,232,0.2);
  }
  .section-header--light .eyebrow-text {
    color: rgba(245, 240, 232, 0.45);
    border-color: rgba(245,240,232,0.1);
  }
  .section-header--light .eyebrow-line--start {
    background: linear-gradient(90deg, transparent, rgba(245,240,232,0.2));
  }
  .section-header--light .eyebrow-line--end {
    background: linear-gradient(90deg, rgba(245,240,232,0.2), transparent);
  }
  .section-header--light .eyebrow-index {
    color: rgba(245,240,232,0.55);
    border-color: rgba(245,240,232,0.2);
  }
  .section-header--light .scroll-hint-line {
    background: rgba(245, 240, 232, 0.1);
  }
  .section-header--light .scroll-hint-text {
    color: rgba(245, 240, 232, 0.28);
  }
  .section-header--light .tag-pill {
    color: rgba(245, 240, 232, 0.55);
    background: rgba(245, 240, 232, 0.04);
    border-color: rgba(245, 240, 232, 0.1);
  }
  .section-header--light .tag-punch {
    background: transparent;
    border-color: rgba(245,240,232,0.15);
    box-shadow: inset 0 0 0 1px rgba(245,240,232,0.1);
  }
  .section-header--light .section-header__blob {
    background: radial-gradient(ellipse at center, rgba(245,240,232,0.03) 0%, transparent 65%);
  }
  .section-header--light .section-header__flourish {
    color: rgba(245,240,232,0.5);
  }
