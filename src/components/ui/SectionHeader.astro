---
interface Props {
  eyebrow?: string;
  title: string[];
  subtitle?: string;
  light?: boolean;
  align?: 'start' | 'center' | 'end';
  class?: string;
  variant?: 'default' | 'minimal' | 'ornamented' | 'editorial';
  size?: 'default' | 'large' | 'small' | 'hero';
  tag?: string;
  scrollHint?: boolean;
  decor?: 'none' | 'line' | 'flourish';
  accentIndex?: number;
  index?: string;
  breadcrumbs?: string[];
}

const {
  eyebrow,
  title,
  subtitle,
  light = false,
  align = 'center',
  class: className = '',
  variant = 'default',
  size = 'default',
  tag,
  scrollHint = false,
  decor = 'none',
  accentIndex = title.length - 1,
  index,
  breadcrumbs,
} = Astro.props;

/* Stagger delays — calm, unhurried */
const dTag = 0;
const dBreadcrumb = 80;
const dIndex = 100;
const dEyebrow = 160;
const dDivider = 280;
const dTitleBase = 380;
const dTitleStep = 160;
const dSubtitleSep = dTitleBase + title.length * dTitleStep + 140;
const dSubtitle = dSubtitleSep + 100;
const dDecor = dSubtitle + 160;
const dScroll = dSubtitle + 360;
---

<header
  class:list={[
    'section-header',
    `section-header--${size}`,
    `section-header--${variant}`,
    `section-header--align-${align}`,
    { 'section-header--light': light },
    className,
  ]}
>
  {/* Soft ambient glow — very subtle */}
  <div class="section-header__glow" aria-hidden="true"></div>
  <div class="section-header__veil" aria-hidden="true"></div>

  {/* Optional botanical flourish */}
  {decor === 'flourish' && (
    <svg class="section-header__flourish" viewBox="0 0 120 60" fill="none" aria-hidden="true">
      <path d="M0 30 Q30 10 60 30 T120 30" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.4"/>
      <path d="M60 30 Q50 20 45 8" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" fill="none" opacity="0.25"/>
      <path d="M60 30 Q70 20 75 8" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" fill="none" opacity="0.25"/>
      <circle cx="45" cy="8" r="1.5" fill="currentColor" opacity="0.2"/>
      <circle cx="75" cy="8" r="1.5" fill="currentColor" opacity="0.2"/>
    </svg>
  )}

  {/* Section index — whisper-quiet */}
  {index && (
    <span class="section-header__index reveal-el" aria-hidden="true" style={`transition-delay:${dIndex}ms`}>
      {index}
    </span>
  )}

  {/* Tag — refined pill */}
  {tag && (
    <div class="section-header__tag reveal-el" style={`transition-delay:${dTag}ms`}>
      <span class="tag-dot" aria-hidden="true"></span>
      <span class="tag-text">{tag}</span>
    </div>
  )}

  {/* Breadcrumbs */}
  {breadcrumbs && breadcrumbs.length > 0 && (
    <nav class="section-header__breadcrumbs reveal-el" aria-label="Breadcrumb" style={`transition-delay:${dBreadcrumb}ms`}>
      {breadcrumbs.map((crumb, i) => (
        <>
          <span class="breadcrumb-item">{crumb}</span>
          {i < breadcrumbs.length - 1 && <span class="breadcrumb-sep" aria-hidden="true"></span>}
        </>
      ))}
    </nav>
  )}

  {/* Eyebrow */}
  {eyebrow && (
    <div class="section-header__eyebrow reveal-el" style={`transition-delay:${dEyebrow}ms`}>
      <span class="eyebrow-text">{eyebrow}</span>
    </div>
  )}

  {/* Divider — a hairline that breathes */}
  <div class="section-header__divider reveal-el" aria-hidden="true" style={`transition-delay:${dDivider}ms`}></div>

  {/* Title — large, light, serene */}
  <h2 class="section-header__title">
    {title.map((line, i) => (
      <span
        class:list={[
          'title-line',
          'reveal-el',
          { 'title-line--accent': i === accentIndex },
        ]}
        style={`transition-delay:${dTitleBase + i * dTitleStep}ms`}
      >
        {i === accentIndex ? (
          <span class="accent-wrap">
            <span class="accent-text">{line}</span>
            <svg class="accent-underline" viewBox="0 0 200 8" preserveAspectRatio="none" aria-hidden="true">
              <path
                d="M2 5 Q50 2 100 4 T198 3"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                stroke-linecap="round"
                class="underline-draw"
              />
            </svg>
          </span>
        ) : (
          line
        )}
      </span>
    ))}
  </h2>

  {/* Subtitle with elegant separator */}
  {subtitle && (
    <div class="section-header__subtitle-wrap">
      <div class="subtitle-sep reveal-el" aria-hidden="true" style={`transition-delay:${dSubtitleSep}ms`}>
        <span class="sep-line sep-line--start"></span>
        <span class="sep-diamond"></span>
        <span class="sep-line sep-line--end"></span>
      </div>
      <p class="section-header__subtitle reveal-el" style={`transition-delay:${dSubtitle}ms`}>
        {subtitle}
      </p>
    </div>
  )}

  {/* Decor line */}
  {decor === 'line' && (
    <div class="section-header__decor-line reveal-el" aria-hidden="true" style={`transition-delay:${dDecor}ms`}></div>
  )}

  {/* Scroll hint */}
  {scrollHint && (
    <div class="section-header__scroll-hint reveal-el" aria-hidden="true" style={`transition-delay:${dScroll}ms`}>
      <span class="scroll-line"></span>
      <span class="scroll-text">Scroll</span>
    </div>
  )}
</header>

<style>
  /* ═══════════════════════════════════════════
     BASE — calm, spacious, breathing
     ═══════════════════════════════════════════ */
  .section-header {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 3.2rem;
    padding: 2.1rem 0 1.2rem;
  }
  .section-header--align-start { text-align: left; align-items: flex-start; }
  .section-header--align-center { text-align: center; align-items: center; }
  .section-header--align-end { text-align: right; align-items: flex-end; }

  /* ═══════════════════════════════════════════
     AMBIENT GLOW — barely there
     ═══════════════════════════════════════════ */
  .section-header__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64%;
    height: 138%;
    background: radial-gradient(ellipse at center, rgba(196,170,148,0.04) 0%, transparent 62%);
    filter: blur(52px);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 2.5s var(--ease-out-expo);
  }
  .section-header.visible .section-header__glow { opacity: 1; }

  .section-header__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.12), transparent 30%),
      radial-gradient(circle at 12% 16%, rgba(196,170,148,0.08), transparent 18%);
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
    mask-image: radial-gradient(circle at center, rgba(0,0,0,0.44), transparent 82%);
  }

  .section-header--align-start .section-header__glow { left: 30%; transform: translate(0, -50%); }
  .section-header--align-end .section-header__glow { left: auto; right: 30%; transform: translate(0, -50%); }

  /* ═══════════════════════════════════════════
     BOTANICAL FLOURISH — whisper of nature
     ═══════════════════════════════════════════ */
  .section-header__flourish {
    position: absolute;
    width: 100px;
    height: 50px;
    pointer-events: none;
    z-index: 1;
    color: var(--earth);
    opacity: 0;
    transition: opacity 2s var(--ease-out-expo) 0.8s;
  }
  .section-header--align-start .section-header__flourish {
    right: -1.5rem;
    top: 1.5rem;
    transform: scaleX(-1);
  }
  .section-header--align-center .section-header__flourish {
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }
  .section-header--align-end .section-header__flourish {
    left: -1.5rem;
    top: 1.5rem;
  }
  .section-header.visible .section-header__flourish { opacity: 0.08; }

  /* ═══════════════════════════════════════════
     INDEX — quiet corner whisper
     ═══════════════════════════════════════════ */
  .section-header__index {
    position: absolute;
    top: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 0.66rem;
    color: var(--taupe);
    opacity: 0;
    letter-spacing: 0.28em;
    transition: opacity 1.2s var(--ease-out-expo);
  }
  .section-header--align-start .section-header__index { left: 0; }
  .section-header--align-center .section-header__index { left: 50%; transform: translateX(-50%); }
  .section-header--align-end .section-header__index { right: 0; }
  .section-header.visible .section-header__index { opacity: 0.18; }

  /* ═══════════════════════════════════════════
     TAG — refined dot + tracking
     ═══════════════════════════════════════════ */
  .section-header__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
  }
  .tag-dot {
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--earth);
    opacity: 0.5;
    flex-shrink: 0;
  }
  .tag-text {
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.85;
  }

  /* ═══════════════════════════════════════════
     BREADCRUMBS — barely there trail
     ═══════════════════════════════════════════ */
  .section-header__breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.9rem;
    position: relative;
    z-index: 2;
  }
  .breadcrumb-item {
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.55;
    transition: opacity 0.4s ease;
  }
  .section-header:hover .breadcrumb-item { opacity: 0.55; }
  .breadcrumb-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--earth);
    opacity: 0.12;
  }

  /* ═══════════════════════════════════════════
     EYEBROW — wide, airy, calm
     ═══════════════════════════════════════════ */
  .section-header__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.34rem;
    position: relative;
    z-index: 2;
  }
  .section-header__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.9rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(184,168,138,0.18), rgba(184,168,138,0.52));
    transform-origin: left center;
    opacity: 0;
    transform: scaleX(0.35);
    transition:
      opacity 0.9s var(--ease-out-expo) 0.28s,
      transform 0.9s var(--ease-out-expo) 0.28s;
  }
  .section-header.visible .section-header__eyebrow::before {
    opacity: 1;
    transform: scaleX(1);
  }
  .eyebrow-text {
    font-family: var(--font-body);
    font-size: 0.54rem;
    font-weight: 400;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: rgba(128, 118, 106, 0.9);
    opacity: 0.82;
    white-space: nowrap;
  }

  /* ═══════════════════════════════════════════
     DIVIDER — hairline that expands
     ═══════════════════════════════════════════ */
  .section-header__divider {
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(184,168,138,0.55), rgba(184,168,138,0.08));
    opacity: 1;
    margin-bottom: 0.95rem;
    position: relative;
    z-index: 2;
    transition: width 1.2s var(--ease-out-expo);
  }
  .section-header__divider::after {
    content: '';
    position: absolute;
    top: 50%;
    right: -0.4rem;
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 50%;
    background: rgba(184,168,138,0.42);
    box-shadow: 0 0 0 0.32rem rgba(184,168,138,0.08);
    transform: translateY(-50%) scale(0.6);
    opacity: 0;
    transition:
      opacity 0.8s var(--ease-out-expo) 0.45s,
      transform 0.8s var(--ease-out-expo) 0.45s;
  }
  .section-header--align-start .section-header__divider { margin-left: 0; margin-right: auto; }
  .section-header--align-center .section-header__divider { margin-left: auto; margin-right: auto; }
  .section-header--align-end .section-header__divider { margin-left: auto; margin-right: 0; }
  .section-header.visible .section-header__divider { width: 46px; }
  .section-header.visible .section-header__divider::after {
    opacity: 1;
    transform: translateY(-50%) scale(1);
  }

  /* ═══════════════════════════════════════════
     TITLE — large, light, serene
     ═══════════════════════════════════════════ */
  .section-header__title {
    position: relative;
    z-index: 2;
    margin: 0;
    line-height: 1.06;
    display: grid;
    gap: 0.06rem;
  }

  .title-line {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(2.08rem, 4vw, 3.42rem);
    line-height: 1.03;
    color: var(--ink);
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  /* Accent wrap with SVG underline */
  .accent-wrap {
    position: relative;
    display: inline-block;
  }
  .accent-text {
    position: relative;
    z-index: 1;
  }
  .accent-underline {
    position: absolute;
    bottom: -1px;
    left: -0.5%;
    width: 101%;
    height: 7px;
    overflow: visible;
    pointer-events: none;
    color: var(--earth);
  }
  .underline-draw {
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    transition: stroke-dashoffset 1.6s var(--ease-out-expo);
  }
  .section-header.visible .underline-draw {
    stroke-dashoffset: 0;
  }

  /* ═══════════════════════════════════════════
     SUBTITLE SEPARATOR — diamond between lines
     ═══════════════════════════════════════════ */
  .section-header__subtitle-wrap {
    position: relative;
    z-index: 2;
  }
  .subtitle-sep {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 1.15rem 0 0.82rem;
  }
  .section-header--align-start .subtitle-sep { justify-content: flex-start; }
  .section-header--align-center .subtitle-sep { justify-content: center; }
  .section-header--align-end .subtitle-sep { justify-content: flex-end; }

  .sep-line {
    width: 0;
    height: 1px;
    background: var(--earth);
    opacity: 0.2;
    transition: width 1s var(--ease-out-expo) 0.3s;
  }
  .section-header.visible .sep-line {
    width: 18px;
  }

  .sep-diamond {
    width: 5px;
    height: 5px;
    border: 1px solid var(--earth);
    opacity: 0;
    transform: rotate(45deg) scale(0.4);
    transition: all 0.8s var(--ease-out-expo) 0.5s;
  }
  .section-header.visible .sep-diamond {
    opacity: 0.3;
    transform: rotate(45deg) scale(1);
  }

  /* ═══════════════════════════════════════════
     SUBTITLE — soft, readable, peaceful
     ═══════════════════════════════════════════ */
  .section-header__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(0.98rem, 1.38vw, 1.12rem);
    color: var(--ink-soft);
    line-height: 1.72;
    max-width: 520px;
    margin: 0;
  }
  .section-header--align-start .section-header__subtitle { margin-left: 0; margin-right: auto; }
  .section-header--align-center .section-header__subtitle { margin-left: auto; margin-right: auto; }
  .section-header--align-end .section-header__subtitle { margin-left: auto; margin-right: 0; }

  /* ═══════════════════════════════════════════
     DECOR LINE — vertical whisper
     ═══════════════════════════════════════════ */
  .section-header__decor-line {
    width: 1px;
    height: 0;
    background: linear-gradient(180deg, var(--earth), transparent);
    opacity: 0.12;
    margin-top: 1.45rem;
    transition: height 1.4s var(--ease-out-expo) 0.5s;
  }
  .section-header.visible .section-header__decor-line { height: 48px; }

  /* ═══════════════════════════════════════════
     SCROLL HINT — gentle invitation
     ═══════════════════════════════════════════ */
  .section-header__scroll-hint {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 1.9rem;
    position: relative;
    z-index: 2;
  }
  .section-header--align-start .section-header__scroll-hint { justify-content: flex-start; }
  .section-header--align-center .section-header__scroll-hint { justify-content: center; }
  .section-header--align-end .section-header__scroll-hint { justify-content: flex-end; }

  .scroll-line {
    display: block;
    width: 1px;
    height: 0;
    background: var(--taupe);
    opacity: 0.12;
    transition: height 1s var(--ease-out-expo) 0.4s;
  }
  .section-header.visible .scroll-line { height: 28px; }

  .scroll-text {
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.22;
  }

  /* ═══════════════════════════════════════════
     REVEAL — soft, calm, no drama
     ═══════════════════════════════════════════ */
  .reveal-el {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 1s var(--ease-out-expo),
      transform 1s var(--ease-out-expo);
  }
  .reveal-el.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══════════════════════════════════════════
     SIZE VARIANTS
     ═══════════════════════════════════════════ */
  .section-header--hero .title-line {
    font-size: clamp(2.8rem, 5.5vw, 4.5rem);
    line-height: 1.04;
  }
  .section-header--large .title-line {
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
  }
  .section-header--small {
    margin-bottom: 2.3rem;
    padding: 1.5rem 0 1rem;
  }
  .section-header--small .title-line {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  /* ═══════════════════════════════════════════
     LIGHT VARIANT
     ═══════════════════════════════════════════ */
  .section-header--light .title-line { color: var(--cream); }
  .section-header--light .accent-underline { color: rgba(196,170,148,0.6); }
  .section-header--light .eyebrow-text { color: rgba(245,240,232,0.75); }
  .section-header--light .section-header__subtitle { color: rgba(245,240,232,0.75); }
  .section-header--light .section-header__divider { background: rgba(196,170,148,0.25); }
  .section-header--light .section-header__eyebrow::before { background: linear-gradient(90deg, rgba(245,240,232,0.12), rgba(196,170,148,0.45)); }
  .section-header--light .sep-line { background: rgba(196,170,148,0.25); }
  .section-header--light .sep-diamond { border-color: rgba(196,170,148,0.3); }
  .section-header--light .scroll-line { background: rgba(245,240,232,0.1); }
  .section-header--light .scroll-text { color: rgba(245,240,232,0.4); }
  .section-header--light .tag-dot { background: rgba(196,170,148,0.5); }
  .section-header--light .tag-text { color: rgba(245,240,232,0.7); }
  .section-header--light .section-header__index { color: rgba(245,240,232,0.15); }
  .section-header--light .breadcrumb-item { color: rgba(245,240,232,0.55); }
  .section-header--light .breadcrumb-sep { background: rgba(245,240,232,0.12); }
  .section-header--light .section-header__decor-line { background: linear-gradient(180deg, rgba(196,170,148,0.2), transparent); }
  .section-header--light .section-header__glow { background: radial-gradient(ellipse at center, rgba(245,240,232,0.02) 0%, transparent 60%); }
  .section-header--light .section-header__flourish { color: rgba(245,240,232,0.4); }
  .section-header--light .section-header__veil { background: radial-gradient(circle at 50% 20%, rgba(245,240,232,0.04), transparent 30%); }

  /* ═══════════════════════════════════════════
     MINIMAL VARIANT
     ═══════════════════════════════════════════ */
  .section-header--minimal {
    margin-bottom: 2rem;
    padding: 1.1rem 0 0.85rem;
  }
  .section-header--minimal .title-line {
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
  }
  .section-header--minimal .section-header__glow,
  .section-header--minimal .section-header__flourish,
  .section-header--minimal .section-header__index {
    display: none;
  }
  .section-header--minimal .section-header__subtitle {
    padding-bottom: 0;
  }

  /* ═══════════════════════════════════════════
     EDITORIAL / ORNAMENTED — same refined look
     ═══════════════════════════════════════════ */
  .section-header--editorial .title-line,
  .section-header--ornamented .title-line {
    letter-spacing: -0.02em;
  }
  .section-header--editorial .section-header__title,
  .section-header--ornamented .section-header__title {
    max-width: 12ch;
  }
  .section-header--editorial .section-header__subtitle,
  .section-header--ornamented .section-header__subtitle {
    max-width: 560px;
    line-height: 1.72;
  }
  .section-header--editorial .section-header__eyebrow,
  .section-header--ornamented .section-header__eyebrow {
    margin-bottom: 0.26rem;
  }

  /* ═══════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════ */
  @media (max-width: 768px) {
    .section-header {
      margin-bottom: 2.6rem;
      padding: 1.85rem 0 1rem;
    }
    .title-line {
      font-size: clamp(1.85rem, 5.5vw, 2.65rem);
    }
    .section-header--hero .title-line {
      font-size: clamp(2.2rem, 7vw, 3.2rem);
    }
    .section-header--large .title-line {
      font-size: clamp(1.9rem, 5vw, 2.8rem);
    }
    .section-header--small .title-line {
      font-size: clamp(1.4rem, 4vw, 1.9rem);
    }
    .section-header__subtitle {
      font-size: 1rem;
      max-width: 100%;
    }
    .eyebrow-text {
      font-size: 0.53rem;
      letter-spacing: 0.26em;
    }
    .section-header__eyebrow {
      gap: 0.5rem;
    }
    .section-header__eyebrow::before {
      width: 1.35rem;
    }
    .tag-text {
      font-size: 0.52rem;
    }
    .section-header__flourish {
      width: 70px;
      height: 35px;
    }
  }

  @media (max-width: 480px) {
    .section-header {
      padding: 1.5rem 0 0.9rem;
    }
    .section-header__eyebrow {
      margin-bottom: 0.26rem;
    }
    .section-header__divider {
      margin-bottom: 0.8rem;
    }
    .subtitle-sep {
      margin: 1.1rem 0 0.75rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.section-header').forEach(header => {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          entry.target.querySelectorAll('[style*="transition-delay"]').forEach((el) => {
            const delayMatch = (el as HTMLElement).style.transitionDelay.match(/(\d+)/);
            const delay = delayMatch ? parseInt(delayMatch[1], 10) : 0;
            setTimeout(() => el.classList.add('visible'), delay);
          });
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    io.observe(header);
  });
</script>
