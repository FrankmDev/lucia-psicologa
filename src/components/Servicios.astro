---
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';

const servicios = [
  {
    num: '01',
    title: 'Terapia Individual',
    paraQuien: 'Para adultos que atraviesan ansiedad, bloqueo, tristeza persistente o dificultades de autoestima.',
    queSeTrabaja: 'Identificación del problema, regulación emocional, patrones de pensamiento y objetivos terapéuticos.',
    modalidad: 'Ciudad Real · Online',
    duracion: '50 min',
    primeraSesion: 'Evaluamos qué ocurre, desde cuándo y qué necesitas trabajar primero.',
  },
  {
    num: '02',
    title: 'Abordaje del Trauma',
    paraQuien: 'Para personas con recuerdos, pérdidas o experiencias que siguen activando miedo, culpa o alerta corporal.',
    queSeTrabaja: 'Trauma, duelo complicado, síntomas de estrés postraumático y estabilización del sistema nervioso.',
    modalidad: 'Ciudad Real · Online',
    duracion: '60–90 min',
    primeraSesion: 'Revisamos tu historia clínica y decidimos si este abordaje es adecuado para ti.',
  },
  {
    num: '03',
    title: 'Ansiedad y Estrés',
    paraQuien: 'Para quien vive con preocupación constante, tensión física, crisis de ansiedad o agotamiento sostenido.',
    queSeTrabaja: 'Detonantes, pensamientos anticipatorios, síntomas físicos, descanso y estrategias de regulación.',
    modalidad: 'Ciudad Real · Online',
    duracion: '50 min',
    primeraSesion: 'Aclaramos síntomas, frecuencia e impacto para plantear un plan de trabajo realista.',
  },
];

const servicesImage = 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1800&auto=format&fit=crop';
---

<section id="servicios" class="servicios" data-servicios>
  <GrainOverlay opacity={0.014} />
  <AmbientLight color="rgba(255,255,255,0.28)" />
  <FloatOrb size={360} top="-12%" right="-8%" color="rgba(141,151,132,0.12)" blur={150} animation="float-1" />
  <FloatOrb size={220} bottom="12%" left="-6%" color="rgba(216,211,200,0.22)" opacity={0.32} blur={110} animation="float-2" />

  <Container maxWidth="1480px" padding="0 clamp(0.85rem, 2.5vw, 2.6rem)">
    <div class="services-shell">
      <header class="services-header reveal-blur" data-delay="80">
        <span class="services-eyebrow">Servicios</span>
        <h2>Terapia individual con evaluación y objetivos claros</h2>
        <p>
          Trabajo con adultos que necesitan entender qué les ocurre, reducir síntomas y construir recursos para sostener cambios fuera de la sesión.
        </p>
      </header>

      <div class="services-hero reveal-scale" data-delay="160">
        <figure class="services-hero__image">
          <img src={servicesImage} alt="Paisaje natural con mar y luz suave" decoding="async" loading="eager" />
          <div class="services-hero__veil"></div>
          <figcaption class="services-hero__caption">
            <span>Proceso terapéutico</span>
            <p>Sesiones presenciales en Ciudad Real y terapia online con el mismo encuadre clínico.</p>
          </figcaption>
        </figure>

        <article class="services-hero__panel">
          <span class="services-label">Enfoque integrador</span>
          <h3>Escucha clínica, estructura y herramientas aplicadas.</h3>
          <p>
            Integro TCC, ACT, TFE y técnicas psicosomáticas según tu caso. La primera fase se centra en comprender el problema, priorizar objetivos y decidir cómo avanzar.
          </p>

          <ul class="services-pills" aria-label="Claves del proceso terapéutico">
            <li>Presencial y online</li>
            <li>TCC · ACT · TFE</li>
            <li>Seguimiento entre sesiones</li>
          </ul>

          <div class="services-actions">
            <a href="#contacto" class="services-button services-button--solid">
              <span>Solicitar primera sesión</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#proceso" class="services-button services-button--ghost">
              <span>Ver cómo trabajo</span>
            </a>
          </div>
        </article>
      </div>

      <div class="services-divider" aria-hidden="true">
        <span></span>
      </div>

      <!-- Editorial chapters — full-width clinical spreads -->
      <div class="services-list" aria-label="Servicios terapéuticos">
        {servicios.map((s, i) => {
          const roman = ['I', 'II', 'III'][i] ?? String(i + 1);
          const nextRoman = ['II', 'III', ''][i] ?? '';
          const total = String(servicios.length).padStart(2, '0');
          return (
            <article class="service-chapter reveal-up" style={`transition-delay: ${260 + i * 90}ms`}>
              <header class="service-chapter__head">
                <div class="service-chapter__index" aria-hidden="true">
                  <span class="service-chapter__chapter">Capítulo {roman}</span>
                  <span class="service-chapter__num">N.º 0{i + 1}<em> de {total}</em></span>
                </div>
                <span class="service-chapter__kicker">Modalidad terapéutica</span>
              </header>

              <div class="service-chapter__body">
                <h3 class="service-chapter__title">{s.title}.</h3>

                <div class="service-chapter__data" role="list">
                  <article class="service-chapter__col" role="listitem">
                    <span class="service-chapter__col-num">01</span>
                    <h4 class="service-chapter__col-label">Para quién</h4>
                    <p>{s.paraQuien}</p>
                  </article>
                  <article class="service-chapter__col" role="listitem">
                    <span class="service-chapter__col-num">02</span>
                    <h4 class="service-chapter__col-label">Qué se trabaja</h4>
                    <p>{s.queSeTrabaja}</p>
                  </article>
                  <article class="service-chapter__col" role="listitem">
                    <span class="service-chapter__col-num">03</span>
                    <h4 class="service-chapter__col-label">Primera sesión</h4>
                    <p>{s.primeraSesion}</p>
                  </article>
                </div>
              </div>

              <footer class="service-chapter__foot">
                <dl class="service-chapter__meta">
                  <div class="service-chapter__meta-item">
                    <dt>Modalidad</dt>
                    <dd>{s.modalidad}</dd>
                  </div>
                  <span class="service-chapter__meta-sep" aria-hidden="true">/</span>
                  <div class="service-chapter__meta-item">
                    <dt>Duración</dt>
                    <dd>{s.duracion}</dd>
                  </div>
                </dl>

                <a href="#contacto" class="service-chapter__cta">
                  <span class="service-chapter__cta-text">Solicitar primera sesión</span>
                  <span class="service-chapter__cta-arrow" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                      <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </a>
              </footer>

              {i < servicios.length - 1 && (
                <div class="service-chapter__divider" aria-hidden="true">
                  <span class="service-chapter__divider-line"></span>
                  <span class="service-chapter__divider-mark">Fin del capítulo {roman}{nextRoman ? ` · Sigue ${nextRoman}` : ''}</span>
                  <span class="service-chapter__divider-line"></span>
                </div>
              )}
            </article>
          );
        })}
      </div>

      <div class="services-note reveal-up" data-delay="660">
        <span class="services-note__line" aria-hidden="true"></span>
        <p>
          Si no sabes qué servicio encaja con tu caso, podemos verlo en el primer contacto y orientar el proceso desde una evaluación inicial.
        </p>
      </div>
    </div>
  </Container>
</section>

<style>
  .servicios {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
    background:
      radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.88), transparent 30%),
      radial-gradient(circle at 84% 14%, rgba(223, 228, 216, 0.58), transparent 30%),
      radial-gradient(circle at 70% 76%, rgba(184, 168, 138, 0.12), transparent 32%),
      linear-gradient(180deg, #fffdfa 0%, var(--color-surface) 58%, #f2efe8 100%);
  }

  .servicios::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.01) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 74%);
    opacity: 0.55;
  }

  .servicios::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    box-shadow: inset 0 0 180px rgba(255, 255, 255, 0.22);
  }

  .services-shell {
    position: relative;
    z-index: 2;
  }

  .services-header {
    max-width: 58rem;
    margin: 0 auto clamp(2.5rem, 4.5vw, 3.8rem);
    text-align: center;
  }

  .services-label {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-label::before {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-header h2 {
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .services-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .services-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-eyebrow::before,
  .services-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(24rem, 0.82fr);
    gap: clamp(1.1rem, 1.8vw, 1.35rem);
    align-items: stretch;
  }

  .services-hero__image,
  .services-hero__panel {
    position: relative;
    border: 1px solid var(--color-line-accent-soft);
    background: rgba(255, 253, 248, 0.88);
    box-shadow: 0 1.4rem 3rem rgba(57, 54, 48, 0.06);
  }

  .services-hero__image {
    min-height: clamp(26rem, 36vw, 34rem);
    overflow: hidden;
    border-radius: 1.6rem;
  }

  .services-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 58%;
    filter: grayscale(10%) saturate(0.82) contrast(1.02) brightness(0.62);
    transform: scale(1.03);
    animation: services-image-breathe 18s ease-in-out infinite alternate;
  }

  .services-hero__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 48% 28%, rgba(255, 251, 244, 0.1), transparent 36%),
      linear-gradient(180deg, rgba(13, 10, 8, 0.12) 0%, rgba(13, 10, 8, 0.46) 100%);
  }

  .services-hero__caption {
    position: absolute;
    left: clamp(1rem, 2.4vw, 1.7rem);
    right: clamp(1rem, 2.4vw, 1.7rem);
    bottom: clamp(1rem, 2.4vw, 1.6rem);
    max-width: 28rem;
    color: rgba(255, 251, 244, 0.9);
  }

  .services-hero__caption span {
    display: inline-flex;
    margin-bottom: 0.65rem;
    font-size: var(--type-meta);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .services-hero__caption p {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.48;
    text-wrap: balance;
  }

  .services-hero__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.1rem;
    padding: var(--card-pd-lg);
    border-radius: var(--card-radius);
    border-color: rgba(111, 125, 103, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(249, 246, 239, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.48), transparent 28%),
      radial-gradient(circle at 100% 100%, rgba(184, 168, 138, 0.12), transparent 36%);
    overflow: hidden;
  }

  .services-hero__panel::before {
    content: '';
    position: absolute;
    inset: 1rem auto 1rem 1rem;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(111, 125, 103, 0.34), transparent);
    pointer-events: none;
  }

  .services-hero__panel::after {
    content: '';
    position: absolute;
    right: -1.5rem;
    bottom: -1.5rem;
    width: 8rem;
    aspect-ratio: 1;
    border: 1px solid rgba(184, 168, 138, 0.18);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35), transparent 64%);
    pointer-events: none;
    animation: services-glow 10s ease-in-out infinite alternate;
  }

  .services-hero__panel > * {
    position: relative;
    z-index: 1;
  }

  .services-hero__panel h3 {
    max-width: 100%;
    margin: 0.9rem 0 0.95rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 2.4vw, 2.2rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.035em;
    text-wrap: balance;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
  }

  .services-hero__panel p {
    margin: 0;
    color: var(--color-text-secondary);
    max-width: 100%;
    font-size: var(--type-body);
    line-height: 1.82;
    text-wrap: pretty;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
    animation-delay: 0.08s;
  }

  .services-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 1.45rem 0 1.65rem;
    padding: 0;
    list-style: none;
  }

  .services-pills li {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    padding: 0.26rem 0.7rem;
    border: 1px solid var(--color-line-accent);
    border-radius: 999px;
    color: rgba(47, 45, 40, 0.7);
    background: rgba(255, 255, 255, 0.7);
    font-size: var(--type-meta);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition:
      transform 0.35s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-pills li:hover {
    transform: translateY(-1px);
    border-color: rgba(111, 125, 103, 0.32);
    background: rgba(111, 125, 103, 0.06);
    color: rgba(47, 45, 40, 0.82);
  }

  .services-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.1rem;
  }

  .services-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3rem;
    padding: 0.78rem 1.25rem;
    border-radius: 999px;
    font-size: var(--type-caption);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition:
      transform 0.45s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-button:hover {
    transform: translateY(-2px);
  }

  .services-button--solid {
    border: 1px solid rgba(111, 125, 103, 0.28);
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.18);
  }

  .services-button--solid:hover {
    border-color: rgba(86, 100, 90, 0.35);
    box-shadow: 0 1.1rem 2rem rgba(86, 100, 90, 0.2);
  }

  .services-button--ghost {
    border: 1px solid var(--color-line-accent);
    background: rgba(255, 255, 255, 0.54);
    color: rgba(47, 45, 40, 0.78);
  }

  .services-button--ghost:hover {
    border-color: rgba(111, 125, 103, 0.28);
    background: rgba(111, 125, 103, 0.06);
  }

  .services-button svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .services-button:hover svg {
    transform: translateX(2px);
  }

  .services-divider {
    position: relative;
    height: clamp(3.6rem, 5vw, 4.9rem);
    margin: -0.1rem 0 -0.1rem;
    overflow: hidden;
  }

  .services-divider span {
    position: absolute;
    left: 0;
    right: 0;
    top: 0.5rem;
    height: calc(100% - 0.8rem);
    background:
      radial-gradient(circle at 10% 60%, transparent 0 0.7rem, rgba(245, 242, 235, 0.94) 0.72rem 1.1rem, transparent 1.15rem),
      radial-gradient(circle at 20% 42%, transparent 0 0.55rem, rgba(245, 242, 235, 0.98) 0.57rem 0.92rem, transparent 0.96rem),
      radial-gradient(circle at 33% 70%, transparent 0 0.72rem, rgba(245, 242, 235, 0.98) 0.74rem 1.18rem, transparent 1.22rem),
      radial-gradient(circle at 46% 46%, transparent 0 0.58rem, rgba(245, 242, 235, 0.98) 0.6rem 0.98rem, transparent 1.02rem),
      radial-gradient(circle at 58% 66%, transparent 0 0.68rem, rgba(245, 242, 235, 0.98) 0.7rem 1.08rem, transparent 1.12rem),
      radial-gradient(circle at 71% 44%, transparent 0 0.56rem, rgba(245, 242, 235, 0.98) 0.58rem 0.94rem, transparent 0.98rem),
      radial-gradient(circle at 84% 68%, transparent 0 0.74rem, rgba(245, 242, 235, 0.98) 0.76rem 1.18rem, transparent 1.22rem),
      linear-gradient(180deg, rgba(245, 242, 235, 0.96), rgba(239, 234, 224, 0.92));
    filter: drop-shadow(0 0.45rem 0.9rem rgba(57, 54, 48, 0.06));
    animation: services-divider-drift 12s ease-in-out infinite alternate;
  }

  /* ═══════════════════════════════════════════════════════════
     CLINICAL CHAPTERS — full-width editorial spreads
     ═══════════════════════════════════════════════════════════ */

  .services-list {
    position: relative;
    display: flex;
    flex-direction: column;
    margin-top: clamp(1rem, 2vw, 1.5rem);
  }

  .service-chapter {
    --chapter-accent: rgba(111, 125, 103, 0.9);
    --chapter-accent-soft: rgba(111, 125, 103, 0.06);
    --chapter-tint: rgba(111, 125, 103, 0.025);

    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0;
    padding: clamp(2.5rem, 4.2vw, 3.8rem) 0 clamp(2.5rem, 4.2vw, 3.8rem);
  }

  .service-chapter:nth-child(1) {
    --chapter-accent: rgba(111, 125, 103, 0.92);
    --chapter-accent-soft: rgba(111, 125, 103, 0.07);
    --chapter-tint: rgba(111, 125, 103, 0.028);
  }
  .service-chapter:nth-child(2) {
    --chapter-accent: rgba(184, 168, 138, 0.96);
    --chapter-accent-soft: rgba(184, 168, 138, 0.08);
    --chapter-tint: rgba(184, 168, 138, 0.03);
  }
  .service-chapter:nth-child(3) {
    --chapter-accent: rgba(138, 145, 130, 0.94);
    --chapter-accent-soft: rgba(138, 145, 130, 0.07);
    --chapter-tint: rgba(138, 145, 130, 0.028);
  }

  .service-chapter::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-line-accent) 14%, var(--color-line-accent) 86%, transparent);
  }

  .service-chapter::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 50%, var(--chapter-tint), transparent 65%);
    pointer-events: none;
    z-index: -1;
  }

  .service-chapter__head {
    display: grid;
    grid-template-columns: minmax(0, auto) minmax(0, 1fr);
    align-items: end;
    justify-content: space-between;
    gap: 2.5rem;
    padding-bottom: 1.4rem;
    border-bottom: 1px solid var(--color-line-accent-soft);
    position: relative;
  }

  .service-chapter__head::before {
    content: '';
    position: absolute;
    left: -1.4rem;
    top: -0.6rem;
    bottom: -0.6rem;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--chapter-accent), transparent);
  }

  .service-chapter__index {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .service-chapter__chapter {
    font-family: 'JetBrains Mono', 'SF Mono', ui-monospace, Menlo, monospace;
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--chapter-accent);
  }

  .service-chapter__num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .service-chapter__num em {
    font-family: 'JetBrains Mono', 'SF Mono', ui-monospace, Menlo, monospace;
    font-style: normal;
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(47, 45, 40, 0.36);
  }

  .service-chapter__kicker {
    justify-self: end;
    align-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: 'JetBrains Mono', 'SF Mono', ui-monospace, Menlo, monospace;
    font-size: var(--type-meta);
    font-weight: 500;
