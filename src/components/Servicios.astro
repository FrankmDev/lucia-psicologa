---
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';

const servicios = [
  {
    num: '01',
    title: 'Terapia Individual',
    desc: 'Un espacio seguro y confidencial para explorar tus emociones, sanar experiencias difíciles y construir una vida con mayor bienestar. Cada sesión se adapta a tu ritmo.',
    tags: ['Presencial', 'Online'],
    duration: '50 min',
  },
  {
    num: '02',
    title: 'Abordaje del Trauma',
    desc: 'Acompañamiento especializado para procesar experiencias dolorosas de forma segura. Integro el modelo IFS y técnicas psicosomáticas para aliviar la carga emocional y devolver el equilibrio a tu sistema.',
    tags: ['Trauma', 'Seguridad'],
    duration: '60-90 min',
  },
  {
    num: '03',
    title: 'Ansiedad y Estrés',
    desc: 'Aprende a gestionar la ansiedad y el agotamiento. Herramientas prácticas adaptadas para recuperar tu equilibrio.',
    tags: ['Ansiedad', 'Burnout'],
    duration: '50 min',
  },
];

const servicesImage = 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1800&auto=format&fit=crop';
---

<section id="servicios" class="servicios" data-servicios>
  <GrainOverlay opacity={0.014} />
  <AmbientLight color="rgba(255,255,255,0.28)" />
  <FloatOrb size={360} top="-12%" right="-8%" color="rgba(141,151,132,0.12)" blur={150} animation="float-1" />
  <FloatOrb size={220} bottom="12%" left="-6%" color="rgba(216,211,200,0.22)" opacity={0.32} blur={110} animation="float-2" />

  <Container maxWidth="1480px" padding="0 clamp(0.85rem, 2.5vw, 2.6rem)">
    <div class="services-shell">
      <header class="services-header reveal-blur" data-delay="80">
        <span class="services-eyebrow">Servicios</span>
        <h2>Una forma de acompañarte con más calma</h2>
        <p>
          Un entorno sereno, claro y humano para que puedas bajar el ruido, ordenar lo que te pasa y avanzar sin exigirte de más.
        </p>
      </header>

      <div class="services-hero reveal-scale" data-delay="160">
        <figure class="services-hero__image">
          <img src={servicesImage} alt="Paisaje sereno con luz suave y mar en calma" decoding="async" loading="eager" />
          <div class="services-hero__veil"></div>
          <figcaption class="services-hero__caption">
            <span>Ritmo tranquilo</span>
            <p>Una consulta que respira y te devuelve espacio para pensar mejor.</p>
          </figcaption>
        </figure>

        <article class="services-hero__panel">
          <span class="services-label">Acompañamiento clínico</span>
          <h3>Escucha, estructura y cuidado en el mismo lugar.</h3>
          <p>
            Cada sesión está pensada para ayudarte a sentir más estabilidad sin perder la delicadeza del proceso. Trabajamos con claridad, presencia y una atención adaptada a tu momento.
          </p>

          <ul class="services-pills" aria-label="Claves del acompañamiento">
            <li>Presencial y online</li>
            <li>Enfoque integrador</li>
            <li>Proceso a tu ritmo</li>
          </ul>

          <div class="services-actions">
            <a href="#contacto" class="services-button services-button--solid">
              <span>Reservar sesión</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#sobre-mi" class="services-button services-button--ghost">
              <span>Conocer más</span>
            </a>
          </div>
        </article>
      </div>

      <div class="services-divider" aria-hidden="true">
        <span></span>
      </div>

      <!-- Editorial horizontal list — replaces identical card grid -->
      <div class="services-list" aria-label="Servicios terapéuticos">
        {servicios.map((s, i) => (
          <article class="service-row reveal-up" style={`transition-delay: ${260 + i * 90}ms`}>
            <div class="service-row__num">
              <span>{s.num}</span>
            </div>
            <div class="service-row__content">
              <div class="service-row__top">
                <h3>{s.title}</h3>
                <div class="service-row__meta">
                  {s.tags.map((tag) => (
                    <span class="service-tag">{tag}</span>
                  ))}
                  <span class="service-tag service-tag--duration">{s.duration}</span>
                </div>
              </div>
              <p class="service-row__desc">{s.desc}</p>
              <a href="#contacto" class="service-row__link">
                <span>Consultar</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="services-note reveal-up" data-delay="660">
        <span class="services-note__line" aria-hidden="true"></span>
        <p>
          Si necesitas combinar enfoques o ajustar el formato, lo hacemos con flexibilidad. La prioridad es que el proceso se sienta seguro, claro y habitable.
        </p>
      </div>
    </div>
  </Container>

  <PageNumber number="03" />
</section>

<style>
  .servicios {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 1.4rem);
    background:
      radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.88), transparent 30%),
      radial-gradient(circle at 84% 14%, rgba(223, 228, 216, 0.58), transparent 30%),
      radial-gradient(circle at 70% 76%, rgba(184, 168, 138, 0.12), transparent 32%),
      linear-gradient(180deg, #fffdfa 0%, var(--color-surface) 58%, #f2efe8 100%);
  }

  .servicios::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.01) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 74%);
    opacity: 0.55;
  }

  .servicios::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    box-shadow: inset 0 0 180px rgba(255, 255, 255, 0.22);
  }

  .services-shell {
    position: relative;
    z-index: 2;
  }

  .services-header {
    max-width: 58rem;
    margin: 0 auto clamp(2.5rem, 4.5vw, 3.8rem);
    text-align: center;
  }

  .services-label {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-label::before {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-header h2 {
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .services-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .services-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-eyebrow::before,
  .services-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(24rem, 0.82fr);
    gap: clamp(1.1rem, 1.8vw, 1.35rem);
    align-items: stretch;
  }

  .services-hero__image,
  .services-hero__panel {
    position: relative;
    border: 1px solid var(--color-line-accent-soft);
    background: rgba(255, 253, 248, 0.88);
    box-shadow: 0 1.4rem 3rem rgba(57, 54, 48, 0.06);
  }

  .services-hero__image {
    min-height: clamp(26rem, 36vw, 34rem);
    overflow: hidden;
    border-radius: 1.6rem;
  }

  .services-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 58%;
    filter: grayscale(10%) saturate(0.82) contrast(1.02) brightness(0.62);
    transform: scale(1.03);
    animation: services-image-breathe 18s ease-in-out infinite alternate;
  }

  .services-hero__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 48% 28%, rgba(255, 251, 244, 0.1), transparent 36%),
      linear-gradient(180deg, rgba(13, 10, 8, 0.12) 0%, rgba(13, 10, 8, 0.46) 100%);
  }

  .services-hero__caption {
    position: absolute;
    left: clamp(1rem, 2.4vw, 1.7rem);
    right: clamp(1rem, 2.4vw, 1.7rem);
    bottom: clamp(1rem, 2.4vw, 1.6rem);
    max-width: 28rem;
    color: rgba(255, 251, 244, 0.9);
  }

  .services-hero__caption span {
    display: inline-flex;
    margin-bottom: 0.65rem;
    font-size: var(--type-meta);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .services-hero__caption p {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.48;
    text-wrap: balance;
  }

  .services-hero__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.1rem;
    padding: clamp(1.9rem, 3.3vw, 3.1rem);
    border-radius: 1.6rem;
    border-color: rgba(111, 125, 103, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(249, 246, 239, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.48), transparent 28%),
      radial-gradient(circle at 100% 100%, rgba(184, 168, 138, 0.12), transparent 36%);
    overflow: hidden;
  }

  .services-hero__panel::before {
    content: '';
    position: absolute;
    inset: 1rem auto 1rem 1rem;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(111, 125, 103, 0.34), transparent);
    pointer-events: none;
  }

  .services-hero__panel::after {
    content: '';
    position: absolute;
    right: -1.5rem;
    bottom: -1.5rem;
    width: 8rem;
    aspect-ratio: 1;
    border: 1px solid rgba(184, 168, 138, 0.18);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35), transparent 64%);
    pointer-events: none;
    animation: services-glow 10s ease-in-out infinite alternate;
  }

  .services-hero__panel > * {
    position: relative;
    z-index: 1;
  }

  .services-hero__panel h3 {
    max-width: 16ch;
    margin: 0.9rem 0 0.95rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-panel-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.06;
    letter-spacing: -0.04em;
    text-wrap: balance;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
  }

  .services-hero__panel p {
    margin: 0;
    color: var(--color-text-secondary);
    max-width: 34ch;
    font-size: var(--type-body);
    line-height: 1.82;
    text-wrap: pretty;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
    animation-delay: 0.08s;
  }

  .services-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 1.45rem 0 1.65rem;
    padding: 0;
    list-style: none;
  }

  .services-pills li {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding: 0.34rem 0.82rem;
    border: 1px solid var(--color-line-accent);
    border-radius: 999px;
    color: rgba(47, 45, 40, 0.72);
    background: rgba(255, 255, 255, 0.7);
    font-size: var(--type-caption);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 0.35s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-pills li:hover {
    transform: translateY(-1px);
    border-color: rgba(111, 125, 103, 0.32);
    background: rgba(111, 125, 103, 0.06);
    color: rgba(47, 45, 40, 0.82);
  }

  .services-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.1rem;
  }

  .services-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3rem;
    padding: 0.78rem 1.25rem;
    border-radius: 999px;
    font-size: var(--type-caption);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition:
      transform 0.45s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-button:hover {
    transform: translateY(-2px);
  }

  .services-button--solid {
    border: 1px solid rgba(111, 125, 103, 0.28);
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.18);
  }

  .services-button--solid:hover {
    border-color: rgba(86, 100, 90, 0.35);
    box-shadow: 0 1.1rem 2rem rgba(86, 100, 90, 0.2);
  }

  .services-button--ghost {
    border: 1px solid var(--color-line-accent);
    background: rgba(255, 255, 255, 0.54);
    color: rgba(47, 45, 40, 0.78);
  }

  .services-button--ghost:hover {
    border-color: rgba(111, 125, 103, 0.28);
    background: rgba(111, 125, 103, 0.06);
  }

  .services-button svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .services-button:hover svg {
    transform: translateX(2px);
  }

  .services-divider {
    position: relative;
    height: clamp(3.6rem, 5vw, 4.9rem);
    margin: -0.1rem 0 -0.1rem;
    overflow: hidden;
  }

  .services-divider span {
    position: absolute;
    left: 0;
    right: 0;
    top: 0.5rem;
    height: calc(100% - 0.8rem);
    background:
      radial-gradient(circle at 10% 60%, transparent 0 0.7rem, rgba(245, 242, 235, 0.94) 0.72rem 1.1rem, transparent 1.15rem),
      radial-gradient(circle at 20% 42%, transparent 0 0.55rem, rgba(245, 242, 235, 0.98) 0.57rem 0.92rem, transparent 0.96rem),
      radial-gradient(circle at 33% 70%, transparent 0 0.72rem, rgba(245, 242, 235, 0.98) 0.74rem 1.18rem, transparent 1.22rem),
      radial-gradient(circle at 46% 46%, transparent 0 0.58rem, rgba(245, 242, 235, 0.98) 0.6rem 0.98rem, transparent 1.02rem),
      radial-gradient(circle at 58% 66%, transparent 0 0.68rem, rgba(245, 242, 235, 0.98) 0.7rem 1.08rem, transparent 1.12rem),
      radial-gradient(circle at 71% 44%, transparent 0 0.56rem, rgba(245, 242, 235, 0.98) 0.58rem 0.94rem, transparent 0.98rem),
      radial-gradient(circle at 84% 68%, transparent 0 0.74rem, rgba(245, 242, 235, 0.98) 0.76rem 1.18rem, transparent 1.22rem),
      linear-gradient(180deg, rgba(245, 242, 235, 0.96), rgba(239, 234, 224, 0.92));
    filter: drop-shadow(0 0.45rem 0.9rem rgba(57, 54, 48, 0.06));
    animation: services-divider-drift 12s ease-in-out infinite alternate;
  }

  /* ═══════════════════════════════════════════════════════════
     EDITORIAL HORIZONTAL LIST — replaces identical card grid
     ═══════════════════════════════════════════════════════════ */

  .services-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-line-accent);
  }

  .service-row {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1.5rem, 3vw, 2.8rem);
    align-items: start;
    padding: clamp(2rem, 3.5vw, 3.2rem) clamp(0.5rem, 1.5vw, 1.2rem);
    border-bottom: 1px solid var(--color-line-accent);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.72), rgba(251, 248, 241, 0.52));
    will-change: transform;
    transition:
      transform 0.55s var(--ease-out-expo),
      border-color 0.45s ease,
      background 0.45s ease,
      box-shadow 0.55s var(--ease-out-expo);
  }

  .service-row:nth-child(1) { --svc-row-accent: rgba(111, 125, 103, 0.85); --svc-row-accent-soft: rgba(111, 125, 103, 0.08); }
  .service-row:nth-child(2) { --svc-row-accent: rgba(184, 168, 138, 0.95); --svc-row-accent-soft: rgba(184, 168, 138, 0.1); }
  .service-row:nth-child(3) { --svc-row-accent: rgba(138, 145, 130, 0.92); --svc-row-accent-soft: rgba(138, 145, 130, 0.1); }

  .service-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--svc-row-accent);
    opacity: 0;
    transition: opacity 0.45s ease;
  }

  .service-row::after {
    content: '';
    position: absolute;
    inset: 0.4rem;
    border: 1px solid transparent;
    border-radius: 0.35rem;
    pointer-events: none;
    transition: border-color 0.55s ease, transform 0.55s var(--ease-out-expo);
  }

  .service-row:hover {
    transform: translateY(-4px);
    border-bottom-color: var(--svc-row-accent);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.92), rgba(249, 246, 239, 0.78)),
      radial-gradient(circle at 100% 0%, var(--svc-row-accent-soft), transparent 50%);
    box-shadow: 0 1.8rem 3.6rem rgba(57, 54, 48, 0.08);
  }

  .service-row:hover::before {
    opacity: 0.7;
  }

  .service-row:hover::after {
    border-color: var(--svc-row-accent-soft);
    transform: scale(0.985);
  }

  .service-row__num {
    position: relative;
    flex-shrink: 0;
    padding-top: 0.2rem;
  }

  .service-row__num::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 140%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%) scale(0);
    border-radius: 50%;
    background: var(--svc-row-accent-soft);
    opacity: 0;
    transition: transform 0.55s var(--ease-out-expo), opacity 0.45s ease;
    pointer-events: none;
  }

  .service-row:hover .service-row__num::before {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }

  .service-row__num span {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(3.4rem, 5vw, 4.4rem);
    height: clamp(3.4rem, 5vw, 4.4rem);
    border: 1px solid rgba(111, 125, 103, 0.18);
    border-radius: 50%;
    color: var(--svc-row-accent);
    font-family: var(--font-display);
    font-size: var(--type-lead);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: 0.02em;
    background: rgba(255, 253, 248, 0.8);
    box-shadow: 0 0.15rem 0.45rem rgba(57, 54, 48, 0.04);
    transition:
      transform 0.55s var(--ease-out-expo),
      border-color 0.4s ease,
      background 0.4s ease,
      color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .service-row:hover .service-row__num span {
    transform: scale(1.06);
    border-color: var(--svc-row-accent);
    background: rgba(255, 255, 255, 0.95);
    color: var(--color-accent-deep);
    box-shadow: 0 0.4rem 1rem rgba(57, 54, 48, 0.06);
  }

  .service-row__content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    min-width: 0;
  }

  .service-row__content::after {
    content: '';
    position: absolute;
    right: 0;
    top: -0.2rem;
    font-family: var(--font-display);
    font-size: clamp(5rem, 8vw, 8rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    color: rgba(111, 125, 103, 0.028);
    user-select: none;
    pointer-events: none;
    transition: color 0.55s ease, transform 0.55s var(--ease-out-expo);
  }

  .service-row:nth-child(1) .service-row__content::after { content: 'I'; }
  .service-row:nth-child(2) .service-row__content::after { content: 'T'; }
  .service-row:nth-child(3) .service-row__content::after { content: 'A'; }

  .service-row:hover .service-row__content::after {
    color: var(--svc-row-accent-soft);
    transform: translateY(-0.2rem);
  }

  .service-row__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .service-row__top h3 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-card-title-lg);
    font-style: italic;
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-wrap: balance;
    transition: color 0.4s ease, transform 0.5s var(--ease-out-expo);
  }

  .service-row:hover .service-row__top h3 {
    color: var(--color-accent-deep);
