---
const servicios = [
  {
    num: '01',
    title: 'Terapia Individual',
    desc: 'Un espacio seguro y confidencial para explorar tus emociones, sanar heridas y construir una vida más plena. Adaptado a tu ritmo y a tus necesidades.',
    image: 'https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?q=80&w=1200&auto=format&fit=crop',
  },
  {
    num: '02',
    title: 'EMDR',
    desc: 'Terapia especializada para procesar recuerdos traumáticos mediante estimulación bilateral. Una de las intervenciones con mayor evidencia científica para el trauma.',
    image: 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1200&auto=format&fit=crop',
  },
  {
    num: '03',
    title: 'Ansiedad y Estrés',
    desc: 'Aprende a gestionar la ansiedad, el estrés crónico y el agotamiento emocional. Herramientas concretas para recuperar tu equilibrio interior.',
    image: 'https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=1200&auto=format&fit=crop',
  },
  {
    num: '04',
    title: 'Crecimiento Personal',
    desc: 'Acompañamiento para quienes buscan un cambio consciente: claridad de propósito, autoestima sólida y una relación más auténtica contigo misma.',
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1200&auto=format&fit=crop',
  },
];
---

<section id="servicios" class="servicios">
  <div class="servicios-sticky">
    <div class="servicios-header reveal">
      <span class="type-eyebrow">Servicios</span>
      <h2 class="servicios-title">
        <span class="type-display">Cómo puedo</span>
        <span class="type-display accent">ayudarte</span>
      </h2>
    </div>

    <div class="servicios-track" id="serviciosTrack">
      {servicios.map((s, i) => (
        <div class="service-panel" data-index={i}>
          <div class="panel-visual">
            <img src={s.image} alt={s.title} loading="lazy" decoding="async" />
            <div class="panel-overlay"></div>
          </div>
          <div class="panel-content">
            <span class="panel-num">{s.num}</span>
            <h3 class="panel-title">{s.title}</h3>
            <p class="panel-desc">{s.desc}</p>
            <a href="#contacto" class="panel-link">Saber más →</a>
          </div>
          <div class="panel-watermark" aria-hidden="true">{s.num}</div>
        </div>
      ))}
    </div>

    <!-- Progress bar -->
    <div class="track-progress">
      <div class="track-bar" id="trackBar"></div>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector('.servicios');
  const track = document.getElementById('serviciosTrack');
  const bar = document.getElementById('trackBar');

  function updateScroll() {
    const rect = section.getBoundingClientRect();
    const sectionHeight = section.offsetHeight;
    const viewportHeight = window.innerHeight;
    const scrollable = sectionHeight - viewportHeight;
    const scrolled = -rect.top;
    const progress = Math.max(0, Math.min(1, scrolled / scrollable));
    const translate = progress * (track.scrollWidth - window.innerWidth);
    track.style.transform = `translateX(-${translate}px)`;
    bar.style.transform = `scaleX(${progress})`;
  }

  window.addEventListener('scroll', updateScroll, { passive: true });
  window.addEventListener('resize', updateScroll);
</script>

<style>
  .servicios {
    position: relative;
    height: 400vh;
    background: var(--ink);
    color: #fff;
  }
  .servicios-sticky {
    position: sticky;
    top: 0;
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .servicios-header {
    position: absolute;
    top: 6vh;
    left: 6vw;
    z-index: 10;
  }
  .servicios-header .type-eyebrow {
    color: rgba(255,255,255,0.3);
    display: block;
    margin-bottom: 1rem;
  }
  .servicios-title {
    display: flex;
    flex-direction: column;
    gap: 0.05em;
  }
  .servicios-title .type-display {
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    color: #fff;
  }
  .servicios-title .accent {
    color: var(--earth);
  }

  .servicios-track {
    display: flex;
    gap: 0;
    will-change: transform;
    padding-left: 6vw;
    padding-top: 10vh;
  }

  .service-panel {
    position: relative;
    flex-shrink: 0;
    width: 85vw;
    max-width: 1100px;
    height: 65vh;
    margin-right: 4vw;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: center;
    gap: 3rem;
    padding: 3rem;
    border: 0.5px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.02);
    overflow: hidden;
  }

  .panel-visual {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 4px;
    overflow: hidden;
  }
  .panel-visual img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(30%);
    transition: filter 0.8s ease, transform 0.8s var(--ease-out-expo);
  }
  .service-panel:hover .panel-visual img {
    filter: grayscale(0%);
    transform: scale(1.04);
  }
  .panel-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(42,31,26,0.3), transparent 60%);
  }

  .panel-content {
    position: relative;
    z-index: 2;
  }
  .panel-num {
    display: block;
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-bottom: 1.5rem;
  }
  .panel-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  .panel-desc {
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255,255,255,0.45);
    margin-bottom: 2rem;
    max-width: 380px;
  }
  .panel-link {
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--earth);
    position: relative;
    padding-bottom: 4px;
  }
  .panel-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 1px;
    background: var(--earth);
    transition: width 0.5s var(--ease-out-expo);
  }
  .panel-link:hover::after {
    width: 100%;
  }

  .panel-watermark {
    position: absolute;
    bottom: -4vh;
    right: -2vw;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20vw;
    font-weight: 300;
    color: rgba(255,255,255,0.015);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .track-progress {
    position: absolute;
    bottom: 6vh;
    left: 6vw;
    right: 6vw;
    height: 1px;
    background: rgba(255,255,255,0.08);
    z-index: 10;
  }
  .track-bar {
    height: 100%;
    background: var(--earth);
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 0.1s linear;
  }

  @media (max-width: 900px) {
    .service-panel {
      width: 90vw;
      grid-template-columns: 1fr;
      height: auto;
      min-height: 55vh;
      padding: 2rem;
    }
    .panel-visual { height: 200px; }
    .panel-watermark { font-size: 30vw; }
  }
</style>
