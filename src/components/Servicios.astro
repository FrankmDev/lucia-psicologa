---
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';

const servicios = [
  {
    num: '01',
    title: 'Terapia Individual',
    desc: 'Un espacio seguro y confidencial para explorar lo que te ocurre, entender tus patrones y construir recursos emocionales. La intervención se adapta a tu problemática, tu momento vital y tus necesidades para que el proceso tenga dirección y continuidad.',
    tags: ['Presencial', 'Online', 'A medida'],
    duration: '50 min',
  },
  {
    num: '02',
    title: 'Trauma y EMDR',
    desc: 'Acompañamiento especializado para procesar experiencias dolorosas, bloqueos emocionales o eventos traumáticos que siguen afectando tu presente. Trabajo desde el modelo PISA (Procesamiento de la Información a Sistemas Adaptativos) y la estimulación bilateral propia del EMDR cuando la evaluación clínica indica que puede ayudarte.',
    tags: ['Trauma', 'EMDR', 'PISA'],
    duration: '60-90 min',
  },
  {
    num: '03',
    title: 'Ansiedad y Estrés',
    desc: 'Trabajo terapéutico para comprender la ansiedad, regular la activación corporal y responder de forma más flexible ante pensamientos, exigencias y situaciones que te desbordan. Combinamos herramientas prácticas con trabajo emocional de fondo para que puedas recuperar margen.',
    tags: ['Ansiedad', 'Estrés', 'Regulación'],
    duration: '50 min',
  },
];

const enfoques = [
  {
    title: 'TCC',
    fullName: 'Terapia Cognitivo Conductual',
    text: 'Ayuda a identificar la relación entre pensamientos, emociones y conductas. Aporta herramientas concretas para cuestionar patrones que sostienen el malestar y practicar respuestas más ajustadas en la vida diaria.',
  },
  {
    title: 'ACT',
    fullName: 'Terapia de Aceptación y Compromiso',
    text: 'Trabaja la relación con pensamientos y emociones difíciles sin luchar contra ellos. El objetivo es avanzar hacia una vida más coherente con tus valores, incluso cuando aparecen ansiedad, miedo o dolor.',
  },
  {
    title: 'TFE',
    fullName: 'Terapia Focalizada en Emociones',
    text: 'Profundiza en lo que sientes para comprender necesidades, heridas y formas de protección. Es útil cuando cuesta poner palabras a la emoción o cuando se repiten patrones relacionales que generan sufrimiento.',
  },
  {
    title: 'IFS',
    fullName: 'Sistema de Familia Interna',
    text: 'Entiende la mente como un sistema de partes internas que intentan protegerte. Permite acercarse con respeto a defensas, bloqueos o conflictos internos para comprender qué función cumplen.',
  },
  {
    title: 'EMDR',
    fullName: 'Desensibilización y Reprocesamiento por Movimientos Oculares',
    text: 'Favorece el reprocesamiento de recuerdos o vivencias que quedaron almacenadas de forma fragmentada o congelada. Puede incluir movimientos oculares, sonidos alternos o golpecitos técnicos conocidos como tapping dentro de un marco seguro.',
  },
];

const servicesImage = 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1800&auto=format&fit=crop';
---

<section id="servicios" class="servicios" data-servicios>
  <GrainOverlay opacity={0.014} />
  <AmbientLight color="rgba(255,255,255,0.28)" />
  <FloatOrb size={360} top="-12%" right="-8%" color="rgba(141,151,132,0.12)" blur={150} animation="float-1" />
  <FloatOrb size={220} bottom="12%" left="-6%" color="rgba(216,211,200,0.22)" opacity={0.32} blur={110} animation="float-2" />

  <Container maxWidth="1480px" padding="0 clamp(0.85rem, 2.5vw, 2.6rem)">
    <div class="services-shell">
      <header class="services-header reveal-blur" data-delay="80">
        <span class="services-eyebrow">Servicios</span>
        <h2>Una terapia adaptada a tu historia y a tu presente</h2>
        <p>
          Integro distintos enfoques terapéuticos para ajustar el tratamiento a tu problemática, tu historia y tus objetivos. No trabajo con un protocolo igual para todo el mundo: elegimos las herramientas según lo que necesitas en cada momento.
        </p>
      </header>

      <div class="services-hero reveal-scale" data-delay="160">
        <figure class="services-hero__image">
          <img src={servicesImage} alt="Paisaje sereno con luz suave y mar en calma" decoding="async" loading="eager" />
          <div class="services-hero__veil"></div>
          <figcaption class="services-hero__caption">
            <span>Ritmo tranquilo</span>
            <p>Un espacio para bajar el ritmo, ordenar lo que ocurre y decidir el siguiente paso.</p>
          </figcaption>
        </figure>

        <article class="services-hero__panel">
          <span class="services-label">Acompañamiento clínico</span>
          <h3>Escucha, estructura y herramientas elegidas para tu caso.</h3>
          <p>
            La terapia no tiene por qué seguir una única técnica. Según lo que necesites, combinamos trabajo cognitivo, emocional, corporal y de procesamiento del trauma para avanzar con seguridad, claridad y objetivos revisables.
          </p>

          <ul class="services-pills" aria-label="Claves del acompañamiento">
            <li>Presencial y online</li>
            <li>TCC, ACT, TFE e IFS</li>
            <li>Trauma y EMDR</li>
          </ul>

          <div class="services-actions">
            <a href="#contacto" class="services-button services-button--solid">
              <span>Solicitar primera sesión</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#sobre-mi" class="services-button services-button--ghost">
              <span>Conocer a Lucía</span>
            </a>
          </div>
        </article>
      </div>

      <section class="services-methods reveal-up" aria-labelledby="enfoques-title">
        <div class="services-methods__intro">
          <span class="services-label">Tipos de terapia</span>
          <h3 id="enfoques-title">Distintos caminos para trabajar lo que te ocurre.</h3>
          <p>
            Elegimos el enfoque según tu situación. A veces necesitas herramientas para el día a día; otras, comprender tus emociones, trabajar partes internas o procesar una experiencia traumática de forma gradual.
          </p>
        </div>

        <div class="methods-grid">
          {enfoques.map((enfoque) => (
            <article class="method-card">
              <span>{enfoque.title}</span>
              <h4>{enfoque.fullName}</h4>
              <p>{enfoque.text}</p>
            </article>
          ))}
        </div>
      </section>

      <div class="services-accordion" data-accordion role="list" aria-label="Servicios terapéuticos">
        {servicios.map((s, i) => (
          <div class="accordion-item" data-accordion-item role="listitem">
            <button class="accordion-trigger" data-accordion-trigger type="button" aria-expanded="false">
              <span class="accordion-num" aria-hidden="true">{s.num}</span>
              <span class="accordion-title">{s.title}</span>
              <span class="accordion-duration">{s.duration}</span>
              <span class="accordion-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <rect x="2.5" y="2.5" width="15" height="15" rx="7.5" stroke="currentColor" stroke-width="0.8" fill="none"/>
                  <path d="M10 6.5v7M6.5 10h7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
            <div class="accordion-body" data-accordion-body role="region">
              <div class="accordion-content">
                <p class="accordion-desc">{s.desc}</p>
                <ul class="accordion-tags" aria-label="Modalidad y duración">
                  {s.tags.map((tag) => (
                    <li class="accordion-tag">{tag}</li>
                  ))}
                </ul>
                <a href="#contacto" class="accordion-cta">
                  <span>Solicitar orientación</span>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <footer class="services-outro" data-outro>
        <p>
          Si necesitas combinar enfoques o ajustar el formato, lo hacemos con flexibilidad. La prioridad es que el proceso sea seguro, comprensible y ajustado a tu caso.
        </p>
        <a href="#contacto" class="services-outro__cta">
          <span>Solicitar primera sesión</span>
          <span class="services-outro__arrow" aria-hidden="true">→</span>
        </a>
      </footer>
    </div>
  </Container>

  <PageNumber number="03" />
</section>

<script>
  const accordion = document.querySelector('[data-accordion]');
  if (accordion) {
    const items = accordion.querySelectorAll('[data-accordion-item]');

    items.forEach((item) => {
      const trigger = item.querySelector('[data-accordion-trigger]');
      trigger.addEventListener('click', () => {
        const isOpen = item.dataset.open === 'true';
        items.forEach((el) => {
          const t = el.querySelector('[data-accordion-trigger]');
          t.setAttribute('aria-expanded', 'false');
          delete el.dataset.open;
        });
        if (!isOpen) {
          item.dataset.open = 'true';
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }
</script>

<style>
  .servicios {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
    background:
      radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.88), transparent 30%),
      radial-gradient(circle at 84% 14%, rgba(223, 228, 216, 0.58), transparent 30%),
      radial-gradient(circle at 70% 76%, rgba(184, 168, 138, 0.12), transparent 32%),
      linear-gradient(180deg, #fffdfa 0%, var(--color-surface) 58%, #f2efe8 100%);
  }

  .servicios::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.01) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 74%);
    opacity: 0.55;
  }

  .servicios::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    box-shadow: inset 0 0 180px rgba(255, 255, 255, 0.22);
  }

  .services-shell {
    position: relative;
    z-index: 2;
  }

  .services-header {
    max-width: 58rem;
    margin: 0 auto clamp(2.5rem, 4.5vw, 3.8rem);
    text-align: center;
  }

  .services-label {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-label::before {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-header h2 {
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .services-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .services-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-eyebrow::before,
  .services-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(24rem, 0.82fr);
    gap: clamp(1.1rem, 1.8vw, 1.35rem);
    align-items: stretch;
  }

  .services-hero__image,
  .services-hero__panel {
    position: relative;
    border: 1px solid var(--color-line-accent-soft);
    background: rgba(255, 253, 248, 0.88);
    box-shadow: 0 1.4rem 3rem rgba(57, 54, 48, 0.06);
  }

  .services-hero__image {
    min-height: clamp(26rem, 36vw, 34rem);
    overflow: hidden;
    border-radius: 1.6rem;
  }

  .services-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 58%;
    filter: grayscale(10%) saturate(0.82) contrast(1.02) brightness(0.62);
    transform: scale(1.03);
    animation: services-image-breathe 18s ease-in-out infinite alternate;
    will-change: transform;
  }

  .services-hero__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 48% 28%, rgba(255, 251, 244, 0.1), transparent 36%),
      linear-gradient(180deg, rgba(13, 10, 8, 0.12) 0%, rgba(13, 10, 8, 0.46) 100%);
  }

  .services-hero__caption {
    position: absolute;
    left: clamp(1rem, 2.4vw, 1.7rem);
    right: clamp(1rem, 2.4vw, 1.7rem);
    bottom: clamp(1rem, 2.4vw, 1.6rem);
    max-width: 28rem;
    color: rgba(255, 251, 244, 0.9);
  }

  .services-hero__caption span {
    display: inline-flex;
    margin-bottom: 0.65rem;
    font-size: var(--type-meta);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .services-hero__caption p {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.48;
    text-wrap: balance;
  }

  .services-hero__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.1rem;
    padding: var(--card-pd-lg);
    border-radius: var(--card-radius);
    border-color: rgba(111, 125, 103, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(249, 246, 239, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.48), transparent 28%),
      radial-gradient(circle at 100% 100%, rgba(184, 168, 138, 0.12), transparent 36%);
    overflow: hidden;
  }

  .services-hero__panel::before {
    content: '';
    position: absolute;
    inset: 1rem auto 1rem 1rem;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(111, 125, 103, 0.34), transparent);
    pointer-events: none;
  }

  .services-hero__panel::after {
    content: '';
    position: absolute;
    right: -1.5rem;
    bottom: -1.5rem;
    width: 8rem;
    aspect-ratio: 1;
    border: 1px solid rgba(184, 168, 138, 0.18);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35), transparent 64%);
    pointer-events: none;
    animation: services-glow 10s ease-in-out infinite alternate;
  }

  .services-hero__panel > * {
    position: relative;
    z-index: 1;
  }

  .services-hero__panel h3 {
    max-width: 16ch;
    margin: 0.9rem 0 0.95rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-panel-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.06;
    letter-spacing: -0.04em;
    text-wrap: balance;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
  }

  .services-hero__panel p {
    margin: 0;
    color: var(--color-text-secondary);
    max-width: 34ch;
    font-size: var(--type-body);
    line-height: 1.82;
    text-wrap: pretty;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
    animation-delay: 0.08s;
  }

  .services-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 1.45rem 0 1.65rem;
    padding: 0;
    list-style: none;
  }

  .services-pills li {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding: 0.34rem 0.82rem;
    border: 1px solid var(--color-line-accent);
    border-radius: 999px;
    color: rgba(47, 45, 40, 0.72);
    background: rgba(255, 255, 255, 0.7);
    font-size: var(--type-caption);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 0.35s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-pills li:hover {
    transform: translateY(-1px);
    border-color: rgba(111, 125, 103, 0.32);
    background: rgba(111, 125, 103, 0.06);
    color: rgba(47, 45, 40, 0.82);
  }

  .services-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.1rem;
  }

  .services-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3rem;
    padding: 0.78rem 1.25rem;
    border-radius: 999px;
    font-size: var(--type-caption);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition:
      transform 0.45s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-button:hover {
    transform: translateY(-2px);
  }

  .services-button--solid {
    border: 1px solid rgba(111, 125, 103, 0.28);
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.18);
  }

  .services-button--solid:hover {
    border-color: rgba(86, 100, 90, 0.35);
    box-shadow: 0 1.1rem 2rem rgba(86, 100, 90, 0.2);
  }

  .services-button--ghost {
    border: 1px solid var(--color-line-accent);
    background: rgba(255, 255, 255, 0.54);
    color: rgba(47, 45, 40, 0.78);
  }

  .services-button--ghost:hover {
    border-color: rgba(111, 125, 103, 0.28);
    background: rgba(111, 125, 103, 0.06);
  }

  .services-button svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .services-button:hover svg {
    transform: translateX(2px);
  }

  .services-methods {
    display: grid;
    grid-template-columns: minmax(18rem, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(1rem, 2vw, 1.35rem);
    align-items: stretch;
    margin: clamp(1.15rem, 2.4vw, 1.7rem) 0 clamp(2.8rem, 5vw, 4.6rem);
  }

  .services-methods__intro {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100%;
    padding: var(--card-pd-lg);
    border-block: 1px solid rgba(111, 125, 103, 0.16);
    background:
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.42), transparent 32%),
      linear-gradient(180deg, rgba(255, 253, 248, 0.58), rgba(250, 248, 242, 0.22));
  }

  .services-methods__intro h3 {
    max-width: 14ch;
    margin: 0.9rem 0 0.95rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-panel-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.06;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .services-methods__intro p {
    max-width: 38ch;
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.78;
    text-wrap: pretty;
  }

  .methods-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .method-card {
    min-height: 13rem;
    padding: clamp(1.15rem, 2.2vw, 1.55rem);
    border: 1px solid rgba(111, 125, 103, 0.13);
    border-radius: var(--card-radius-sm);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.86), rgba(249, 246, 239, 0.68)),
      radial-gradient(circle at 100% 0%, rgba(223, 228, 216, 0.34), transparent 34%);
    transition: transform 0.35s ease, border-color 0.35s ease, background 0.35s ease;
  }

  .method-card:hover {
    transform: translateY(-0.16rem);
    border-color: rgba(111, 125, 103, 0.24);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(249, 246, 239, 0.78)),
      radial-gradient(circle at 100% 0%, rgba(223, 228, 216, 0.48), transparent 34%);
  }

  .method-card span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    min-height: 2rem;
    margin-bottom: 1.05rem;
    padding: 0.2rem 0.62rem;
    border: 1px solid rgba(111, 125, 103, 0.16);
    border-radius: 999px;
    color: var(--color-accent);
    background: rgba(255, 255, 255, 0.58);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  .method-card h4 {
    margin: 0 0 0.58rem;
    color: rgba(47, 45, 40, 0.9);
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.15;
    text-wrap: balance;
  }

  .method-card p {
    margin: 0;
    color: #5f5c55;
    font-size: var(--type-card-body);
    line-height: 1.62;
    text-wrap: pretty;
  }

  /* ── Accordion ──────────────────────────────────────────── */
  .services-accordion {
    max-width: 64rem;
    margin: 0 auto;
    border-top: 1px solid rgba(111, 125, 103, 0.12);
  }

  .accordion-item {
    position: relative;
    border-bottom: 1px solid rgba(111, 125, 103, 0.10);
  }

  .accordion-item:first-child {
    --accent: rgba(111, 125, 103, 0.85);
  }
  .accordion-item:nth-child(2) {
