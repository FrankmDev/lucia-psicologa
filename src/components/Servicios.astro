---
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';

const enfoques = [
  {
    label: 'TCC',
    title: 'Terapia Cognitivo-Conductual (TCC)',
    tagline: 'Desactivar tus reacciones automáticas y aprender nuevas formas de actuar ante las dificultades del día a día.',
    consiste:
      'Es una terapia profundamente práctica y de colaboración. Funciona como un entrenamiento: analizamos el "bucle" o circuito cerrado que se crea entre lo que piensas, lo que sientes y lo que terminas haciendo (por ejemplo: pensar "voy a fallar" → sentir ansiedad → evitar hacer la tarea).',
    ayuda:
      'Aprenderás a cuestionar y flexibilizar esos pensamientos, y a adquirir herramientas y estrategias concretas para gestionar el día a día, reducir la ansiedad y romper círculos viciosos.',
    color: '111, 125, 103',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  },
  {
    label: 'ACT',
    title: 'Terapia de Aceptación y Compromiso (ACT)',
    tagline: 'Dejar de luchar contra lo que no puedes controlar y empezar a caminar hacia lo que de verdad te importa.',
    consiste:
      'A diferencia de otras terapias, aquí no intentamos "eliminar" o "cambiar" los pensamientos o emociones desagradables. Aprendemos a aceptarlos y a hacerles espacio para que dejen de dominarnos.',
    ayuda:
      'Te ayuda a entrenar la flexibilidad mental y a descubrir cuáles son tus valores reales (lo que de verdad da sentido a tu vida). Así, podrás tomar decisiones y actuar de forma coherente con esos valores, incluso cuando sientas miedo o malestar.',
    color: '184, 168, 138',
    icon: 'M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 007.92 12.446a9 9 0 11-8.313-12.454z',
  },
  {
    label: 'TFE',
    title: 'Terapia Focalizada en las Emociones (TFE)',
    tagline: 'Utiliza tus emociones como una brújula para entender tus necesidades y sanar tus relaciones.',
    consiste:
      'Se basa en la idea de que las emociones no son el problema, sino la clave del cambio. En lugar de analizarlas intelectualmente, nos sumergimos en ellas en un espacio seguro para entender qué nos están queriendo decir.',
    ayuda:
      'Te ayuda a transformar emociones dolorosas (como la vergüenza o el miedo al abandono) en emociones sanadoras, permitiéndote construir vínculos más seguros, fuertes y conectados con los demás.',
    color: '138, 154, 137',
    icon: 'M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z',
  },
  {
    label: 'IFS',
    title: 'Terapia de los Sistemas de la Familia Interna (IFS)',
    tagline: 'Hacer las paces con todas tus "partes" internas para recuperar el equilibrio y la autocompasión.',
    consiste:
      '¿Alguna vez has sentido que "una parte de mí quiere hacer esto, pero otra parte siente pánico"? IFS entiende que nuestra mente está formada por diferentes "partes" (como la autoexigente, la miedosa o la que busca protegerse).',
    ayuda:
      'En lugar de "pelear" contra los aspectos de ti que no te gustan, aprenderás a escucharlos con curiosidad y compasión. Al entender por qué actúan así y sanar sus heridas, tu "Yo central" (más sabio, calmado y adulto) toma las riendas de tu vida con armonía.',
    color: '122, 138, 138',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  },
  {
    label: 'EMDR',
    title: 'EMDR (Desensibilización y Reprocesamiento por Movimientos Oculares)',
    tagline: 'Ayuda a tu cerebro a archivar y sanar recuerdos dolorosos o traumáticos que se quedaron "atascados".',
    consiste:
      'Cuando vivimos experiencias muy difíciles (desde pequeños traumas cotidianos hasta eventos graves), a veces el cerebro no puede procesar esa información y el recuerdo se queda "bloqueado" con toda su carga de dolor, ansiedad o miedo. EMDR utiliza la estimulación bilateral (como movimientos oculares guiados) para activar el sistema natural de procesamiento del cerebro.',
    ayuda:
      'Permite que el cerebro "reprocese" ese recuerdo. No vas a olvidar lo que pasó, pero la carga emocional dolorosa desaparecerá: el recuerdo dejará de doler en el presente y pasará a ser simplemente parte de tu historia.',
    color: '168, 138, 122',
    icon: 'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0',
  },
];

const servicesImage = 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1800&auto=format&fit=crop';
---

<section id="servicios" class="servicios section--cream">
  <GrainOverlay opacity={0.014} />
  <AmbientLight color="rgba(255,255,255,0.28)" />
  <FloatOrb size={360} top="-12%" right="-8%" color="rgba(141,151,132,0.12)" blur={150} animation="float-1" />
  <FloatOrb size={220} bottom="12%" left="-6%" color="rgba(216,211,200,0.22)" opacity={0.32} blur={110} animation="float-2" />

  <Container maxWidth="1480px" padding="0 var(--content-padding-x)">
    <div class="services-shell">
      <header class="services-header reveal-blur" data-delay="80">
        <span class="services-eyebrow">Servicios</span>
        <h2>Una terapia adaptada a tu historia y a tu presente</h2>
        <p>
          Integro distintos enfoques para adaptar la terapia a ti, no al revés.
        </p>
      </header>

      <div class="services-hero reveal-scale" data-delay="160">
        <figure class="services-hero__image">
          <img src={servicesImage} alt="Paisaje sereno con luz suave y mar en calma" decoding="async" loading="eager" />
          <div class="services-hero__veil"></div>
          <figcaption class="services-hero__caption">
            <span>Ritmo tranquilo</span>
            <p>Un espacio para bajar el ritmo, ordenar lo que ocurre y decidir el siguiente paso.</p>
          </figcaption>
        </figure>

        <article class="services-hero__panel">
          <span class="services-label">Acompañamiento clínico</span>
          <h3>Escucha, estructura y herramientas elegidas para tu caso.</h3>
          <p>
            Según lo que necesites, combinamos trabajo cognitivo, emocional, corporal, partes internas y procesamiento del trauma. <a href="#enfoques" class="services-inline-link">Ver enfoques</a>.
          </p>

          <ul class="services-pills" aria-label="Claves del acompañamiento">
            <li>Presencial y online</li>
            <li>Enfoque integrador</li>
            <li>Trauma y EMDR</li>
          </ul>

          <div class="services-actions">
            <a href="#contacto" class="services-button services-button--solid">
              <span>Solicitar primera sesión</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#sobre-mi" class="services-button services-button--ghost">
              <span>Conocer a Lucía</span>
            </a>
          </div>
        </article>
      </div>

      <section id="enfoques" class="services-methods spotlight-section reveal-up" aria-labelledby="enfoques-title">
        <header class="services-methods__header">
          <span class="services-eyebrow">Enfoques</span>
          <h3 id="enfoques-title">Cinco lentes para entender lo que te ocurre.</h3>
          <p class="services-methods__lede">
            Cada enfoque aporta una perspectiva única para comprender tu experiencia y construir cambios sostenibles.
          </p>
        </header>
        <div class="enfoques-list" aria-label="Enfoques terapéuticos">
          {enfoques.map((enfoque, index) => (
            <article
              class="enfoque-item reveal-up"
              data-enfoque-item
              style={`--category-hue: ${enfoque.color}; transition-delay: ${240 + index * 60}ms`}
            >
              <h4 class="enfoque-item__heading">
                <button
                  class="enfoque-trigger"
                  type="button"
                  aria-expanded="false"
                  aria-controls={`enfoque-answer-${index}`}
                >
                  <span class="enfoque-chip">
                    <span class="enfoque-chip__icon" aria-hidden="true">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d={enfoque.icon} />
                      </svg>
                    </span>
                    <span>{enfoque.label}</span>
                  </span>
                  <span class="enfoque-summary">
                    <span class="enfoque-title">{enfoque.title}</span>
                    <span class="enfoque-tagline"><strong>La clave:</strong> {enfoque.tagline}</span>
                  </span>
                  <span class="enfoque-icon" aria-hidden="true">
                    <svg viewBox="0 0 20 20" fill="none" class="enfoque-icon-svg" aria-hidden="true">
                      <rect x="2" y="9" width="16" height="2" rx="1" fill="currentColor" class="enfoque-icon-h"/>
                      <rect x="9" y="2" width="2" height="16" rx="1" fill="currentColor" class="enfoque-icon-v"/>
                    </svg>
                  </span>
                </button>
              </h4>
              <div id={`enfoque-answer-${index}`} class="enfoque-answer">
                <div class="enfoque-answer__inner">
                  <div class="enfoque-answer__body">
                    <h5>¿En qué consiste?</h5>
                    <p>{enfoque.consiste}</p>
                    <h5>¿Cómo te ayuda?</h5>
                    <p>{enfoque.ayuda}</p>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <footer class="services-outro" data-outro>
        <p>
          Si necesitas combinar enfoques o ajustar el formato, lo hacemos con flexibilidad. La prioridad es que el proceso sea seguro, comprensible y ajustado a tu caso.
        </p>
        <a href="#contacto" class="services-outro__cta">
          <span>Solicitar primera sesión</span>
          <span class="services-outro__arrow" aria-hidden="true">→</span>
        </a>
      </footer>
    </div>
  </Container>

  <PageNumber number="01" />
</section>

<style>
  .servicios {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
  }

  .section--cream {
    background:
      radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.88), transparent 30%),
      radial-gradient(circle at 84% 14%, rgba(223, 228, 216, 0.58), transparent 30%),
      radial-gradient(circle at 70% 76%, rgba(184, 168, 138, 0.12), transparent 32%),
      linear-gradient(180deg, #fffdfa 0%, var(--color-surface) 58%, #f2efe8 100%);
  }

  .servicios::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.01) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 74%);
    opacity: 0.55;
  }

  .servicios::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    box-shadow: inset 0 0 180px rgba(255, 255, 255, 0.22);
  }

  .services-shell {
    position: relative;
    z-index: 2;
  }

  .services-header {
    max-width: 58rem;
    margin: 0 auto clamp(2.5rem, 4.5vw, 3.8rem);
    text-align: center;
  }

  .services-label {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-label::before {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-header h2 {
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);

    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .services-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .services-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-eyebrow::before,
  .services-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(24rem, 0.82fr);
    gap: clamp(1.1rem, 1.8vw, 1.35rem);
    align-items: stretch;
  }

  .services-hero__image,
  .services-hero__panel {
    position: relative;
    border: 1px solid var(--color-line-accent-soft);
    background: rgba(255, 253, 248, 0.88);
    box-shadow: 0 1.4rem 3rem rgba(57, 54, 48, 0.06);
  }

  .services-hero__image {
    min-height: clamp(26rem, 36vw, 34rem);
    overflow: hidden;
    border-radius: 1.6rem;
  }

  .services-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
    filter: grayscale(10%) saturate(0.82) contrast(1.02) brightness(0.72);
    transform: scale(1.03);
    animation: services-image-breathe 18s ease-in-out infinite alternate;
    will-change: transform;
  }

  .services-hero__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 48% 28%, rgba(255, 251, 244, 0.1), transparent 36%),
      linear-gradient(180deg, rgba(13, 10, 8, 0.12) 0%, rgba(13, 10, 8, 0.46) 100%);
  }

  .services-hero__caption {
    position: absolute;
    left: clamp(1rem, 2.4vw, 1.7rem);
    right: clamp(1rem, 2.4vw, 1.7rem);
    bottom: clamp(1rem, 2.4vw, 1.6rem);
    max-width: 28rem;
    color: rgba(255, 251, 244, 0.9);
  }

  .services-hero__caption span {
    display: inline-flex;
    margin-bottom: 0.65rem;
    font-size: var(--type-meta);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .services-hero__caption p {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);

    font-weight: 400;
    line-height: 1.48;
    text-wrap: balance;
  }

  .services-hero__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.1rem;
    padding: var(--card-pd-lg);
    border-radius: var(--card-radius);
    border-color: rgba(111, 125, 103, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(249, 246, 239, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.48), transparent 28%),
      radial-gradient(circle at 100% 100%, rgba(184, 168, 138, 0.12), transparent 36%);
    overflow: hidden;
  }

  .services-hero__panel::before {
    content: '';
    position: absolute;
    inset: 1rem auto 1rem 1rem;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(111, 125, 103, 0.34), transparent);
    pointer-events: none;
  }

  .services-hero__panel::after {
    content: '';
    position: absolute;
    right: -1.5rem;
    bottom: -1.5rem;
    width: 8rem;
    aspect-ratio: 1;
    border: 1px solid rgba(184, 168, 138, 0.18);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35), transparent 64%);
    pointer-events: none;
    animation: services-glow 10s ease-in-out infinite alternate;
  }

  .services-hero__panel > * {
    position: relative;
    z-index: 1;
  }

  .services-hero__panel h3 {
    max-width: 16ch;
    margin: 0.9rem 0 0.95rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-panel-title);

    font-weight: 400;
    line-height: 1.06;
    letter-spacing: -0.04em;
    text-wrap: balance;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
  }

  .services-hero__panel p {
    margin: 0;
    color: var(--color-text-secondary);
    max-width: 34ch;
    font-size: var(--type-body);
    line-height: 1.82;
    text-wrap: pretty;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
    animation-delay: 0.08s;
  }

  .services-inline-link {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(111, 125, 103, 0.3);
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .services-inline-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-deep);
  }

  .services-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 1.45rem 0 1.65rem;
    padding: 0;
    list-style: none;
  }

  .services-pills li {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding: 0.34rem 0.82rem;
    border: 1px solid var(--color-line-accent);
    border-radius: 999px;
    color: rgba(47, 45, 40, 0.72);
    background: rgba(255, 255, 255, 0.7);
    font-size: var(--type-caption);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 0.35s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-pills li:hover {
    transform: translateY(-1px);
    border-color: rgba(111, 125, 103, 0.32);
    background: rgba(111, 125, 103, 0.06);
    color: rgba(47, 45, 40, 0.82);
  }

  .services-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.1rem;
  }

  .services-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3rem;
    padding: 0.78rem 1.25rem;
    border-radius: 999px;
    font-size: var(--type-caption);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition:
      transform 0.45s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-button:hover {
    transform: translateY(-2px);
  }

  .services-button--solid {
    border: 1px solid rgba(111, 125, 103, 0.28);
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.18);
  }

  .services-button--solid:hover {
    border-color: rgba(86, 100, 90, 0.35);
    box-shadow: 0 1.1rem 2rem rgba(86, 100, 90, 0.2);
  }

  .services-button--ghost {
    border: 1px solid var(--color-line-accent);
    background: rgba(255, 255, 255, 0.54);
    color: rgba(47, 45, 40, 0.78);
  }

  .services-button--ghost:hover {
    border-color: rgba(111, 125, 103, 0.28);
    background: rgba(111, 125, 103, 0.06);
  }

  .services-button svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .services-button:hover svg {
    transform: translateX(2px);
  }

  .services-methods {
    position: relative;
    margin-top: clamp(2.6rem, 5vw, 4.2rem);
  }

  .services-methods__header {
    max-width: 56rem;
    margin: 0 auto clamp(1.8rem, 3vw, 2.8rem);
    text-align: center;
  }

  .services-methods__header h3 {
    max-width: 34rem;
    margin: 0.9rem auto 0.85rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);

    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .services-methods__lede {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.78;
    text-wrap: pretty;
  }

  .enfoques-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  .enfoque-item {
    position: relative;
    border: 1px solid rgba(111, 125, 103, 0.1);
    border-radius: var(--card-radius-sm);
    background: linear-gradient(180deg, rgba(255, 253, 248, 0.92), rgba(250, 247, 240, 0.84));
    box-shadow: 0 0.35rem 0.9rem rgba(57, 54, 48, 0.03);
    overflow: hidden;
    transition:
      border-color 0.4s ease,
      background 0.4s ease,
      box-shadow 0.4s ease,
      transform 0.4s var(--ease-out-expo);
  }

  .enfoque-item:hover {
    border-color: rgba(111, 125, 103, 0.18);
    box-shadow: 0 0.55rem 1.2rem rgba(57, 54, 48, 0.05);
  }

  .enfoque-item.open {
    border-color: rgba(var(--category-hue), 0.24);
    background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(252, 249, 243, 0.9));
    box-shadow:
      0 0.75rem 1.8rem rgba(57, 54, 48, 0.05),
