</style>

<script>
  document.querySelectorAll('.enfoque-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('[data-enfoque-item]');
      const answer = item?.querySelector('.enfoque-answer');
      const isOpen = answer?.classList.contains('open');

      document.querySelectorAll('[data-enfoque-item]').forEach((sibling) => {
        if (sibling !== item) {
          sibling.classList.remove('open');
          const siblingAnswer = sibling.querySelector('.enfoque-answer');
          siblingAnswer?.classList.remove('open');
          const siblingTrigger = sibling.querySelector('.enfoque-trigger');
          siblingTrigger?.setAttribute('aria-expanded', 'false');
        }
      });

      answer?.classList.toggle('open');
      item?.classList.toggle('open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
