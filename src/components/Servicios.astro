---
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';

const enfoques = [
  {
    label: 'TCC',
    title: 'Terapia Cognitivo Conductual',
    text: 'Relaciona pensamientos, emociones y conducta para generar cambios concretos y sostenibles en el día a día.',
    color: '111, 125, 103',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  },
  {
    label: 'ACT',
    title: 'Terapia de Aceptación y Compromiso',
    text: 'Trabaja aceptación, valores y flexibilidad ante lo difícil.',
    color: '184, 168, 138',
    icon: 'M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 007.92 12.446a9 9 0 11-8.313-12.454z',
  },
  {
    label: 'TFE',
    title: 'Terapia Focalizada en Emociones',
    text: 'Comprende emociones y heridas vinculares. Útil si tus reacciones emocionales te desbordan.',
    color: '138, 154, 137',
    icon: 'M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z',
  },
  {
    label: 'IFS',
    title: 'Sistema de Familia Interna',
    text: 'Explora partes internas y conflictos. Útil si una parte de ti quiere algo y otra lo boicotea.',
    color: '122, 138, 138',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  },
  {
    label: 'EMDR',
    title: 'Desensibilización y Reprocesamiento',
    text: 'Reprocesa experiencias dolorosas mediante estimulación bilateral.',
    color: '168, 138, 122',
    icon: 'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0',
  },
];

const servicesImage = 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1800&auto=format&fit=crop';
---

<section id="servicios" class="servicios section--cream">
  <GrainOverlay opacity={0.014} />
  <AmbientLight color="rgba(255,255,255,0.28)" />
  <FloatOrb size={360} top="-12%" right="-8%" color="rgba(141,151,132,0.12)" blur={150} animation="float-1" />
  <FloatOrb size={220} bottom="12%" left="-6%" color="rgba(216,211,200,0.22)" opacity={0.32} blur={110} animation="float-2" />

  <Container maxWidth="1480px" padding="0 var(--content-padding-x)">
    <div class="services-shell">
      <header class="services-header reveal-blur" data-delay="80">
        <span class="services-eyebrow">Servicios</span>
        <h2>Una terapia adaptada a tu historia y a tu presente</h2>
        <p>
          Integro distintos enfoques para adaptar la terapia a ti, no al revés.
        </p>
        <p class="services-header__note">
          Los enfoques son las herramientas; los formatos de abajo son donde las combino según tu caso.
        </p>
      </header>

      <div class="services-hero reveal-scale" data-delay="160">
        <figure class="services-hero__image">
          <img src={servicesImage} alt="Paisaje sereno con luz suave y mar en calma" decoding="async" loading="eager" />
          <div class="services-hero__veil"></div>
          <figcaption class="services-hero__caption">
            <span>Ritmo tranquilo</span>
            <p>Un espacio para bajar el ritmo, ordenar lo que ocurre y decidir el siguiente paso.</p>
          </figcaption>
        </figure>

        <article class="services-hero__panel">
          <span class="services-label">Acompañamiento clínico</span>
          <h3>Escucha, estructura y herramientas elegidas para tu caso.</h3>
          <p>
            Según lo que necesites, combinamos trabajo cognitivo, emocional, corporal, partes internas y procesamiento del trauma. <a href="#enfoques" class="services-inline-link">Ver enfoques</a>.
          </p>

          <ul class="services-pills" aria-label="Claves del acompañamiento">
            <li>Presencial y online</li>
            <li>Enfoque integrador</li>
            <li>Trauma y EMDR</li>
          </ul>

          <div class="services-actions">
            <a href="#contacto" class="services-button services-button--solid">
              <span>Solicitar primera sesión</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#sobre-mi" class="services-button services-button--ghost">
              <span>Conocer a Lucía</span>
            </a>
          </div>
        </article>
      </div>

      <section class="services-methods spotlight-section reveal-up" aria-labelledby="enfoques-title">
        <header class="services-methods__header">
          <span class="services-eyebrow">Enfoques</span>
          <h3 id="enfoques-title">Cinco lentes para entender lo que te ocurre.</h3>
          <p class="services-methods__lede">
            Cada enfoque aporta una perspectiva única para comprender tu experiencia y construir cambios sostenibles.
          </p>
        </header>
        <div class="methods-bento">
          {enfoques.map((enfoque, index) => (
            <article
              class:list={['method-card', 'reveal-up', { 'method-card--featured': index === 0 }]}
              style={`transition-delay: ${240 + index * 60}ms`}
            >
              <span class="method-card__number" aria-hidden="true">0{index + 1}</span>
              <span class="method-card__accent" aria-hidden="true"></span>
              <div class="method-card__band">
                <span class="method-card__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={enfoque.icon} />
                  </svg>
                </span>
                <span class="method-card__label">{enfoque.label}</span>
              </div>
              <div class="method-card__body">
                <h4>{enfoque.title}</h4>
                <p>{enfoque.text}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <footer class="services-outro" data-outro>
        <p>
          Si necesitas combinar enfoques o ajustar el formato, lo hacemos con flexibilidad. La prioridad es que el proceso sea seguro, comprensible y ajustado a tu caso.
        </p>
        <a href="#contacto" class="services-outro__cta">
          <span>Solicitar primera sesión</span>
          <span class="services-outro__arrow" aria-hidden="true">→</span>
        </a>
      </footer>
    </div>
  </Container>

  <PageNumber number="01" />
</section>

<style>
  .servicios {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
  }

  .section--cream {
    background:
      radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.88), transparent 30%),
      radial-gradient(circle at 84% 14%, rgba(223, 228, 216, 0.58), transparent 30%),
      radial-gradient(circle at 70% 76%, rgba(184, 168, 138, 0.12), transparent 32%),
      linear-gradient(180deg, #fffdfa 0%, var(--color-surface) 58%, #f2efe8 100%);
  }

  .servicios::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.01) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 74%);
    opacity: 0.55;
  }

  .servicios::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    box-shadow: inset 0 0 180px rgba(255, 255, 255, 0.22);
  }

  .services-shell {
    position: relative;
    z-index: 2;
  }

  .services-header {
    max-width: 58rem;
    margin: 0 auto clamp(2.5rem, 4.5vw, 3.8rem);
    text-align: center;
  }

  .services-label {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-label::before {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-header h2 {
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);

    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .services-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .services-header__note {
    max-width: 38rem;
    margin: 1rem auto 0;
    color: var(--color-text-muted);
    font-size: var(--type-body-sm);
    line-height: 1.7;
    text-wrap: pretty;

  }

  .services-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .services-eyebrow::before,
  .services-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .services-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(24rem, 0.82fr);
    gap: clamp(1.1rem, 1.8vw, 1.35rem);
    align-items: stretch;
  }

  .services-hero__image,
  .services-hero__panel {
    position: relative;
    border: 1px solid var(--color-line-accent-soft);
    background: rgba(255, 253, 248, 0.88);
    box-shadow: 0 1.4rem 3rem rgba(57, 54, 48, 0.06);
  }

  .services-hero__image {
    min-height: clamp(26rem, 36vw, 34rem);
    overflow: hidden;
    border-radius: 1.6rem;
  }

  .services-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
    filter: grayscale(10%) saturate(0.82) contrast(1.02) brightness(0.72);
    transform: scale(1.03);
    animation: services-image-breathe 18s ease-in-out infinite alternate;
    will-change: transform;
  }

  .services-hero__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 48% 28%, rgba(255, 251, 244, 0.1), transparent 36%),
      linear-gradient(180deg, rgba(13, 10, 8, 0.12) 0%, rgba(13, 10, 8, 0.46) 100%);
  }

  .services-hero__caption {
    position: absolute;
    left: clamp(1rem, 2.4vw, 1.7rem);
    right: clamp(1rem, 2.4vw, 1.7rem);
    bottom: clamp(1rem, 2.4vw, 1.6rem);
    max-width: 28rem;
    color: rgba(255, 251, 244, 0.9);
  }

  .services-hero__caption span {
    display: inline-flex;
    margin-bottom: 0.65rem;
    font-size: var(--type-meta);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .services-hero__caption p {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);

    font-weight: 400;
    line-height: 1.48;
    text-wrap: balance;
  }

  .services-hero__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.1rem;
    padding: var(--card-pd-lg);
    border-radius: var(--card-radius);
    border-color: rgba(111, 125, 103, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(249, 246, 239, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.48), transparent 28%),
      radial-gradient(circle at 100% 100%, rgba(184, 168, 138, 0.12), transparent 36%);
    overflow: hidden;
  }

  .services-hero__panel::before {
    content: '';
    position: absolute;
    inset: 1rem auto 1rem 1rem;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(111, 125, 103, 0.34), transparent);
    pointer-events: none;
  }

  .services-hero__panel::after {
    content: '';
    position: absolute;
    right: -1.5rem;
    bottom: -1.5rem;
    width: 8rem;
    aspect-ratio: 1;
    border: 1px solid rgba(184, 168, 138, 0.18);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.35), transparent 64%);
    pointer-events: none;
    animation: services-glow 10s ease-in-out infinite alternate;
  }

  .services-hero__panel > * {
    position: relative;
    z-index: 1;
  }

  .services-hero__panel h3 {
    max-width: 16ch;
    margin: 0.9rem 0 0.95rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-panel-title);

    font-weight: 400;
    line-height: 1.06;
    letter-spacing: -0.04em;
    text-wrap: balance;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
  }

  .services-hero__panel p {
    margin: 0;
    color: var(--color-text-secondary);
    max-width: 34ch;
    font-size: var(--type-body);
    line-height: 1.82;
    text-wrap: pretty;
    animation: services-copy-rise 1.1s var(--ease-out-expo) both;
    animation-delay: 0.08s;
  }

  .services-inline-link {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(111, 125, 103, 0.3);
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .services-inline-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-deep);
  }

  .services-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 1.45rem 0 1.65rem;
    padding: 0;
    list-style: none;
  }

  .services-pills li {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding: 0.34rem 0.82rem;
    border: 1px solid var(--color-line-accent);
    border-radius: 999px;
    color: rgba(47, 45, 40, 0.72);
    background: rgba(255, 255, 255, 0.7);
    font-size: var(--type-caption);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 0.35s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-pills li:hover {
    transform: translateY(-1px);
    border-color: rgba(111, 125, 103, 0.32);
    background: rgba(111, 125, 103, 0.06);
    color: rgba(47, 45, 40, 0.82);
  }

  .services-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.1rem;
  }

  .services-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3rem;
    padding: 0.78rem 1.25rem;
    border-radius: 999px;
    font-size: var(--type-caption);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition:
      transform 0.45s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .services-button:hover {
    transform: translateY(-2px);
  }

  .services-button--solid {
    border: 1px solid rgba(111, 125, 103, 0.28);
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.18);
  }

  .services-button--solid:hover {
    border-color: rgba(86, 100, 90, 0.35);
    box-shadow: 0 1.1rem 2rem rgba(86, 100, 90, 0.2);
  }

  .services-button--ghost {
    border: 1px solid var(--color-line-accent);
    background: rgba(255, 255, 255, 0.54);
    color: rgba(47, 45, 40, 0.78);
  }

  .services-button--ghost:hover {
    border-color: rgba(111, 125, 103, 0.28);
    background: rgba(111, 125, 103, 0.06);
  }

  .services-button svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .services-button:hover svg {
    transform: translateX(2px);
  }

  .services-methods {
    position: relative;
    margin-top: clamp(2.6rem, 5vw, 4.2rem);
  }

  .services-methods__header {
    max-width: 56rem;
    margin: 0 auto clamp(1.8rem, 3vw, 2.8rem);
    text-align: center;
  }

  .services-methods__header h3 {
    max-width: 34rem;
    margin: 0.9rem auto 0.85rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);

    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .services-methods__lede {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.78;
    text-wrap: pretty;
  }

  .methods-bento {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: clamp(1rem, 1.6vw, 1.4rem);
  }

  /* ── Approach cards: archive-card aesthetic ───────────────── */
  .method-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: clamp(15rem, 18vw, 18.5rem);
    padding: clamp(1.45rem, 2.2vw, 1.95rem);
    border: 1px solid rgba(111, 125, 103, 0.10);
    border-radius: var(--card-radius);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.96) 0%, rgba(250, 247, 240, 0.88) 100%);
    box-shadow:
      0 0.5rem 1.4rem rgba(57, 54, 48, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    overflow: hidden;
    transition:
      transform 0.55s var(--ease-out-expo),
      box-shadow 0.55s var(--ease-out-expo),
      border-color 0.4s ease;
  }

  .method-card__accent {
    position: absolute;
    top: 0;
    left: 1.6rem;
    right: 1.6rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(111, 125, 103, 0.22), transparent);
    opacity: 0.7;
    transition: opacity 0.4s ease, background 0.4s ease;
  }

  .method-card__band {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.2rem;
    padding: 0.32rem 0.85rem 0.32rem 0.32rem;
    border: 1px solid rgba(111, 125, 103, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.64);
    align-self: flex-start;
    transition:
      border-color 0.4s ease,
      background 0.4s ease,
      transform 0.45s var(--ease-out-expo);
  }

  .method-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 50%;
    color: rgba(111, 125, 103, 0.9);
    background: rgba(111, 125, 103, 0.07);
    border: 1px solid rgba(111, 125, 103, 0.14);
    transition:
      transform 0.5s var(--ease-out-expo),
      background 0.4s ease,
      border-color 0.4s ease;
    flex-shrink: 0;
  }

  .method-card__icon svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  .method-card__label {
    color: rgba(111, 125, 103, 0.92);
    font-size: var(--type-caption);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .method-card__number {
    position: absolute;
    right: clamp(0.6rem, 1.2vw, 1rem);
    bottom: clamp(-0.5rem, -0.4vw, -0.2rem);
    font-family: var(--font-display);
    font-size: clamp(4.2rem, 6.5vw, 6.2rem);

    font-weight: 400;
    line-height: 1;
    color: rgba(184, 168, 138, 0.10);
    pointer-events: none;
    transition:
      transform 0.6s var(--ease-out-expo),
      color 0.45s ease;
  }

  .method-card__body {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .method-card h4 {
    margin: 0 0 0.55rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-card-title);

    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .method-card p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-card-body);
    line-height: 1.62;
    text-wrap: pretty;
  }

  .method-card:hover {
    transform: translateY(-0.5rem);
    border-color: rgba(111, 125, 103, 0.22);
    box-shadow:
      0 1.2rem 2.8rem rgba(57, 54, 48, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  .method-card:hover .method-card__accent {
    opacity: 1;
    background: linear-gradient(90deg, transparent, rgba(184, 168, 138, 0.45), transparent);
  }

  .method-card:hover .method-card__band {
