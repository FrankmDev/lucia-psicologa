---
import GrainOverlay from './ui/GrainOverlay.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

const steps = [
  {
    title: 'Primer contacto',
    text: 'Me cuentas el motivo de consulta, desde cuándo ocurre y si prefieres terapia presencial u online.',
  },
  {
    title: 'Evaluación inicial',
    text: 'Recogemos información clínica relevante y definimos objetivos concretos, realistas y compartidos.',
  },
  {
    title: 'Intervención',
    text: 'Trabajamos con herramientas clínicas adaptadas a tu caso: regulación emocional, pensamiento, conducta y cuerpo.',
  },
  {
    title: 'Revisión',
    text: 'Valoramos avances, ajustamos objetivos y cerramos el proceso cuando hay más estabilidad y autonomía.',
  },
];
---

<section id="proceso" class="proceso" data-proceso>
  <GrainOverlay opacity={0.012} />
  <AmbientLight color="rgba(255,255,255,0.24)" />
  <FloatOrb size={340} top="-16%" right="-10%" color="rgba(141,151,132,0.12)" blur={145} opacity={0.34} animation="float-1" />
  <FloatOrb size={240} bottom="4%" left="-8%" color="rgba(216,211,200,0.24)" blur={120} opacity={0.28} animation="float-2" />

  <Container maxWidth="1180px" padding="0 clamp(1rem, 4vw, 4rem)">
    <div class="process-shell">
      <header class="process-header reveal-blur" data-delay="80">
        <span class="process-eyebrow">Proceso</span>
        <h2>Cómo empieza y cómo se sostiene el proceso.</h2>
        <p>
          Desde el primer contacto sabrás qué puedes esperar, qué información necesito y cómo decidimos los siguientes pasos.
        </p>
      </header>

      <div class="process-flow" aria-label="Fases del proceso terapéutico">
        <div class="process-track" aria-hidden="true">
          {steps.map((_, index) => (
            <div class="process-track__item">
              <span>0{index + 1}</span>
            </div>
          ))}
        </div>

        <div class="process-steps">
          {steps.map((step, index) => (
            <article class="process-step reveal-up" style={`transition-delay: ${160 + index * 70}ms`}>
              <span class="process-step__num" aria-hidden="true">0{index + 1}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="process-close reveal-up" data-delay="420">
        <p>Si tienes dudas antes de empezar, puedes plantearlas en el primer mensaje.</p>
        <a href="#contacto" class="process-link">
          <span>Solicitar primera sesión</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</section>

<style>
  .proceso {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
    background:
      radial-gradient(circle at 16% 8%, rgba(255, 255, 255, 0.9), transparent 30%),
      radial-gradient(circle at 82% 16%, rgba(223, 228, 216, 0.46), transparent 30%),
      linear-gradient(180deg, var(--color-surface-elevated) 0%, var(--color-surface) 68%, #f3efe7 100%);
  }

  .proceso::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.008) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 44%, #000 0%, transparent 72%);
    opacity: 0.72;
  }

  .process-shell {
    position: relative;
    z-index: 2;
  }

  .process-header {
    max-width: 48rem;
    margin: 0 auto clamp(2.8rem, 4.5vw, 4rem);
    text-align: center;
  }

  .process-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .process-eyebrow::before,
  .process-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .process-header h2 {
    max-width: 48rem;
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .process-header p {
    max-width: 39rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.78;
    text-wrap: pretty;
  }

  .process-flow {
    position: relative;
    padding: var(--card-pd-sm);
    border: 1px solid rgba(111, 125, 103, 0.14);
    border-radius: var(--card-radius);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.72), rgba(250, 248, 242, 0.52)),
      radial-gradient(circle at 50% 0%, rgba(223, 228, 216, 0.3), transparent 54%);
    box-shadow: 0 1.4rem 3rem rgba(57, 54, 48, 0.045);
  }

  .process-track {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    align-items: center;
    margin: 0 clamp(0.25rem, 1vw, 0.7rem) clamp(1rem, 1.8vw, 1.35rem);
    min-height: 2.8rem;
  }

  .process-track::before {
    content: '';
    position: absolute;
    left: calc(12.5% + 1.25rem);
    right: calc(12.5% + 1.25rem);
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, rgba(111, 125, 103, 0.08), rgba(111, 125, 103, 0.34), rgba(111, 125, 103, 0.08));
    transform: translateY(-50%);
  }

  .process-track__item {
    position: relative;
    display: flex;
    justify-content: center;
    z-index: 1;
  }

  .process-track__item span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid rgba(111, 125, 103, 0.28);
    border-radius: 999px;
    background: #fffdf8;
    color: var(--color-accent-deep);
    font-family: var(--font-display);
    font-size: var(--type-body-sm);
    font-style: italic;
    line-height: 1;
    box-shadow: 0 0 0 0.45rem rgba(255, 253, 248, 0.84);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.8rem, 1.4vw, 1.05rem);
  }

  .process-step {
    position: relative;
    min-height: clamp(12.5rem, 15vw, 14.4rem);
    overflow: hidden;
    padding: var(--card-pd-sm);
    border: 1px solid rgba(111, 125, 103, 0.11);
    border-radius: var(--card-radius-sm);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(251, 248, 241, 0.9)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.28), transparent 38%);
    box-shadow: 0 1rem 2rem rgba(57, 54, 48, 0.045);
    transition:
      transform 0.45s var(--ease-out-expo),
      border-color 0.35s ease,
      box-shadow 0.45s ease,
      background 0.35s ease;
  }

  .process-step::after {
    content: '';
    position: absolute;
    right: -2.8rem;
    bottom: -3rem;
    width: 8rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(111, 125, 103, 0.08), transparent 68%);
    opacity: 0.58;
    transition: transform 0.7s var(--ease-out-expo), opacity 0.45s ease;
    pointer-events: none;
  }

  .process-step:hover {
    transform: translateY(-4px);
    border-color: rgba(111, 125, 103, 0.24);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(249, 246, 239, 0.96)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.38), transparent 36%);
    box-shadow: 0 1.4rem 2.6rem rgba(57, 54, 48, 0.07);
  }

  .process-step:hover::after {
    opacity: 0.84;
    transform: scale(1.08);
  }

  .process-step__num {
    display: inline-flex;
    margin-bottom: clamp(1.25rem, 2vw, 1.7rem);
    color: rgba(184, 168, 138, 0.92);
    font-family: var(--font-display);
    font-size: var(--type-card-title-sm);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
  }

  .process-step h3 {
    margin: 0 0 0.75rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .process-step p {
    max-width: 25ch;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--type-body-sm);
    line-height: 1.68;
    text-wrap: pretty;
  }

  .process-close {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    max-width: 48rem;
    margin: clamp(2rem, 4vw, 3rem) auto 0;
    text-align: center;
  }

  .process-close p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.7;
  }

  .process-link {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    gap: 0.58rem;
    min-height: 2.9rem;
    padding: 0.76rem 1.15rem;
    border: 1px solid rgba(86, 100, 90, 0.26);
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    font-size: var(--type-caption);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.14);
    transition: transform 0.45s var(--ease-out-expo), box-shadow 0.45s ease, background 0.35s ease;
  }

  .process-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 1.1rem 1.9rem rgba(86, 100, 90, 0.17);
  }

  .process-link svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .process-link:hover svg {
    transform: translateX(2px);
  }

  @media (max-width: 920px) {
    .process-track,
    .process-steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .process-track {
      row-gap: 0.9rem;
      margin-bottom: 1.2rem;
    }

    .process-track::before {
      display: none;
    }

    .process-track__item::before {
      content: '';
      position: absolute;
      left: 50%;
      right: -50%;
      top: 50%;
      height: 1px;
      background: rgba(111, 125, 103, 0.2);
      transform: translateY(-50%);
    }

    .process-track__item:nth-child(2n)::before {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .proceso {
      padding: 4.8rem 0 5.8rem;
    }

    .process-header {
      text-align: left;
      margin-bottom: 2rem;
      padding: 0 4vw;
    }

    .process-eyebrow {
      justify-content: flex-start;
    }

    .process-eyebrow::after {
      display: none;
    }

    .process-header h2 {
      font-size: var(--type-section-title-sm);
      line-height: 1.02;
      letter-spacing: -0.02em;
    }

    .process-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }

    .process-flow {
      padding: var(--card-pd-sm);
      border-radius: var(--card-radius-sm);
    }

    .process-track {
      display: none;
    }

    .process-steps {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }

    .process-step {
      min-height: auto;
      padding: var(--card-pd-sm);
      border-radius: var(--card-radius-sm);
    }

    .process-step__num {
      margin-bottom: 0.7rem;
      font-size: var(--type-body);
    }

    .process-step h3 {
      font-size: var(--type-card-title);
      margin-bottom: 0.55rem;
    }

    .process-step p {
      max-width: none;
      font-size: var(--type-card-body);
      line-height: 1.58;
    }

    .process-close {
      display: block;
      text-align: left;
      margin-top: 1.8rem;
      gap: 1rem;
      padding: 0 4vw;
    }

    .process-close p {
      font-size: var(--type-body-sm);
      line-height: 1.6;
    }

    .process-link {
      width: 100%;
      margin-top: 1rem;
      min-height: 2.8rem;
      font-size: var(--type-meta);
      letter-spacing: 0.16em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-step,
    .process-step::after,
    .process-link,
    .process-link svg {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
