      opacity: 0.03;
    }
    .proceso.visible .grid-line--v2 {
      height: 100%;
      opacity: 0.025;
    }
  }
</style>

<script>
  (function() {
    'use strict';

    /* ── Section visibility for grid lines ── */
    const section = document.querySelector('.proceso');
    if (section) {
      const ioSection = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            ioSection.unobserve(entry.target);
          }
        });
      }, { threshold: 0.05 });
      ioSection.observe(section);
    }

    /* ── Staggered card reveal ── */
    const cards = document.querySelectorAll('.process-card');
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    cards.forEach((card) => {
      if (prefersReduced) {
        card.classList.add('is-visible');
        return;
      }

      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });

      io.observe(card);
    });

    /* ── Connector reveal ── */
    const connector = document.querySelector('.process-connector');
    if (connector) {
      const ioConn = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            ioConn.unobserve(entry.target);
          }
        });
      }, { threshold: 0.5 });
      ioConn.observe(connector);
    }

    /* ── Footer reveal ── */
    const footer = document.querySelector('.proceso-footer');
    if (footer) {
      const ioFooter = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            ioFooter.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      ioFooter.observe(footer);
    }
  })();
</script>
