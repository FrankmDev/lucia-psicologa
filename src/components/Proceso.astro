---
import GrainOverlay from './ui/GrainOverlay.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

const steps = [
  {
    num: '01',
    title: 'Primer contacto',
    text: 'Me cuentas brevemente qué te preocupa, desde cuándo ocurre y qué modalidad prefieres. No necesitas explicarlo todo: solo lo suficiente para valorar el siguiente paso.',
  },
  {
    num: '02',
    title: 'Primera sesión',
    text: 'Ordenamos el motivo de consulta, recogemos información relevante y definimos un primer objetivo de trabajo claro, realista y ajustado a tu situación.',
  },
  {
    num: '03',
    title: 'Plan de trabajo',
    text: 'Definimos prioridades y elegimos las herramientas más adecuadas para tu caso: regulación emocional, pensamiento, conducta, cuerpo, partes internas o procesamiento del trauma.',
  },
  {
    num: '04',
    title: 'Revisión del proceso',
    text: 'Valoramos avances, ajustamos objetivos y revisamos si el enfoque sigue siendo el adecuado. El cierre llega cuando hay más estabilidad, recursos y autonomía.',
  },
];
---

<section id="proceso" class="proceso" data-proceso>
  <GrainOverlay opacity={0.012} />
  <AmbientLight color="rgba(255,255,255,0.24)" />
  <FloatOrb size={340} top="-16%" right="-10%" color="rgba(141,151,132,0.12)" blur={145} opacity={0.34} animation="float-1" />
  <FloatOrb size={240} bottom="4%" left="-8%" color="rgba(216,211,200,0.24)" blur={120} opacity={0.28} animation="float-2" />

  <Container maxWidth="1080px" padding="0 clamp(1rem, 4vw, 4rem)">
    <div class="process-shell">
      <header class="process-header reveal-blur" data-delay="80">
        <span class="section-eyebrow">Proceso</span>
        <h2>Cómo empezamos a trabajar.</h2>
        <p>
          El proceso comienza con una primera conversación para entender qué ocurre, valorar qué necesitas y decidir con claridad si conviene trabajar desde TCC, ACT, TFE, IFS, EMDR u otra combinación.
        </p>
      </header>

      <div class="process-track">
        <div class="process-line" aria-hidden="true"></div>

        <div class="process-steps stagger-children">
          {steps.map((step, index) => (
            <article class="process-step reveal-up" style={`transition-delay: ${160 + index * 90}ms`}>
              <div class="process-step__node">
                <span class="process-step__circle">{step.num}</span>
                {index < steps.length - 1 && <span class="process-step__connector" aria-hidden="true"></span>}
              </div>
              <div class="process-step__body">
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="process-close reveal-up" data-delay="480">
        <p>Si tienes dudas sobre el enfoque, la modalidad o si EMDR puede encajar en tu caso, puedes plantearlas en el primer mensaje.</p>
        <a href="#contacto" class="process-link">
          <span>Solicitar orientación inicial</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</section>

<style>
  .proceso {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
    background:
      radial-gradient(circle at 16% 8%, rgba(255, 255, 255, 0.9), transparent 30%),
      radial-gradient(circle at 82% 16%, rgba(223, 228, 216, 0.46), transparent 30%),
      linear-gradient(180deg, var(--color-surface-elevated) 0%, var(--color-surface) 68%, #f3efe7 100%);
  }

  .proceso::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.008) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 44%, #000 0%, transparent 72%);
    opacity: 0.72;
  }

  .process-shell {
    position: relative;
    z-index: 2;
  }

  .process-header {
    max-width: 48rem;
    margin: 0 auto clamp(2.8rem, 4.5vw, 4rem);
    text-align: center;
  }

  .process-header h2 {
    max-width: 48rem;
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .process-header p {
    max-width: 39rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.78;
    text-wrap: pretty;
  }

  /* ── Timeline track ─────────────────────────────────────── */
  .process-track {
    position: relative;
    max-width: 920px;
    margin: 0 auto;
  }

  .process-line {
    position: absolute;
    top: 2.2rem;
    left: 12.5%;
    right: 12.5%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(111,125,103,0.18) 12%, rgba(111,125,103,0.18) 88%, transparent 100%);
    z-index: 0;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.8rem, 1.4vw, 1.05rem);
    position: relative;
    z-index: 1;
  }

  .process-step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.1rem;
  }

  .process-step__node {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .process-step__circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 50%;
    border: 1.5px solid rgba(111, 125, 103, 0.22);
    background: linear-gradient(180deg, rgba(255,255,255,0.9), rgba(251,248,241,0.85));
    box-shadow:
      0 0.6rem 1.2rem rgba(57, 54, 48, 0.06),
      inset 0 1px 0 rgba(255,255,255,0.9);
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    color: rgba(184, 168, 138, 0.92);
    line-height: 1;
    transition:
      transform 0.45s var(--ease-out-expo),
      border-color 0.35s ease,
      box-shadow 0.45s ease;
  }

  .process-step:hover .process-step__circle {
    transform: translateY(-3px);
    border-color: rgba(111, 125, 103, 0.38);
    box-shadow: 0 1rem 2rem rgba(57, 54, 48, 0.1);
  }

  .process-step__circle::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(111, 125, 103, 0.06);
    animation: circle-pulse 3s ease-in-out infinite;
    pointer-events: none;
  }
  .process-step:nth-child(2) .process-step__circle::after { animation-delay: 0.5s; }
  .process-step:nth-child(3) .process-step__circle::after { animation-delay: 1s; }
  .process-step:nth-child(4) .process-step__circle::after { animation-delay: 1.5s; }
  @keyframes circle-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.12); opacity: 0; }
  }

  .process-step__connector {
    position: absolute;
    top: 50%;
    left: 100%;
    width: clamp(0.8rem, 2vw, 2rem);
    height: 1px;
    background: linear-gradient(90deg, rgba(111, 125, 103, 0.18), rgba(111, 125, 103, 0.06));
    transform: translateY(-50%);
  }

  .process-step__body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0 0.3rem;
  }

  .process-step h3 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .process-step p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--type-body-sm);
    line-height: 1.68;
    text-wrap: pretty;
  }

  .process-close {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    max-width: 48rem;
    margin: clamp(2rem, 4vw, 3rem) auto 0;
    text-align: center;
    flex-wrap: wrap;
  }

  .process-close p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.7;
  }

  .process-link {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    gap: 0.58rem;
    min-height: 2.9rem;
    padding: 0.76rem 1.15rem;
    border: 1px solid rgba(86, 100, 90, 0.26);
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    font-size: var(--type-caption);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.14);
    transition: transform 0.45s var(--ease-out-expo), box-shadow 0.45s ease;
  }

  .process-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 1.1rem 1.9rem rgba(86, 100, 90, 0.17);
  }

  .process-link svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .process-link:hover svg {
    transform: translateX(2px);
  }

  @media (max-width: 960px) {
    .process-line {
      display: none;
    }
    .process-steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.6rem 1rem;
    }
    .process-step__connector {
      display: none;
    }
    .process-step__circle {
      width: 4rem;
      height: 4rem;
    }
  }

  @media (max-width: 640px) {
    .proceso {
      padding: 4.8rem 0 5.8rem;
    }

    .process-header {
      text-align: left;
      margin-bottom: 2rem;
      padding: 0 4vw;
    }

    .section-eyebrow {
      justify-content: flex-start;
    }
    .section-eyebrow::after {
      display: none;
    }

    .process-header h2 {
      font-size: var(--type-section-title-sm);
      line-height: 1.02;
      letter-spacing: -0.02em;
    }

    .process-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }

    .process-steps {
      grid-template-columns: 1fr;
      gap: 1.4rem;
    }

    .process-step {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: 1rem;
      padding: var(--card-pd-sm);
      border: 1px solid rgba(111, 125, 103, 0.11);
      border-radius: var(--card-radius-sm);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(251, 248, 241, 0.9)),
        radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.28), transparent 38%);
    }

    .process-step__node {
      flex-shrink: 0;
    }

    .process-step__circle {
      width: 3.2rem;
      height: 3.2rem;
      font-size: var(--type-body);
    }

    .process-step h3 {
      font-size: var(--type-card-title);
    }

    .process-step p {
      font-size: var(--type-card-body);
      line-height: 1.58;
    }

    .process-close {
      display: block;
      text-align: left;
      margin-top: 1.8rem;
      padding: 0 4vw;
    }

    .process-close p {
      font-size: var(--type-body-sm);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .process-link {
      width: 100%;
      min-height: 2.8rem;
      font-size: var(--type-meta);
      letter-spacing: 0.16em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-step__circle,
    .process-link,
    .process-link svg {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
