  /* ═══════════════════════════════════════════════════════════
     REDUCED MOTION
     ═══════════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .process-card {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .process-card__title-sep,
    .detail-accent,
    .orn-line,
    .orn-fleur,
    .connector-track,
    .connector-dot {
      transition: none !important;
      animation: none !important;
    }
    .process-card.is-visible .process-card__title-sep {
      width: 28px;
      opacity: 0.2;
    }
    .process-card.is-visible .detail-accent {
      height: 28px;
    }
    .process-connector.is-visible .connector-track {
      opacity: 0.1;
      height: 100%;
    }
    .process-connector.is-visible .connector-dot {
      opacity: 0.25;
      transform: translateX(-50%) scale(1);
    }
    .grid-line {
      transition: none !important;
    }
    .proceso.visible .grid-line--v1 {
