---
import GrainOverlay from './ui/GrainOverlay.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';
import PageNumber from './ui/PageNumber.astro';

const steps = [
  {
    num: '01',
    title: 'Primer contacto',
    text: 'Me cuentas qué te preocupa, desde cuándo ocurre y qué modalidad prefieres.',
  },
  {
    num: '02',
    title: 'Primera sesión',
    text: 'Ordenamos el motivo de consulta y definimos un primer objetivo realista.',
  },
  {
    num: '03',
    title: 'Plan de trabajo',
    text: 'Elegimos herramientas según tu caso: regulación, emoción, cuerpo o trauma.',
  },
  {
    num: '04',
    title: 'Revisión y ajuste',
    text: 'Revisamos avances, ajustamos objetivos y consolidamos autonomía.',
  },
];
---

<section id="proceso" class="proceso section--warm" data-proceso>
  <GrainOverlay opacity={0.012} />
  <AmbientLight color="rgba(255,255,255,0.24)" />
  <FloatOrb size={340} top="-16%" right="-10%" color="rgba(141,151,132,0.12)" blur={145} opacity={0.34} animation="float-1" />
  <FloatOrb size={240} bottom="4%" left="-8%" color="rgba(216,211,200,0.24)" blur={120} opacity={0.28} animation="float-2" />

  <Container maxWidth="1480px" padding="0 var(--content-padding-x)">
    <div class="process-shell">
      <header class="process-header reveal-blur" data-delay="80">
        <span class="section-eyebrow">Proceso</span>
        <h2>Cómo empezamos a trabajar.</h2>
        <p>
          Un proceso claro, con objetivos revisables y herramientas ajustadas a lo que necesitas en cada momento.
        </p>
      </header>

      <div class="process-track">
        <div class="process-line" aria-hidden="true">
          <span class="process-line__bar"></span>
        </div>
        <div class="process-steps stagger-children">
          {steps.map((step, index) => (
            <article class="process-step reveal-up" style={`transition-delay: ${160 + index * 90}ms`}>
              <div class="process-step__node">
                <span class="process-step__circle">{step.num}</span>
              </div>
              <div class="process-step__body">
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="process-close reveal-up" data-delay="480">
        <p>Si tienes dudas sobre el enfoque, la modalidad o si EMDR puede encajar en tu caso, puedes plantearlo en el primer mensaje.</p>
        <a href="#contacto" class="process-link">
          <span>Solicitar orientación inicial</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </Container>

  <PageNumber number="03" />
</section>

<style>
  .proceso {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
  }

  .section--warm {
    background:
      radial-gradient(circle at 16% 8%, rgba(255, 255, 255, 0.82), transparent 30%),
      radial-gradient(circle at 84% 12%, rgba(223, 228, 216, 0.46), transparent 30%),
      radial-gradient(circle at 50% 90%, rgba(184, 168, 138, 0.1), transparent 32%),
      linear-gradient(180deg, #f5f0e8 0%, #ede7dc 68%, #e8e1d4 100%);
  }

  .proceso::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.012) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.01) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 44%, #000 0%, transparent 72%);
    opacity: 0.72;
  }

  .process-shell {
    position: relative;
    z-index: 2;
  }

  .process-header {
    max-width: 58rem;
    margin: 0 auto clamp(3.2rem, 5vw, 4.8rem);
    text-align: center;
  }

  .process-header h2 {
    max-width: 48rem;
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);

    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .process-header p {
    max-width: 39rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.78;
    text-wrap: pretty;
  }

  /* ── Process timeline ──────────────────────────────────── */
  .process-track {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .process-line {
    position: absolute;
    top: 2.3rem;
    left: 8%;
    right: 8%;
    height: 2px;
    z-index: 0;
    pointer-events: none;
  }

  .process-line__bar {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(111, 125, 103, 0.05), rgba(111, 125, 103, 0.18) 25%, rgba(111, 125, 103, 0.18) 75%, rgba(111, 125, 103, 0.05));
    border-radius: 1px;
  }

  .process-line__bar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(111, 125, 103, 0.02), rgba(111, 125, 103, 0.42), rgba(111, 125, 103, 0.02));
    box-shadow: 0 0 18px rgba(111, 125, 103, 0.12);
    transform: scaleX(0);
    transform-origin: left;
    animation: line-grow 1.6s var(--ease-out-expo) forwards;
    animation-delay: 0.6s;
  }

  @keyframes line-grow {
    to { transform: scaleX(1); }
  }

  .process-steps {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: clamp(0.55rem, 1.1vw, 0.9rem);
  }

  .process-step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(1rem, 1.5vw, 1.3rem);
    padding: 0;
    height: 100%;
  }

  .process-step__node {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .process-step__node::after {
    content: '';
    position: absolute;
    top: calc(100% + 0.2rem);
    left: 50%;
    width: 1px;
    height: clamp(1rem, 1.5vw, 1.25rem);
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.32), rgba(111, 125, 103, 0.04));
    transform: translateX(-50%);
    pointer-events: none;
  }

  .process-step__circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.6rem;
    height: 4.6rem;
    border-radius: 50%;
    border: 1.5px solid rgba(111, 125, 103, 0.22);
    background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(251,248,241,0.92));
    box-shadow:
      0 0.8rem 1.8rem rgba(57, 54, 48, 0.08),
      inset 0 1px 0 rgba(255,255,255,0.9);
    font-family: var(--font-display);
    font-size: var(--type-card-title);

    font-weight: 400;
    color: rgba(184, 168, 138, 0.92);
    line-height: 1;
    transition:
      transform 0.45s var(--ease-out-expo),
      border-color 0.35s ease,
      box-shadow 0.45s ease,
      color 0.35s ease;
  }

  .process-step:hover .process-step__circle {
    transform: scale(1.08);
    border-color: rgba(111, 125, 103, 0.42);
    color: rgba(111, 125, 103, 0.92);
    box-shadow: 0 1rem 2rem rgba(57, 54, 48, 0.12);
  }

  .process-step__circle::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(111, 125, 103, 0.06);
    animation: circle-pulse 3s ease-in-out infinite;
    pointer-events: none;
  }
  .process-step:nth-child(2) .process-step__circle::after { animation-delay: 0.5s; }
  .process-step:nth-child(3) .process-step__circle::after { animation-delay: 1s; }
  .process-step:nth-child(4) .process-step__circle::after { animation-delay: 1.5s; }
  @keyframes circle-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.15); opacity: 0; }
  }

  .process-step__body {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    gap: 0.65rem;
    width: 100%;
    padding: clamp(1.35rem, 2.2vw, 1.85rem) clamp(1.1rem, 1.8vw, 1.45rem);
    border-radius: var(--card-radius-sm);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.82), rgba(251, 248, 241, 0.62));
    border: 1px solid rgba(111, 125, 103, 0.12);
    box-shadow:
      0 0.6rem 1.4rem rgba(57, 54, 48, 0.04),
      0 0.2rem 0.4rem rgba(57, 54, 48, 0.02),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
    transition: transform 0.4s var(--ease-out-expo), border-color 0.35s ease, background 0.35s ease, box-shadow 0.4s ease;
  }

  .process-step:hover .process-step__body {
    transform: translateY(-0.4rem);
    border-color: rgba(111, 125, 103, 0.22);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.95), rgba(251, 248, 241, 0.78));
    box-shadow:
      0 1rem 2.2rem rgba(57, 54, 48, 0.08),
      0 0.3rem 0.6rem rgba(57, 54, 48, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .process-step h3 {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 1.2em;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);

    font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0;
    text-wrap: nowrap;
  }

  .process-step p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--type-body-sm);
    line-height: 1.58;
    text-wrap: pretty;
  }

  .process-close {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    max-width: 52rem;
    margin: clamp(2.8rem, 5vw, 4rem) auto 0;
    text-align: center;
    flex-wrap: wrap;
    padding: clamp(1.4rem, 2.5vw, 2rem) clamp(1.6rem, 3vw, 2.6rem);
    border-radius: var(--card-radius);
    background: rgba(255, 253, 248, 0.6);
    border: 1px solid rgba(111, 125, 103, 0.1);
  }

  .process-close p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.7;
    text-wrap: pretty;
    flex: 1 1 28rem;
  }

  .process-link {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    gap: 0.58rem;
    min-height: 2.9rem;
    padding: 0.76rem 1.25rem;
    border: 1px solid rgba(86, 100, 90, 0.26);
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    font-size: var(--type-caption);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.14);
    transition: transform 0.45s var(--ease-out-expo), box-shadow 0.45s ease;
  }

  .process-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 1.1rem 1.9rem rgba(86, 100, 90, 0.17);
  }

  .process-link svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .process-link:hover svg {
    transform: translateX(2px);
  }

  @media (max-width: 960px) {
    .process-line {
      top: 0;
      bottom: 0;
      left: 1.8rem;
      right: auto;
      width: 2px;
      height: auto;
    }
    .process-line__bar {
      background: linear-gradient(180deg, rgba(111, 125, 103, 0.06), rgba(111, 125, 103, 0.22) 20%, rgba(111, 125, 103, 0.22) 80%, rgba(111, 125, 103, 0.06));
    }
    .process-line__bar::before {
      background: linear-gradient(180deg, transparent, rgba(111, 125, 103, 0.35), transparent);
      transform: scaleY(0);
      transform-origin: top;
    }
    @keyframes line-grow {
      to { transform: scaleY(1); }
    }
    .process-steps {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 1.4rem;
    }
    .process-step {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: 1.2rem;
      padding: 0;
      height: auto;
    }
    .process-step__node::after {
      top: 50%;
      left: calc(100% + 0.2rem);
      width: 1.1rem;
      height: 1px;
      background: linear-gradient(90deg, rgba(111, 125, 103, 0.32), rgba(111, 125, 103, 0.04));
      transform: translateY(-50%);
    }
    .process-step__body {
      flex: 1 1 auto;
      padding: var(--card-pd-sm);
    }
    .process-step h3 {
      display: block;
      min-height: auto;
      font-size: var(--type-card-title);
      text-wrap: balance;
    }
  }

  @media (max-width: 640px) {
    .proceso {
      padding: 4.8rem 0 5.8rem;
    }

    .process-header {
      text-align: left;
      margin-bottom: 2.4rem;
    }

    .section-eyebrow {
      justify-content: flex-start;
    }
    .section-eyebrow::after {
      display: none;
    }

    .process-header h2 {
      font-size: var(--type-section-title-sm);
      line-height: 1.02;
      letter-spacing: -0.02em;
    }

    .process-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }

    .process-line {
      left: 1.4rem;
    }

    .process-step {
      gap: 0.9rem;
    }

    .process-step__circle {
      width: 3.2rem;
      height: 3.2rem;
      font-size: var(--type-body);
    }

    .process-step__body {
      padding: var(--card-pd-sm);
    }

    .process-step h3 {
      font-size: var(--type-card-title-lg);
    }

    .process-step p {
      font-size: var(--type-card-body);
      line-height: 1.58;
    }

    .process-close {
      display: block;
      text-align: left;
      margin-top: 2.2rem;
      padding: var(--card-pd-sm);
    }

    .process-close p {
      font-size: var(--type-body-sm);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .process-link {
      width: 100%;
      min-height: 2.8rem;
      font-size: var(--type-meta);
      letter-spacing: 0.16em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-step__circle,
    .process-link,
    .process-link svg,
    .process-line__bar::before {
      transition: none !important;
      animation: none !important;
    }
  }
</style>
