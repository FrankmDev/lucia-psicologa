---
import Container from './ui/Container.astro';
import GrainOverlay from './ui/GrainOverlay.astro';

const especialidades = [
  {
    titulo: "Ansiedad y Estrés",
    descripcion: "Restauramos el equilibrio. Encontramos la raíz del ruido mental para devolverle a tu cuerpo la capacidad de habitar la calma.",
    num: "01",
    img: "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?q=80&w=1200&auto=format&fit=crop&crop=entropy"
  },
  {
    titulo: "Trauma y Abordaje Integrador",
    descripcion: "Sanación profunda. Procesamos experiencias dolorosas de forma segura para que el pasado deje de activarse en el presente.",
    num: "02",
    img: "https://images.unsplash.com/photo-1448375240586-882707db888b?q=80&w=1200&auto=format&fit=crop&crop=entropy"
  },
  {
    titulo: "Autoestima",
    descripcion: "Reconstrucción del yo. Transformamos el diálogo interno hacia uno de compasión, respeto y amor propio.",
    num: "03",
    img: "https://images.unsplash.com/photo-1490750967868-88aa4486c946?q=80&w=1200&auto=format&fit=crop&crop=entropy"
  },
  {
    titulo: "Duelo y Pérdida",
    descripcion: "Acompañamiento en la sombra. Un espacio sagrado para transitar la pérdida sin prisa ni juicio.",
    num: "04",
    img: "https://images.unsplash.com/photo-1470770841072-f978cf4d019e?q=80&w=1200&auto=format&fit=crop&crop=entropy"
  }
];
---

<section id="especialidades" class="editorial-section">
  <GrainOverlay opacity={0.03} zIndex={1} />
  
  <div class="ed-container">
    <div class="ed-sticky-sidebar">
      <div class="ed-sidebar-content reveal-up">
        <span class="ed-kicker">Especialidades</span>
        <h2 class="ed-huge-title">
          <span class="italic">Áreas</span><br/>
          de enfoque
        </h2>
        <p class="ed-sidebar-desc">
          Un abordaje clínico y humano diseñado para ir a la raíz del malestar, devolviéndote la autonomía emocional.
        </p>
        <div class="ed-sidebar-line"></div>
      </div>
    </div>

    <div class="ed-scroll-content">
      {especialidades.map((esp, i) => (
        <article class="ed-item reveal-blur">
          <div class="ed-item-image-wrapper" data-parallax="0.05">
            <img src={esp.img} alt={esp.titulo} class="ed-item-image" loading="lazy" />
            <div class="ed-image-overlay"></div>
          </div>
          
          <div class="ed-item-text">
            <div class="ed-item-meta">
              <span class="ed-item-num">{esp.num}</span>
              <div class="ed-item-line"></div>
            </div>
            <h3 class="ed-item-title">{esp.titulo}</h3>
            <p class="ed-item-desc">{esp.descripcion}</p>
            
            <a href="#contacto" class="ed-item-link">
              <span class="link-text">Saber más</span>
              <span class="link-arrow">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .editorial-section {
    position: relative;
    background-color: var(--cream);
    color: var(--ink);
    padding: 15rem 0;
    overflow: hidden;
  }

  .ed-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 4vw;
    display: grid;
    grid-template-columns: 35% 1fr;
    gap: 8vw;
    position: relative;
    z-index: 2;
  }

  /* Sticky Sidebar */
  .ed-sticky-sidebar {
    position: relative;
    height: 100%;
  }
  .ed-sidebar-content {
    position: sticky;
    top: 20vh;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .ed-kicker {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--taupe);
  }
  .ed-huge-title {
    font-family: var(--font-display);
    font-size: var(--type-decorative-lg);
    font-weight: 300;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-left: -5px;
  }
  .ed-huge-title .italic {
    font-style: italic;
    color: var(--earth);
  }
  .ed-sidebar-desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: var(--type-lead);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 28ch;
    margin-top: 2rem;
  }
  .ed-sidebar-line {
    width: 100%;
    height: 1px;
    background: rgba(44, 44, 44, 0.1);
    margin-top: 3rem;
  }

  /* Scrolling Content */
  .ed-scroll-content {
    display: flex;
    flex-direction: column;
    gap: 12rem;
    padding-top: 10vh;
    padding-bottom: 20vh;
  }

  .ed-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4vw;
    align-items: center;
  }
  .ed-item:nth-child(even) {
    grid-template-columns: 1.2fr 0.8fr;
  }

  .ed-item-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
  }
  .ed-item:nth-child(even) .ed-item-image-wrapper {
    aspect-ratio: 4/5;
    order: 2;
  }

  .ed-item-image {
    width: 100%;
    height: 120%;
    object-fit: cover;
    transform: translateY(-10%);
    filter: grayscale(20%) contrast(1.1);
    transition: transform 1.5s var(--ease-out-expo), filter 1.5s ease;
  }
  .ed-item:hover .ed-item-image {
    transform: translateY(-10%) scale(1.05);
    filter: grayscale(0%) contrast(1.1);
  }
  .ed-image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(107, 125, 106, 0.1);
    mix-blend-mode: multiply;
  }

  .ed-item-text {
    display: flex;
    flex-direction: column;
  }
  .ed-item:nth-child(even) .ed-item-text {
    order: 1;
    align-items: flex-end;
    text-align: right;
  }

  .ed-item-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    width: 100%;
  }
  .ed-item:nth-child(even) .ed-item-meta {
    flex-direction: row-reverse;
  }
  .ed-item-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--type-subsection-title);
    color: var(--earth);
  }
  .ed-item-line {
    flex: 1;
    height: 1px;
    background: rgba(44, 44, 44, 0.15);
  }

  .ed-item-title {
    font-family: var(--font-display);
    font-size: var(--type-section-title-sm);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .ed-item-desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: var(--type-lead);
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 32ch;
    margin-bottom: 3rem;
  }

  .ed-item-link {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-body);
    font-size: var(--type-caption);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    position: relative;
    padding-bottom: 0.5rem;
  }
  .ed-item-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.6s var(--ease-out-expo);
  }
  .ed-item-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .link-arrow {
    transition: transform 0.4s ease;
  }
  .ed-item-link:hover .link-arrow {
    transform: translateX(5px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .ed-container {
      grid-template-columns: 1fr;
      gap: 6rem;
    }
    .ed-sidebar-content {
      position: relative;
      top: 0;
    }
    .ed-scroll-content {
      padding-top: 0;
      gap: 8rem;
    }
  }

  @media (max-width: 768px) {
    .editorial-section {
      padding: 8rem 0;
    }
    .ed-item {
      grid-template-columns: 1fr !important;
      gap: 3rem;
    }
    .ed-item:nth-child(even) .ed-item-image-wrapper {
      order: 1;
    }
    .ed-item:nth-child(even) .ed-item-text {
      order: 2;
      align-items: flex-start;
      text-align: left;
    }
    .ed-item:nth-child(even) .ed-item-meta {
      flex-direction: row;
    }
    .ed-item-image-wrapper {
      aspect-ratio: 4/5 !important;
    }
    .ed-huge-title {
      font-size: var(--type-decorative-lg);
    }
  }
</style>
