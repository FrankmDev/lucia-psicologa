---
const servicios = [
  {
    titulo: "Ansiedad y Estrés",
    descripcion: "Abordaje fisiológico y cognitivo para desactivar el bucle de miedo. Pautas claras para recuperar el control de tu sistema nervioso.",
    num: "01",
    img: "https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=800&auto=format&fit=crop"
  },
  {
    titulo: "Trauma y EMDR",
    descripcion: "Procesamiento de memorias dolorosas que quedaron bloqueadas. Una metodología veloz y validada para resolver el origen del dolor.",
    num: "02",
    img: "https://images.unsplash.com/photo-1518241353330-0f7941c2d9b5?q=80&w=800&auto=format&fit=crop"
  },
  {
    titulo: "Autoestima y Autoconocimiento",
    descripcion: "Reconstruye tu monólogo interno. Entiende por qué tu mente generó esas creencias para poder reescribirlas.",
    num: "03",
    img: "https://images.unsplash.com/photo-1499209974431-9dddcece7f88?q=80&w=800&auto=format&fit=crop"
  },
  {
    titulo: "Duelo y Pérdida",
    descripcion: "Un contenedor seguro donde depositar la pena inmensa, sin plazos artificiales ni mensajes de falsa positividad.",
    num: "04",
    img: "https://images.unsplash.com/photo-1519681393784-d120267933ba?q=80&w=800&auto=format&fit=crop"
  }
];
---

<section id="especialidades" class="relative py-32 md:py-40 lg:py-52 bg-surface overflow-hidden paper-texture">
  <div class="relative z-10 max-w-[1240px] mx-auto px-6 sm:px-10 lg:px-16">

    <!-- Section Header -->
    <div class="mb-20 md:mb-28 reveal">
      <p class="section-label mb-6">Servicios</p>
      <hr class="divider-draw mb-14 reveal" />
      <h2 class="text-text-primary">
        <span class="block font-body font-light text-[5vw] md:text-[2.4vw] lg:text-[1.9vw] leading-[1.15] tracking-[-0.01em]">
          Cómo puedo
        </span>
        <span class="block font-display italic text-[9vw] md:text-[5vw] lg:text-[4vw] leading-[1.05] tracking-[-0.02em] text-accent mt-1" style="font-weight: 400;">
          ayudarte
        </span>
      </h2>
    </div>

    <!-- Services List -->
    <div class="services-list" id="services-list">
      {servicios.map((servicio, i) => (
        <a href="#contacto" class="service-item hover-target" data-img={servicio.img} style={`transition-delay: ${0.08 + i * 0.1}s`}>
          <span class="service-num">{servicio.num}</span>
          <div class="service-content">
            <h3 class="service-title">{servicio.titulo}</h3>
            <p class="service-desc">{servicio.descripcion}</p>
          </div>
          <div class="service-arrow">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
              <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="service-hover-line" aria-hidden="true"></div>
        </a>
      ))}
    </div>

    <!-- Floating hover image -->
    <div id="service-hover-img" class="service-hover-img" aria-hidden="true">
      <img src="" alt="" />
    </div>

  </div>
</section>

<style>
  .services-list {
    position: relative;
  }

  .service-item {
    position: relative;
    display: grid;
    grid-template-columns: 4rem 1fr auto;
    gap: 2rem;
    align-items: center;
    padding: 2.2rem 0;
    border-bottom: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    transition: padding 0.5s var(--ease-refugio);
    overflow: hidden;
  }
  .service-item:first-child {
    border-top: 1px solid var(--border-light);
  }
  .service-item:hover {
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .service-num {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--accent);
    opacity: 0.25;
    transition: opacity 0.5s ease;
  }
  .service-item:hover .service-num {
    opacity: 0.6;
  }

  .service-content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .service-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    transition: color 0.4s ease, transform 0.5s var(--ease-refugio);
  }
  .service-item:hover .service-title {
    color: var(--accent);
    transform: translateX(0.5rem);
  }
  .service-desc {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 32rem;
    transition: opacity 0.4s ease, transform 0.5s var(--ease-refugio);
  }
  .service-item:hover .service-desc {
    opacity: 0.8;
    transform: translateX(0.5rem);
  }

  .service-arrow {
    color: var(--text-muted);
    transition: color 0.4s ease, transform 0.5s var(--ease-refugio);
  }
  .service-item:hover .service-arrow {
    color: var(--accent);
    transform: translateX(0.5rem);
  }

  .service-hover-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.7s var(--ease-refugio);
  }
  .service-item:hover .service-hover-line {
    transform: scaleX(1);
  }

  .service-hover-img {
    position: fixed;
    top: 0;
    left: 0;
    width: 280px;
    height: 200px;
    pointer-events: none;
    z-index: 50;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.92);
    transition: opacity 0.4s ease, transform 0.5s var(--ease-refugio);
    overflow: hidden;
    clip-path: polygon(3% 0, 100% 0, 97% 100%, 0 97%);
  }
  .service-hover-img.is-visible {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
  .service-hover-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.75) contrast(1.05);
  }

  @media (max-width: 720px) {
    .service-item {
      grid-template-columns: 2.5rem 1fr auto;
      gap: 1rem;
      padding: 1.6rem 0;
    }
    .service-num {
      font-size: 1.1rem;
    }
    .service-title {
      font-size: 1.15rem;
    }
    .service-hover-img {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const list = document.getElementById('services-list');
    const hoverImg = document.getElementById('service-hover-img');
    const imgEl = hoverImg?.querySelector('img');
    if (!list || !hoverImg || !imgEl) return;

    const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
    if (isTouchDevice) return;

    let currentImg = '';
    let mouseX = 0, mouseY = 0;
    let imgX = 0, imgY = 0;

    list.querySelectorAll('.service-item').forEach(item => {
      item.addEventListener('mouseenter', () => {
        const src = item.dataset.img;
        if (src && src !== currentImg) {
          currentImg = src;
          imgEl.src = src;
        }
        hoverImg.classList.add('is-visible');
      });
      item.addEventListener('mouseleave', () => {
        hoverImg.classList.remove('is-visible');
      });
      item.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });
    });

    const animate = () => {
      imgX += (mouseX - imgX) * 0.12;
      imgY += (mouseY - imgY) * 0.12;
      hoverImg.style.left = imgX + 'px';
      hoverImg.style.top = imgY + 'px';
      requestAnimationFrame(animate);
    };
    animate();
  });
</script>
