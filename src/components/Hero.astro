---
import Eyebrow from './ui/Eyebrow.astro';
import Button from './ui/Button.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import DecorativeRing from './ui/DecorativeRing.astro';

const heroImage = "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?q=80&w=2000&auto=format&fit=crop";
const profileImage = "/images/sobre-mi/lucia-portrait.jpg";
---

<section id="inicio" class="hero" data-hero>
  <div class="hero-bg">
    <img src={heroImage} alt="Paisaje natural de calma y serenidad" decoding="async" loading="eager" class="hero-bg-img" />
    <div class="hero-overlay"></div>
    <div class="hero-vignette" aria-hidden="true"></div>
  </div>

  <GrainOverlay animated opacity={0.025} zIndex={2} />
  <AmbientLight />
  <DustParticles count={10} />

  <FloatOrb size={300} top="15%" right="10%" color="rgba(107,125,106,0.12)" animation="float-1" />
  <FloatOrb size={200} bottom="20%" left="8%" color="rgba(196,170,148,0.08)" animation="float-2" />
  <FloatOrb size={150} top="60%" right="25%" color="rgba(168,146,124,0.1)" animation="float-3" />

  <InkBlob width={450} height={350} top="-5%" right="-3%" color="var(--sage)" opacity={0.035} />
  <InkBlob width={350} height={300} bottom="-8%" left="-5%" color="var(--gold)" opacity={0.035} animation="morph-2" />

  <DecorativeRing size={400} top="-100px" right="-100px" />
  <DecorativeRing size={250} bottom="10%" left="-60px" duration={25} reverse />

  <div class="hero-content" data-parallax-content>
    <Eyebrow text="Psicología Clínica · Ciudad Real · Online" light={true} centered={true} />

    <h1 class="hero-title">
      <span class="title-line">
        <span class="title-inner" data-split>Un espacio para</span>
      </span>
      <span class="title-line title-line--accent">
        <span class="title-inner" data-split>encontrarte</span>
        <svg class="title-underline" viewBox="0 0 200 12" preserveAspectRatio="none" aria-hidden="true">
          <path d="M2 8 Q50 2 100 6 T198 4" stroke="rgba(196,170,148,0.5)" stroke-width="2" fill="none" stroke-linecap="round" class="underline-path"/>
        </svg>
      </span>
    </h1>

    <p class="hero-tagline">
      Acompañamiento psicológico para quienes buscan sentirse mejor.<br class="hide-mobile"/>
      Con la calidez y el rigor profesional que necesitas.
    </p>

    <div class="hero-credentials">
      <div class="credential-item">
        <span class="credential-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3.5 2.5 6.5 6 7 3.5-.5 6-3.5 6-7V4L8 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
        </span>
        <span class="credential-text">Psicóloga clínica colegiada</span>
      </div>
      <div class="credential-sep" aria-hidden="true"></div>
      <div class="credential-item">
        <span class="credential-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M5 8l2.5 2.5L11 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="credential-text">Terapia online y presencial</span>
      </div>
      <div class="credential-sep" aria-hidden="true"></div>
      <div class="credential-item">
        <span class="credential-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 6l6-4 6 4v6l-6 4-6-4V6z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M8 8v6" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M8 8L4 6" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M8 8l4-2" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
        </span>
        <span class="credential-text">Online y Presencial</span>
      </div>
    </div>

    <div class="hero-cta">
      <Button href="#contacto" variant="hero" class="btn-hero-cta" data-cta>
        Reservar primera sesión
      </Button>
      <a href="#sobre-mi" class="btn-hero-ghost">
        <span class="ghost-text">Conóceme</span>
        <span class="ghost-line" aria-hidden="true"></span>
        <span class="ghost-dot" aria-hidden="true"></span>
      </a>
    </div>

    <div class="hero-therapist">
      <div class="therapist-avatar">
        <img src={profileImage} alt="Lucía, psicóloga clínica" loading="lazy" />
        <span class="avatar-ring" aria-hidden="true"></span>
        <span class="avatar-pulse" aria-hidden="true"></span>
      </div>
      <div class="therapist-info">
        <span class="therapist-name">Lucía Millán Jiménez</span>
        <span class="therapist-role">Psicóloga Clínica</span>
      </div>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
    <span class="scroll-text">Descubre más</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100dvh;
    overflow: hidden;
    background: #0d0a08;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 120px 5vw 100px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: grayscale(15%) brightness(0.55) saturate(0.8) contrast(1.1);
    transform: scale(1.08);
    animation: hero-breathe 20s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes hero-breathe {
    0%   { transform: scale(1.08) translateY(0); }
    100% { transform: scale(1.15) translateY(-8px); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(13,10,8,0.3) 0%, transparent 60%),
      radial-gradient(ellipse at 30% 70%, rgba(42,31,26,0.4) 0%, transparent 50%),
      linear-gradient(180deg, rgba(13,10,8,0.5) 0%, rgba(13,10,8,0.2) 50%, rgba(13,10,8,0.6) 100%);
    z-index: 1;
  }
  .hero-vignette {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 200px 80px rgba(13,10,8,0.6);
    z-index: 1;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 940px;
    margin: 0 auto;
    padding: 0 5vw;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    will-change: transform;
  }

  .hero-title {
    max-width: 58rem;
    margin-bottom: 1.45rem;
    line-height: 1;
  }
  .title-line {
    display: block;
    overflow: hidden;
  }
  .title-inner {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(3rem, 6.6vw, 5.5rem);
    line-height: 1;
    color: #F5F0E8;
    letter-spacing: -0.045em;
    text-shadow: 0 2px 40px rgba(0,0,0,0.3);
    will-change: transform;
    opacity: 0;
    transform: translateY(110%);
    animation: title-rise 1.4s var(--ease-out-expo) forwards;
  }
  .title-line:nth-child(1) .title-inner {
    animation-delay: 0.6s;
  }
  .title-line--accent {
    position: relative;
    display: inline-block;
  }
  .title-line--accent .title-inner {
    animation-delay: 0.85s;
    color: rgba(245,240,232,0.95);
    font-weight: 300;
  }
  .title-underline {
    position: absolute;
    bottom: clamp(-6px, -0.45vw, -2px);
    left: 3%;
    width: 94%;
    height: 12px;
    overflow: visible;
    pointer-events: none;
  }
  .underline-path {
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    animation: draw-line 1.2s var(--ease-out-expo) forwards;
    animation-delay: 1.8s;
  }
  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }
  @keyframes title-rise {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 300;
    font-size: clamp(1rem, 1.3vw, 1.13rem);
    color: rgba(245,240,232,0.74);
    margin-bottom: clamp(2rem, 3.6vw, 3rem);
    letter-spacing: 0;
    max-width: 620px;
    line-height: 1.76;
    text-wrap: pretty;
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 1.1s var(--ease-out-expo) forwards;
    animation-delay: 1.1s;
  }

  .hero-credentials {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 2.4rem;
    flex-wrap: wrap;
    row-gap: 0.8rem;
  }
  .credential-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.2rem;
    opacity: 0;
    transform: translateY(12px);
    animation: reveal-up 0.9s var(--ease-out-expo) forwards;
  }
  .credential-item:nth-child(1) { animation-delay: 1.25s; }
  .credential-item:nth-child(3) { animation-delay: 1.4s; }
  .credential-item:nth-child(5) { animation-delay: 1.55s; }
  .credential-icon {
    color: rgba(196,170,148,0.7);
    display: flex;
    align-items: center;
    transition: color 0.4s ease, transform 0.4s var(--ease-out-expo);
  }
  .credential-item:hover .credential-icon {
    color: rgba(196,170,148,0.95);
    transform: scale(1.15);
  }
  .credential-icon svg {
    width: 16px; height: 16px;
  }
  .credential-text {
    font-family: var(--font-body);
    font-size: max(0.58rem, 10px);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.82);
    transition: color 0.3s ease;
  }
  .credential-item:hover .credential-text {
    color: rgba(245,240,232,0.95);
  }
  .credential-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(196,170,148,0.25);
    animation: sep-blink 4s ease-in-out infinite;
  }
  @keyframes sep-blink {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.7; }
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 1.1s var(--ease-out-expo) forwards;
    animation-delay: 1.6s;
  }

  .btn-hero-ghost {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 18px 8px;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.75);
    text-decoration: none;
    transition: color 0.4s ease;
  }
  .btn-hero-ghost:hover {
    color: rgba(245,240,232,0.95);
  }
  .ghost-text {
    position: relative;
    z-index: 1;
    transition: letter-spacing 0.5s var(--ease-out-expo);
  }
  .btn-hero-ghost:hover .ghost-text {
    letter-spacing: 0.26em;
  }
  .ghost-line {
    position: absolute;
    bottom: 10px;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(245,240,232,0.2);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.6s var(--ease-out-expo), background 0.3s ease;
  }
  .btn-hero-ghost:hover .ghost-line {
    transform: scaleX(1);
    background: rgba(245,240,232,0.4);
  }
  .ghost-dot {
    position: absolute;
    bottom: 9px;
    left: 50%;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: rgba(196,170,148,0.6);
    transform: translateX(-50%) scale(0);
    transition: transform 0.4s var(--ease-out-expo) 0.2s;
  }
  .btn-hero-ghost:hover .ghost-dot {
    transform: translateX(-50%) scale(1);
  }

  .hero-therapist {
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: reveal-up 1s var(--ease-out-expo) forwards;
    animation-delay: 2s;
  }
  .therapist-avatar {
    position: relative;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: visible;
  }
  .therapist-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(20%) brightness(0.95);
    border: 2px solid rgba(245,240,232,0.12);
    padding: 2px;
    transition: filter 0.5s ease, transform 0.5s var(--ease-out-expo);
  }
  .therapist-avatar:hover img {
    filter: grayscale(0%) brightness(1);
    transform: scale(1.08);
  }
  .avatar-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(196,170,148,0.2);
    animation: ring-spin-slow 12s linear infinite;
    pointer-events: none;
  }
  @keyframes ring-spin-slow {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .avatar-pulse {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(196,170,148,0.08);
    animation: avatar-pulse 3s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes avatar-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.08); opacity: 0; }
  }
  .therapist-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  .therapist-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--type-card-title-sm);
    color: rgba(245,240,232,0.92);
    letter-spacing: 0.02em;
  }
  .therapist-role {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.65);
  }

  .scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    opacity: 0;
    animation: reveal-fade 2s ease forwards;
    animation-delay: 3s;
  }
  .scroll-mouse {
    width: 20px;
    height: 32px;
    border: 1.5px solid rgba(245,240,232,0.15);
    border-radius: 12px;
    position: relative;
  }
  .scroll-wheel {
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 6px;
    background: rgba(245,240,232,0.4);
    border-radius: 2px;
    animation: wheel-scroll 2s ease-in-out infinite;
  }
  @keyframes wheel-scroll {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.6; }
    50% { transform: translateX(-50%) translateY(6px); opacity: 0.2; }
  }
  .scroll-text {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.3);
  }

  @keyframes reveal-fade { to { opacity: 1; } }
  @keyframes reveal-up { to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 1024px) {
    .hero { padding: 100px 5vw 80px; }
    .hero-content { max-width: 900px; }
    .title-inner { font-size: clamp(2.9rem, 8vw, 5rem); }
  }

  @media (max-width: 768px) {
    .hero { padding: 90px 5vw 80px; min-height: 100svh; }
    .hide-mobile { display: none; }
    .title-inner {
      font-size: clamp(2.6rem, 11vw, 4rem);
      line-height: 1.05;
      letter-spacing: -0.035em;
    }
    .title-underline { height: 7px; bottom: -3px; }
    .hero-tagline {
      font-size: 0.95rem;
      margin-bottom: 1.6rem;
      line-height: 1.65;
    }
    .hero-credentials {
      margin-bottom: 1.6rem;
      flex-direction: column;
      gap: 0.45rem;
    }
    .credential-sep { display: none; }
    .credential-item { padding: 0; gap: 0.4rem; }
    .hero-cta {
      flex-direction: column;
      gap: 0.7rem;
      width: 100%;
      max-width: 260px;
      margin-bottom: 1.6rem;
    }
    .btn-hero-cta,
    .btn-hero-ghost {
      width: 100%;
      justify-content: center;
      padding: 15px 24px;
      font-size: max(0.58rem, 10px);
      letter-spacing: 0.16em;
    }
    .hero-therapist { gap: 0.8rem; }
    .therapist-avatar { width: 44px; height: 44px; }
    .therapist-name { font-size: 0.95rem; }
    .therapist-role { font-size: max(0.55rem, 9px); letter-spacing: 0.12em; }
    .scroll-hint { bottom: 16px; }
    .scroll-text { font-size: max(0.55rem, 9px); letter-spacing: 0.14em; }
  }

  @media (max-width: 380px) {
    .hero { padding: 80px 4vw 70px; }
    .title-inner {
      font-size: clamp(2.3rem, 10vw, 3.2rem);
    }
    .hero-tagline { font-size: 0.9rem; }
  }
</style>

<script>
  const hero = document.querySelector('[data-hero]');
  const content = document.querySelector('[data-parallax-content]');
  if (content && hero && !window.matchMedia('(pointer: coarse)').matches) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
      const y = (e.clientY - rect.top - rect.height / 2) / rect.height;
      (content as HTMLElement).style.transform = `translate(${x * -8}px, ${y * -6}px)`;
    });
    hero.addEventListener('mouseleave', () => {
      (content as HTMLElement).style.transform = 'translate(0, 0)';
    });
  }

  const heroBg = document.querySelector('.hero-bg-img');
  if (heroBg && hero && !window.matchMedia('(pointer: coarse)').matches) {
    window.addEventListener('scroll', () => {
      const rect = hero.getBoundingClientRect();
      const progress = Math.max(0, Math.min(1, -rect.top / rect.height));
      (heroBg as HTMLElement).style.transform = `scale(1.08) translateY(${progress * 30}px)`;
    }, { passive: true });
  }
</script>
