---
import Eyebrow from './ui/Eyebrow.astro';
import Button from './ui/Button.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import DecorativeRing from './ui/DecorativeRing.astro';
import profileImage from '../assets/about.avif';

const heroImage = "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=2200&auto=format&fit=crop&crop=entropy";

const badges = [
  { label: 'Terapia Individual', icon: 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z' },
  { label: 'Online', icon: 'M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7zm18 0H4v10h16V7zM8 21h8' },
  { label: 'Trauma y EMDR', icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
];
---

<section id="inicio" class="hero" data-hero>
  <div class="hero-bg">
    <img src={heroImage} alt="Paisaje natural con luz suave" fetchpriority="high" decoding="async" loading="eager" class="hero-bg-img" />
    <div class="hero-overlay"></div>
    <div class="hero-header-shade" aria-hidden="true"></div>
    <div class="hero-vignette" aria-hidden="true"></div>
  </div>

  <GrainOverlay animated opacity={0.025} zIndex={2} />
  <AmbientLight />
  <DustParticles count={10} />

  <FloatOrb size={300} top="15%" right="10%" color="rgba(107,125,106,0.12)" animation="float-1" />
  <FloatOrb size={200} bottom="20%" left="8%" color="rgba(196,170,148,0.08)" animation="float-2" />
  <FloatOrb size={150} top="60%" right="25%" color="rgba(168,146,124,0.1)" animation="float-3" class="hide-mobile" />

  <InkBlob width={450} height={350} top="-5%" right="-3%" color="var(--sage)" opacity={0.035} />
  <InkBlob width={350} height={300} bottom="-8%" left="-5%" color="var(--gold)" opacity={0.035} animation="morph-2" class="hide-mobile" />

  <DecorativeRing size={400} top="-100px" right="-100px" />
  <DecorativeRing size={250} bottom="10%" left="-60px" duration={25} reverse class="hide-mobile" />

  <div class="hero-fade" aria-hidden="true"></div>

  <div class="hero-content" data-parallax-content>
    <Eyebrow text="Psicología · Ciudad Real · Online" light={true} centered={true} />

    <h1 class="hero-title">
      <span class="title-line">
        <span class="title-inner" data-split>Entender lo que te ocurre</span>
      </span>
      <span class="title-line title-line--accent">
        <span class="title-inner" data-split>Trabajarlo a tu medida</span>
        <svg class="title-underline" viewBox="0 0 200 12" preserveAspectRatio="none" aria-hidden="true">
          <path d="M2 8 Q50 2 100 6 T198 4" stroke="rgba(196,170,148,0.5)" stroke-width="2" fill="none" stroke-linecap="round" class="underline-path"/>
        </svg>
      </span>
    </h1>

    <p class="hero-tagline">
      Terapia individual para ansiedad, trauma, duelo y malestar emocional.<br class="hide-mobile"/>
      Integro TCC, ACT, TFE, IFS y EMDR según tu caso.
    </p>

    <div class="hero-badges" aria-label="Modalidades de terapia">
      {badges.map((badge) => (
        <span class="hero-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d={badge.icon} />
          </svg>
          <span>{badge.label}</span>
        </span>
      ))}
    </div>

    <div class="hero-cta">
      <Button href="#contacto" variant="hero" class="btn-hero-cta" data-cta>
        Solicitar primera sesión
      </Button>
      <a href="#proceso" class="btn-hero-ghost">
        <span class="ghost-text">Ver proceso</span>
        <span class="ghost-line" aria-hidden="true"></span>
      </a>
    </div>

    <div class="hero-therapist">
      <div class="therapist-avatar">
        <img src={profileImage.src} alt="Lucía, psicóloga general sanitaria" loading="lazy" />
        <span class="avatar-ring" aria-hidden="true"></span>
        <span class="avatar-pulse" aria-hidden="true"></span>
      </div>
      <div class="therapist-info">
        <span class="therapist-name">Lucía Millán Jiménez</span>
        <span class="therapist-role">Psicóloga General Sanitaria</span>
      </div>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    --hero-edge: clamp(1.25rem, 5vw, 4.25rem);
    --hero-fade-height: clamp(140px, 20vh, 260px);

    position: relative;
    width: 100%;
    min-height: 100dvh;
    height: auto;
    padding-top: var(--site-header-height, 0px);
    overflow: hidden;
    contain: paint;
    background: #0d0a08;
    display: grid;
    place-items: center;
    box-sizing: border-box;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    object-fit: cover;
    object-position: center 55%;
    filter: brightness(0.62) saturate(0.86) contrast(1.04);
    will-change: transform;
    transition: transform 0.1s linear;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 48%, rgba(13,10,8,0.52) 0%, transparent 72%),
      linear-gradient(180deg, rgba(13,10,8,0.54) 0%, rgba(13,10,8,0.32) 44%, rgba(13,10,8,0.48) 100%);
    z-index: 1;
  }
  .hero-vignette {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 180px 72px rgba(13,10,8,0.64);
    z-index: 1;
    pointer-events: none;
  }
  .hero-header-shade {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: clamp(140px, 24vh, 260px);
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(8,6,5,0.72) 0%, rgba(8,6,5,0.52) 28%, rgba(8,6,5,0.22) 62%, transparent 100%),
      radial-gradient(ellipse 82% 70% at 50% 0%, rgba(8,6,5,0.42) 0%, transparent 74%);
  }

  /* Soft melt into the next section — contained inside the 100dvh hero */
  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: var(--hero-fade-height);
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(13, 10, 8, 0) 0%,
        rgba(13, 10, 8, 0) 34%,
        rgba(13, 10, 8, 0.04) 48%,
        rgba(13, 10, 8, 0.12) 60%,
        rgba(55, 48, 42, 0.22) 72%,
        rgba(118, 108, 97, 0.32) 82%,
        rgba(195, 185, 172, 0.46) 90%,
        rgba(255, 253, 250, 0.82) 96%,
        #fffdfa 100%
      );
  }

  @supports (backdrop-filter: blur(1px)) {
    .hero-fade {
      backdrop-filter: blur(24px) saturate(1.03);
      -webkit-backdrop-filter: blur(24px) saturate(1.03);
      mask-image: linear-gradient(
        180deg,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, 0) 34%,
        rgba(0, 0, 0, 0.18) 54%,
        rgba(0, 0, 0, 0.85) 78%,
        rgba(0, 0, 0, 1) 100%
      );
      -webkit-mask-image: linear-gradient(
        180deg,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, 0) 34%,
        rgba(0, 0, 0, 0.18) 54%,
        rgba(0, 0, 0, 0.85) 78%,
        rgba(0, 0, 0, 1) 100%
      );
    }
  }

  .hero-content {
    position: relative;
    z-index: 3;
    isolation: isolate;
    width: 100%;
    max-width: 940px;
    margin: 0 auto;
    padding: 0 var(--hero-edge);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0;
    text-align: center;
    will-change: transform;
  }
  .hero :global(.eyebrow-text) {
    color: #fbf8f2;
  }
  .hero :global(.eyebrow-line) {
    background: rgba(227,213,191,0.5);
  }
  .hero :global(.eyebrow-dot) {
    background: rgba(227,213,191,0.65);
  }

  .hero-title {
    max-width: 58rem;
    margin: 0 0 clamp(1rem, 2.4vw, 1.45rem);
    line-height: 1;
  }
  .title-line {
    display: block;
    overflow: hidden;
  }
  .title-inner {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;

    font-size: var(--type-hero);
    line-height: 1;
    color: #fbf8f2;
    letter-spacing: -0.028em;
    text-shadow: 0 2px 24px rgba(0,0,0,0.34);
    will-change: transform;
    opacity: 0;
    transform: translateY(110%);
    animation: title-rise 1.4s var(--ease-out-expo) forwards;
  }
  .title-line:nth-child(1) .title-inner {
    animation-delay: 0.6s;
  }
  .title-line--accent {
    position: relative;
    display: inline-block;
  }
  .title-line--accent .title-inner {
    animation-delay: 0.85s;
    font-weight: 300;
    color: #fbf8f2;
  }
  .title-underline {
    position: absolute;
    bottom: clamp(-6px, -0.45vw, -2px);
    left: 3%;
    width: 94%;
    height: 12px;
    overflow: visible;
    pointer-events: none;
  }
  .underline-path {
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    animation: draw-line 1.2s var(--ease-out-expo) forwards;
    animation-delay: 1.8s;
  }
  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }
  @keyframes title-rise {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 400;
    font-size: var(--type-lead);
    color: #fbf8f2;
    margin: 0 0 clamp(1.6rem, 3.2vw, 2.2rem);
    letter-spacing: 0.01em;
    max-width: 620px;
    line-height: 1.82;
    text-wrap: pretty;
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 1.1s var(--ease-out-expo) forwards;
    animation-delay: 1.1s;
  }

  .hero-badges {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin: 0 0 clamp(1.55rem, 3vw, 2.4rem);
    padding: 0.55rem 0.65rem;
    border: 1px solid rgba(245,240,232,0.18);
    border-radius: 999px;
    background: rgba(13,10,8,0.26);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 0;
    transform: translateY(16px);
    animation: reveal-up 1s var(--ease-out-expo) forwards;
    animation-delay: 1.35s;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(245,240,232,0.08);
    border: 1px solid rgba(245,240,232,0.08);
    color: #fbf8f2;
    font-size: var(--type-meta);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 0.35s ease, border-color 0.35s ease, transform 0.35s var(--ease-out-expo);
  }
  .hero-badge:hover {
    background: rgba(245,240,232,0.14);
    border-color: rgba(196,170,148,0.25);
    transform: translateY(-2px);
  }
  .hero-badge svg {
    color: rgba(196,170,148,0.85);
    flex-shrink: 0;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin: 0 0 clamp(1.6rem, 3vw, 2.5rem);
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 1.1s var(--ease-out-expo) forwards;
    animation-delay: 1.65s;
  }

  .hero :global(.btn-hero-cta) {
    background: linear-gradient(135deg, #6f7d67 0%, #56645a 100%);
    border-color: rgba(255,255,255,0.12);
    color: #fbf8f1;
    box-shadow: 0 12px 32px rgba(0,0,0,0.22);
  }
  .hero :global(.btn-hero-cta:hover) {
    background: linear-gradient(135deg, #7d8c74 0%, #65745f 100%);
    border-color: rgba(255,255,255,0.22);
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.28);
  }
  .hero :global(.btn-hero-cta .btn__arrow) {
    color: rgba(245,240,232,0.7);
  }

  .btn-hero-ghost {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 16px 28px;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2f2d28;
    text-decoration: none;
    border: 1px solid #fbf8f2;
    border-radius: 100px;
    background: #fbf8f2;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    transition: all 0.45s var(--ease-out-expo);
  }
  .btn-hero-ghost:hover {
    background: #fff;
    border-color: #fff;
    color: #2f2d28;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
  }
  .ghost-text {
    position: relative;
    z-index: 1;
    transition: letter-spacing 0.5s var(--ease-out-expo);
  }
  .btn-hero-ghost:hover .ghost-text {
    letter-spacing: 0.24em;
  }
  .ghost-line {
    position: absolute;
    bottom: 12px;
    left: 28px;
    right: 28px;
    height: 1px;
    background: rgba(47,45,40,0.14);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.6s var(--ease-out-expo), background 0.3s ease;
  }
  .btn-hero-ghost:hover .ghost-line {
    transform: scaleX(1);
    background: rgba(47,45,40,0.35);
  }

  .hero-therapist {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 0.65rem 1.1rem 0.65rem 0.75rem;
    border: 1px solid rgba(245,240,232,0.1);
    border-radius: 999px;
    background: rgba(13,10,8,0.24);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 0;
    animation: reveal-up 1s var(--ease-out-expo) forwards;
    animation-delay: 2s;
  }
  .therapist-avatar {
    position: relative;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: visible;
  }
  .therapist-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(20%) brightness(0.95);
    border: 2px solid rgba(245,240,232,0.12);
    padding: 2px;
    transition: filter 0.5s ease, transform 0.5s var(--ease-out-expo);
  }
  .therapist-avatar:hover img {
    filter: grayscale(0%) brightness(1);
    transform: scale(1.08);
  }
  .avatar-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(196,170,148,0.2);
    animation: ring-spin-slow 12s linear infinite;
    pointer-events: none;
  }
  @keyframes ring-spin-slow {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .avatar-pulse {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(196,170,148,0.08);
    animation: avatar-pulse 3s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes avatar-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.08); opacity: 0; }
  }
  .therapist-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  .therapist-name {
    font-family: var(--font-display);

    font-weight: 400;
    font-size: var(--type-card-title-sm);
    color: #fbf8f2;
    letter-spacing: 0.02em;
  }
  .therapist-role {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(251,248,242,0.8);
  }

  .scroll-hint {
    position: absolute;
    bottom: clamp(40px, 8vh, 90px);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: reveal-fade 2s ease forwards;
    animation-delay: 3s;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(245,240,232,0.2);
    position: relative;
    overflow: hidden;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(245,240,232,0.7);
    animation: line-scroll 2.5s ease-in-out infinite;
  }
  @keyframes line-scroll {
    0% { transform: translateY(-100%); }
    50% { transform: translateY(0%); }
    100% { transform: translateY(100%); }
  }

  @keyframes reveal-fade { to { opacity: 1; } }
  @keyframes reveal-up { to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 1024px) {
    .hero {
      --hero-edge: clamp(1.25rem, 4vw, 2.5rem);
    }
    .hero-content { max-width: 700px; }
    .hero-title {
      margin-bottom: clamp(0.6rem, 1.5vw, 0.9rem);
    }
    .title-inner {
      font-size: clamp(2.5rem, 5vw, 3.6rem);
    }
    .hero-tagline {
      max-width: 480px;
      font-size: clamp(0.92rem, 1.8vw, 1rem);
      margin-bottom: clamp(0.85rem, 2vw, 1.25rem);
      line-height: 1.65;
    }
    .hero-badges {
      margin-bottom: clamp(0.85rem, 2vw, 1.25rem);
    }
    .hero-cta {
      margin-bottom: clamp(0.85rem, 2vw, 1.25rem);
    }
  }

  @media (max-width: 768px) {
    .hero {
      --hero-edge: clamp(1rem, 5vw, 1.4rem);
      --hero-fade-height: clamp(100px, 16vh, 180px);

      height: 100svh;
      max-height: 100svh;
      min-height: 0;
    }
    .hero-bg-img {
      object-position: 58% center;
      animation: none;
      will-change: auto;
      transform: none;
    }
    .hero-overlay {
      background:
        radial-gradient(ellipse 86% 66% at 50% 45%, rgba(13,10,8,0.48) 0%, transparent 76%),
        linear-gradient(180deg, rgba(13,10,8,0.48) 0%, rgba(13,10,8,0.26) 30%, rgba(13,10,8,0.42) 100%);
    }
    .hero-vignette {
      box-shadow: inset 0 0 150px 48px rgba(13,10,8,0.62);
    }
    .hero-header-shade {
      height: clamp(128px, 26vh, 220px);
      background:
        linear-gradient(180deg, rgba(8,6,5,0.78) 0%, rgba(8,6,5,0.56) 30%, rgba(8,6,5,0.24) 66%, transparent 100%),
        radial-gradient(ellipse 94% 76% at 50% 0%, rgba(8,6,5,0.42) 0%, transparent 76%);
    }
    .hero-content {
      max-width: 30rem;
      justify-content: center;
    }
    .hide-mobile { display: none; }
    .hero :global(.eyebrow) {
      max-width: min(100%, 21rem);
      margin-bottom: 0.85rem;
      gap: 0.45rem;
    }
    .hero :global(.eyebrow-text) {
      white-space: normal;
      text-wrap: balance;
      line-height: 1.45;
      letter-spacing: 0.12em;
    }
    .hero :global(.eyebrow-line),
    .hero :global(.eyebrow-dot) {
      flex: 0 0 auto;
    }
    .hero-title {
      margin-bottom: 0.8rem;
    }
    .title-inner {
      font-size: clamp(2.25rem, 11vw, 3.7rem);
      line-height: 1.02;
      letter-spacing: -0.035em;
      text-shadow: 0 2px 20px rgba(0,0,0,0.34);
    }
    .title-line--accent { display: inline-block; }
    .title-underline { height: 4px; bottom: -3px; }
    .hero-tagline {
      max-width: 21rem;
      font-size: clamp(0.92rem, 4vw, 1.02rem);
      margin-bottom: 1rem;
      line-height: 1.55;
    }
    .hero-badges {
      width: min(100%, 22rem);
      margin-bottom: 1rem;
      padding: 0.45rem;
      gap: 0.4rem;
      border-radius: 1rem;
    }
    .hero-badge {
      flex: 1 1 auto;
      justify-content: center;
      padding: 0.4rem 0.65rem;
      font-size: 0.65rem;
      letter-spacing: 0.08em;
    }
    .hero-cta {
      width: min(100%, 22rem);
      flex-direction: column;
      gap: 0.7rem;
      margin-bottom: 0;
    }
    .hero :global(.btn-hero-cta),
    .btn-hero-ghost {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      white-space: nowrap;
    }
    .hero :global(.btn-hero-cta) {
      width: 100%;
      min-height: 3.05rem;
      padding: 0.85rem 1rem;
      gap: 0.5rem;
    }
    .btn-hero-ghost {
      width: 100%;
      justify-content: center;
      padding: 0.85rem 1rem;
      min-height: 2.8rem;
    }
    .ghost-line {
      left: 1rem;
      right: 1rem;
    }
    .hero-therapist {
      display: none;
    }
