---
import Eyebrow from './ui/Eyebrow.astro';
import Button from './ui/Button.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import DecorativeRing from './ui/DecorativeRing.astro';
import profileImage from '../assets/about.avif';

const heroImage = "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=2200&auto=format&fit=crop&crop=entropy";
---

<section id="inicio" class="hero" data-hero>
  <div class="hero-bg">
    <img src={heroImage} alt="Paisaje natural con luz suave" fetchpriority="high" decoding="async" loading="eager" class="hero-bg-img" />
    <div class="hero-overlay"></div>
    <div class="hero-header-shade" aria-hidden="true"></div>
    <div class="hero-vignette" aria-hidden="true"></div>
  </div>

  <GrainOverlay animated opacity={0.025} zIndex={2} />
  <AmbientLight />
  <DustParticles count={10} />

  <FloatOrb size={300} top="15%" right="10%" color="rgba(107,125,106,0.12)" animation="float-1" />
  <FloatOrb size={200} bottom="20%" left="8%" color="rgba(196,170,148,0.08)" animation="float-2" />
  <FloatOrb size={150} top="60%" right="25%" color="rgba(168,146,124,0.1)" animation="float-3" class="hide-mobile" />

  <InkBlob width={450} height={350} top="-5%" right="-3%" color="var(--sage)" opacity={0.035} />
  <InkBlob width={350} height={300} bottom="-8%" left="-5%" color="var(--gold)" opacity={0.035} animation="morph-2" class="hide-mobile" />

  <DecorativeRing size={400} top="-100px" right="-100px" />
  <DecorativeRing size={250} bottom="10%" left="-60px" duration={25} reverse class="hide-mobile" />

  <div class="hero-content" data-parallax-content>
    <Eyebrow text="Psicología clínica · Ciudad Real · Online" light={true} centered={true} />

    <h1 class="hero-title">
      <span class="title-line">
        <span class="title-inner" data-split>Entender lo que te ocurre</span>
      </span>
      <span class="title-line title-line--accent">
        <span class="title-inner" data-split>Trabajarlo a tu medida</span>
        <svg class="title-underline" viewBox="0 0 200 12" preserveAspectRatio="none" aria-hidden="true">
          <path d="M2 8 Q50 2 100 6 T198 4" stroke="rgba(196,170,148,0.5)" stroke-width="2" fill="none" stroke-linecap="round" class="underline-path"/>
        </svg>
      </span>
    </h1>

    <p class="hero-tagline">
      Terapia individual para ansiedad, trauma, duelo y malestar emocional,<br class="hide-mobile"/>
      integrando TCC, ACT, TFE, IFS y EMDR según tu caso.
    </p>

    <div class="hero-credentials">
      <div class="credential-item">
        <span class="credential-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3.5 2.5 6.5 6 7 3.5-.5 6-3.5 6-7V4L8 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
        </span>
        <span class="credential-text">Col. CM03673 · EMDR Nivel I</span>
      </div>
      <div class="credential-sep" aria-hidden="true"></div>
      <div class="credential-item">
        <span class="credential-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M5 8l2.5 2.5L11 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="credential-text">Consulta presencial y online</span>
      </div>
    </div>

    <div class="hero-cta">
      <Button href="#contacto" variant="hero" class="btn-hero-cta" data-cta>
        Solicitar primera sesión
      </Button>
      <a href="#proceso" class="btn-hero-ghost">
        <span class="ghost-text">Ver cómo sería el proceso</span>
        <span class="ghost-line" aria-hidden="true"></span>
        <span class="ghost-dot" aria-hidden="true"></span>
      </a>
    </div>

    <div class="hero-therapist">
      <div class="therapist-avatar">
        <img src={profileImage.src} alt="Lucía, psicóloga clínica" loading="lazy" />
        <span class="avatar-ring" aria-hidden="true"></span>
        <span class="avatar-pulse" aria-hidden="true"></span>
      </div>
      <div class="therapist-info">
        <span class="therapist-name">Lucía Millán Jiménez</span>
        <span class="therapist-role">Psicóloga Clínica</span>
      </div>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    --hero-edge: clamp(1.25rem, 5vw, 4.25rem);

    position: relative;
    width: 100%;
    height: 100dvh;
    max-height: 100dvh;
    min-height: 0;
    padding-top: var(--site-header-height, 0px);
    overflow: hidden;
    contain: paint;
    background: #0d0a08;
    display: grid;
    place-items: center;
    box-sizing: border-box;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    max-width: none;
    max-height: none;
    object-fit: cover;
    object-position: center 40%;
    filter: brightness(1.02) saturate(0.94) contrast(1.04);
    will-change: transform;
    transition: transform 0.1s linear;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 76% 60% at 50% 48%, rgba(13,10,8,0.22) 0%, transparent 76%),
      linear-gradient(180deg, rgba(13,10,8,0.24) 0%, rgba(13,10,8,0.1) 48%, rgba(13,10,8,0.42) 100%);
    z-index: 1;
  }
  .hero-vignette {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 180px 72px rgba(13,10,8,0.36);
    z-index: 1;
    pointer-events: none;
  }
  .hero-header-shade {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: clamp(140px, 24vh, 260px);
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(8,6,5,0.72) 0%, rgba(8,6,5,0.52) 28%, rgba(8,6,5,0.22) 62%, transparent 100%),
      radial-gradient(ellipse 82% 70% at 50% 0%, rgba(8,6,5,0.42) 0%, transparent 74%);
  }

  .hero-content {
    position: relative;
    z-index: 3;
    isolation: isolate;
    width: 100%;
    max-width: 940px;
    margin: 0 auto;
    padding: 0 var(--hero-edge);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0;
    text-align: center;
    will-change: transform;
  }
  .hero :global(.eyebrow-text) {
    color: rgba(251,248,242,0.88);
  }
  .hero :global(.eyebrow-line) {
    background: rgba(227,213,191,0.34);
  }
  .hero :global(.eyebrow-dot) {
    background: rgba(227,213,191,0.5);
  }
  .hero-content::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: clamp(-3rem, -5vw, -1.8rem) clamp(-3.2rem, -5vw, -1.4rem);
    border-radius: 999px;
    pointer-events: none;
    background:
      radial-gradient(ellipse 72% 58% at 50% 43%, rgba(10,7,5,0.74) 0%, rgba(10,7,5,0.54) 36%, rgba(10,7,5,0.24) 64%, transparent 86%),
      radial-gradient(ellipse 58% 48% at 50% 66%, rgba(74,52,41,0.2) 0%, transparent 72%);
    filter: blur(18px);
    transform: scale(1.04);
  }
  .hero-content::after {
    content: '';
    position: absolute;
    z-index: -1;
    inset: clamp(-1.3rem, -2.4vw, -0.7rem) clamp(-1.4rem, -2.8vw, -0.8rem);
    border-radius: 999px;
    pointer-events: none;
    background: radial-gradient(ellipse 62% 48% at 50% 46%, rgba(13,10,8,0.4) 0%, rgba(13,10,8,0.2) 56%, transparent 100%);
  }

  .hero-title {
    max-width: 58rem;
    margin: 0 0 clamp(1rem, 2.4vw, 1.45rem);
    line-height: 1;
  }
  .title-line {
    display: block;
    overflow: hidden;
  }
  .title-inner {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--type-hero);
    line-height: 1;
    color: #fbf8f2;
    letter-spacing: -0.028em;
    text-shadow: 0 2px 24px rgba(0,0,0,0.34);
    will-change: transform;
    opacity: 0;
    transform: translateY(110%);
    animation: title-rise 1.4s var(--ease-out-expo) forwards;
  }
  .title-line:nth-child(1) .title-inner {
    animation-delay: 0.6s;
  }
  .title-line--accent {
    position: relative;
    display: inline-block;
  }
  .title-line--accent .title-inner {
    animation-delay: 0.85s;
    font-weight: 300;
    background: linear-gradient(135deg, rgba(251,248,242,0.98) 40%, rgba(196,170,148,0.78) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .title-underline {
    position: absolute;
    bottom: clamp(-6px, -0.45vw, -2px);
    left: 3%;
    width: 94%;
    height: 12px;
    overflow: visible;
    pointer-events: none;
  }
  .underline-path {
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    animation: draw-line 1.2s var(--ease-out-expo) forwards;
    animation-delay: 1.8s;
  }
  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }
  @keyframes title-rise {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 400;
    font-size: var(--type-lead);
    color: rgba(251,248,242,0.93);
    margin: 0 0 clamp(1.6rem, 3.2vw, 2.6rem);
    letter-spacing: 0.01em;
    max-width: 620px;
    line-height: 1.82;
    text-wrap: pretty;
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 1.1s var(--ease-out-expo) forwards;
    animation-delay: 1.1s;
  }

  .hero-credentials {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin: 0 0 clamp(1.55rem, 3vw, 2.4rem);
    flex-wrap: wrap;
    row-gap: 0.8rem;
  }
  .credential-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.2rem;
    opacity: 0;
    transform: translateY(12px);
    animation: reveal-up 0.9s var(--ease-out-expo) forwards;
  }
  .credential-item:nth-child(1) { animation-delay: 1.25s; }
  .credential-item:nth-child(3) { animation-delay: 1.4s; }
  .credential-icon {
    color: rgba(227,213,191,0.88);
    display: flex;
    align-items: center;
    transition: color 0.4s ease, transform 0.4s var(--ease-out-expo);
  }
  .credential-item:hover .credential-icon {
    color: rgba(196,170,148,0.95);
    transform: scale(1.15);
  }
  .credential-icon svg {
    width: 16px; height: 16px;
  }
  .credential-text {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(251,248,242,0.94);
    text-shadow: 0 1px 14px rgba(0,0,0,0.26);
    transition: color 0.3s ease;
  }
  .credential-item:hover .credential-text {
    color: rgba(245,240,232,0.95);
  }
  .credential-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(196,170,148,0.25);
    animation: sep-blink 4s ease-in-out infinite;
  }
  @keyframes sep-blink {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.7; }
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin: 0 0 clamp(1.6rem, 3vw, 2.5rem);
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 1.1s var(--ease-out-expo) forwards;
    animation-delay: 1.6s;
  }

  .btn-hero-ghost {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 18px 8px;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(251,248,242,0.94);
    text-decoration: none;
    transition: color 0.4s ease;
  }
  .btn-hero-ghost:hover {
    color: rgba(245,240,232,0.95);
  }
  .ghost-text {
    position: relative;
    z-index: 1;
    transition: letter-spacing 0.5s var(--ease-out-expo);
  }
  .btn-hero-ghost:hover .ghost-text {
    letter-spacing: 0.26em;
  }
  .ghost-line {
    position: absolute;
    bottom: 10px;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(245,240,232,0.2);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.6s var(--ease-out-expo), background 0.3s ease;
  }
  .btn-hero-ghost:hover .ghost-line {
    transform: scaleX(1);
    background: rgba(245,240,232,0.4);
  }
  .ghost-dot {
    position: absolute;
    bottom: 9px;
    left: 50%;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: rgba(196,170,148,0.6);
    transform: translateX(-50%) scale(0);
    transition: transform 0.4s var(--ease-out-expo) 0.2s;
  }
  .btn-hero-ghost:hover .ghost-dot {
    transform: translateX(-50%) scale(1);
  }

  .hero-therapist {
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: reveal-up 1s var(--ease-out-expo) forwards;
    animation-delay: 2s;
  }
  .therapist-avatar {
    position: relative;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: visible;
  }
  .therapist-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(20%) brightness(0.95);
    border: 2px solid rgba(245,240,232,0.12);
    padding: 2px;
    transition: filter 0.5s ease, transform 0.5s var(--ease-out-expo);
  }
  .therapist-avatar:hover img {
    filter: grayscale(0%) brightness(1);
    transform: scale(1.08);
  }
  .avatar-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(196,170,148,0.2);
    animation: ring-spin-slow 12s linear infinite;
    pointer-events: none;
  }
  @keyframes ring-spin-slow {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .avatar-pulse {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(196,170,148,0.08);
    animation: avatar-pulse 3s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes avatar-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.08); opacity: 0; }
  }
  .therapist-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  .therapist-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--type-card-title-sm);
    color: rgba(245,240,232,0.92);
    letter-spacing: 0.02em;
  }
  .therapist-role {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.65);
  }

  .scroll-hint {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: reveal-fade 2s ease forwards;
    animation-delay: 3s;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(245,240,232,0.12);
    position: relative;
    overflow: hidden;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(245,240,232,0.5);
    animation: line-scroll 2.5s ease-in-out infinite;
  }
  @keyframes line-scroll {
    0% { transform: translateY(-100%); }
    50% { transform: translateY(0%); }
    100% { transform: translateY(100%); }
  }

  @keyframes reveal-fade { to { opacity: 1; } }
  @keyframes reveal-up { to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 1024px) {
    .hero {
      --hero-edge: clamp(1.25rem, 4vw, 2.5rem);
    }
    .hero-content { max-width: 700px; }
    .hero-title {
      margin-bottom: clamp(0.6rem, 1.5vw, 0.9rem);
    }
    .title-inner {
      font-size: clamp(2.5rem, 5vw, 3.6rem);
    }
    .hero-tagline {
      max-width: 480px;
      font-size: clamp(0.92rem, 1.8vw, 1rem);
      margin-bottom: clamp(0.85rem, 2vw, 1.25rem);
      line-height: 1.65;
    }
    .hero-credentials {
      margin-bottom: clamp(0.85rem, 2vw, 1.25rem);
    }
    .hero-cta {
      margin-bottom: clamp(0.85rem, 2vw, 1.25rem);
    }
  }

  @media (max-width: 768px) {
    .hero {
      --hero-edge: clamp(1rem, 5vw, 1.4rem);

      height: 100svh;
      max-height: 100svh;
      min-height: 0;
    }
    .hero-bg-img {
      object-position: 58% center;
      animation: none;
      will-change: auto;
      transform: none;
    }
    .hero-overlay {
      background:
        radial-gradient(ellipse 86% 66% at 50% 45%, rgba(13,10,8,0.24) 0%, transparent 76%),
        linear-gradient(180deg, rgba(13,10,8,0.24) 0%, rgba(13,10,8,0.1) 32%, rgba(13,10,8,0.48) 100%);
    }
    .hero-vignette {
      box-shadow: inset 0 0 150px 48px rgba(13,10,8,0.36);
    }
    .hero-header-shade {
      height: clamp(128px, 26vh, 220px);
      background:
        linear-gradient(180deg, rgba(8,6,5,0.78) 0%, rgba(8,6,5,0.56) 30%, rgba(8,6,5,0.24) 66%, transparent 100%),
        radial-gradient(ellipse 94% 76% at 50% 0%, rgba(8,6,5,0.42) 0%, transparent 76%);
    }
    .hero-content {
      max-width: 30rem;
      justify-content: center;
    }
    .hero-content::before {
      inset: -1.65rem -0.9rem;
      border-radius: 999px;
      background:
        radial-gradient(ellipse 86% 66% at 50% 42%, rgba(10,7,5,0.76) 0%, rgba(10,7,5,0.56) 40%, rgba(10,7,5,0.24) 68%, transparent 92%),
        radial-gradient(ellipse 72% 50% at 50% 68%, rgba(74,52,41,0.2) 0%, transparent 76%);
      filter: blur(14px);
      transform: scale(1.03);
    }
    .hero-content::after {
      inset: -0.7rem -0.5rem;
      border-radius: 999px;
      background: radial-gradient(ellipse 70% 52% at 50% 45%, rgba(13,10,8,0.38) 0%, rgba(13,10,8,0.18) 58%, transparent 100%);
    }
    .hide-mobile { display: none; }
    .hero :global(.eyebrow) {
      max-width: min(100%, 21rem);
      margin-bottom: 0.85rem;
      gap: 0.45rem;
    }
    .hero :global(.eyebrow-text) {
      white-space: normal;
      text-wrap: balance;
      line-height: 1.45;
      letter-spacing: 0.12em;
    }
    .hero :global(.eyebrow-line),
    .hero :global(.eyebrow-dot) {
      flex: 0 0 auto;
    }
    .hero-title {
      margin-bottom: 0.8rem;
    }
    .title-inner {
      font-size: clamp(2.55rem, 12vw, 4.1rem);
      line-height: 0.98;
      letter-spacing: -0.035em;
      text-shadow: 0 2px 20px rgba(0,0,0,0.34);
    }
    .title-line--accent { display: inline-block; }
    .title-underline { height: 4px; bottom: -3px; }
    .hero-tagline {
      max-width: 21rem;
      font-size: clamp(0.92rem, 4vw, 1.02rem);
      margin-bottom: 1rem;
      line-height: 1.55;
    }
    .hero-credentials {
      width: min(100%, 22rem);
      margin-bottom: 1rem;
      gap: 0.45rem;
      row-gap: 0.45rem;
    }
    .credential-sep { display: none; }
    .credential-item {
      flex: 1 1 calc(50% - 0.45rem);
      justify-content: center;
      min-height: 2.35rem;
      padding: 0.48rem 0.7rem;
      gap: 0.4rem;
      border: 1px solid rgba(245,240,232,0.1);
      border-radius: 999px;
      background: rgba(13,10,8,0.18);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .credential-item:first-child {
      flex-basis: 100%;
    }
    .credential-text {
      font-size: 0.63rem;
      letter-spacing: 0.075em;
      line-height: 1.2;
    }
    .credential-icon svg { width: 13px; height: 13px; }
    .hero-cta {
      width: min(100%, 22rem);
      flex-direction: column;
      gap: 0.7rem;
      margin-bottom: 0;
    }
    .hero :global(.btn-hero-cta),
    .btn-hero-ghost {
      font-size: 0.66rem;
      letter-spacing: 0.12em;
