<script>
  const hero = document.querySelector('[data-hero]');
  const content = document.querySelector('[data-parallax-content]');
  if (content && hero && !window.matchMedia('(pointer: coarse)').matches) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
      const y = (e.clientY - rect.top - rect.height / 2) / rect.height;
      (content as HTMLElement).style.transform = `translate(${x * -8}px, ${y * -6}px)`;
    });
    hero.addEventListener('mouseleave', () => {
      (content as HTMLElement).style.transform = 'translate(0, 0)';
    });
  }
</script>
