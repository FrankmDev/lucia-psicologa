---
import GrainOverlay from './ui/GrainOverlay.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

const contactRoutes = [
  {
    label: 'Email',
    value: 'luciamillanpsico@gmail.com',
    href: 'mailto:luciamillanpsico@gmail.com',
    icon: 'M3 8l2.8 2.8c1.4 1.4 3.6 1.4 5 0l2.8-2.8M3 8V6a2 2 0 012-2h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
  },
  {
    label: 'Teléfono',
    value: '722 53 59 14',
    href: 'tel:+34722535914',
    icon: 'M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z',
  },
  {
    label: 'Modalidad',
    value: 'Presencial y online',
    icon: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zm0-18a8 8 0 110 16 8 8 0 010-16zM8 12l3 3 5-5',
  },
  {
    label: 'Dirección',
    value: 'c/ Toledo, 8, 2° Planta, 13001 Ciudad Real',
    href: 'https://www.google.com/maps/search/?api=1&query=Calle+Toledo+8+Ciudad+Real',
    icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0zM12 7a3 3 0 100 6 3 3 0 000-6z',
  },
];
---

<section id="contacto" class="contacto" data-contacto>
  <GrainOverlay opacity={0.01} />
  <AmbientLight color="rgba(255,255,255,0.18)" />
  <FloatOrb size={360} top="-18%" right="-12%" color="rgba(141,151,132,0.08)" blur={170} opacity={0.28} animation="float-1" />
  <FloatOrb size={260} bottom="2%" left="-10%" color="rgba(216,211,200,0.18)" blur={145} opacity={0.24} animation="float-2" />

  <Container maxWidth="1240px" padding="0 clamp(1rem, 4vw, 4.25rem)">
    <div class="contact-shell">
      <header class="contact-header reveal-blur" data-delay="80">
        <span class="section-eyebrow">Contacto</span>
        <h2>Empezamos con un primer mensaje.</h2>
        <p>
          Cuéntame brevemente qué te preocupa, desde cuándo ocurre y si prefieres consulta presencial u online. Con esa información puedo orientarte y valorar el primer paso.
        </p>
      </header>

      <div class="contact-layout" aria-label="Contacto y formulario">
        <aside class="contact-info reveal-scale" data-delay="160">
          <div class="contact-info__panel">
            <h3 class="contact-info__title">Datos de contacto</h3>
            <p class="contact-info__lead">
              Respondo en un plazo de 24–48 horas. Si prefieres una vía más directa, también puedes llamar o escribir por WhatsApp.
            </p>

            <div class="contact-routes">
              {contactRoutes.map((route) => (
                route.href ? (
                  <a class="contact-route" href={route.href} {...(route.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                    <span class="contact-route__icon" aria-hidden="true">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                        <path d={route.icon} />
                      </svg>
                    </span>
                    <div class="contact-route__text">
                      <span class="contact-route__label">{route.label}</span>
                      <strong class="contact-route__value">{route.value}</strong>
                    </div>
                  </a>
                ) : (
                  <div class="contact-route">
                    <span class="contact-route__icon" aria-hidden="true">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                        <path d={route.icon} />
                      </svg>
                    </span>
                    <div class="contact-route__text">
                      <span class="contact-route__label">{route.label}</span>
                      <strong class="contact-route__value">{route.value}</strong>
                    </div>
                  </div>
                )
              ))}
            </div>

            <div class="contact-info__note">
              <span class="note-label">La consulta</span>
              <p>Un espacio tranquilo en el centro de Ciudad Real, con opción de terapia online cuando encaja mejor con tu situación.</p>
            </div>
          </div>
        </aside>

        <form
          id="contactForm"
          class="contact-form-card reveal-scale"
          data-delay="220"
          action="mailto:luciamillanpsico@gmail.com"
          method="POST"
          enctype="text/plain"
        >
          <noscript>
            <div class="form-noscript">
              <p>Puedes escribirme directamente a <a href="mailto:luciamillanpsico@gmail.com">luciamillanpsico@gmail.com</a> o llamar al <a href="tel:+34722535914">722 53 59 14</a>.</p>
            </div>
          </noscript>

          <div class="form-head">
            <span class="form-kicker">Mensaje inicial</span>
            <h3>Cuéntame lo justo para orientarte.</h3>
          </div>

          <div class="form-fields">
            <div class="form-field">
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder=" "
                autocomplete="name"
                required
                aria-required="true"
                aria-describedby="nombre-hint"
              />
              <label for="nombre">Nombre</label>
              <span id="nombre-hint" class="field-hint" role="alert">Indica tu nombre.</span>
            </div>

            <div class="form-field">
              <input
                type="email"
                id="email"
                name="email"
                placeholder=" "
                autocomplete="email"
                required
                aria-required="true"
                aria-describedby="email-hint"
              />
              <label for="email">Email</label>
              <span id="email-hint" class="field-hint" role="alert">Necesito un email para responderte.</span>
            </div>

            <div class="form-field form-field--full">
              <textarea
                id="mensaje"
                name="mensaje"
                placeholder=" "
                rows="5"
                required
                aria-required="true"
                aria-describedby="mensaje-hint"
              ></textarea>
              <label for="mensaje">Motivo de consulta</label>
              <span id="mensaje-hint" class="field-hint" role="alert">Cuéntame qué ocurre, desde cuándo, qué modalidad prefieres y si quieres consultar por trauma o EMDR.</span>
            </div>
          </div>

          <div class="form-actions">
            <p class="form-disclaimer">Tus datos se tratan con confidencialidad profesional. Evita incluir información clínica muy sensible en el primer mensaje.</p>
            <button type="submit" class="contact-submit" id="contactSubmit">
              <span class="submit-text">Enviar mensaje inicial</span>
              <span class="submit-loading" aria-hidden="true">Abriendo correo...</span>
              <span class="submit-success" aria-hidden="true">Mensaje preparado</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          <div id="formFeedback" class="form-feedback" role="status" aria-live="polite">
            <p class="feedback-success">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
                <path d="M5 8l2.5 2.5L11 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              El navegador abrirá tu cliente de correo. Si no se abre, escríbeme a <a href="mailto:luciamillanpsico@gmail.com">luciamillanpsico@gmail.com</a>.
            </p>
            <p class="feedback-error">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
                <path d="M8 5v3M8 10.5v.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              Algo no ha funcionado. Escríbeme directamente a <a href="mailto:luciamillanpsico@gmail.com">luciamillanpsico@gmail.com</a>.
            </p>
          </div>
        </form>
      </div>
    </div>
  </Container>
</section>

<script>
  (function() {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('contactSubmit');
    const feedback = document.getElementById('formFeedback');
    if (!form || !submitBtn || !feedback) return;

    const action = form.getAttribute('action') || '';
    const isMailto = action.startsWith('mailto:');

    form.addEventListener('submit', function(e) {
      if (isMailto) {
        submitBtn.classList.add('is-success');
        feedback.classList.add('show-success');
        return;
      }

      e.preventDefault();
      submitBtn.classList.add('is-loading');
      submitBtn.disabled = true;
      feedback.classList.remove('show-success', 'show-error');

      const formData = new FormData(form);

      fetch(action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      })
      .then(response => {
        if (response.ok) {
          submitBtn.classList.remove('is-loading');
          submitBtn.classList.add('is-success');
          feedback.classList.add('show-success');
          form.reset();
        } else {
          throw new Error('Response not OK');
        }
      })
      .catch(() => {
        submitBtn.classList.remove('is-loading');
        submitBtn.classList.add('is-error');
        feedback.classList.add('show-error');
        submitBtn.disabled = false;
      });
    });
  })();
</script>

<style>
  .contacto {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py) 0 calc(var(--section-py) + 0.5rem);
    background:
      radial-gradient(circle at 14% 10%, rgba(255, 255, 255, 0.92), transparent 30%),
      radial-gradient(circle at 82% 14%, rgba(223, 228, 216, 0.48), transparent 30%),
      linear-gradient(180deg, var(--color-surface-elevated) 0%, var(--color-surface) 58%, #f3efe7 100%);
  }

  .contacto::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.008) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 74%);
    opacity: 0.6;
  }

  .contact-shell {
    position: relative;
    z-index: 2;
  }

  .contact-header {
    max-width: 50rem;
    margin: 0 auto clamp(2.4rem, 4vw, 3.4rem);
    text-align: center;
  }

  .contact-header h2 {
    max-width: 49rem;
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .contact-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.78;
    text-wrap: pretty;
  }

  /* ── Layout: info + form ──────────────────────────────── */
  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }

  /* ── Info panel ───────────────────────────────────────── */
  .contact-info__panel {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding: var(--card-pd-lg);
    border: 1px solid rgba(111, 125, 103, 0.12);
    border-radius: var(--card-radius);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.78), rgba(249, 246, 239, 0.92)),
      radial-gradient(circle at 0% 0%, rgba(223, 228, 216, 0.28), transparent 38%);
  }

  .contact-info__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.12;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .contact-info__lead {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body);
    line-height: 1.72;
    text-wrap: pretty;
  }

  .contact-routes {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .contact-route {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(111, 125, 103, 0.08);
    color: inherit;
    text-decoration: none;
    transition: background 0.3s ease;
    border-radius: 0.5rem;
    margin: 0 -0.5rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }
  .contact-route:last-child {
    border-bottom: 0;
  }
  .contact-route:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  .contact-route__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: rgba(111, 125, 103, 0.08);
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .contact-route__text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .contact-route__label {
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .contact-route__value {
    font-size: var(--type-body);
    font-weight: 400;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }
  .contact-route:hover .contact-route__value {
    color: var(--color-ink);
  }

  .contact-info__note {
    padding: 1rem 1.1rem;
    border-radius: var(--card-radius-sm);
    background: rgba(111, 125, 103, 0.04);
    border: 1px solid rgba(111, 125, 103, 0.08);
  }

  .note-label {
    display: block;
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .contact-info__note p {
    margin: 0;
    font-size: var(--type-body-sm);
    color: var(--color-text-muted);
    line-height: 1.62;
  }

  /* ── Form card ────────────────────────────────────────── */
  .contact-form-card {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    padding: var(--card-pd-lg);
    border: 1px solid rgba(111, 125, 103, 0.12);
    border-radius: var(--card-radius);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.88), rgba(249, 246, 239, 0.96)),
      radial-gradient(circle at 100% 0%, rgba(223, 228, 216, 0.24), transparent 38%);
    position: relative;
  }

  .contact-form-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-image: radial-gradient(circle at 1px 1px, rgba(111,125,103,0.02) 1px, transparent 0);
    background-size: 20px 20px;
    pointer-events: none;
    z-index: 0;
  }

  .contact-form-card > * {
    position: relative;
    z-index: 1;
  }

  .form-head {
    margin-bottom: 0.2rem;
  }

  .form-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .form-kicker::before {
    content: '';
    width: 2rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.28);
  }

  .form-head h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.12;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .form-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem 1.2rem;
  }

  .form-field {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  .form-field input,
  .form-field textarea {
    order: 2;
    width: 100%;
    padding: 1rem 0.85rem;
    border: 1px solid rgba(111, 125, 103, 0.18);
    border-radius: 0.65rem;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: var(--type-body);
    line-height: 1.5;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    outline: none;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: transparent;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: rgba(111, 125, 103, 0.42);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 0 0 3px rgba(111, 125, 103, 0.08);
  }

  .form-field label {
    order: 1;
    margin-bottom: 0.35rem;
    color: var(--color-text-muted);
    font-size: var(--type-caption);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .form-field input:focus + label,
  .form-field textarea:focus + label,
  .form-field input:not(:placeholder-shown) + label,
  .form-field textarea:not(:placeholder-shown) + label {
    color: var(--color-accent);
  }

  .field-hint {
    order: 3;
    margin-top: 0.35rem;
    color: var(--color-error);
    font-size: var(--type-micro);
    line-height: 1.4;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .form-field input:invalid:not(:placeholder-shown) ~ .field-hint,
  .form-field textarea:invalid:not(:placeholder-shown) ~ .field-hint {
    opacity: 1;
    transform: translateY(0);
  }

  .form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.4rem;
  }

  .form-disclaimer {
    margin: 0;
    font-size: var(--type-micro);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .contact-submit {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 3.1rem;
    padding: 0.85rem 1.6rem;
    border: 1px solid rgba(111, 125, 103, 0.28);
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.96), rgba(86, 100, 90, 0.96));
    color: #fbf8f1;
    font-family: var(--font-body);
    font-size: var(--type-caption);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 0 0.9rem 1.6rem rgba(86, 100, 90, 0.14);
    transition: transform 0.45s var(--ease-out-expo), box-shadow 0.45s ease;
  }

  .contact-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 1.1rem 1.9rem rgba(86, 100, 90, 0.17);
  }

  .contact-submit svg {
    transition: transform 0.45s var(--ease-out-expo);
  }

  .contact-submit:hover svg {
    transform: translateX(2px);
  }

  .contact-submit.is-loading .submit-text,
  .contact-submit.is-success .submit-text,
  .contact-submit.is-error .submit-text {
    opacity: 0;
    position: absolute;
  }

  .submit-loading,
  .submit-success {
    position: absolute;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .contact-submit.is-loading .submit-loading,
  .contact-submit.is-success .submit-success {
    opacity: 1;
    position: static;
  }

  .form-feedback {
    margin-top: 0.8rem;
    font-size: var(--type-body-sm);
    line-height: 1.6;
  }

  .feedback-success,
  .feedback-error {
    display: none;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0.85rem 1rem;
    border-radius: 0.5rem;
  }

  .feedback-success {
    color: var(--color-accent-deep);
    background: rgba(111, 125, 103, 0.06);
    border: 1px solid rgba(111, 125, 103, 0.12);
  }

  .feedback-error {
    color: var(--color-error);
    background: rgba(180, 60, 60, 0.04);
    border: 1px solid rgba(180, 60, 60, 0.1);
  }

  .form-feedback.show-success .feedback-success,
  .form-feedback.show-error .feedback-error {
    display: flex;
  }

  .form-noscript {
    padding: 1rem;
    border-radius: 0.5rem;
    background: rgba(111, 125, 103, 0.06);
    border: 1px solid rgba(111, 125, 103, 0.12);
    font-size: var(--type-body-sm);
    line-height: 1.6;
  }

  .form-noscript a {
    color: var(--color-accent-deep);
    text-decoration: underline;
  }

  @media (max-width: 960px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
    .contact-info__panel {
      padding: var(--card-pd-md);
    }
  }

  @media (max-width: 640px) {
    .contacto {
      padding: 4.8rem 0 5.8rem;
    }

    .contact-header {
      margin-bottom: 2rem;
      padding: 0 4vw;
    }

    .contact-header h2 {
      font-size: var(--type-section-title-sm);
      line-height: 1.02;
      letter-spacing: -0.02em;
    }

    .contact-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }

    .section-eyebrow {
      justify-content: flex-start;
    }
    .section-eyebrow::after {
      display: none;
    }

    .contact-form-card {
      padding: var(--card-pd-md);
