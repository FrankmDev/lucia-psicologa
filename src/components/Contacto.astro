---
import Container from './ui/Container.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import DecorativeRing from './ui/DecorativeRing.astro';

const contactImage = "https://images.unsplash.com/photo-1580489944761-15a19d654956?q=80&w=400&auto=format&fit=crop";
---

<section id="contacto" class="contacto" data-contacto>
  <GrainOverlay opacity={0.02} />
  <AmbientLight color="rgba(196,170,148,0.04)" />
  <DustParticles count={10} color="rgba(196,170,148,0.15)" />
  <FloatOrb size={380} top="-10%" right="-6%" color="var(--sage-muted)" blur={110} opacity={0.35} animation="float-1" />
  <FloatOrb size={280} bottom="12%" left="-5%" color="var(--gold-soft)" opacity={0.35} animation="float-2" />
  <FloatOrb size={160} top="55%" right="4%" color="var(--sage-muted)" opacity={0.25} animation="float-3" />

  <InkBlob width={340} height={280} top="-6%" left="-6%" color="var(--sage)" opacity={0.03} animation="morph-2" />
  <InkBlob width={300} height={240} bottom="-6%" right="-5%" color="var(--gold)" opacity={0.025} animation="morph-blob" />

  <DecorativeRing size={500} top="-10%" left="-15%" />
  <DecorativeRing size={350} bottom="-5%" right="-10%" duration={40} reverse />

  <!-- Decorative corners -->
  <svg class="deco-corner deco-corner--tr" viewBox="0 0 100 100" fill="none" aria-hidden="true">
    <path d="M100 100 L100 20 Q100 0 80 0 L0 0" stroke="var(--earth)" stroke-width="0.5" opacity="0.05"/>
  </svg>
  <svg class="deco-corner deco-corner--bl" viewBox="0 0 100 100" fill="none" aria-hidden="true">
    <path d="M0 0v80c0 11.046 8.954 20 20 20h80" stroke="var(--earth)" stroke-width="0.5" opacity="0.04"/>
  </svg>

  <!-- Floating dots -->
  <div class="contacto-dots" aria-hidden="true">
    <span class="contacto-dot contacto-dot--1"></span>
    <span class="contacto-dot contacto-dot--2"></span>
    <span class="contacto-dot contacto-dot--3"></span>
  </div>

  <Container maxWidth="1200px">
    <div class="contacto-hero-text">
      <span class="hero-eyebrow reveal-up">Contacto</span>
      <h2 class="contacto-title">
        <span class="title-line">
          <span class="title-inner" data-split>Hablemos</span>
        </span>
        <span class="title-line title-line--accent">
          <span class="title-inner" data-split>juntas</span>
          <svg class="title-underline" viewBox="0 0 200 12" preserveAspectRatio="none" aria-hidden="true">
            <path d="M2 8 Q50 2 100 6 T198 4" stroke="var(--gold)" stroke-width="1.5" fill="none" stroke-linecap="round" class="underline-path"/>
          </svg>
        </span>
      </h2>
      <p class="hero-subtitle reveal-blur" data-delay="200">Cuéntame brevemente qué te trae aquí. Te responderé en menos de 24 horas.</p>
    </div>

    <div class="contacto-layout">
      <!-- Left: Info -->
      <div class="contacto-info">
        <div class="info-portrait-wrap reveal-scale" data-delay="300">
          <div class="info-portrait" data-img-reveal>
            <img src={contactImage} alt="Lucia" decoding="async" loading="lazy" />
          </div>
          <div class="portrait-frame" aria-hidden="true"></div>
          <div class="portrait-frame portrait-frame--inner" aria-hidden="true"></div>
        </div>

        <div class="availability-badge reveal-up" data-delay="500">
          <span class="availability-dot" aria-hidden="true">
            <span class="dot-pulse"></span>
          </span>
          <span class="availability-text">Disponible esta semana</span>
        </div>

        <div class="info-list stagger-children" data-delay="600">
          <a href="mailto:hola@luciapsicologia.es" class="info-item reveal-up">
            <span class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 18 18" fill="none">
                <rect x="2" y="4" width="14" height="11" rx="2" stroke="currentColor" stroke-width="0.9"/>
                <path d="M2 6 L9 11 L16 6" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div class="info-content">
              <span class="info-label">Email</span>
              <span class="info-val">hola@luciapsicologia.es</span>
            </div>
          </a>

          <a href="tel:+34600123456" class="info-item reveal-up">
            <span class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 18 18" fill="none">
                <path d="M4 2 C4 2 1 5 1 9 C1 14 4 16 4 16 M14 2 C14 2 17 5 17 9 C17 14 14 16 14 16" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
                <path d="M5 2 L5 16 M13 2 L13 16" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
                <path d="M1 6 L17 6 M1 12 L17 12" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
              </svg>
            </span>
            <div class="info-content">
              <span class="info-label">Telefono</span>
              <span class="info-val">+34 600 123 456</span>
            </div>
          </a>

          <div class="info-item reveal-up">
            <span class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 18 18" fill="none">
                <path d="M9 1 C5 1 2 4 2 7 C2 11 5 14 9 17 C13 14 16 11 16 7 C16 4 13 1 9 1Z" stroke="currentColor" stroke-width="0.9" stroke-linejoin="round"/>
                <circle cx="9" cy="7" r="2" stroke="currentColor" stroke-width="0.9"/>
              </svg>
            </span>
            <div class="info-content">
              <span class="info-label">Ubicacion</span>
              <span class="info-val">Cordoba · Online</span>
            </div>
          </div>
        </div>

        <div class="social-proof reveal-up" data-delay="800">
          <div class="proof-avatars" aria-hidden="true">
            <span class="proof-avatar" style="--avatar-color: #B8A99A;">M</span>
            <span class="proof-avatar" style="--avatar-color: #A8B5A0;">A</span>
            <span class="proof-avatar" style="--avatar-color: #C4AA94;">C</span>
            <span class="proof-avatar proof-avatar--more">+</span>
          </div>
          <p class="proof-text">Mas de <strong>200 personas</strong> han confiado en este acompanamiento</p>
        </div>

        <p class="contact-note reveal-up" data-delay="900">Presencial en Cordoba y online desde cualquier lugar.</p>
      </div>

      <!-- Right: Form card -->
      <div class="contacto-form-card reveal-right" data-delay="400">
        <div class="form-card-glow" aria-hidden="true"></div>
        <div class="form-card-header">
          <h3 class="form-card-title">Envia un mensaje</h3>
          <p class="form-card-subtitle">Te respondere lo antes posible</p>
        </div>

        <form class="contacto-form" onsubmit="event.preventDefault(); alert('Formulario de demostracion.');">
          <div class="form-field-group">
            <div class="form-field reveal-up" data-delay="500">
              <input type="text" id="nombre" name="nombre" placeholder=" " required />
              <label for="nombre">Nombre</label>
              <span class="field-line" aria-hidden="true"></span>
              <span class="field-glow" aria-hidden="true"></span>
            </div>
            <div class="form-field reveal-up" data-delay="600">
              <input type="email" id="email" name="email" placeholder=" " required />
              <label for="email">Email</label>
              <span class="field-line" aria-hidden="true"></span>
              <span class="field-glow" aria-hidden="true"></span>
            </div>
          </div>

          <div class="form-field reveal-up" data-delay="700">
            <input type="tel" id="telefono" name="telefono" placeholder=" " />
            <label for="telefono">Telefono</label>
            <span class="field-line" aria-hidden="true"></span>
            <span class="field-glow" aria-hidden="true"></span>
          </div>

          <div class="form-field reveal-up" data-delay="800">
            <textarea id="mensaje" name="mensaje" placeholder=" " rows="4" required></textarea>
            <label for="mensaje">Que te gustaria contarme?</label>
            <span class="field-line" aria-hidden="true"></span>
            <span class="field-glow" aria-hidden="true"></span>
          </div>

          <button type="submit" class="btn-solid reveal-up" data-delay="900">
            <span>Enviar mensaje</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>

        <div class="form-trust-badges stagger-children" data-delay="1000">
          <div class="trust-badge reveal-up">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M7 1 L8.8 5.2 L13 5.2 L9.6 8.2 L10.8 12.4 L7 9.8 L3.2 12.4 L4.4 8.2 L1 5.2 L5.2 5.2Z" stroke="currentColor" stroke-width="0.8" stroke-linejoin="round"/>
            </svg>
            <span>Respuesta en 24h</span>
          </div>
          <div class="trust-badge reveal-up">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="3" y="5" width="8" height="7" rx="1" stroke="currentColor" stroke-width="0.8"/>
              <path d="M5 5 V3.5 C5 2 6 1.5 7 1.5 C8 1.5 9 2 9 3.5 V5" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"/>
            </svg>
            <span>Datos protegidos</span>
          </div>
          <div class="trust-badge reveal-up">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="0.8"/>
              <path d="M7 4 V7 L9.5 9" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Primera sesion flexible</span>
          </div>
        </div>

        <p class="form-trust reveal-up" data-delay="1100">Tus datos estan seguros. Nunca los comparto con terceros.</p>
      </div>
    </div>

    <!-- Footer CTA -->
    <div class="contacto-footer reveal-up" data-delay="1000">
      <div class="footer-ornament" aria-hidden="true">
        <span class="orn-line"></span>
        <span class="orn-fleur">&#10086;</span>
        <span class="orn-line"></span>
      </div>
      <p class="contacto-footer-text">Prefieres llamar directamente?</p>
      <a href="tel:+34600123456" class="contacto-footer-link">
        <span>+34 600 123 456</span>
        <span class="link-underline" aria-hidden="true"></span>
      </a>
    </div>
  </Container>
</section>

<style>
  .contacto {
    position: relative;
    width: 100%;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 60% 30%, rgba(107,125,106,0.035) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 70%, rgba(196,170,148,0.04) 0%, transparent 45%),
      var(--white-warm);
    padding: 10rem 0 12rem;
  }
  .contacto::before {
    content: '';
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: min(80vw, 900px);
    height: min(80vw, 900px);
    border-radius: 50%;
    border: 1px solid rgba(107,125,106,0.025);
    pointer-events: none;
    z-index: 0;
  }

  .deco-corner {
    position: absolute;
    width: 80px;
    height: 80px;
    pointer-events: none;
    z-index: 1;
  }
  .deco-corner--tr { top: 8%; right: 4%; transform: rotate(90deg); }
  .deco-corner--bl { bottom: 8%; left: 4%; transform: rotate(-90deg); }

  .contacto-dots {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .contacto-dot {
    position: absolute;
    border-radius: 50%;
    background: var(--earth);
    will-change: transform;
  }
  .contacto-dot--1 {
    width: 4px; height: 4px;
    top: 20%; left: 10%;
    opacity: 0.05;
    animation: float-gentle 11s ease-in-out infinite;
  }
  .contacto-dot--2 {
    width: 3px; height: 3px;
    bottom: 25%; right: 12%;
    opacity: 0.07;
    animation: float-gentle-reverse 13s ease-in-out infinite;
    animation-delay: -4s;
  }
  .contacto-dot--3 {
    width: 5px; height: 5px;
    top: 55%; left: 5%;
    opacity: 0.04;
    animation: float-gentle 9s ease-in-out infinite;
    animation-delay: -2s;
  }

  .contacto-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    position: relative;
    z-index: 2;
  }

  /* Hero text like style */
  .contacto-hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    margin-bottom: 4.5rem;
    position: relative;
    z-index: 3;
  }
  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--sage-dark);
  }
  .contacto-title {
    margin: 0;
    line-height: 1.05;
  }
  .title-line {
    display: block;
    position: relative;
    width: fit-content;
    margin: 0 auto;
  }
  .title-inner {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(3rem, 6vw, 4.5rem);
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .title-line--accent .title-inner {
    color: var(--earth);
  }
  .title-underline {
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 12px;
    pointer-events: none;
    overflow: visible;
  }
  .underline-path {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    transition: stroke-dashoffset 1.5s var(--ease-out-expo) 0.5s;
  }
  .contacto.visible .underline-path {
    stroke-dashoffset: 0;
  }
  .hero-subtitle {
    font-family: var(--font-body);
    font-size: var(--type-section-subtitle);
    font-weight: 300;
    color: var(--ink-soft);
    opacity: 0.7;
    margin: 0.5rem 0 0;
    max-width: 480px;
    line-height: 1.6;
  }

  .contacto-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 1rem;
  }

  .info-portrait-wrap {
    position: relative;
    width: 180px;
    height: 225px;
    margin-bottom: 2rem;
  }
  .info-portrait {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 2px;
    overflow: hidden;
    z-index: 2;
  }
  .info-portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--white-warm);
    transform-origin: right;
    z-index: 2;
    transition: transform 1.2s var(--ease-out-expo);
  }
  .info-portrait.revealed::after {
    transform: scaleX(0);
  }
  .info-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(15%) brightness(0.95);
    transition: filter 0.8s ease, transform 1.5s var(--ease-out-expo);
    transform: scale(1.1);
  }
  .info-portrait.revealed img {
    transform: scale(1);
  }
  .info-portrait:hover img {
    filter: grayscale(0%) brightness(1);
  }
  .portrait-frame {
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(196,170,148,0.1);
    pointer-events: none;
    z-index: 3;
    transition: border-color 0.5s ease;
  }
  .portrait-frame--inner {
    inset: 18px;
    border-color: rgba(196,170,148,0.05);
  }
  .info-portrait-wrap:hover .portrait-frame {
    border-color: rgba(196,170,148,0.2);
  }

  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(176, 190, 170, 0.07);
    border: 1px solid rgba(176, 190, 170, 0.14);
    border-radius: 100px;
    padding: 0.4rem 0.9rem;
    margin-bottom: 2rem;
    width: fit-content;
    transition: border-color 0.4s ease, background 0.4s ease;
  }
  .availability-badge:hover {
    background: rgba(176, 190, 170, 0.11);
    border-color: rgba(176, 190, 170, 0.25);
  }
  .availability-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sage);
    position: relative;
  }
  .dot-pulse {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: var(--sage);
    animation: pulse-dot 2.5s ease-out infinite;
  }
  .availability-text {
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.55;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 320px;
    margin-bottom: 2rem;
  }
  .info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 0;
    border-top: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.5s var(--ease-out-expo), background 0.4s ease;
    position: relative;
  }
  .info-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: var(--sage-muted);
    opacity: 0.25;
    transition: width 0.5s var(--ease-out-expo);
  }
  .info-item:hover::before {
    width: 3px;
  }
  .info-item:last-child {
    border-bottom: 1px solid var(--line);
  }
  .info-item:hover {
    padding-left: 0.75rem;
  }
  .info-icon {
    color: var(--taupe);
    opacity: 0.3;
    flex-shrink: 0;
    transition: opacity 0.4s ease, color 0.4s ease, transform 0.5s var(--ease-out-expo);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(196, 170, 148, 0.05);
  }
  .info-item:hover .info-icon {
    opacity: 0.8;
    color: var(--sage-dark);
    transform: scale(1.08);
  }
  .info-content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1;
    text-align: left;
  }
  .info-label {
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.45;
  }
  .info-val {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--ink-soft);
    transition: color 0.3s ease;
  }
  .info-item:hover .info-val {
    color: var(--ink);
  }

  .social-proof {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .proof-avatars {
    display: flex;
    align-items: center;
  }
  .proof-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--avatar-color, rgba(168, 169, 158, 0.15));
    border: 2px solid var(--white-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.78rem;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    margin-left: -10px;
    transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s ease;
  }
  .proof-avatar:first-child {
    margin-left: 0;
  }
  .proof-avatar--more {
    background: rgba(196, 170, 148, 0.12);
    color: var(--taupe);
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 400;
    font-size: 0.7rem;
  }
  .social-proof:hover .proof-avatar:nth-child(1) { transform: translateY(-4px); }
  .social-proof:hover .proof-avatar:nth-child(2) { transform: translateY(-4px); transition-delay: 0.05s; }
  .social-proof:hover .proof-avatar:nth-child(3) { transform: translateY(-4px); transition-delay: 0.1s; }
  .social-proof:hover .proof-avatar:nth-child(4) { transform: translateY(-4px); transition-delay: 0.15s; }
  .proof-text {
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--taupe);
    opacity: 0.5;
    line-height: 1.5;
    margin: 0;
  }
  .proof-text strong {
    color: var(--ink-soft);
    font-weight: 400;
  }
  .contact-note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--taupe);
    opacity: 0.4;
    line-height: 1.4;
    margin: 0;
  }

  /* Form card */
  .contacto-form-card {
    position: relative;
    background: linear-gradient(165deg, rgba(255,253,249,0.92) 0%, rgba(250,247,240,0.72) 50%, rgba(252,249,243,0.52) 100%);
    border: 1px solid rgba(196,170,148,0.12);
    border-radius: 3px;
    padding: 3rem 3.2rem 2.5rem;
    box-shadow:
      0 1px 2px rgba(44,44,44,0.015),
      0 4px 8px rgba(44,44,44,0.015),
      0 12px 24px rgba(44,44,44,0.02),
      0 24px 48px rgba(44,44,44,0.015);
    transition: transform 0.9s var(--ease-out-expo), box-shadow 0.9s var(--ease-out-expo), border-color 0.6s ease;
  }
  .contacto-form-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 0;
    background: linear-gradient(180deg, rgba(107,125,106,0.3), rgba(107,125,106,0.05));
    transition: height 1s var(--ease-out-expo);
    border-radius: 1px;
  }
  .contacto-form-card:hover::after {
    height: 60%;
  }
  .contacto-form-card:hover {
    transform: translateY(-6px);
    border-color: rgba(196,170,148,0.18);
    box-shadow:
      0 2px 4px rgba(44,44,44,0.02),
