---
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

const contactRoutes = [
  {
    label: 'Email',
    value: 'luciamillanpsico@gmail.com',
    href: 'mailto:luciamillanpsico@gmail.com',
  },
  {
    label: 'Teléfono',
    value: '722535914',
    href: 'tel:722535914',
  },
  {
    label: 'Consulta',
    value: 'Ciudad Real · Online',
  },
  {
    label: 'Dirección',
    value: 'c/ Toledo, 8, 2° Planta, 13001, Ciudad Real',
    href: 'https://www.google.com/search?sca_esv=46bc13bb03f41cf0&sxsrf=ANbL-n4P7jqJ8RBIUqoY7eJLwLqci3o1Xw:1779809431733&kgmid=/g/11z35hqkg2&q=Luc%C3%ADa+Mill%C3%A1n+Jim%C3%A9nez,+Psic%C3%B3logo&shem=rimspwouoe&shndl=30&source=sh/x/loc/uni/m1/1&kgs=07d8cea2c96db48f&utm_source=rimspwouoe,sh/x/loc/uni/m1/1',
  },
];

const quietSteps = [
  'Escríbeme solo lo esencial.',
  'Te respondo con una primera orientación.',
  'Elegimos juntas el formato que encaje.',
];
---

<section id="contacto" class="contacto" data-contacto>
  <GrainOverlay opacity={0.01} />
  <AmbientLight color="rgba(255,255,255,0.18)" />
  <FloatOrb size={360} top="-18%" right="-12%" color="rgba(141,151,132,0.08)" blur={170} opacity={0.28} animation="float-1" />
  <FloatOrb size={260} bottom="2%" left="-10%" color="rgba(216,211,200,0.18)" blur={145} opacity={0.24} animation="float-2" />

  <Container maxWidth="1240px" padding="0 clamp(1rem, 4vw, 4.25rem)">
    <div class="contact-shell">
      <header class="contact-header reveal-blur" data-delay="80">
        <span class="contact-eyebrow">Contacto</span>
        <h2>Empezamos con una conversación sencilla.</h2>
        <p>
          No hace falta tenerlo todo ordenado para escribir. Puedes acercarte con lo que haya ahora; yo te responderé con claridad, cuidado y un siguiente paso posible.
        </p>
      </header>

      <div class="contact-layout" aria-label="Contacto y formulario">
        <aside class="contact-portrait reveal-scale" data-delay="160">
          <div class="portrait-frame" aria-hidden="true">
            <div class="portrait-image"></div>
          </div>

          <div class="portrait-note">
            <span>Primera respuesta</span>
            <p>
              Puedes contarme poco, mucho o simplemente decir que necesitas orientación. El primer contacto también puede ser tranquilo.
            </p>
          </div>
        </aside>

        <!-- 
          FORM CONFIGURATION:
          For production, replace the form action with your Formspree endpoint:
          action="https://formspree.io/f/YOUR_FORM_ID"
          Or use Netlify Forms by adding data-netlify="true" and name="contact"
        -->
        <form
          id="contactForm"
          class="contact-form-card reveal-scale"
          data-delay="220"
          action="mailto:luciamillanpsico@gmail.com"
          method="POST"
          enctype="text/plain"
        >
          <div class="form-head">
            <span class="form-kicker">Mensaje inicial</span>
            <h3>Cuéntame lo básico, sin presión.</h3>
            <p>Te responderé con una propuesta clara y sin compromiso para valorar juntas cómo empezar.</p>
          </div>

          <div class="form-fields">
            <div class="form-field">
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder=" "
                autocomplete="name"
                required
                aria-required="true"
                aria-describedby="nombre-hint"
              />
              <label for="nombre">Nombre</label>
              <span id="nombre-hint" class="field-hint" role="alert">Por favor, dime cómo te llamas.</span>
            </div>

            <div class="form-field">
              <input
                type="email"
                id="email"
                name="email"
                placeholder=" "
                autocomplete="email"
                required
                aria-required="true"
                aria-describedby="email-hint"
              />
              <label for="email">Email</label>
              <span id="email-hint" class="field-hint" role="alert">Necesito un email para poder responderte.</span>
            </div>

            <div class="form-field form-field--full">
              <textarea
                id="mensaje"
                name="mensaje"
                placeholder=" "
                rows="5"
                required
                aria-required="true"
                aria-describedby="mensaje-hint"
              ></textarea>
              <label for="mensaje">¿Qué te gustaría contarme?</label>
              <span id="mensaje-hint" class="field-hint" role="alert">Cuéntame lo que necesites, incluso si no sabes por dónde empezar.</span>
            </div>
          </div>

          <div class="quiet-list" aria-label="Qué ocurre después">
            {quietSteps.map((step, index) => (
              <div class="quiet-step">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <p>{step}</p>
              </div>
            ))}
          </div>

          <div class="form-actions">
            <p>Tus datos se tratan con confidencialidad.</p>
            <button type="submit" class="contact-submit" id="contactSubmit">
              <span class="submit-text">Enviar mensaje</span>
              <span class="submit-loading" aria-hidden="true">Enviando...</span>
              <span class="submit-success" aria-hidden="true">Mensaje enviado</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          <div id="formFeedback" class="form-feedback" role="status" aria-live="polite">
            <p class="feedback-success">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
                <path d="M5 8l2.5 2.5L11 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Gracias por escribir. Te responderé en un plazo máximo de 24 horas laborables.
            </p>
            <p class="feedback-error">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
                <path d="M8 5v3M8 10.5v.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              Algo no ha funcionado. Puedes escribirme directamente a <a href="mailto:luciamillanpsico@gmail.com">luciamillanpsico@gmail.com</a>.
            </p>
          </div>
        </form>

        <div class="contact-rail reveal-up" data-delay="320" aria-label="Datos de contacto">
          {contactRoutes.map((route) => (
            route.href ? (
              <a class="contact-route" href={route.href}>
                <span>{route.label}</span>
                <strong>{route.value}</strong>
              </a>
            ) : (
              <div class="contact-route">
                <span>{route.label}</span>
                <strong>{route.value}</strong>
              </div>
            )
          ))}
        </div>
      </div>
    </div>
  </Container>

  <PageNumber number="07" />
</section>

<script>
  (function() {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('contactSubmit');
    const feedback = document.getElementById('formFeedback');
    if (!form || !submitBtn || !feedback) return;

    const action = form.getAttribute('action') || '';
    const isMailto = action.startsWith('mailto:');

    form.addEventListener('submit', function(e) {
      if (isMailto) {
        // mailto: fallback — let the browser handle it natively
        // but show a success message since we can't track the email client
        submitBtn.classList.add('is-success');
        feedback.classList.add('show-success');
        return;
      }

      e.preventDefault();
      submitBtn.classList.add('is-loading');
      submitBtn.disabled = true;
      feedback.classList.remove('show-success', 'show-error');

      const formData = new FormData(form);

      fetch(action, {
        method: 'POST',
        body: formData,
        headers: { Accept: 'application/json' },
      })
        .then((response) => {
          if (response.ok) {
            submitBtn.classList.remove('is-loading');
            submitBtn.classList.add('is-success');
            feedback.classList.add('show-success');
            form.reset();
          } else {
            throw new Error('Form submission failed');
          }
        })
        .catch(() => {
          submitBtn.classList.remove('is-loading');
          submitBtn.classList.add('is-error');
          feedback.classList.add('show-error');
          submitBtn.disabled = false;
        });
    });

    // Real-time validation — comforting messages, not alarming
    form.querySelectorAll('.form-field input, .form-field textarea').forEach((input) => {
      const field = input.closest('.form-field');
      if (!field) return;

      input.addEventListener('blur', function() {
        if (input.validity.valid) {
          field.classList.add('is-valid');
          field.classList.remove('is-invalid');
        } else if (input.value.trim()) {
          field.classList.add('is-invalid');
          field.classList.remove('is-valid');
        }
      });

      input.addEventListener('input', function() {
        if (input.validity.valid) {
          field.classList.add('is-valid');
          field.classList.remove('is-invalid');
        }
      });
    });
  })();
</script>

<style>
  .contacto {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py--spacious) 0 calc(var(--section-py--spacious) + 0.5rem);
    background:
      radial-gradient(circle at 18% 8%, rgba(255, 255, 255, 0.84), transparent 30%),
      radial-gradient(circle at 84% 18%, rgba(223, 228, 216, 0.26), transparent 34%),
      linear-gradient(180deg, var(--color-surface) 0%, var(--color-surface-elevated) 58%, #f4f0e9 100%);
  }

  .contacto::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.007) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.005) 1px, transparent 1px);
    background-size: 10rem 10rem;
    mask-image: radial-gradient(circle at 50% 36%, #000 0%, transparent 76%);
    opacity: 0.55;
  }

  .contact-shell {
    position: relative;
    z-index: 2;
  }

  .contact-header {
    max-width: 56rem;
    margin: 0 auto clamp(3rem, 5vw, 4.6rem);
    text-align: center;
  }

  .contact-header h2 {
    max-width: 56rem;
    margin: 1rem auto 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 0.98;
    letter-spacing: -0.018em;
    text-wrap: balance;
  }

  .contact-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.86;
    text-wrap: pretty;
  }

  .contact-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .contact-eyebrow::before,
  .contact-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  .contact-layout {
    display: grid;
    grid-auto-flow: dense;
    grid-template-columns: minmax(18rem, 5fr) minmax(0, 7fr);
    gap: clamp(1rem, 2.4vw, 1.8rem);
    align-items: stretch;
  }

  .contact-portrait,
  .contact-form-card,
  .contact-rail {
    position: relative;
    border: 1px solid var(--color-line-accent);
    background: rgba(255, 253, 248, 0.58);
    box-shadow: 0 1.1rem 2.8rem rgba(57, 54, 48, 0.035);
  }

  .contact-portrait {
    display: grid;
    grid-template-rows: minmax(21rem, 1fr) auto;
    gap: clamp(1rem, 1.8vw, 1.35rem);
    min-height: 39rem;
    padding: var(--card-pd-sm);
    border-radius: var(--card-radius);
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.68), rgba(250, 248, 242, 0.42)),
      rgba(255, 253, 248, 0.5);
  }

  .portrait-frame {
    position: relative;
    min-height: 100%;
    overflow: hidden;
    border-radius: 1.15rem;
    background: rgba(223, 228, 216, 0.24);
  }

  .portrait-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 253, 248, 0.48);
    border-radius: inherit;
    pointer-events: none;
  }

  .portrait-image {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.02), rgba(47, 45, 40, 0.12)),
      url('https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?q=80&w=960&h=1280&auto=format&fit=crop&crop=entropy') center / cover;
    filter: grayscale(0.22) contrast(1.02) saturate(0.68) brightness(1.04);
    transform: scale(1.015);
    transition: transform 1.2s var(--ease-out-expo), filter 0.8s ease;
  }

  .contact-portrait:hover .portrait-image {
    filter: grayscale(0.18) contrast(1.03) saturate(0.74) brightness(1.05);
    transform: scale(1.045);
  }

  .portrait-note {
    padding: 0.2rem 0.15rem 0.1rem;
  }

  .portrait-note span,
  .form-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    width: fit-content;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .portrait-note span::before,
  .form-kicker::before {
    content: '';
    width: 2rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.26);
  }

  .portrait-note p {
    max-width: 27rem;
    margin: 1rem 0 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.18;
  }

  .contact-form-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 39rem;
    padding: var(--card-pd-lg);
    border-radius: var(--card-radius);
    background:
      radial-gradient(circle at 100% 0%, rgba(223, 228, 216, 0.18), transparent 42%),
      linear-gradient(145deg, rgba(255, 253, 248, 0.82), rgba(250, 248, 242, 0.58));
  }

  .form-head {
    max-width: 36rem;
    margin-bottom: clamp(1.7rem, 3vw, 2.5rem);
  }

  .form-head h3 {
    max-width: 34rem;
    margin: 0.95rem 0 0.65rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-section-title-sm);
    font-style: italic;
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: -0.012em;
  }

  .form-head p {
    max-width: 30rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--type-body);
    line-height: 1.72;
  }

  /* ═══════════════════════════════════════════════════════════
     EDITORIAL FORM FIELDS — border-bottom only, like a letter
     ═══════════════════════════════════════════════════════════ */

  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .form-field {
    position: relative;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: var(--type-body);
    color: var(--color-ink);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-line-accent);
    padding: 28px 0 10px;
    outline: none;
    transition: border-color 0.4s ease, background 0.3s ease;
    border-radius: 0;
    line-height: 1.5;
  }

  .form-field textarea {
    resize: vertical;
    min-height: 90px;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--color-accent);
  }

  .form-field.is-valid input,
  .form-field.is-valid textarea {
    border-color: rgba(111, 125, 103, 0.35);
  }

  .form-field.is-invalid input,
  .form-field.is-invalid textarea {
    border-color: rgba(184, 110, 110, 0.45);
  }

  .form-field label {
    position: absolute;
    left: 0;
    top: 28px;
    font-size: var(--type-small);
    font-weight: 300;
    color: var(--taupe);
    pointer-events: none;
    transition: all 0.3s var(--ease-out-expo);
  }

  .form-field input:focus + label,
  .form-field input:not(:placeholder-shown) + label,
  .form-field textarea:focus + label,
  .form-field textarea:not(:placeholder-shown) + label {
    top: 0;
    font-size: var(--type-meta);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .form-field.is-invalid label {
    color: rgba(184, 110, 110, 0.85);
  }

  .field-hint {
    display: block;
    max-height: 0;
    overflow: hidden;
    font-size: var(--type-caption);
    font-weight: 300;
    line-height: 1.5;
    color: rgba(184, 110, 110, 0.75);
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .form-field.is-invalid .field-hint {
    max-height: 3rem;
    padding-top: 0.4rem;
  }

  .quiet-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: clamp(1.15rem, 2vw, 1.65rem);
    border-block: 1px solid var(--color-line-accent-soft);
  }

  .quiet-step {
    display: grid;
    gap: 0.5rem;
    padding: clamp(0.82rem, 1.35vw, 1rem);
    border-right: 1px solid var(--color-line-accent-soft);
  }

  .quiet-step:last-child {
    border-right: 0;
  }

  .quiet-step span {
    color: rgba(111, 125, 103, 0.58);
    font-family: var(--font-display);
    font-size: var(--type-body);
    font-style: italic;
    line-height: 1;
  }

  .quiet-step p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-card-body);
    line-height: 1.52;
  }

  .form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    margin-top: clamp(1.25rem, 2.4vw, 2rem);
  }

  .form-actions > p {
    max-width: 15rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--type-card-body);
    line-height: 1.6;
  }

  .contact-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 3.15rem;
    padding: 0 1.25rem 0 1.35rem;
    border: 1px solid rgba(86, 100, 90, 0.14);
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-accent-deep), var(--color-accent));
    color: #fbf8f1;
    font: inherit;
    font-size: var(--type-card-body);
    font-weight: 500;
    cursor: pointer;
    box-shadow: 0 0.75rem 1.35rem rgba(86, 100, 90, 0.12);
    transition: transform 0.42s var(--ease-out-expo), box-shadow 0.42s ease, filter 0.28s ease;
    position: relative;
  }

  .contact-submit:hover:not(:disabled) {
    transform: translateY(-2px);
    filter: saturate(1.03);
    box-shadow: 0 0.9rem 1.7rem rgba(86, 100, 90, 0.15);
  }

  .contact-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .contact-submit svg {
    transition: transform 0.35s var(--ease-out-expo);
  }

  .contact-submit:hover:not(:disabled) svg {
    transform: translateX(0.18rem);
  }

  .submit-loading,
  .submit-success {
    display: none;
  }

  .contact-submit.is-loading .submit-text,
  .contact-submit.is-success .submit-text,
  .contact-submit.is-error .submit-text {
    display: none;
  }

  .contact-submit.is-loading .submit-loading,
  .contact-submit.is-success .submit-success,
  .contact-submit.is-error .submit-success {
    display: inline;
  }

  .contact-submit.is-success {
    background: linear-gradient(135deg, #65745f, #839079);
  }

  /* ═══════════════════════════════════════════════════════════
     FORM FEEDBACK — comforting, not alarming
     ═══════════════════════════════════════════════════════════ */

  .form-feedback {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s var(--ease-out-expo), padding 0.5s var(--ease-out-expo), opacity 0.4s ease;
    opacity: 0;
  }

  .form-feedback.show-success,
  .form-feedback.show-error {
    max-height: 6rem;
    padding-top: 1.2rem;
    opacity: 1;
  }

  .feedback-success,
  .feedback-error {
    display: none;
    align-items: center;
    gap: 0.7rem;
    margin: 0;
    padding: 0.85rem 1.1rem;
    border-radius: 1rem;
    font-size: var(--type-small);
    line-height: 1.5;
  }

  .feedback-success {
    color: var(--color-accent-deep);
    background: rgba(111, 125, 103, 0.08);
    border: 1px solid rgba(111, 125, 103, 0.14);
  }

  .feedback-error {
    color: rgba(47, 45, 40, 0.78);
    background: rgba(184, 110, 110, 0.06);
    border: 1px solid rgba(184, 110, 110, 0.14);
  }

  .feedback-error a {
    color: var(--color-accent-deep);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .form-feedback.show-success .feedback-success,
  .form-feedback.show-error .feedback-error {
    display: flex;
  }

  .feedback-success svg,
  .feedback-error svg {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .contact-rail {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-radius: 1.25rem;
    background: rgba(255, 253, 248, 0.36);
    box-shadow: none;
    overflow: hidden;
