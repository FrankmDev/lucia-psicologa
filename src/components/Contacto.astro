---
import PageNumber from './ui/PageNumber.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

const contactRoutes = [
  {
    label: 'Email',
    value: 'luciamillanpsico@gmail.com',
    href: 'mailto:luciamillanpsico@gmail.com',
  },
  {
    label: 'Teléfono',
    value: '722 535 914',
    href: 'tel:722535914',
  },
  {
    label: 'Consulta',
    value: 'Ciudad Real · Online',
  },
  {
    label: 'Dirección',
    value: 'C/ Toledo, 8, 2ª Planta, 13001, Ciudad Real',
    href: 'https://www.google.com/search?sca_esv=46bc13bb03f41cf0&sxsrf=ANbL-n4P7jqJ8RBIUqoY7eJLwLqci3o1Xw:1779809431733&kgmid=/g/11z35hqkg2&q=Luc%C3%ADa+Mill%C3%A1n+Jim%C3%A9nez,+Psic%C3%B3logo&shem=rimspwouoe&shndl=30&source=sh/x/loc/uni/m1/1&kgs=07d8cea2c96db48f&utm_source=rimspwouoe,sh/x/loc/uni/m1/1',
  },
];

const quietSteps = [
  'Escríbeme solo lo esencial.',
  'Te respondo con una primera orientación.',
  'Elegimos juntas el formato que encaje.',
];
---

<section id="contacto" class="contacto" data-contacto>
  <GrainOverlay opacity={0.01} />
  <AmbientLight color="rgba(255,255,255,0.18)" />
  <FloatOrb size={360} top="-18%" right="-12%" color="rgba(141,151,132,0.08)" blur={170} opacity={0.28} animation="float-1" />
  <FloatOrb size={260} bottom="2%" left="-10%" color="rgba(216,211,200,0.18)" blur={145} opacity={0.24} animation="float-2" />

  <Container maxWidth="1240px" padding="0 clamp(1rem, 4vw, 4.25rem)">
    <div class="contact-shell">
      <header class="contact-header reveal-blur" data-delay="80">
        <span class="contact-eyebrow">Contacto</span>
        <h2>Empezamos con una conversación sencilla.</h2>
        <p>
          No hace falta tenerlo todo ordenado para escribir. Puedes acercarte con lo que haya ahora; yo te responderé con claridad, cuidado y un siguiente paso posible.
        </p>
      </header>

      <div class="contact-layout" aria-label="Contacto y formulario">
        <aside class="contact-portrait reveal-scale" data-delay="160">
          <div class="portrait-frame" aria-hidden="true">
            <div class="portrait-image"></div>
          </div>

          <div class="portrait-note">
            <span>Primera respuesta</span>
            <p>
              Puedes contarme poco, mucho o simplemente decir que necesitas orientación. El primer contacto también puede ser tranquilo.
            </p>
          </div>
        </aside>

        <form class="contact-form-card reveal-scale" data-delay="220" onsubmit="event.preventDefault(); alert('Formulario de demostración.');">
          <div class="form-head">
            <span class="form-kicker">Mensaje inicial</span>
            <h3>Cuéntame lo básico, sin presión.</h3>
            <p>Te responderé con una propuesta clara y sin compromiso para valorar juntas cómo empezar.</p>
          </div>

          <div class="form-grid">
            <label class="field">
              <span>Nombre</span>
              <input type="text" name="nombre" autocomplete="name" required />
            </label>

            <label class="field">
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>

            <label class="field field--full">
              <span>¿Qué te gustaría contarme?</span>
              <textarea name="mensaje" rows="5" required></textarea>
            </label>
          </div>

          <div class="quiet-list" aria-label="Qué ocurre después">
            {quietSteps.map((step, index) => (
              <div class="quiet-step">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <p>{step}</p>
              </div>
            ))}
          </div>

          <div class="form-actions">
            <p>Tus datos se tratan con confidencialidad.</p>
            <button type="submit" class="contact-submit">
              <span>Enviar mensaje</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </form>

        <div class="contact-rail reveal-up" data-delay="320" aria-label="Datos de contacto">
          {contactRoutes.map((route) => (
            route.href ? (
              <a class="contact-route" href={route.href}>
                <span>{route.label}</span>
                <strong>{route.value}</strong>
              </a>
            ) : (
              <div class="contact-route">
                <span>{route.label}</span>
                <strong>{route.value}</strong>
              </div>
            )
          ))}
        </div>
      </div>
    </div>
  </Container>

  <PageNumber number="07" />
</section>

<style>
  .contacto {
    --ct-ink: #2f2d28;
    --ct-text: rgba(47, 45, 40, 0.7);
    --ct-muted: rgba(47, 45, 40, 0.52);
    --ct-sage: #6f7d67;
    --ct-sage-deep: #56645a;
    --ct-paper: #fffdf8;
    --ct-cream: #faf8f2;
    --ct-line: rgba(111, 125, 103, 0.13);
    --ct-line-soft: rgba(111, 125, 103, 0.075);

    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: clamp(6.2rem, 9vw, 9.4rem) 0 clamp(6.6rem, 10vw, 10rem);
    background:
      radial-gradient(circle at 18% 8%, rgba(255, 255, 255, 0.84), transparent 30%),
      radial-gradient(circle at 84% 18%, rgba(223, 228, 216, 0.26), transparent 34%),
      linear-gradient(180deg, var(--cream) 0%, var(--ct-cream) 58%, #f4f0e9 100%);
  }

  .contacto::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(rgba(78, 74, 66, 0.007) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 74, 66, 0.005) 1px, transparent 1px);
    background-size: 10rem 10rem;
    mask-image: radial-gradient(circle at 50% 36%, #000 0%, transparent 76%);
    opacity: 0.55;
  }

  .contact-shell {
    position: relative;
    z-index: 2;
  }

  .contact-header {
    max-width: 56rem;
    margin: 0 auto clamp(3rem, 5vw, 4.6rem);
    text-align: center;
  }

  .contact-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--ct-sage);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .contact-eyebrow::before,
  .contact-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.28);
  }

  .contact-header h2 {
    max-width: 56rem;
    margin: 1rem auto 1rem;
    color: var(--ct-ink);
    font-family: var(--font-display);
    font-size: clamp(2.9rem, 6.2vw, 5.8rem);
    font-style: italic;
    font-weight: 300;
    line-height: 0.98;
    letter-spacing: -0.018em;
    text-wrap: balance;
  }

  .contact-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--ct-text);
    font-size: clamp(1rem, 1.2vw, 1.08rem);
    line-height: 1.86;
    text-wrap: pretty;
  }

  .contact-layout {
    display: grid;
    grid-auto-flow: dense;
    grid-template-columns: minmax(18rem, 5fr) minmax(0, 7fr);
    gap: clamp(1rem, 2.4vw, 1.8rem);
    align-items: stretch;
  }

  .contact-portrait,
  .contact-form-card,
  .contact-rail {
    position: relative;
    border: 1px solid var(--ct-line);
    background: rgba(255, 253, 248, 0.58);
    box-shadow: 0 1.1rem 2.8rem rgba(57, 54, 48, 0.035);
  }

  .contact-portrait {
    display: grid;
    grid-template-rows: minmax(21rem, 1fr) auto;
    gap: clamp(1rem, 1.8vw, 1.35rem);
    min-height: 39rem;
    padding: clamp(0.85rem, 1.6vw, 1.15rem);
    border-radius: 1.65rem;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.68), rgba(250, 248, 242, 0.42)),
      rgba(255, 253, 248, 0.5);
  }

  .portrait-frame {
    position: relative;
    min-height: 100%;
    overflow: hidden;
    border-radius: 1.15rem;
    background: rgba(223, 228, 216, 0.24);
  }

  .portrait-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 253, 248, 0.48);
    border-radius: inherit;
    pointer-events: none;
  }

  .portrait-image {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.02), rgba(47, 45, 40, 0.12)),
      url('https://picsum.photos/seed/lucia-quiet-therapy-window/960/1280') center / cover;
    filter: grayscale(0.22) contrast(1.02) saturate(0.68) brightness(1.04);
    transform: scale(1.015);
    transition: transform 1.2s var(--ease-out-expo), filter 0.8s ease;
  }

  .contact-portrait:hover .portrait-image {
    filter: grayscale(0.18) contrast(1.03) saturate(0.74) brightness(1.05);
    transform: scale(1.045);
  }

  .portrait-note {
    padding: 0.2rem 0.15rem 0.1rem;
  }

  .portrait-note span,
  .form-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    width: fit-content;
    color: var(--ct-sage);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .portrait-note span::before,
  .form-kicker::before {
    content: '';
    width: 2rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.26);
  }

  .portrait-note p {
    max-width: 27rem;
    margin: 1rem 0 0;
    color: var(--ct-ink);
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.18;
  }

  .contact-form-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 39rem;
    padding: clamp(1.35rem, 2.9vw, 2.65rem);
    border-radius: 1.65rem;
    background:
      radial-gradient(circle at 100% 0%, rgba(223, 228, 216, 0.18), transparent 42%),
      linear-gradient(145deg, rgba(255, 253, 248, 0.82), rgba(250, 248, 242, 0.58));
  }

  .form-head {
    max-width: 36rem;
    margin-bottom: clamp(1.7rem, 3vw, 2.5rem);
  }

  .form-head h3 {
    max-width: 34rem;
    margin: 0.95rem 0 0.65rem;
    color: var(--ct-ink);
    font-family: var(--font-display);
    font-size: clamp(2.15rem, 4vw, 4rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: -0.012em;
  }

  .form-head p {
    max-width: 30rem;
    margin: 0;
    color: var(--ct-muted);
    font-size: 0.98rem;
    line-height: 1.72;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.9rem, 1.4vw, 1.1rem);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .field--full {
    grid-column: 1 / -1;
  }

  .field span {
    color: var(--ct-sage-deep);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .field input,
  .field textarea {
    width: 100%;
    border: 1px solid rgba(111, 125, 103, 0.12);
    border-radius: 0.95rem;
    background: rgba(255, 253, 248, 0.68);
    color: var(--ct-ink);
    font: inherit;
    font-size: 0.98rem;
    line-height: 1.5;
    outline: none;
    transition: border-color 0.28s ease, background 0.28s ease, box-shadow 0.28s ease;
  }

  .field input {
    min-height: 3.25rem;
    padding: 0 1rem;
  }

  .field textarea {
    min-height: 9rem;
    padding: 0.95rem 1rem;
    resize: vertical;
  }

  .field input:focus,
  .field textarea:focus {
    border-color: rgba(111, 125, 103, 0.32);
    background: rgba(255, 253, 248, 0.94);
    box-shadow: 0 0 0 0.2rem rgba(111, 125, 103, 0.065);
  }

  .quiet-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: clamp(1.15rem, 2vw, 1.65rem);
    border-block: 1px solid var(--ct-line-soft);
  }

  .quiet-step {
    display: grid;
    gap: 0.5rem;
    padding: clamp(0.82rem, 1.35vw, 1rem);
    border-right: 1px solid var(--ct-line-soft);
  }

  .quiet-step:last-child {
    border-right: 0;
  }

  .quiet-step span {
    color: rgba(111, 125, 103, 0.58);
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    line-height: 1;
  }

  .quiet-step p {
    margin: 0;
    color: var(--ct-text);
    font-size: 0.84rem;
    line-height: 1.52;
  }

  .form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    margin-top: clamp(1.25rem, 2.4vw, 2rem);
  }

  .form-actions p {
    max-width: 15rem;
    margin: 0;
    color: var(--ct-muted);
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .contact-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 3.15rem;
    padding: 0 1.25rem 0 1.35rem;
    border: 1px solid rgba(86, 100, 90, 0.14);
    border-radius: 999px;
    background: linear-gradient(135deg, var(--ct-sage-deep), var(--ct-sage));
    color: #fbf8f1;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 500;
    cursor: pointer;
    box-shadow: 0 0.75rem 1.35rem rgba(86, 100, 90, 0.12);
    transition: transform 0.42s var(--ease-out-expo), box-shadow 0.42s ease, filter 0.28s ease;
  }

  .contact-submit:hover {
    transform: translateY(-2px);
    filter: saturate(1.03);
    box-shadow: 0 0.9rem 1.7rem rgba(86, 100, 90, 0.15);
  }

  .contact-submit svg {
    transition: transform 0.35s var(--ease-out-expo);
  }

  .contact-submit:hover svg {
    transform: translateX(0.18rem);
  }

  .contact-rail {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-radius: 1.25rem;
    background: rgba(255, 253, 248, 0.36);
    box-shadow: none;
    overflow: hidden;
  }

  .contact-route {
    display: grid;
    gap: 0.45rem;
    min-height: 5.4rem;
    padding: clamp(0.95rem, 1.45vw, 1.15rem);
    border-right: 1px solid var(--ct-line-soft);
    color: inherit;
    text-decoration: none;
    transition: background 0.35s ease;
  }

  .contact-route:last-child {
    border-right: 0;
  }

  .contact-route span {
    color: var(--ct-sage);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .contact-route strong {
    color: var(--ct-ink);
    font-size: clamp(0.9rem, 1vw, 0.98rem);
    font-weight: 400;
    line-height: 1.35;
  }

  a.contact-route:hover {
    background: rgba(223, 228, 216, 0.14);
  }

  @media (max-width: 980px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-portrait,
    .contact-form-card {
      min-height: auto;
    }

    .contact-portrait {
      grid-template-rows: minmax(18rem, 28rem) auto;
    }

    .contact-rail {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .contact-route:nth-child(2n) {
      border-right: 0;
    }

    .contact-route:nth-child(-n + 2) {
      border-bottom: 1px solid var(--ct-line-soft);
    }
  }

  @media (max-width: 640px) {
    .contacto {
      padding: 4.8rem 0 5.8rem;
    }

    .contact-header {
      text-align: left;
      margin-bottom: 2.2rem;
      padding: 0 2vw;
    }

    .contact-eyebrow {
      justify-content: flex-start;
    }

    .contact-eyebrow::after {
      display: none;
    }

    .contact-header h2,
    .contact-header p {
      margin-left: 0;
      margin-right: 0;
    }

    .contact-header h2 {
      font-size: clamp(2.3rem, 10.5vw, 3.2rem);
      line-height: 0.98;
      letter-spacing: -0.015em;
    }

    .contact-header p {
      font-size: 0.95rem;
      line-height: 1.65;
    }

    .contact-portrait,
    .contact-form-card {
      border-radius: 1.1rem;
    }

    .contact-portrait {
      grid-template-rows: minmax(14rem, 18rem) auto;
      padding: 0.7rem;
      min-height: auto;
    }

    .portrait-note p {
      font-size: clamp(1.15rem, 5.5vw, 1.45rem);
      line-height: 1.15;
    }

    .contact-form-card {
      padding: 1rem;
      min-height: auto;
    }

    .form-head {
      margin-bottom: 1.4rem;
    }

    .form-head h3 {
      font-size: clamp(1.9rem, 9vw, 2.8rem);
    }

    .form-head p {
      font-size: 0.9rem;
      line-height: 1.55;
    }

    .form-grid,
    .quiet-list,
    .contact-rail {
      grid-template-columns: 1fr;
    }

    .field span {
      font-size: max(0.58rem, 10px);
    }

    .field input {
      min-height: 2.9rem;
      font-size: 0.95rem;
    }

    .field textarea {
      min-height: 7rem;
      font-size: 0.95rem;
    }

    .quiet-step,
    .quiet-step:last-child,
    .contact-route,
    .contact-route:last-child,
    .contact-route:nth-child(-n + 2) {
      border-right: 0;
      border-bottom: 1px solid var(--ct-line-soft);
    }

    .quiet-step:last-child,
    .contact-route:last-child {
      border-bottom: 0;
    }

    .quiet-step span {
      font-size: 0.92rem;
    }
    .quiet-step p {
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .form-actions {
      align-items: stretch;
      flex-direction: column;
      gap: 0.9rem;
      margin-top: 1.1rem;
    }

    .form-actions p {
      max-width: none;
      font-size: 0.78rem;
    }

    .contact-submit {
      width: 100%;
      min-height: 2.9rem;
      font-size: max(0.58rem, 10px);
      letter-spacing: 0.16em;
    }

    .contact-route {
      min-height: 4.6rem;
      padding: 0.85rem;
    }

    .contact-route strong {
      font-size: 0.88rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .portrait-image,
    .contact-submit,
    .contact-submit svg,
    .contact-route {
      transition: none;
      transform: none;
    }
  }
</style>
