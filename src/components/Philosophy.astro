    height: 3px;
    border-radius: 50%;
    background: rgba(196,170,148,0.15);
    opacity: 0;
    transform: scale(0);
    transition: opacity 0.5s ease 0.2s, transform 0.5s var(--ease-out-expo) 0.2s;
