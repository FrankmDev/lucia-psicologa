</style>

<script>
  const phiSection = document.querySelector('[data-philosophy]');
  const phiBg = document.querySelector('.phi-bg-img');
  if (phiBg && phiSection && !window.matchMedia('(pointer: coarse)').matches) {
    window.addEventListener('scroll', () => {
      const rect = phiSection.getBoundingClientRect();
      const progress = Math.max(0, Math.min(1, -rect.top / rect.height));
      (phiBg as HTMLElement).style.transform = `scale(1.05) translateY(${progress * 30}px)`;
    }, { passive: true });
  }

  const phiContent = document.querySelector('[data-phi-content]');
  if (phiContent && phiSection && !window.matchMedia('(pointer: coarse)').matches) {
    phiSection.addEventListener('mousemove', (e) => {
      const rect = phiSection.getBoundingClientRect();
      const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
      const y = (e.clientY - rect.top - rect.height / 2) / rect.height;
      (phiContent as HTMLElement).style.transform = `translate(${x * -5}px, ${y * -3}px)`;
    });
    phiSection.addEventListener('mouseleave', () => {
      (phiContent as HTMLElement).style.transform = 'translate(0, 0)';
    });
  }

  // Values container observer
  const valuesContainer = document.querySelector('[data-values]');
  if (valuesContainer) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    io.observe(valuesContainer);
  }

  // Quote observer for line animations
  const quoteWrap = document.querySelector('.phi-quote-wrap');
  if (quoteWrap) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    io.observe(quoteWrap);
  }

  // Visual caption observer
  const visualEl = document.querySelector('.phi-editorial__visual');
  if (visualEl) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    io.observe(visualEl);
  }

  // Spotlight follow on image frame
  const spotFrame = document.querySelector('[data-spotlight]');
  if (spotFrame && !window.matchMedia('(pointer: coarse)').matches) {
    spotFrame.addEventListener('mousemove', (e) => {
      const rect = spotFrame.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      spotFrame.style.setProperty('--mouse-x', `${x}%`);
      spotFrame.style.setProperty('--mouse-y', `${y}%`);
    });
  }
</script>
