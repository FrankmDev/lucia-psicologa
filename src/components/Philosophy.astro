---
import Button from './ui/Button.astro';
import PageNumber from './ui/PageNumber.astro';
import Container from './ui/Container.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

const backgroundImage =
  'https://images.unsplash.com/photo-1448375240586-882707db888b?q=80&w=2200&auto=format&fit=crop';
const inlineImage =
  'https://images.unsplash.com/photo-1511497584788-876760111969?q=80&w=700&auto=format&fit=crop';

const phrase = [
  'La',
  'terapia',
  'no',
  'tiene',
  'por',
  'qué',
  'ser',
  'un',
  'lugar',
  'duro.',
  'Puede',
  'ser',
  'un',
  'espacio',
  'seguro',
  'donde',
  'respirar,',
  'ordenar',
  'y',
  'volver',
  'a',
  'ti.',
];

const anchors = [
  {
    title: 'Regular',
    short: 'Suelo',
    text: 'Bajar el ruido antes de entrar en lo importante.',
  },
  {
    title: 'Comprender',
    short: 'Claridad',
    text: 'Dar sentido a lo que se repite sin juicio.',
  },
  {
    title: 'Integrar',
    short: 'Ritmo',
    text: 'Convertir lo trabajado en una forma más amable de vivir.',
  },
];
---

<section id="filosofia" class="philosophy spotlight-section" data-philosophy>
  <div class="ph-bg" aria-hidden="true">
    <img src={backgroundImage} alt="" width="2200" height="1467" decoding="async" loading="lazy" />
    <div class="ph-bg__wash"></div>
  </div>

  <GrainOverlay opacity={0.026} zIndex={2} />
  <AmbientLight color="rgba(255,255,255,0.12)" />
  <FloatOrb size={340} top="-16%" right="-10%" color="rgba(141,151,132,0.12)" blur={145} animation="float-1" />
  <FloatOrb size={230} bottom="4%" left="-7%" color="rgba(216,211,200,0.16)" opacity={0.3} blur={120} animation="float-2" />

  <Container maxWidth="1360px" padding="0 clamp(1rem, 4vw, 4.25rem)">
    <div class="ph-shell">
      <div class="ph-note reveal-blur" data-delay="80">
        <span>Filosofía terapéutica</span>
      </div>

      <div class="ph-composition">
        <header class="ph-hero reveal-blur" data-delay="120">
          <h2>
            Calma para mirar
            <span class="ph-heading-image" style={`--ph-inline-image: url('${inlineImage}')`} aria-hidden="true"></span>
            lo que pesa.
          </h2>
          <p>
            Un acompañamiento clínico, cercano y sin prisa para sentir seguridad mientras das forma a lo que necesitas cuidar.
          </p>
        </header>

        <aside class="ph-quiet-card reveal-scale" data-delay="220">
          <div class="ph-card-top">
            <span>Proceso seguro</span>
            <i aria-hidden="true"></i>
          </div>

          <p class="ph-reveal-line" aria-label="La terapia no tiene por qué ser un lugar duro. Puede ser un espacio seguro donde respirar, ordenar y volver a ti.">
            {phrase.map((word) => (
              <span data-ph-word>{word}</span>
            ))}
          </p>

          <div class="ph-actions">
            <Button href="#contacto" variant="hero" class="ph-button">
              Reservar sesión
            </Button>
            <a href="#sobre-mi" class="ph-link">
              <span>Conocer a Lucía</span>
              <i aria-hidden="true"></i>
            </a>
          </div>
        </aside>
      </div>

      <div class="ph-anchors reveal-up" data-delay="360" aria-label="Principios del enfoque">
        {anchors.map((anchor) => (
          <article class="ph-anchor">
            <div class="ph-anchor__mark" aria-hidden="true">
              <span>{anchor.short}</span>
            </div>
            <div class="ph-anchor__copy">
              <h3>{anchor.title}</h3>
              <p>{anchor.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </Container>

  <PageNumber number="04" light={true} />
</section>

<style>
  .philosophy {
    --ph-ink: #f5f0e8;
    --ph-text: rgba(245, 240, 232, 0.76);
    --ph-muted: rgba(245, 240, 232, 0.56);
    --ph-sage: #a8a99e;
    --ph-gold: #b8a88a;
    --ph-depth: #0c0907;
    --ph-line: rgba(245, 240, 232, 0.14);
    --ph-panel: rgba(245, 240, 232, 0.075);

    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: clamp(5.6rem, 8vw, 8.2rem) 0 clamp(5.8rem, 8vw, 8.6rem);
    background: var(--ph-depth);
    color: var(--ph-ink);
  }

  .ph-bg,
  .ph-bg img,
  .ph-bg__wash {
    position: absolute;
    inset: 0;
  }

  .ph-bg {
    z-index: 0;
    overflow: hidden;
  }

  .ph-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    filter: grayscale(18%) saturate(0.68) contrast(1.1) brightness(var(--ph-bg-brightness, 0.48));
    transform: scale(var(--ph-bg-scale, 1.08));
    transition: transform 0.18s linear, filter 0.18s linear;
    will-change: transform, filter;
  }

  .ph-bg__wash {
    background:
      radial-gradient(ellipse at 30% 24%, rgba(245, 240, 232, 0.13), transparent 42%),
      radial-gradient(ellipse at 76% 72%, rgba(111, 125, 103, 0.22), transparent 42%),
      linear-gradient(90deg, rgba(12, 9, 7, 0.96) 0%, rgba(12, 9, 7, 0.7) 46%, rgba(12, 9, 7, 0.96) 100%),
      linear-gradient(180deg, rgba(12, 9, 7, 0.8) 0%, rgba(12, 9, 7, 0.54) 46%, rgba(12, 9, 7, 0.92) 100%);
  }

  .philosophy::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(rgba(245, 240, 232, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245, 240, 232, 0.014) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 52% 45%, #000 0%, transparent 76%);
    opacity: 0.34;
  }

  .ph-shell {
    position: relative;
    z-index: 2;
  }

  .ph-note {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: clamp(1.45rem, 3vw, 2.4rem);
    color: var(--ph-sage);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .ph-note::before {
    content: '';
    width: clamp(2.4rem, 7vw, 5.2rem);
    height: 1px;
    background: rgba(196, 170, 148, 0.42);
  }

  .ph-composition {
    display: grid;
    grid-template-columns: minmax(0, 7.4fr) minmax(18.5rem, 4.6fr);
    gap: clamp(2rem, 4.6vw, 4.8rem);
    align-items: center;
    min-height: clamp(24rem, 44vw, 34rem);
    padding: clamp(1.4rem, 3.4vw, 3.1rem) 0 clamp(2.2rem, 4vw, 3.4rem);
  }

  .ph-hero {
    max-width: min(100%, 62rem);
    transform: translateY(clamp(-0.6rem, -0.8vw, -0.2rem));
  }

  .ph-hero h2 {
    margin: 0;
    color: var(--ph-ink);
    font-family: var(--font-display);
    font-size: clamp(2.9rem, 6.4vw, 5.7rem);
    font-style: italic;
    font-weight: 300;
    line-height: 0.98;
    letter-spacing: -0.045em;
    text-wrap: balance;
  }

  .ph-heading-image {
    display: inline-block;
    width: clamp(4.8rem, 8vw, 7.6rem);
    height: clamp(1.85rem, 3.3vw, 2.9rem);
    margin: 0 0.08em;
    border: 1px solid rgba(245, 240, 232, 0.25);
    border-radius: 999px;
    background-image:
      linear-gradient(rgba(12, 9, 7, 0.04), rgba(12, 9, 7, 0.32)),
      var(--ph-inline-image);
    background-position: center;
    background-size: cover;
    vertical-align: middle;
    box-shadow:
      0 0.8rem 1.8rem rgba(0, 0, 0, 0.2),
      inset 0 0 0 1px rgba(255, 255, 255, 0.16);
  }

  .ph-hero p {
    max-width: 35rem;
    margin: clamp(1.1rem, 2vw, 1.45rem) 0 0;
    color: var(--ph-text);
    font-size: clamp(0.98rem, 1.22vw, 1.08rem);
    line-height: 1.76;
    text-wrap: pretty;
  }

  .ph-quiet-card {
    position: relative;
    align-self: center;
    justify-self: end;
    width: min(100%, 25rem);
    padding: clamp(1.05rem, 1.9vw, 1.45rem);
    border: 1px solid rgba(245, 240, 232, 0.15);
    border-radius: 1.15rem;
    background:
      linear-gradient(135deg, rgba(245, 240, 232, 0.13), rgba(245, 240, 232, 0.035) 58%),
      radial-gradient(circle at 0% 0%, rgba(168, 169, 158, 0.13), transparent 30%),
      radial-gradient(circle at 100% 100%, rgba(184, 168, 138, 0.11), transparent 34%);
    box-shadow:
      0 1.2rem 2.5rem rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(13px);
    overflow: hidden;
  }

  .ph-quiet-card::before {
    content: '';
    position: absolute;
    inset: 0.9rem;
    border: 1px solid rgba(245, 240, 232, 0.07);
    border-radius: 0.85rem;
    pointer-events: none;
  }

  .ph-quiet-card::after {
    content: '';
    position: absolute;
    right: -3.2rem;
    bottom: -3.4rem;
    width: 8.6rem;
    aspect-ratio: 1;
    border: 1px solid rgba(184, 168, 138, 0.16);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245, 240, 232, 0.08), transparent 64%);
    pointer-events: none;
  }

  .ph-card-top,
  .ph-reveal-line,
  .ph-actions {
    position: relative;
    z-index: 1;
  }

  .ph-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: clamp(0.95rem, 2vw, 1.35rem);
    padding-bottom: clamp(0.85rem, 1.7vw, 1.1rem);
    border-bottom: 1px solid rgba(245, 240, 232, 0.12);
  }

  .ph-card-top span {
    color: rgba(196, 170, 148, 0.78);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .ph-card-top i {
    width: 2.8rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(196, 170, 148, 0.6), transparent);
  }

  .ph-reveal-line {
    max-width: 29ch;
    margin: 0;
    color: var(--ph-ink);
    font-family: var(--font-body);
    font-size: clamp(0.92rem, 1.08vw, 1.02rem);
    font-style: normal;
    font-weight: 300;
    line-height: 1.86;
    letter-spacing: 0.01em;
  }

  .ph-reveal-line span {
    display: inline-block;
    margin-right: 0.2em;
    opacity: var(--ph-word-opacity, 0.26);
    transform: translateY(calc((1 - var(--ph-word-opacity, 0.26)) * 0.22rem));
    transition: opacity 0.18s linear, transform 0.18s linear;
  }

  .ph-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.15rem;
    margin-top: clamp(1.2rem, 2.4vw, 1.75rem);
    padding-top: clamp(0.95rem, 1.8vw, 1.2rem);
    border-top: 1px solid rgba(245, 240, 232, 0.1);
  }

  .ph-link {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    min-height: 3rem;
    color: rgba(245, 240, 232, 0.82);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: color 0.25s ease, letter-spacing 0.25s ease;
  }

  .ph-link i {
    width: 2.45rem;
    height: 1px;
    background: rgba(196, 170, 148, 0.48);
    transform-origin: left;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .ph-link:hover {
    color: var(--ph-ink);
    letter-spacing: 0.23em;
  }

  .ph-link:hover i {
    transform: scaleX(1.16);
    background: rgba(196, 170, 148, 0.72);
  }

  .ph-anchors {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.75rem, 1.5vw, 1rem);
  }

  .ph-anchor {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(0.85rem, 1.5vw, 1.15rem);
    min-height: clamp(7.4rem, 9.4vw, 8.8rem);
    padding: clamp(1.05rem, 1.8vw, 1.4rem);
    border-block: 1px solid rgba(245, 240, 232, 0.13);
    overflow: hidden;
    background:
      radial-gradient(circle at 100% 0%, rgba(168, 169, 158, 0.12), transparent 38%),
      linear-gradient(180deg, rgba(245, 240, 232, 0.055), rgba(245, 240, 232, 0.022));
    backdrop-filter: blur(8px);
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      transform 0.45s var(--ease-out-expo);
  }

  .ph-anchor::after {
    content: '';
    position: absolute;
    inset: auto 1.35rem 0.9rem 1.35rem;
    height: 1px;
    background: rgba(196, 170, 148, 0.5);
    transform: scaleX(0.2);
    transform-origin: left;
    transition: transform 0.42s var(--ease-out-expo);
  }

  .ph-anchor:hover {
    border-color: rgba(196, 170, 148, 0.22);
    background:
      radial-gradient(circle at 100% 0%, rgba(168, 169, 158, 0.17), transparent 38%),
      linear-gradient(180deg, rgba(245, 240, 232, 0.08), rgba(245, 240, 232, 0.032));
    transform: translateY(-0.22rem);
  }

  .ph-anchor:hover::after {
    transform: scaleX(1);
  }

  .ph-anchor__mark {
    display: grid;
    place-items: center;
    width: clamp(3.2rem, 5vw, 4.2rem);
    aspect-ratio: 1;
    border: 1px solid rgba(196, 170, 148, 0.18);
    border-radius: 50%;
    color: rgba(196, 170, 148, 0.72);
    background: rgba(245, 240, 232, 0.045);
  }

  .ph-anchor__mark span {
    max-width: 3.4rem;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-align: center;
    text-transform: uppercase;
  }

  .ph-anchor__copy {
    align-self: center;
  }

  .ph-anchor h3 {
    margin: 0;
    color: var(--ph-ink);
    font-family: var(--font-display);
    font-size: clamp(1.32rem, 1.8vw, 1.68rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }

  .ph-anchor p {
    max-width: 15.5rem;
    margin: 0.42rem 0 0;
    color: var(--ph-muted);
    font-size: 0.82rem;
    line-height: 1.58;
    text-wrap: pretty;
  }

  @media (max-width: 980px) {
    .ph-composition {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: clamp(1.2rem, 4vw, 2.4rem) 0 clamp(2rem, 5vw, 3rem);
    }

    .ph-quiet-card {
      justify-self: start;
      width: min(100%, 34rem);
    }

    .ph-reveal-line {
      max-width: 34rem;
      font-size: clamp(0.94rem, 2.2vw, 1.04rem);
    }
  }

  @media (max-width: 760px) {
    .philosophy {
      padding: 5.2rem 0 6.2rem;
    }

    .ph-note {
      gap: 0.65rem;
      margin-bottom: 1.3rem;
    }

    .ph-note::before {
      width: 1.6rem;
    }

    .ph-hero h2 {
      font-size: clamp(2.55rem, 13vw, 4.2rem);
      line-height: 1.02;
    }

    .ph-anchors {
      grid-template-columns: 1fr;
    }

    .ph-anchor + .ph-anchor {
      border-top: 1px solid rgba(245, 240, 232, 0.12);
      border-left: 0;
    }

    .ph-anchor {
      min-height: auto;
    }
  }

  @media (max-width: 540px) {
    .ph-actions {
      align-items: stretch;
    }

    .ph-actions :global(.ph-button) {
      width: 100%;
    }

    .ph-link {
      justify-content: space-between;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ph-bg img,
    .ph-reveal-line span,
    .ph-anchor,
    .ph-anchor::after {
      transition: none;
    }
  }
</style>

<script>
  const philosophy = document.querySelector('[data-philosophy]');

  if (philosophy) {
    const words = Array.from(philosophy.querySelectorAll('[data-ph-word]'));
    const image = philosophy.querySelector('.ph-bg img');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

    const updateMotion = () => {
      if (reduceMotion) {
        words.forEach((word) => word.style.setProperty('--ph-word-opacity', '1'));
        image?.style.setProperty('--ph-bg-scale', '1.08');
        image?.style.setProperty('--ph-bg-brightness', '0.5');
        return;
      }

      const rect = philosophy.getBoundingClientRect();
      const progress = clamp((window.innerHeight * 0.78 - rect.top) / (rect.height * 0.7), 0, 1);

      words.forEach((word, index) => {
        const start = index / words.length;
        const opacity = clamp((progress - start * 0.72) * 4.4, 0.26, 1);
        word.style.setProperty('--ph-word-opacity', opacity.toFixed(3));
      });

      if (image) {
        image.style.setProperty('--ph-bg-scale', (1.08 + progress * 0.045).toFixed(3));
        image.style.setProperty('--ph-bg-brightness', (0.46 + progress * 0.08).toFixed(3));
      }
    };

    let ticking = false;
    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateMotion();
          ticking = false;
        });
        ticking = true;
      }
    };

    updateMotion();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
  }
</script>
