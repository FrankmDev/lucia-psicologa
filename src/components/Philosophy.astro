---
import Button from './ui/Button.astro';
import PageNumber from './ui/PageNumber.astro';
import Container from './ui/Container.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import AmbientLight from './ui/AmbientLight.astro';
import FloatOrb from './ui/FloatOrb.astro';

const backgroundImage =
  'https://images.unsplash.com/photo-1448375240586-882707db888b?q=80&w=2200&auto=format&fit=crop';

const phrase = [
  'La',
  'terapia',
  'puede',
  'ayudarte',
  'a',
  'entender',
  'síntomas,',
  'regular',
  'emociones',
  'y',
  'tomar',
  'decisiones',
  'con',
  'más',
  'margen.',
];

const anchors = [
  {
    num: '01',
    title: 'Evaluar',
    text: 'Comprender qué ocurre, de dónde viene y qué factores mantienen el malestar.',
  },
  {
    num: '02',
    title: 'Regular',
    text: 'Desarrollar recursos para manejar activación, ansiedad, bloqueo o desbordamiento emocional.',
  },
  {
    num: '03',
    title: 'Integrar',
    text: 'Trasladar lo trabajado a tus decisiones, vínculos y vida diaria.',
  },
];
---

<section id="filosofia" class="philosophy spotlight-section dark-surface" data-philosophy data-surface="dark">
  <div class="ph-bg" aria-hidden="true">
    <img src={backgroundImage} alt="" width="2200" height="1467" decoding="async" loading="lazy" />
    <div class="ph-bg__wash"></div>
    <div class="ph-bg__vignette" aria-hidden="true"></div>
  </div>

  <GrainOverlay opacity={0.026} zIndex={2} />
  <AmbientLight color="rgba(255,255,255,0.12)" />
  <FloatOrb size={340} top="-16%" right="-10%" color="rgba(141,151,132,0.12)" blur={145} animation="float-1" />
  <FloatOrb size={230} bottom="4%" left="-7%" color="rgba(216,211,200,0.16)" opacity={0.3} blur={120} animation="float-2" />

  <Container maxWidth="1280px" padding="0 clamp(1rem, 4vw, 4.25rem)">
    <div class="ph-shell">
      <header class="ph-header reveal-blur" data-delay="80">
        <span class="ph-eyebrow">Filosofía</span>
        <h2>Un proceso clínico con dirección.</h2>
        <p>
          Evaluamos, definimos objetivos y revisamos avances para que cada sesión tenga una función dentro de un proceso adaptado a ti.
        </p>
      </header>

      <div class="ph-manifesto reveal-scale" data-delay="180">
        <div class="ph-manifesto__frame" aria-hidden="true">
          <span class="ph-frame__tl"></span>
          <span class="ph-frame__tr"></span>
          <span class="ph-frame__bl"></span>
          <span class="ph-frame__br"></span>
        </div>

        <p class="ph-reveal-line" aria-label="La terapia puede ayudarte a entender síntomas, regular emociones y tomar decisiones con más margen.">
          {phrase.map((word) => (
            <span data-ph-word>{word}</span>
          ))}
        </p>

        <div class="ph-actions">
          <Button href="#contacto" variant="hero" class="ph-button">
            Solicitar primera sesión
          </Button>
          <a href="#proceso" class="ph-link">
            <span>Ver cómo trabajo</span>
            <i aria-hidden="true"></i>
          </a>
        </div>
      </div>

      <div class="ph-trail" aria-label="Principios del enfoque">
        <div class="ph-trail__line" aria-hidden="true"></div>
        {anchors.map((anchor, index) => (
          <article class="ph-trail__stop reveal-up" style={`transition-delay: ${320 + index * 90}ms`}>
            <span class="ph-stop__num">{anchor.num}</span>
            <h3>{anchor.title}</h3>
            <p>{anchor.text}</p>
          </article>
        ))}
      </div>
    </div>
  </Container>

  <PageNumber number="04" light={true} />
</section>

<style>
  .philosophy {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: var(--section-py--generous) 0 var(--section-py--generous);
    background: var(--color-bg);
    color: var(--color-ink);
  }

  /* ── Background ─────────────────────────────────────────── */
  .ph-bg,
  .ph-bg img,
  .ph-bg__wash,
  .ph-bg__vignette {
    position: absolute;
    inset: 0;
  }

  .ph-bg {
    z-index: 0;
    overflow: hidden;
  }

  .ph-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    filter: grayscale(15%) saturate(0.68) contrast(1.1) brightness(var(--ph-bg-brightness, 0.48));
    transform: scale(var(--ph-bg-scale, 1.08));
    transition: transform 0.18s linear, filter 0.18s linear;
    will-change: transform, filter;
  }

  .ph-bg__wash {
    background:
      radial-gradient(ellipse at 30% 24%, rgba(245, 240, 232, 0.13), transparent 42%),
      radial-gradient(ellipse at 76% 72%, rgba(111, 125, 103, 0.22), transparent 42%),
      linear-gradient(90deg, rgba(12, 9, 7, 0.96) 0%, rgba(12, 9, 7, 0.7) 46%, rgba(12, 9, 7, 0.96) 100%),
      linear-gradient(180deg, rgba(12, 9, 7, 0.8) 0%, rgba(12, 9, 7, 0.54) 46%, rgba(12, 9, 7, 0.92) 100%);
  }

  .ph-bg__vignette {
    box-shadow: inset 0 0 200px 80px rgba(12, 9, 7, 0.55);
    pointer-events: none;
  }

  .philosophy::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(rgba(245, 240, 232, 0.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245, 240, 232, 0.011) 1px, transparent 1px);
    background-size: 8.5rem 8.5rem;
    mask-image: radial-gradient(circle at 50% 48%, #000 0%, transparent 76%);
    opacity: 0.34;
  }

  .ph-shell {
    position: relative;
    z-index: 2;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .ph-header {
    max-width: 52rem;
    margin: 0 auto clamp(2.6rem, 4.5vw, 4rem);
    text-align: center;
  }

  .ph-header h2 {
    max-width: 48rem;
    margin: 1rem auto 1rem;
    font-family: var(--font-display);
    font-size: var(--type-section-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .ph-header p {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: var(--type-lead);
    line-height: 1.78;
    text-wrap: pretty;
  }

  .ph-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.78rem;
    color: var(--color-accent);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .ph-eyebrow::before,
  .ph-eyebrow::after {
    content: '';
    width: 2.35rem;
    height: 1px;
    background: rgba(111, 125, 103, 0.34);
  }

  /* ── Manifesto (editorial quote block) ──────────────────── */
  .ph-manifesto {
    position: relative;
    max-width: 58rem;
    margin: 0 auto clamp(3.2rem, 5.5vw, 4.8rem);
    padding: var(--card-pd-lg) var(--card-pd-md);
    text-align: center;
  }

  .ph-manifesto__frame {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .ph-frame__tl,
  .ph-frame__tr,
  .ph-frame__bl,
  .ph-frame__br {
    position: absolute;
    width: 2.8rem;
    height: 2.8rem;
    border-color: rgba(196, 170, 148, 0.28);
    transition: border-color 0.5s ease;
  }

  .ph-frame__tl {
    top: 0; left: 0;
    border-top: 1px solid;
    border-left: 1px solid;
  }
  .ph-frame__tr {
    top: 0; right: 0;
    border-top: 1px solid;
    border-right: 1px solid;
  }
  .ph-frame__bl {
    bottom: 0; left: 0;
    border-bottom: 1px solid;
    border-left: 1px solid;
  }
  .ph-frame__br {
    bottom: 0; right: 0;
    border-bottom: 1px solid;
    border-right: 1px solid;
  }

  .ph-manifesto:hover .ph-frame__tl,
  .ph-manifesto:hover .ph-frame__tr,
  .ph-manifesto:hover .ph-frame__bl,
  .ph-manifesto:hover .ph-frame__br {
    border-color: rgba(196, 170, 148, 0.48);
  }

  .ph-reveal-line {
    max-width: 34ch;
    margin: 0 auto;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-subsection-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.56;
    letter-spacing: -0.01em;
    text-wrap: pretty;
  }

  .ph-reveal-line span {
    display: inline-block;
    margin-right: 0.18em;
    opacity: var(--ph-word-opacity, 0.22);
    transform: translateY(calc((1 - var(--ph-word-opacity, 0.22)) * 0.28rem));
    transition: opacity 0.18s linear, transform 0.18s linear;
  }

  .ph-actions {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem 1.5rem;
    margin-top: clamp(1.8rem, 3vw, 2.6rem);
    padding-top: clamp(1.2rem, 2vw, 1.6rem);
    border-top: 1px solid rgba(196, 170, 148, 0.2);
  }

  .ph-link {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    min-height: 3rem;
    color: rgba(245, 240, 232, 0.82);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: color 0.25s ease, letter-spacing 0.25s ease;
  }

  .ph-link i {
    width: 2.45rem;
    height: 1px;
    background: rgba(196, 170, 148, 0.42);
    transform-origin: left;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .ph-link:hover {
    color: var(--color-ink);
    letter-spacing: 0.23em;
  }

  .ph-link:hover i {
    transform: scaleX(1.16);
    background: rgba(196, 170, 148, 0.68);
  }

  /* ── Trail (3 stops, no cards) ──────────────────────────── */
  .ph-trail {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 960px;
    margin: 0 auto;
    padding-top: 0.5rem;
  }

  .ph-trail__line {
    position: absolute;
    top: 2.6rem;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(196, 170, 148, 0.22), rgba(196, 170, 148, 0.22), transparent);
    opacity: 0.6;
    pointer-events: none;
  }

  .ph-trail__stop {
    position: relative;
    flex: 1;
    max-width: 280px;
    text-align: center;
    transition: transform 0.45s var(--ease-out-expo);
  }

  .ph-trail__stop:nth-child(2) {
    transform: translateY(-0.4rem);
  }
  .ph-trail__stop:nth-child(4) {
    transform: translateY(0.6rem);
  }

  .ph-trail__stop:hover {
    transform: translateY(-0.25rem);
  }
  .ph-trail__stop:nth-child(2):hover {
    transform: translateY(-0.65rem);
  }
  .ph-trail__stop:nth-child(4):hover {
    transform: translateY(0.35rem);
  }

  .ph-stop__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(3.4rem, 5vw, 4.4rem);
    aspect-ratio: 1;
    margin-bottom: clamp(1.2rem, 2vw, 1.7rem);
    border: 1px solid rgba(196, 170, 148, 0.2);
    border-radius: 50%;
    color: rgba(196, 170, 148, 0.72);
    background: rgba(245, 240, 232, 0.06);
    font-family: var(--font-display);
    font-size: var(--type-lead);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: 0.02em;
    transition:
      transform 0.5s var(--ease-out-expo),
      border-color 0.35s ease,
      background 0.35s ease,
      color 0.35s ease;
  }

  .ph-trail__stop:hover .ph-stop__num {
    transform: scale(1.08);
    border-color: rgba(196, 170, 148, 0.4);
    background: rgba(245, 240, 232, 0.12);
    color: rgba(196, 170, 148, 0.92);
  }

  .ph-trail__stop h3 {
    margin: 0 0 0.55rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-style: italic;
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
    transition: color 0.35s ease;
  }

  .ph-trail__stop:hover h3 {
    color: var(--color-gold);
  }

  .ph-trail__stop p {
    max-width: 24ch;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: var(--type-body-sm);
    line-height: 1.72;
    text-wrap: pretty;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 760px) {
    .philosophy {
      padding: 4.8rem 0 5.8rem;
    }

    .ph-header {
      margin-bottom: 2.2rem;
      padding: 0 4vw;
    }

    .ph-header h2 {
      font-size: var(--type-section-title);
      line-height: 1.02;
      letter-spacing: -0.03em;
    }

    .ph-header p {
      font-size: var(--type-body);
      line-height: 1.65;
    }

    .ph-eyebrow {
      gap: 0.55rem;
      letter-spacing: 0.18em;
    }

    .ph-eyebrow::before,
    .ph-eyebrow::after {
      width: 1.45rem;
    }

    .ph-reveal-line {
      max-width: none;
      font-size: var(--type-card-title);
      line-height: 1.48;
    }

    .ph-manifesto {
      padding: var(--card-pd-sm);
      margin-bottom: 2.6rem;
    }

    .ph-actions {
      margin-top: 1.4rem;
      padding-top: 1rem;
    }

    .ph-trail {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
      padding-top: 0;
    }

    .ph-trail__line {
      display: none;
    }

    .ph-trail__stop {
      max-width: 28rem;
    }

    .ph-trail__stop:nth-child(2),
    .ph-trail__stop:nth-child(4) {
      transform: none;
    }

    .ph-trail__stop:hover,
    .ph-trail__stop:nth-child(2):hover,
    .ph-trail__stop:nth-child(4):hover {
      transform: none;
    }

    .ph-stop__num {
      margin-bottom: 0.9rem;
      width: clamp(3rem, 8vw, 3.8rem);
      font-size: var(--type-small);
    }

    .ph-trail__stop h3 {
      font-size: var(--type-card-title);
    }

    .ph-trail__stop p {
      font-size: var(--type-card-body);
      line-height: 1.6;
    }
  }

  @media (max-width: 540px) {
    .ph-actions {
      align-items: stretch;
      flex-direction: column;
      width: 100%;
      gap: 0.7rem;
    }

    .ph-actions :global(.ph-button) {
      width: 100%;
      min-height: 2.9rem;
      font-size: var(--type-meta);
      letter-spacing: 0.16em;
    }

    .ph-link {
      justify-content: space-between;
      width: 100%;
      min-height: 2.8rem;
      font-size: var(--type-meta);
      letter-spacing: 0.18em;
    }

    .ph-manifesto {
      padding: 1.4rem 1rem;
    }

    .ph-frame__tl,
    .ph-frame__tr,
    .ph-frame__bl,
    .ph-frame__br {
      width: 1.4rem;
      height: 1.4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ph-bg img,
    .ph-reveal-line span,
    .ph-trail__stop,
    .ph-stop__num {
      transition: none !important;
    }

    .ph-trail__stop:hover,
    .ph-trail__stop:nth-child(2):hover,
    .ph-trail__stop:nth-child(4):hover {
      transform: none;
    }
  }
</style>

<script>
  const philosophy = document.querySelector('[data-philosophy]');

  if (philosophy) {
    const words = Array.from(philosophy.querySelectorAll('[data-ph-word]'));
    const image = philosophy.querySelector('.ph-bg img');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

    const updateMotion = () => {
      if (reduceMotion) {
        words.forEach((word) => word.style.setProperty('--ph-word-opacity', '1'));
        image?.style.setProperty('--ph-bg-scale', '1.08');
        image?.style.setProperty('--ph-bg-brightness', '0.5');
        return;
      }

      const rect = philosophy.getBoundingClientRect();
      const progress = clamp((window.innerHeight * 0.78 - rect.top) / (rect.height * 0.7), 0, 1);

      words.forEach((word, index) => {
        const start = index / words.length;
        const opacity = clamp((progress - start * 0.72) * 4.4, 0.22, 1);
        word.style.setProperty('--ph-word-opacity', opacity.toFixed(3));
      });

      if (image) {
        image.style.setProperty('--ph-bg-scale', (1.08 + progress * 0.045).toFixed(3));
        image.style.setProperty('--ph-bg-brightness', (0.46 + progress * 0.08).toFixed(3));
      }
    };

    let ticking = false;
    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateMotion();
          ticking = false;
        });
        ticking = true;
      }
    };

    updateMotion();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
  }
</script>
