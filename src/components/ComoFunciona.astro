---
import SectionHeader from './ui/SectionHeader.astro';
import CardSurface from './ui/CardSurface.astro';
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';
import InkBlob from './ui/InkBlob.astro';
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';

const pasos = [
  {
    numero: "01",
    titulo: "Primer contacto",
    descripcion: "Comenzamos con una primera conversación para conocer el motivo de consulta, revisar desde cuándo ocurre y valorar qué enfoque puede encajar mejor."
  },
  {
    numero: "02",
    titulo: "Evaluación específica",
    descripcion: "Exploramos el origen de lo que te sucede, los factores que lo mantienen y los recursos que ya tienes para definir un camino de trabajo realista."
  },
  {
    numero: "03",
    titulo: "Intervención y trabajo",
    descripcion: "Trabajamos de forma estructurada con herramientas adaptadas a tu caso para que puedas regularte mejor, comprender tus patrones y avanzar con más autonomía."
  }
];
---

<section id="como-trabajo" class="como-funciona" data-como-funciona>
  <GrainOverlay opacity={0.02} />
  <AmbientLight color="rgba(196,170,148,0.04)" />
  <DustParticles count={12} color="rgba(196,170,148,0.15)" />

  <!-- Ambient orbs -->
  <FloatOrb size={450} top="-10%" right="-10%" color="var(--sage-muted)" blur={120} opacity={0.25} animation="float-1" />
  <FloatOrb size={300} bottom="-5%" left="-5%" color="var(--gold-soft)" opacity={0.3} animation="float-2" />

  <!-- Ink blobs -->
  <InkBlob width={400} height={350} top="30%" left="-10%" color="var(--earth)" opacity={0.03} animation="morph-blob" />

  <div class="cf-watermark" aria-hidden="true">
    <span class="watermark-text">Ruta</span>
  </div>

  <Container maxWidth="1480px" padding="0 var(--content-padding-x)">
    <SectionHeader
      eyebrow="El proceso"
      title={['Una ruta clara', 'hacia el bienestar']}
      subtitle="Un camino estructurado y transparente para que entiendas qué estamos trabajando, por qué y con qué objetivo."
      variant="ornamented"
      align="center"
      index="04"
      class="reveal-blur"
    />

    <div class="cf-timeline">
      <div class="cf-timeline-track" aria-hidden="true">
        <div class="cf-timeline-progress"></div>
      </div>

      <div class="cf-steps">
        {pasos.map((paso, i) => (
          <div class={`cf-step cf-step--${i % 2 === 0 ? 'left' : 'right'} reveal-up`} style={`transition-delay: ${100 + i * 200}ms`}>
            <div class="cf-step-node" aria-hidden="true">
              <div class="node-ring"></div>
              <div class="node-dot"></div>
            </div>

            <CardSurface watermark={paso.numero} class="cf-card" hoverable={true}>
              <div class="cf-card-glow" aria-hidden="true"></div>
              <div class="cf-card-inner">
                <span class="cf-card-num" aria-hidden="true">{paso.numero}</span>
                <div class="cf-card-content">
                  <span class="cf-card-label">Paso {paso.numero}</span>
                  <h3 class="cf-card-title">{paso.titulo}</h3>
                  <p class="cf-card-desc">{paso.descripcion}</p>
                </div>
              </div>
            </CardSurface>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>

<style>
  .como-funciona {
    position: relative;
    width: 100%;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 70% 30%, rgba(196,170,148,0.05) 0%, transparent 60%),
      radial-gradient(ellipse at 30% 70%, rgba(107,125,106,0.04) 0%, transparent 50%),
      var(--parchment);
    padding: 10rem 0 12rem;
  }

  .cf-watermark {
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    user-select: none;
    width: 100%;
    text-align: center;
  }
  .watermark-text {
    font-family: var(--font-display);

    font-weight: 400;
    font-size: var(--type-decorative-xl);
    color: var(--earth);
    opacity: 0.015;
    line-height: 1;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  /* Timeline */
  .cf-timeline {
    position: relative;
    margin-top: 5rem;
    z-index: 2;
    padding: 2rem 0;
  }

  .cf-timeline-track {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    background: rgba(196,170,148,0.15);
  }
  .cf-timeline-progress {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform: scaleY(0);
    transform-origin: top;
    background: linear-gradient(180deg, var(--sage-dark) 0%, transparent 100%);
    transition: transform 1.5s var(--ease-out-expo);
  }
  .como-funciona.visible .cf-timeline-progress {
    transform: scaleY(1);
  }

  .cf-steps {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    position: relative;
  }

  .cf-step {
    position: relative;
    width: calc(50% - 3rem);
    display: flex;
    flex-direction: column;
  }
  .cf-step--left {
    align-self: flex-start;
    text-align: right;
  }
  .cf-step--right {
    align-self: flex-end;
    text-align: left;
  }

  /* Node */
  .cf-step-node {
    position: absolute;
    top: 3rem;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
  }
  .cf-step--left .cf-step-node {
    right: -3rem;
    transform: translateX(50%);
  }
  .cf-step--right .cf-step-node {
    left: -3rem;
    transform: translateX(-50%);
  }

  .node-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(196,170,148,0.25);
    background: var(--parchment);
    transition: transform 0.6s var(--ease-out-expo), border-color 0.4s ease;
  }
  .node-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sage-dark);
    opacity: 0.5;
    transition: transform 0.6s var(--ease-out-expo), opacity 0.4s ease;
  }
  .cf-step:hover .node-ring {
    transform: scale(1.3);
    border-color: rgba(107,125,106,0.3);
  }
  .cf-step:hover .node-dot {
    transform: scale(1.2);
    opacity: 1;
  }

  /* Card */
  .cf-card {
    padding: 3rem;
    border-radius: 3px;
    position: relative;
    overflow: hidden;
    transition: transform 0.6s var(--ease-out-expo), box-shadow 0.6s ease;
  }
  .cf-step:hover .cf-card {
    transform: translateY(-5px);
    box-shadow: 
      0 12px 32px rgba(0,0,0,0.04),
      0 0 0 1px rgba(107,125,106,0.06) inset;
  }
  
  .cf-card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(196,170,148,0.04) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
    z-index: 0;
  }
  .cf-step:hover .cf-card-glow {
    opacity: 1;
  }

  .cf-card-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .cf-step--left .cf-card-inner {
    align-items: flex-end;
  }
  .cf-step--right .cf-card-inner {
    align-items: flex-start;
  }

  .cf-card-num {
    font-family: var(--font-display);

    font-weight: 400;
    font-size: var(--type-decorative-lg);
    color: var(--earth);
    opacity: 0.08;
    line-height: 1;
    margin-bottom: -1.5rem;
    transition: opacity 0.5s ease, transform 0.5s var(--ease-out-expo), color 0.5s ease;
  }
  .cf-step:hover .cf-card-num {
    opacity: 0.15;
    color: var(--sage-dark);
    transform: translateY(-4px);
  }

  .cf-card-content {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .cf-card-label {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--taupe);
    opacity: 0.5;
  }

  .cf-card-title {
    font-family: var(--font-display);

    font-weight: 400;
    font-size: var(--type-subsection-title);
    color: var(--ink);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
    transition: color 0.4s ease;
  }
  .cf-step:hover .cf-card-title {
    color: var(--earth);
  }

  .cf-card-desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: var(--type-small);
    line-height: 1.7;
    color: var(--ink-soft);
    opacity: 0.8;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .cf-timeline-track {
      left: 1.5rem;
    }
    .cf-step {
      width: calc(100% - 4rem);
      align-self: flex-end;
      text-align: left;
    }
    .cf-step--left .cf-step-node,
    .cf-step--right .cf-step-node {
      left: -2.5rem;
      right: auto;
      transform: translateX(-50%);
    }
    .cf-step--left .cf-card-inner {
      align-items: flex-start;
    }
    .cf-card {
      padding: 2.5rem 2rem;
    }
  }

  @media (max-width: 600px) {
    .como-funciona {
      padding: 8rem 0 10rem;
    }
    .cf-timeline-track {
      left: 1rem;
    }
    .cf-step {
      width: calc(100% - 3rem);
    }
    .cf-step--left .cf-step-node,
    .cf-step--right .cf-step-node {
      left: -2rem;
    }
    .cf-card {
      padding: 2rem 1.5rem;
    }
    .cf-card-num {
      font-size: var(--type-section-title-sm);
    }
    .cf-card-title {
      font-size: var(--type-card-title);
    }
    .cf-steps {
      gap: 2.5rem;
    }
  }
</style>
