---
import Container from './ui/Container.astro';
import AmbientLight from './ui/AmbientLight.astro';
import DustParticles from './ui/DustParticles.astro';
import GrainOverlay from './ui/GrainOverlay.astro';

const pasos = [
  {
    numero: "01",
    titulo: "Primer contacto",
    descripcion: "Comenzamos con una primera sesión para conocerte, entender qué te preocupa y ver cómo puedo ayudarte. Es un espacio sin compromiso, donde tú decides si quieres continuar."
  },
  {
    numero: "02",
    titulo: "Evaluación específica",
    descripcion: "Exploramos juntos el origen de lo que te sucede. Utilizo herramientas diagnósticas validadas para entender mejor tu situación y definir el camino a seguir."
  },
  {
    numero: "03",
    titulo: "Intervención y trabajo",
    descripcion: "Trabajamos de forma estructurada para que puedas gestionar lo que te resulta difícil. Mi objetivo es que adquieras las herramientas que necesitas para sentirte mejor y seguir adelante con autonomía."
  }
];
---

<section id="como-trabajo" class="relative py-32 md:py-40 lg:py-52 bg-base overflow-hidden paper-texture">
  <GrainOverlay opacity={0.02} />
  <AmbientLight color="rgba(196,170,148,0.04)" />
  <DustParticles count={10} color="rgba(196,170,148,0.15)" />
  <Container maxWidth="1240px">
    <!-- Section Header -->
    <div class="mb-20 md:mb-28 reveal">
      <p class="section-label mb-6">El proceso</p>
      <hr class="divider-draw mb-14 reveal" />
      <h2 class="section-title text-text-primary">
        <span class="section-title__kicker block font-body font-light">
          Una ruta clara hacia el
        </span>
        <span class="section-title__main block font-display italic text-accent mt-1">
          bienestar
        </span>
      </h2>
    </div>

    <!-- Steps Grid -->
    <div class="relative grid md:grid-cols-3 gap-12 md:gap-8 lg:gap-12">
      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-[5rem] left-[16%] right-[16%] h-px bg-border" aria-hidden="true"></div>

      {pasos.map((paso, i) => (
        <div class="relative group reveal" style={`transition-delay: ${0.1 + i * 0.14}s`}>
          <!-- Giant decorative number -->
          <span class="step-giant-num" aria-hidden="true">{paso.numero}</span>

          <!-- Content -->
          <div class="relative z-10 md:pt-4">
            <span class="step-label">Paso {paso.numero}</span>
            <h3 class="step-title">{paso.titulo}</h3>
            <p class="step-desc">{paso.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>

<style>
  .step-giant-num {
    position: absolute;
    top: -1.5rem;
    left: -0.5rem;
    font-family: var(--font-display);
    font-size: clamp(6rem, 12vw, 10rem);
    font-weight: 300;
    line-height: 1;
    color: var(--accent);
    opacity: 0.045;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .section-title__kicker {
    font-size: var(--type-section-kicker);
    line-height: 1.15;
    letter-spacing: 0;
  }
  .section-title__main {
    font-size: var(--type-section-title);
    font-weight: 400;
    line-height: var(--leading-title);
    letter-spacing: 0;
  }

  .step-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: var(--type-card-title);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: 1rem;
    transition: color 0.4s ease;
  }
  .group:hover .step-title {
    color: var(--accent);
  }

  .step-desc {
    font-family: var(--font-body);
    font-size: var(--type-card-body);
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .step-giant-num {
      top: -1rem;
      left: -0.25rem;
      font-size: 5rem;
    }
  }
</style>
