---
import GrainOverlay from './ui/GrainOverlay.astro';
import FloatOrb from './ui/FloatOrb.astro';

const links = [
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Blog', href: '#blog' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header class="nav-root" id="navRoot">
  <div class="nav-island" id="navIsland">
    <!-- Warm ambient glow behind scrolled island -->
    <div class="island-glow" aria-hidden="true"></div>

    <!-- Logo -->
    <a href="#inicio" class="nav-mark" aria-label="Inicio" data-nav-reveal>
      <span class="mark-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
          <path d="M14 2C14 2 9 7 9 13c0 3 2 5.5 5 6.5V26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M14 2C14 2 19 7 19 13c0 3-2 5.5-5 6.5V26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M14 19.5c-2-1.5-4.5-3-4.5-6.5 0-2.5 2-5 2-5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/>
          <path d="M14 19.5c2-1.5 4.5-3 4.5-6.5 0-2.5-2-5-2-5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/>
        </svg>
      </span>
      <span class="mark-text">Lucía</span>
    </a>

    <!-- Desktop Links -->
    <nav class="nav-links" aria-label="Principal" id="navLinks">
      {links.map((l, i) => (
        <a href={l.href} class="nav-link" data-nav-link data-nav-reveal style={`transition-delay: ${i * 60 + 200}ms`}>
          <span class="link-text">{l.label}</span>
          <span class="link-track" aria-hidden="true">
            <span class="link-fill"></span>
          </span>
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <a href="#contacto" class="nav-cta" data-nav-reveal style="transition-delay: 500ms">
      <span class="cta-text">Reservar</span>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M1 6h10M6 1l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <!-- Mobile Trigger -->
    <button class="nav-trigger" id="menuTrigger" aria-label="Abrir menú" aria-expanded="false" data-nav-reveal>
      <span class="trigger-line"></span>
      <span class="trigger-line"></span>
    </button>
  </div>

  <!-- Scroll progress hairline -->
  <div class="scroll-hairline" aria-hidden="true">
    <div class="hairline-fill" id="hairlineFill"></div>
  </div>

  <!-- Mobile Overlay -->
  <div class="nav-overlay" id="menuOverlay" aria-hidden="true">
    <div class="overlay-bg" aria-hidden="true">
      <div class="overlay-bg__layer"></div>
      <div class="overlay-bg__layer"></div>
      <div class="overlay-bg__layer"></div>
    </div>
    <div class="overlay-vignette" aria-hidden="true"></div>
    <GrainOverlay opacity={0.015} zIndex={1} />
    <FloatOrb size={300} top="15%" right="10%" color="rgba(196,170,148,0.06)" blur={100} animation="float-1" />
    <FloatOrb size={220} bottom="20%" left="5%" color="rgba(111,125,103,0.05)" blur={90} animation="float-2" />

    <div class="overlay-content">
      <nav class="overlay-nav" aria-label="Principal">
        {links.map((l, i) => (
          <a href={l.href} class="overlay-link" style={`transition-delay: ${i * 80 + 350}ms`}>
            <span class="link-num">0{i + 1}</span>
            <span class="link-label">{l.label}</span>
            <span class="link-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <path d="M4 10h12M10 4l6 6-6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </nav>

      <div class="overlay-footer">
        <a href="#contacto" class="overlay-cta">
          <span>Pide tu primera sesión</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="overlay-divider" aria-hidden="true"></div>
        <div class="overlay-meta">
          <span>lucia@psicologia.es</span>
          <span class="meta-sep">·</span>
          <span>+34 600 000 000</span>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const trigger = document.getElementById('menuTrigger');
  const overlay = document.getElementById('menuOverlay');
  const navLinks = overlay.querySelectorAll('.overlay-link');
  const navRoot = document.getElementById('navRoot');
  const navDesktopLinks = document.querySelectorAll('[data-nav-link]');
  const hairlineFill = document.getElementById('hairlineFill');

  // Menu toggle
  function openMenu() {
    overlay.classList.add('open');
    trigger.classList.add('open');
    trigger.setAttribute('aria-expanded', 'true');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    navRoot.classList.add('menu-open');
  }
  function closeMenu() {
    overlay.classList.remove('open');
    trigger.classList.remove('open');
    trigger.setAttribute('aria-expanded', 'false');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    navRoot.classList.remove('menu-open');
  }
  trigger.addEventListener('click', () => {
    overlay.classList.contains('open') ? closeMenu() : openMenu();
  });
  navLinks.forEach(l => l.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('open')) closeMenu();
  });
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay || e.target.classList.contains('overlay-bg')) closeMenu();
  });

  // ── Smart hide / show on scroll direction ──────────────────
  let lastScrollY = window.scrollY;
  let ticking = false;
  const topThreshold = 80;
  const hideThreshold = 140;

  function handleScroll() {
    const currentScrollY = window.scrollY;
    const scrollingDown = currentScrollY > lastScrollY;
    const scrollingUp = currentScrollY < lastScrollY;
    const pastTop = currentScrollY > topThreshold;

    if (!pastTop) {
      navRoot.classList.remove('is-hidden', 'is-visible');
    } else {
      if (scrollingDown && currentScrollY > hideThreshold) {
        navRoot.classList.add('is-hidden');
        navRoot.classList.remove('is-visible');
      }
      if (scrollingUp) {
        navRoot.classList.add('is-visible');
        navRoot.classList.remove('is-hidden');
      }
    }

    // Hairline progress
    if (hairlineFill) {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (currentScrollY / docHeight) * 100 : 0;
      hairlineFill.style.width = progress + '%';
    }

    lastScrollY = currentScrollY;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(handleScroll);
      ticking = true;
    }
  }, { passive: true });
  handleScroll();

  // Active section tracking
  const sections = ['#inicio', '#sobre-mi', '#servicios', '#proceso', '#blog', '#contacto'];
  const sectionElements = sections.map(s => document.querySelector(s)).filter(Boolean);

  function updateActiveLink() {
    const scrollPos = window.scrollY + 200;
    let activeSection = '#inicio';
    sectionElements.forEach(section => {
      if (section.offsetTop <= scrollPos) {
        activeSection = '#' + section.id;
      }
    });
    navDesktopLinks.forEach(link => {
      const href = link.getAttribute('href');
      link.classList.toggle('active', href === activeSection);
    });
  }
  window.addEventListener('scroll', updateActiveLink, { passive: true });
  updateActiveLink();

  // Entrance reveal
  const revealEls = document.querySelectorAll('[data-nav-reveal]');
  revealEls.forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(12px)';
    const delay = parseFloat(el.style.transitionDelay) || (i * 60);
    setTimeout(() => {
      el.style.transition = 'opacity 0.9s var(--ease-out-expo), transform 0.9s var(--ease-out-expo), color 0.6s ease';
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, 200 + delay);
  });
</script>

<style>
  /* ═══════════════════════════════════════════════════════════
     NAVIGATION — Chameleon Island
     Transparent over hero, warm glass over content.
     Color-inverts seamlessly as user scrolls.
     ═══════════════════════════════════════════════════════════ */

  .nav-root {
    --nav-cream: #f5f0e8;
    --nav-ink: #2f2d28;
    --nav-ink-soft: #49463f;
    --nav-sage: #6f7d67;
    --nav-sage-deep: #56645a;
    --nav-gold: #b8a88a;
    --nav-gold-soft: rgba(184, 168, 138, 0.14);
    --nav-line: rgba(111, 125, 103, 0.14);
    --nav-line-soft: rgba(111, 125, 103, 0.08);

    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 900;
    display: flex;
    justify-content: center;
    padding: clamp(14px, 2vw, 22px) 3vw;
    pointer-events: none;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .nav-root.is-hidden {
    transform: translateY(calc(-100% - 40px));
  }

  .nav-root.is-visible {
    transform: translateY(0);
  }

  /* Prevent island from hiding when menu is open */
  .nav-root.menu-open {
    transform: translateY(0) !important;
  }

  /* ── Island ───────────────────────────────────────────────── */
  .nav-island {
    pointer-events: auto;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    width: min(1280px, 94vw);
    min-height: 64px;
    padding: 0.55rem 2.2rem;
    border-radius: 22px;
    transition:
      background 0.7s ease,
      backdrop-filter 0.7s ease,
      box-shadow 0.7s ease,
      border-color 0.7s ease,
      min-height 0.55s var(--ease-out-expo),
      padding 0.55s var(--ease-out-expo),
      gap 0.55s var(--ease-out-expo),
      width 0.6s var(--ease-out-expo),
      border-radius 0.6s var(--ease-out-expo);
  }

  /* At top: transparent, light text for dark hero */
  .nav-root:not(.is-visible):not(.menu-open) .nav-island {
    background: transparent;
    border: 1px solid transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Scrolled: warm cream glass with ink text */
  .nav-root.is-visible .nav-island,
  .nav-root.menu-open .nav-island {
    width: min(720px, 90vw);
    min-height: 0;
    padding: 0.5rem 0.55rem 0.5rem 0.9rem;
    gap: 1.1rem;
    border-radius: 100px;
    background: rgba(251, 248, 241, 0.82);
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    border: 1px solid var(--nav-line);
    box-shadow:
      0 8px 32px rgba(47, 45, 40, 0.06),
      0 2px 8px rgba(47, 45, 40, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  /* Warm ambient glow behind scrolled island */
  .island-glow {
    position: absolute;
    inset: -60% -30%;
    border-radius: 50%;
    background: radial-gradient(ellipse at 50% 50%, rgba(184, 168, 138, 0.1) 0%, transparent 60%);
    pointer-events: none;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.9s ease, transform 0.9s ease;
    z-index: -1;
  }
  .nav-root.is-visible .island-glow,
  .nav-root.menu-open .island-glow {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Logo ─────────────────────────────────────────────────── */
  .nav-mark {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    transition: opacity 0.35s ease;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .nav-mark:hover { opacity: 0.72; }

  .mark-icon {
    color: rgba(245, 240, 232, 0.85);
    transition: color 0.5s ease, transform 0.5s var(--ease-out-expo);
    display: flex;
    align-items: center;
  }
  .nav-mark:hover .mark-icon {
    transform: rotate(10deg) scale(1.08);
  }
  /* Scrolled: ink color */
  .nav-root.is-visible .mark-icon,
  .nav-root.menu-open .mark-icon {
    color: rgba(47, 45, 40, 0.7);
  }

  .mark-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--type-card-title-sm);
    color: rgba(245, 240, 232, 0.95);
    letter-spacing: 0.02em;
    line-height: 1;
    transition: color 0.5s ease, text-shadow 0.5s ease;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.2);
  }
  /* Scrolled: ink color, no shadow */
  .nav-root.is-visible .mark-text,
  .nav-root.menu-open .mark-text {
    color: var(--nav-ink);
    text-shadow: none;
  }

  /* ── Desktop Links ────────────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.2rem;
    transition: gap 0.55s var(--ease-out-expo);
  }
  .nav-root.is-visible .nav-links {
    gap: 1.2rem;
  }

  .nav-link {
    position: relative;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
    padding: 6px 0;
    text-decoration: none;
    transition: color 0.5s ease;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.18);
  }
  .nav-link:hover,
  .nav-link.active {
    color: rgba(245, 240, 232, 0.95);
  }
  /* Scrolled: ink colors */
  .nav-root.is-visible .nav-link {
    color: rgba(47, 45, 40, 0.6);
    text-shadow: none;
  }
  .nav-root.is-visible .nav-link:hover,
  .nav-root.is-visible .nav-link.active {
    color: var(--nav-ink);
  }

  /* Elegant underline track */
  .link-track {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%;
    height: 1px;
    background: rgba(196, 170, 148, 0.12);
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.4s ease, background 0.4s ease;
  }
  .nav-root.is-visible .link-track {
    background: rgba(111, 125, 103, 0.12);
  }
  .nav-link:hover .link-track,
  .nav-link.active .link-track {
    opacity: 1;
  }
  .link-fill {
    display: block;
    width: 100%; height: 100%;
    background: rgba(196, 170, 148, 0.55);
    transform: translateX(-101%);
    transition: transform 0.55s var(--ease-out-expo), background 0.4s ease;
  }
  .nav-root.is-visible .link-fill {
    background: var(--nav-sage);
  }
  .nav-link:hover .link-fill,
  .nav-link.active .link-fill {
    transform: translateX(0);
  }

  /* ── CTA ──────────────────────────────────────────────────── */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 9px 20px;
    background: rgba(245, 240, 232, 0.08);
    border: 1px solid rgba(196, 170, 148, 0.2);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.92);
    text-decoration: none;
    transition: all 0.5s var(--ease-out-expo);
    flex-shrink: 0;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.12);
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
  .nav-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(245, 240, 232, 0.06);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .nav-cta:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }
  .nav-cta:hover {
    background: rgba(245, 240, 232, 0.14);
    border-color: rgba(196, 170, 148, 0.35);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.14);
  }
  /* Scrolled: sage gradient CTA */
  .nav-root.is-visible .nav-cta {
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.92), rgba(86, 100, 90, 0.92));
    border-color: rgba(111, 125, 103, 0.3);
    color: #fbf8f1;
    text-shadow: none;
    box-shadow: 0 4px 16px rgba(86, 100, 90, 0.12);
  }
  .nav-root.is-visible .nav-cta::before {
    background: rgba(255, 255, 255, 0.08);
  }
  .nav-root.is-visible .nav-cta:hover {
    background: linear-gradient(180deg, rgba(111, 125, 103, 1), rgba(86, 100, 90, 1));
    border-color: rgba(111, 125, 103, 0.45);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(86, 100, 90, 0.18);
  }
  .nav-cta svg {
    position: relative;
    z-index: 1;
    transition: transform 0.4s var(--ease-out-expo);
    color: rgba(196, 170, 148, 0.5);
  }
  .nav-cta:hover svg {
    transform: translateX(2px);
    color: rgba(196, 170, 148, 0.8);
  }
  .nav-root.is-visible .nav-cta svg {
    color: rgba(251, 248, 241, 0.7);
  }

  /* ── Scroll hairline ──────────────────────────────────────── */
  .scroll-hairline {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 1px;
    background: rgba(196, 170, 148, 0.04);
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .nav-root.is-visible .scroll-hairline {
    opacity: 1;
  }
  .hairline-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--nav-sage), rgba(111, 125, 103, 0.2));
    transition: width 0.1s linear;
  }

  /* ── Mobile Trigger ───────────────────────────────────────── */
  .nav-trigger {
    display: none;
    width: 40px; height: 40px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
    z-index: 902;
    background: none;
    border: none;
    flex-shrink: 0;
    position: relative;
  }
  .trigger-line {
    display: block;
    width: 22px; height: 1.2px;
    background: rgba(245, 240, 232, 0.75);
    transition: transform 0.45s var(--ease-out-expo), opacity 0.25s ease, background 0.5s ease;
    border-radius: 1px;
  }
  .nav-root.is-visible .trigger-line {
    background: rgba(47, 45, 40, 0.55);
  }
  .nav-trigger.open .trigger-line:first-child {
    transform: translateY(3.6px) rotate(45deg);
    background: rgba(245, 240, 232, 0.8);
  }
  .nav-trigger.open .trigger-line:last-child {
    transform: translateY(-3.6px) rotate(-45deg);
    background: rgba(245, 240, 232, 0.8);
  }

  /* ── Mobile Overlay ───────────────────────────────────────── */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 901;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.85s ease, visibility 0.85s ease;
    pointer-events: none;
    overflow: hidden;
  }
  .nav-overlay.open {
    opacity: 1;
    visibility: visible;
    pointer-events: all;
  }

  .overlay-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .overlay-bg__layer {
    position: absolute;
    inset: 0;
    background: #16120f;
    transform: translateY(-101%);
    transition: transform 0.85s var(--ease-out-expo);
  }
  .overlay-bg__layer:nth-child(2) { background: rgba(22, 18, 15, 0.97); transition-delay: 0.04s; }
  .overlay-bg__layer:nth-child(3) { background: rgba(42, 31, 26, 0.92); transition-delay: 0.08s; }
  .nav-overlay.open .overlay-bg__layer { transform: translateY(0); }
  .nav-overlay.open .overlay-bg__layer:nth-child(2) { transition-delay: 0.08s; }
  .nav-overlay.open .overlay-bg__layer:nth-child(3) { transition-delay: 0.16s; }

  .overlay-vignette {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 150px 60px rgba(13, 10, 8, 0.45);
    z-index: 1;
    pointer-events: none;
  }

  .overlay-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 100px 5vw 60px;
  }

  .overlay-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    margin-bottom: auto;
  }
  .overlay-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.55rem 0;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo), color 0.3s ease;
    text-decoration: none;
  }
  .nav-overlay.open .overlay-link {
    opacity: 1;
    transform: translateY(0);
  }
  .overlay-link:hover .link-label { color: rgba(196, 170, 148, 0.85); }
  .overlay-link:hover .link-arrow { opacity: 1; transform: translateX(0); }

  .link-num {
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.18);
    transform: translateY(-0.3em);
    min-width: 20px;
  }
  .link-label {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    color: rgba(245, 240, 232, 0.9);
