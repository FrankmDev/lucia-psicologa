---
const links = [
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Blog', href: '#blog' },
  { label: 'Contacto', href: '#contacto' },
];

const isHome = Astro.url.pathname === '/';
const resolveHref = (href: string) => (isHome ? href : `/${href}`);
---

<header class="nav-root" id="navRoot">
  <div class="nav-island" id="navIsland">
    <!-- Warm ambient glow behind scrolled island -->
    <div class="island-glow" aria-hidden="true"></div>

    <!-- Logo -->
    <a href={isHome ? '#inicio' : '/'} class="nav-mark" aria-label="Inicio" data-nav-reveal>
      <img src="/logo-white.webp" alt="Lucía" class="mark-logo mark-logo--dark" width="auto" height="32" />
      <img src="/logo-dark.webp" alt="Lucía" class="mark-logo mark-logo--light" width="auto" height="32" />
    </a>

    <!-- Desktop Links -->
    <nav class="nav-links" aria-label="Principal" id="navLinks">
      {links.map((l, i) => (
        <a href={resolveHref(l.href)} class="nav-link" data-nav-link data-nav-reveal style={`transition-delay: ${i * 60 + 200}ms`}>
          <span class="link-text">{l.label}</span>
          <span class="link-track" aria-hidden="true">
            <span class="link-fill"></span>
          </span>
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <a href={resolveHref('#contacto')} class="nav-cta" data-nav-reveal style="transition-delay: 500ms">
      <span class="cta-text">Reservar</span>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M1 6h10M6 1l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <!-- Mobile Trigger -->
    <button class="nav-trigger" id="menuTrigger" aria-label="Abrir menú" aria-expanded="false" data-nav-reveal>
      <span class="trigger-line"></span>
      <span class="trigger-line"></span>
      <span class="trigger-line"></span>
    </button>
  </div>

  <!-- Scroll progress hairline -->
  <div class="scroll-hairline" aria-hidden="true">
    <div class="hairline-fill" id="hairlineFill"></div>
  </div>

    <!-- Mobile Overlay -->
  <div class="nav-overlay" id="menuOverlay" aria-hidden="true">
    <div class="overlay-backdrop" aria-hidden="true"></div>

    <div class="overlay-card">
      <div class="overlay-grain" aria-hidden="true"></div>
      <div class="overlay-card__inner">
        
        <!-- Ornamental Divider -->
        <div class="overlay-divider" aria-hidden="true">
          <span class="divider-line"></span>
          <span class="divider-dot"></span>
          <span class="divider-line"></span>
        </div>

        <!-- Navigation -->
        <nav class="overlay-nav" aria-label="Principal">
          {links.map((l, i) => (
            <a href={resolveHref(l.href)} class="overlay-link" style={`transition-delay: ${i * 65 + 140}ms`}>
              <span class="link-number">0{i + 1}</span>
              <span class="link-label">{l.label}</span>
              <span class="link-arrow" aria-hidden="true">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M1 5h8M5 1l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </nav>

        <!-- Services Mini-Cards -->
        <div class="overlay-services" aria-hidden="true">
          <span class="services-heading">Modalidades</span>
          <div class="services-grid">
            <div class="service-chip">
              <span class="service-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </span>
              <span>Terapia Individual</span>
            </div>
            <div class="service-chip">
              <span class="service-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                  <line x1="8" y1="21" x2="16" y2="21"/>
                  <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
              </span>
              <span>Online</span>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="overlay-footer">
          <div class="footer-divider" aria-hidden="true">
            <span class="divider-line"></span>
            <span class="divider-dot"></span>
            <span class="divider-line"></span>
          </div>
          <a href={resolveHref('#contacto')} class="overlay-cta">
            <span>Contactar</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="overlay-meta">
            <span class="meta-item">luciamillanpsico@gmail.com</span>
            <span class="meta-sep">·</span>
            <span class="meta-item">722535914</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const trigger = document.getElementById('menuTrigger');
  const overlay = document.getElementById('menuOverlay');
  const navLinks = overlay.querySelectorAll('.overlay-link');
  const navRoot = document.getElementById('navRoot');
  const navDesktopLinks = document.querySelectorAll('[data-nav-link]');
  const hairlineFill = document.getElementById('hairlineFill');

  // Menu toggle
  function openMenu() {
    overlay.classList.add('open');
    trigger.classList.add('open');
    trigger.setAttribute('aria-expanded', 'true');
    trigger.setAttribute('aria-label', 'Cerrar menú');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    navRoot.classList.add('menu-open');
  }
  function closeMenu() {
    overlay.classList.remove('open');
    trigger.classList.remove('open');
    trigger.setAttribute('aria-expanded', 'false');
    trigger.setAttribute('aria-label', 'Abrir menú');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    navRoot.classList.remove('menu-open');
  }
  trigger.addEventListener('click', () => {
    overlay.classList.contains('open') ? closeMenu() : openMenu();
  });
  navLinks.forEach(l => l.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('open')) closeMenu();
  });
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay || e.target.classList.contains('overlay-backdrop')) closeMenu();
  });

  // ── Smart hide / show on scroll direction ──────────────────
  let lastScrollY = window.scrollY;
  let ticking = false;
  const topThreshold = 80;
  const hideThreshold = 140;

  function handleScroll() {
    const currentScrollY = window.scrollY;
    const scrollingDown = currentScrollY > lastScrollY;
    const scrollingUp = currentScrollY < lastScrollY;
    const pastTop = currentScrollY > topThreshold;

    if (!pastTop) {
      navRoot.classList.remove('is-hidden', 'is-visible');
    } else {
      if (scrollingDown && currentScrollY > hideThreshold) {
        navRoot.classList.add('is-hidden');
        navRoot.classList.remove('is-visible');
      }
      if (scrollingUp) {
        navRoot.classList.add('is-visible');
        navRoot.classList.remove('is-hidden');
      }
    }

    // Hairline progress
    if (hairlineFill) {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (currentScrollY / docHeight) * 100 : 0;
      hairlineFill.style.transform = 'scaleX(' + (progress / 100) + ')';
    }

    lastScrollY = currentScrollY;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(handleScroll);
      ticking = true;
    }
  }, { passive: true });
  handleScroll();

  // Active section tracking
  const sections = ['#inicio', '#sobre-mi', '#servicios', '#proceso', '#blog', '#contacto'];
  const sectionElements = sections.map(s => document.querySelector(s)).filter(Boolean);

  function updateActiveLink() {
    const scrollPos = window.scrollY + 200;
    let activeSection = '#inicio';
    sectionElements.forEach(section => {
      if (section.offsetTop <= scrollPos) {
        activeSection = '#' + section.id;
      }
    });
    navDesktopLinks.forEach(link => {
      const href = link.getAttribute('href');
      link.classList.toggle('active', href === activeSection);
    });
  }
  window.addEventListener('scroll', updateActiveLink, { passive: true });
  updateActiveLink();

  // Entrance reveal
  const revealEls = document.querySelectorAll('[data-nav-reveal]');
  revealEls.forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(12px)';
    const delay = parseFloat(el.style.transitionDelay) || (i * 60);
    setTimeout(() => {
      el.style.transition = 'opacity 0.9s var(--ease-out-expo), transform 0.9s var(--ease-out-expo), color 0.6s ease';
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, 200 + delay);
  });
</script>

<style>
  :global(:root) {
    --site-header-height: calc(clamp(14px, 2vw, 22px) * 2 + 64px);
  }

  /* ═══════════════════════════════════════════════════════════
     NAVIGATION — Chameleon Island
     Transparent over hero, warm glass over content.
     Color-inverts seamlessly as user scrolls.
     ═══════════════════════════════════════════════════════════ */

  .nav-root {
    --nav-cream: #f5f0e8;
    --nav-ink: #2f2d28;
    --nav-ink-soft: #49463f;
    --nav-sage: #6f7d67;
    --nav-sage-deep: #56645a;
    --nav-gold: #b8a88a;
    --nav-gold-soft: rgba(184, 168, 138, 0.14);
    --nav-line: rgba(111, 125, 103, 0.14);
    --nav-line-soft: rgba(111, 125, 103, 0.08);

    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 900;
    display: flex;
    justify-content: center;
    padding: clamp(14px, 2vw, 22px) 3vw;
    pointer-events: none;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .nav-root.is-hidden {
    transform: translateY(calc(-100% - 40px));
  }

  .nav-root.is-visible {
    transform: translateY(0);
  }

  /* Prevent island from hiding when menu is open */
  .nav-root.menu-open {
    transform: translateY(0) !important;
  }

  /* ── Island ───────────────────────────────────────────────── */
  .nav-island {
    pointer-events: auto;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    width: min(1280px, 94vw);
    min-height: 64px;
    padding: 0.55rem 2.2rem;
    border-radius: 22px;
    transition:
      background 0.7s ease,
      backdrop-filter 0.7s ease,
      box-shadow 0.7s ease,
      border-color 0.7s ease,
      min-height 0.55s var(--ease-out-expo),
      padding 0.55s var(--ease-out-expo),
      gap 0.55s var(--ease-out-expo),
      width 0.6s var(--ease-out-expo),
      border-radius 0.6s var(--ease-out-expo);
  }

  /* At top: transparent, light text for dark hero */
  .nav-root:not(.is-visible):not(.menu-open) .nav-island {
    background: transparent;
    border: 1px solid transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Scrolled: warm cream glass with ink text */
  .nav-root.is-visible .nav-island,
  .nav-root.menu-open .nav-island {
    z-index: 902;
    width: min(720px, 90vw);
    min-height: 0;
    padding: 0.5rem 0.55rem 0.5rem 0.9rem;
    gap: 1.1rem;
    border-radius: 100px;
    background: rgba(251, 248, 241, 0.82);
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    border: 1px solid transparent;
    background-clip: padding-box;
    position: relative;
    box-shadow:
      0 8px 32px rgba(47, 45, 40, 0.06),
      0 2px 8px rgba(47, 45, 40, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  .nav-root.is-visible .nav-island::before,
  .nav-root.menu-open .nav-island::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 100px;
    padding: 1px;
    background: linear-gradient(180deg, rgba(184, 168, 138, 0.35), rgba(111, 125, 103, 0.12) 40%, rgba(111, 125, 103, 0.08) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: -1;
  }

  /* Keep island above overlay when menu is open */
  .nav-root.menu-open .nav-island {
    z-index: 904;
  }

  /* Warm ambient glow behind scrolled island */
  .island-glow {
    position: absolute;
    inset: -60% -30%;
    border-radius: 50%;
    background: radial-gradient(ellipse at 50% 50%, rgba(184, 168, 138, 0.1) 0%, transparent 60%);
    pointer-events: none;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.9s ease, transform 0.9s ease;
    z-index: -1;
  }
  .nav-root.is-visible .island-glow,
  .nav-root.menu-open .island-glow {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Logo ─────────────────────────────────────────────────── */
  .nav-mark {
    display: grid;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.35s ease;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .nav-mark:hover { opacity: 0.72; }
  .nav-mark:active .mark-logo {
    transform: scale(0.95);
  }

  .mark-logo {
    height: 32px;
    width: auto;
    grid-row: 1;
    grid-column: 1;
    transition: opacity 0.5s ease, transform 0.5s var(--ease-out-expo);
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.08));
  }
  .nav-mark:hover .mark-logo {
    transform: scale(1.05);
  }

  /* Dark logo — visible at top (over dark hero) */
  .mark-logo--dark {
    opacity: 1;
  }
  .nav-root.is-visible .mark-logo--dark,
  .nav-root.menu-open .mark-logo--dark {
    opacity: 0;
  }

  /* Light logo — visible when scrolled (over cream island) */
  .mark-logo--light {
    opacity: 0;
  }
  .nav-root.is-visible .mark-logo--light,
  .nav-root.menu-open .mark-logo--light {
    opacity: 1;
  }

  /* ── Desktop Links ────────────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.2rem;
    transition: gap 0.55s var(--ease-out-expo);
  }
  .nav-root.is-visible .nav-links {
    gap: 1.2rem;
  }

  .nav-link {
    position: relative;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
    padding: 6px 0;
    text-decoration: none;
    transition: color 0.5s ease, transform 0.3s var(--ease-out-expo);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.18);
  }
  .nav-link:hover,
  .nav-link.active {
    color: rgba(245, 240, 232, 0.95);
    transform: translateY(-1px);
  }
  .nav-link:active {
    transform: translateY(0);
  }
  /* Scrolled: ink colors */
  .nav-root.is-visible .nav-link {
    color: rgba(47, 45, 40, 0.6);
    text-shadow: none;
  }
  .nav-root.is-visible .nav-link:hover,
  .nav-root.is-visible .nav-link.active {
    color: var(--nav-ink);
    transform: translateY(-1px);
  }
  .nav-root.is-visible .nav-link:active {
    transform: translateY(0);
  }

  /* Elegant underline track */
  .link-track {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%;
    height: 1px;
    background: rgba(196, 170, 148, 0.12);
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.4s ease, background 0.4s ease;
  }
  .nav-root.is-visible .link-track {
    background: rgba(111, 125, 103, 0.12);
  }
  .nav-link:hover .link-track,
  .nav-link.active .link-track {
    opacity: 1;
  }
  .link-fill {
    display: block;
    width: 100%; height: 100%;
    background: rgba(196, 170, 148, 0.55);
    transform: translateX(-101%);
    transition: transform 0.55s var(--ease-out-expo), background 0.4s ease;
  }
  .nav-root.is-visible .link-fill {
    background: var(--nav-sage);
  }
  .nav-link:hover .link-fill,
  .nav-link.active .link-fill {
    transform: translateX(0);
  }

  /* ── CTA ──────────────────────────────────────────────────── */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 9px 20px;
    background: rgba(245, 240, 232, 0.08);
    border: 1px solid rgba(196, 170, 148, 0.2);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: var(--type-meta);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.92);
    text-decoration: none;
    transition: all 0.5s var(--ease-out-expo);
    flex-shrink: 0;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.12);
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
  .nav-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(245, 240, 232, 0.06);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .nav-cta:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }
  .nav-cta::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
    transform: skewX(-20deg);
    transition: none;
    pointer-events: none;
  }
  .nav-cta:hover::after {
    animation: cta-shine 0.75s var(--ease-out-expo);
  }
  @keyframes cta-shine {
    0% { left: -100%; }
    100% { left: 200%; }
  }
  .nav-cta:hover {
    background: rgba(245, 240, 232, 0.14);
    border-color: rgba(196, 170, 148, 0.35);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.14);
  }
  /* Scrolled: sage gradient CTA */
  .nav-root.is-visible .nav-cta {
    background: linear-gradient(180deg, rgba(111, 125, 103, 0.92), rgba(86, 100, 90, 0.92));
    border-color: rgba(111, 125, 103, 0.3);
    color: #fbf8f1;
    text-shadow: none;
    box-shadow: 0 4px 16px rgba(86, 100, 90, 0.12);
  }
  .nav-root.is-visible .nav-cta::before {
    background: rgba(255, 255, 255, 0.08);
  }
  .nav-root.is-visible .nav-cta:hover {
    background: linear-gradient(180deg, rgba(111, 125, 103, 1), rgba(86, 100, 90, 1));
    border-color: rgba(111, 125, 103, 0.45);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(86, 100, 90, 0.18);
  }
  .nav-cta svg {
    position: relative;
    z-index: 1;
    transition: transform 0.4s var(--ease-out-expo);
    color: rgba(196, 170, 148, 0.5);
  }
  .nav-cta:hover svg {
    transform: translateX(2px);
    color: rgba(196, 170, 148, 0.8);
  }
  .nav-root.is-visible .nav-cta svg {
    color: rgba(251, 248, 241, 0.7);
  }

  /* ── Scroll hairline ──────────────────────────────────────── */
  .scroll-hairline {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 1px;
    background: rgba(196, 170, 148, 0.04);
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .nav-root.is-visible .scroll-hairline {
    opacity: 1;
  }
  .hairline-fill {
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: linear-gradient(90deg, var(--nav-sage), rgba(111, 125, 103, 0.5));
    will-change: transform;
    transition: transform 0.05s linear;
    box-shadow: 0 0 6px rgba(111, 125, 103, 0.15);
  }

  /* ── Mobile Trigger ───────────────────────────────────────── */
  .nav-trigger {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    z-index: 902;
    background: none;
    border: none;
    flex-shrink: 0;
    position: relative;
    padding: 10px;
    border-radius: 50%;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    transition: transform 0.3s var(--ease-out-expo), background 0.3s ease;
  }
  .nav-trigger:active {
    transform: scale(0.92);
  }
  .nav-root.is-visible .nav-trigger {
    background: rgba(47, 45, 40, 0.04);
  }
  .nav-root.is-visible .nav-trigger:hover {
    background: rgba(47, 45, 40, 0.1);
  }
  .trigger-line {
    display: block;
    width: 20px;
    height: 1.2px;
    background: rgba(245, 240, 232, 0.7);
    transition: transform 0.4s var(--ease-out-expo), opacity 0.3s ease, background 0.5s ease, width 0.3s var(--ease-out-expo);
    border-radius: 1px;
  }
  .trigger-line:nth-child(2) {
    width: 14px;
    margin-left: auto;
    margin-right: auto;
  }
  .nav-trigger:hover .trigger-line:nth-child(2) {
    width: 20px;
  }
  .nav-trigger:hover .trigger-line:nth-child(1) {
    transform: translateY(-1px);
  }
  .nav-trigger:hover .trigger-line:nth-child(3) {
    transform: translateY(1px);
  }
  .nav-root.is-visible .trigger-line {
    background: rgba(47, 45, 40, 0.5);
  }
  .nav-root.is-visible .nav-trigger:hover .trigger-line {
    background: rgba(47, 45, 40, 0.7);
  }
